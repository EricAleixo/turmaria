<div class="min-h-screen flex bg-base-200">
  <!-- Conteúdo principal -->
  <main class="flex-1 px-8 py-10">

    <h1 class="text-4xl font-bold mb-2">Estados Brasileiros</h1>
    <p class="text-gray-600 mb-8">Gerencie informações sobre os estados e suas cidades</p>

  
    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Total de Estados -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">Total de Estados</h2>
          <p class="text-3xl font-bold text-primary"><%= Estado.count %></p>
        </div>
      </div>

      <!-- Total de Cidades -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">Total de Cidades</h2>
          <p class="text-3xl font-bold text-success"><%= Cidade.count %></p>
        </div>
      </div>

      <!-- Maior Estado -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">Maior Estado</h2>
          <p class="text-2xl font-bold text-info">
            <%= Estado.all.max_by { |e| e.cidades.size }&.nome || "N/A" %>
          </p>
        </div>
      </div>
    </div>

    <!-- Botão de adicionar -->
    <div class="flex justify-end mb-4">
      <%= link_to 'Adicionar Estado', new_estado_path, class: 'btn btn-success' %>
    </div>

    <!-- Tabela -->
    <div class="overflow-x-auto bg-base-100 shadow rounded-lg">
      <table class="table table-zebra w-full text-center">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>UF</th>
            <th>Região</th>
            <th>Cidades</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @estados.each_with_index do |estado, index| %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= estado.nome %></td>
              <td><span class="text-gray-900"><%= estado.sigla %></span></td>
              <td>
                <%= estado.regiao.present? ? estado.regiao : "Indefinida" %>
              </td>
              <td><%= estado.cidades.count %> <small class="text-xs">municípios</small></td>
              <td class="space-x-2">
                <%= link_to estado_path(estado), class: 'btn btn-xs btn-outline', title: "Visualizar" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Zm8.25-3.75a.75.75 0 0 1 .75.75v2.25h2.25a.75.75 0 0 1 0 1.5h-2.25v2.25a.75.75 0 0 1-1.5 0v-2.25H7.5a.75.75 0 0 1 0-1.5h2.25V7.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
                  </svg>
                <% end %>


                <%= link_to edit_estado_path(estado), class: 'btn btn-xs btn-outline btn-info', title: "Editar" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.2Z" />
                  </svg>
                <% end %>


                <%= link_to confirm_delete_estado_path(estado), class: 'btn btn-xs btn-outline btn-error', title: "Excluir" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd" />
                  </svg>
                <% end %>

              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </main>
</div>
