<!-- O contêiner principal agora usa classes otimizadas para mobile -->
<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <main class="flex-1 p-4 sm:p-8">
        <!-- Header com gradiente e animação -->
        <div class="mb-8">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-800">
                        Estados Brasileiros
                    </h1>
                    <p class="text-gray-500 text-sm sm:text-base mt-1">
                        Gerencie informações sobre os estados e suas cidades
                    </p>
                </div>
            </div>
        </div>

        <!-- Grid de Cards Estatísticos -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-8">
            <!-- Card Total de Estados -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">Total</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Total de Estados</h2>
                    <p class="text-4xl font-bold text-gray-800">
                        <%= Estado.count %>
                    </p>
                </div>
            </div>

            <!-- Card Total de Cidades -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full">Cidades</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Total de Municípios</h2>
                    <p class="text-4xl font-bold text-gray-800">
                        <%= Cidade.count %>
                    </p>
                </div>
            </div>

            <!-- Card Maior Estado -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-purple-600 bg-purple-50 px-3 py-1 rounded-full">Destaque</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Estado com Mais Cidades</h2>
                    <% maior_estado = Estado.all.max_by { |e| e.cidades.size } %>
                    <p class="text-2xl font-bold text-gray-800 truncate">
                        <%= maior_estado ? maior_estado.nome : "Nenhum estado" %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Botão de Adicionar -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
            <div class="text-sm text-gray-600">
                Mostrando <span class="font-semibold text-gray-800"><%= @estados.count %></span> estados
            </div>
            <%= link_to new_estado_path, class: 'btn bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 gap-2 w-full sm:w-auto' do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Adicionar Estado
            <% end %>
        </div>

        <!-- Tabela -->
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="table w-full">
                    <thead>
                        <tr class="border-b-2 border-gray-200">
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">#</span>
                            </th>
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-6 text-left">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Estado</span>
                            </th>
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">UF</span>
                            </th>
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center hidden sm:table-cell">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Região</span>
                            </th>
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center hidden md:table-cell">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Municípios</span>
                            </th>
                            <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center">
                                <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Ações</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @estados.each_with_index do |estado, index| %>
                            <tr class="border-b border-gray-100 hover:bg-gradient-to-r hover:from-green-50/40 hover:to-transparent transition-all duration-200 group">
                                
                                <!-- Número -->
                                <td class="py-4 px-4 text-center">
                                    <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-gray-100 to-gray-200 text-gray-700 font-bold text-sm group-hover:from-green-100 group-hover:to-green-200 group-hover:text-green-700 transition-all duration-200 mx-auto shadow-sm">
                                        <%= index + 1 %>
                                    </div>
                                </td>
                                
                                <!-- Nome do Estado -->
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center text-white font-bold text-base shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-200">
                                            <%= estado.sigla %>
                                        </div>
                                        <div>
                                            <span class="text-base font-bold text-gray-800 block"><%= estado.nome %></span>
                                            <span class="text-xs text-gray-500 block sm:hidden"><%= estado.regiao.presence || "Indefinida" %></span>
                                        </div>
                                    </div>
                                </td>
                                
                                <!-- Sigla UF -->
                                <td class="py-4 px-4 text-center">
                                    <span class="inline-flex items-center justify-center px-3 py-2 rounded-xl bg-gradient-to-br from-blue-50 to-blue-100 text-blue-700 font-bold text-sm border-2 border-blue-200 group-hover:from-blue-100 group-hover:to-blue-200 group-hover:border-blue-300 transition-all duration-200 shadow-sm">
                                        <%= estado.sigla %>
                                    </span>
                                </td>
                                
                                <!-- Região -->
                                <td class="py-4 px-4 text-center hidden sm:table-cell">
                                    <span class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-gradient-to-br from-gray-50 to-gray-100 text-gray-700 text-sm font-semibold border-2 border-gray-200 group-hover:from-green-50 group-hover:to-green-100 group-hover:text-green-700 group-hover:border-green-200 transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                                        </svg>
                                        <%= estado.regiao.presence || "Indefinida" %>
                                    </span>
                                </td>
                                
                                <!-- Cidades -->
                                <td class="py-4 px-4 text-center hidden md:table-cell">
                                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-gradient-to-br from-purple-50 to-purple-100 text-purple-700 font-bold text-sm border-2 border-purple-200 group-hover:from-purple-100 group-hover:to-purple-200 group-hover:border-purple-300 transition-all duration-200 shadow-sm">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                                        </svg>
                                        <span class="text-base"><%= estado.cidades.count %></span>
                                    </span>
                                </td>
                                
                                <!-- Ações -->
                                <td class="py-4 px-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <!-- Botão Ver -->
                                        <%= link_to estado_cidades_path(estado), 
                                            class: "btn btn-sm btn-circle bg-gradient-to-br from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                            title: "Ver cidades" do %>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                        <% end %>
                                        
                                        <!-- Botão Editar -->
                                        <%= link_to edit_estado_path(estado), 
                                            class: "btn btn-sm btn-circle bg-gradient-to-br from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                            title: "Editar estado" do %>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                            </svg>
                                        <% end %>

                                        <!-- Botão Excluir -->
                                        <%= link_to confirm_delete_estado_path(estado), 
                                            class: "btn btn-sm btn-circle bg-gradient-to-br from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                            title: "Deletar estado" do %>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                            </svg>
                                        <% end %>
                                    </div>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Empty State (caso não haja estados) -->
        <% if @estados.empty? %>
            <div class="text-center py-16">
                <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-100 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-gray-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-700 mb-2">Nenhum estado cadastrado</h3>
                <p class="text-gray-500 mb-6">Comece adicionando seu primeiro estado</p>
                <%= link_to new_estado_path, class: 'btn bg-gradient-to-r from-green-600 to-green-700 text-white border-0 gap-2' do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Adicionar Estado
                <% end %>
            </div>
        <% end %>
    </main>
</div>