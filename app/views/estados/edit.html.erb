<div class="min-h-screen bg-gray-100 py-10 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto bg-white p-8 shadow-md rounded-lg">
    
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Editar Estado</h1>

    <%= form_with(model: @estado, local: true, class: "space-y-6") do |form| %>
      
      <div>
        <%= form.label :nome, "Nome do Estado", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :nome, class: "mt-1 block w-full rounded-md border border-gray-300 shadow-sm p-2 focus:ring focus:ring-indigo-200" %>
      </div>

      <div>
        <%= form.label :sigla, "UF", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :sigla, class: "mt-1 block w-24 rounded-md border border-gray-300 shadow-sm p-2 uppercase focus:ring focus:ring-indigo-200" %>
      </div>

      <div>
  <%= dropdown(
        form: form,
        method: :regiao,
        collection: [
          ["Norte", "Norte"],
          ["Nordeste", "Nordeste"],
          ["Centro-Oeste", "Centro-Oeste"],
          ["Sudeste", "Sudeste"],
          ["Sul", "Sul"]
        ],
        placeholder: "Selecione a região",
        label: "Região"
      ) %>
      </div>

      <div class="flex justify-end">
        <%= form.submit "Atualizar Estado", class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-md" %>
      </div>

    <% end %>

    <div class="mt-6">
      <%= link_to "← Voltar para Estados", estados_path, class: "text-sm text-blue-600 hover:underline" %>
    </div>
    
  </div>
</div>
