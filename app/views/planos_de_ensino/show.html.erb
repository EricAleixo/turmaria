<div class="px-4 py-8 sm:px-6 lg:px-8">

  <!-- Breadcrumb -->
  <nav class="mb-4 flex items-center gap-1.5 text-sm text-gray-400">
    <%= link_to @escola.nome, escola_path(@escola), class: "hover:text-gray-600" %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
    <%= link_to "Planos de Ensino", escola_planos_de_ensino_path(@escola), class: "hover:text-gray-600" %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
    <span class="font-medium text-gray-600"><%= @plano_de_ensino.disciplina.nome %></span>
  </nav>

  <% cor = @plano_de_ensino.disciplina.cor_nome.presence || "#9CA3AF" %>

  <!-- Card de identificação: professor / turma / escola -->
  <div class="mb-6 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
    <div class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300 p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-4">
          <% if @plano_de_ensino.professor.foto.attached? %>
            <div class="h-14 w-14 rounded-full overflow-hidden border-2 border-white shadow-sm shrink-0">
              <%= image_tag @plano_de_ensino.professor.foto.variant(resize_to_fill: [56, 56]), class: "object-cover w-full h-full" %>
            </div>
          <% else %>
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white text-blue-600 text-xl font-bold shadow-sm shrink-0">
              <%= @plano_de_ensino.professor.nome[0].upcase %>
            </div>
          <% end %>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-white/80">Professor(a)</p>
            <h2 class="text-xl font-bold text-white"><%= @plano_de_ensino.professor.nome %></h2>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <%= link_to edit_escola_plano_de_ensino_path(@escola, @plano_de_ensino),
                class: "inline-flex items-center gap-1.5 rounded-lg bg-white/90 px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-white transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
            </svg>
            Editar
          <% end %>
          <%= delete_button_with_modal(
              path: escola_plano_de_ensino_path(@escola, @plano_de_ensino),
              modal_id: dom_id(@plano_de_ensino, :delete),
              title: "Excluir plano de ensino",
              message: "Tem certeza que deseja excluir este plano de ensino",
              item_name: "#{@plano_de_ensino.disciplina.nome} - #{@plano_de_ensino.turma.nome}",
              btn_class: "inline-flex items-center gap-1.5 rounded-lg bg-white/90 px-3 py-2 text-sm font-semibold text-red-600 shadow-sm hover:bg-white transition-colors"
            ) %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6 p-6 sm:grid-cols-4">
      <div>
        <p class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />
          </svg>
          Escola
        </p>
        <p class="text-sm font-medium text-gray-800"><%= @escola.nome %></p>
      </div>
      <div>
        <p class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0Zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0Z" />
          </svg>
          Turma
        </p>
        <p class="text-sm font-medium text-gray-800"><%= @plano_de_ensino.turma.nome %> · <%= @plano_de_ensino.turma.serie %>º ano</p>
      </div>
      <div>
        <p class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-gray-400">
          <span class="h-2 w-2 rounded-full shrink-0" style="background-color: <%= cor %>;"></span>
          Disciplina
        </p>
        <p class="text-sm font-medium text-gray-800"><%= @plano_de_ensino.disciplina.nome %></p>
      </div>
      <div>
        <p class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          Período
        </p>
        <p class="text-sm font-medium text-gray-800">
          <%= @plano_de_ensino.turma.ano_letivo.try(:ano) || @plano_de_ensino.turma.ano_letivo.id %> · <%= @plano_de_ensino.bimestre %>º Bimestre
        </p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 border-t border-gray-100 px-6 py-4">
      <% status_classes = {
           "rascunho" => "bg-gray-100 text-gray-800",
           "em_elaboracao" => "bg-blue-100 text-blue-800",
           "publicado" => "bg-emerald-100 text-emerald-800"
         } %>
      <% status_dot = { "rascunho" => "bg-gray-400", "em_elaboracao" => "bg-blue-500", "publicado" => "bg-emerald-500" } %>
      <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium <%= status_classes[@plano_de_ensino.status] %>">
        <span class="h-1.5 w-1.5 rounded-full <%= status_dot[@plano_de_ensino.status] %>"></span>
        <%= @plano_de_ensino.status_humanizado %>
      </span>
      <% if @plano_de_ensino.curso.present? %>
        <span class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-xs font-medium text-purple-800">
          <%= @plano_de_ensino.curso %>
        </span>
      <% end %>
      <span class="ml-auto text-xs text-gray-400">Atualizado em <%= @plano_de_ensino.updated_at.strftime("%d/%m/%Y") %></span>
    </div>
  </div>

  <!-- Corpo: nav lateral + conteúdo -->
  <div class="flex gap-8 items-start">

    <!-- Nav lateral -->
    <aside class="w-52 hidden lg:block shrink-0">
      <div class="sticky top-8 rounded-xl border border-gray-100 bg-white p-3 shadow-sm">
        <h3 class="mb-2 px-2 text-xs font-semibold uppercase tracking-widest text-gray-400">Estrutura</h3>
        <nav id="show-nav" class="space-y-1">
          <a data-target="ementa" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-blue-700 bg-blue-50" href="#ementa">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12" />
            </svg>
            Ementa
          </a>
          <a data-target="objetivos" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50" href="#objetivos">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zM12 15a3 3 0 100-6 3 3 0 000 6z" />
            </svg>
            Objetivos
          </a>
          <a data-target="competencias" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50" href="#competencias">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
            Competências
          </a>
          <a data-target="conteudo" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50" href="#conteudo">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
            </svg>
            Conteúdo
          </a>
          <a data-target="avaliacao" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50" href="#avaliacao">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Avaliação
          </a>
          <a data-target="bibliografia" class="show-nav-link flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50" href="#bibliografia">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
            Bibliografia
          </a>
        </nav>
      </div>
    </aside>

    <!-- Conteúdo do plano -->
    <div class="flex-1 min-w-0 space-y-6">

      <div id="ementa" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
        <h3 class="mb-3 flex items-center gap-2 text-lg font-bold text-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12" />
          </svg>
          Ementa
        </h3>
        <% if @plano_de_ensino.ementa.present? %>
          <p class="text-sm text-gray-600 whitespace-pre-line"><%= @plano_de_ensino.ementa %></p>
        <% else %>
          <p class="text-sm italic text-gray-400">Não informado.</p>
        <% end %>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div id="objetivos" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
          <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-gray-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zM12 15a3 3 0 100-6 3 3 0 000 6z" />
            </svg>
            Objetivos
          </h3>
          <div class="space-y-4">
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Gerais</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.objetivos_gerais.presence || "Não informado." %></p>
            </div>
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Específicos</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.objetivos_especificos.presence || "Não informado." %></p>
            </div>
          </div>
        </div>

        <div id="competencias" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
          <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-gray-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
            Competências e Habilidades
          </h3>
          <div class="space-y-4">
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Competências</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.competencias.presence || "Não informado." %></p>
            </div>
            <div>
              <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-gray-400">Habilidades (BNCC)</p>
              <% if @plano_de_ensino.habilidades.present? %>
                <div class="flex flex-wrap gap-1.5">
                  <% @plano_de_ensino.habilidades.split(",").map(&:strip).reject(&:blank?).each do |codigo| %>
                    <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700"><%= codigo %></span>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm italic text-gray-400">Não informado.</p>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div id="conteudo" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
          </svg>
          Conteúdo e Metodologia
        </h3>
        <div class="space-y-4">
          <div>
            <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Conteúdos programáticos</p>
            <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.conteudos_programaticos.presence || "Não informado." %></p>
          </div>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Metodologia</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.metodologia.presence || "Não informado." %></p>
            </div>
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Recursos didáticos</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.recursos_didaticos.presence || "Não informado." %></p>
            </div>
          </div>
          <% if @plano_de_ensino.cronograma_unidades.present? %>
            <div>
              <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Cronograma por unidade</p>
              <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.cronograma_unidades %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div id="avaliacao" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
        <h3 class="mb-3 flex items-center gap-2 text-lg font-bold text-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Avaliação
        </h3>
        <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.criterios_avaliacao.presence || "Não informado." %></p>
      </div>

      <div id="bibliografia" class="overflow-hidden rounded-xl border border-gray-100 bg-white p-6 shadow-lg scroll-mt-8">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-gray-800">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          Bibliografia
        </h3>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Básica</p>
            <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.bibliografia_basica.presence || "Não informado." %></p>
          </div>
          <div>
            <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Complementar</p>
            <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.bibliografia_complementar.presence || "Não informado." %></p>
          </div>
        </div>
        <% if @plano_de_ensino.observacoes.present? %>
          <div class="mt-4 border-t border-gray-100 pt-4">
            <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-400">Observações</p>
            <p class="text-sm text-gray-700 whitespace-pre-line"><%= @plano_de_ensino.observacoes %></p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>

<script>
  (function () {
    var links = document.querySelectorAll('#show-nav .show-nav-link');
    var sections = Array.from(links).map(function (l) { return document.getElementById(l.dataset.target); });

    function setActive(id) {
      links.forEach(function (l) {
        var isActive = l.dataset.target === id;
        l.classList.toggle('bg-blue-50', isActive);
        l.classList.toggle('text-blue-700', isActive);
        l.classList.toggle('text-gray-500', !isActive);
        l.classList.toggle('hover:bg-gray-50', !isActive);
      });
    }

    var ignoreObserver = false;
    var manualScrollTimeout = null;

    links.forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        var target = document.getElementById(link.dataset.target);

        ignoreObserver = true;
        clearTimeout(manualScrollTimeout);

        if (target) {
          window.scrollTo({ top: target.offsetTop - 32, behavior: 'smooth' });
        }
        setActive(link.dataset.target);

        manualScrollTimeout = setTimeout(function () { ignoreObserver = false; }, 700);
      });
    });

    var observer = new IntersectionObserver(function (entries) {
      if (ignoreObserver) return;
      entries.forEach(function (entry) {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    sections.forEach(function (s) { if (s) observer.observe(s); });
  })();
</script>