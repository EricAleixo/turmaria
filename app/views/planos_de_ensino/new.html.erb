<div class="px-4 py-8 sm:px-6 lg:px-8">
  <%= link_to escola_planos_de_ensino_path(@escola), class: "mb-4 inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
    Voltar para Planos de Ensino
  <% end %>

  <h1 class="mb-1 text-2xl font-bold text-gray-800">Novo Plano de Ensino</h1>
  <p class="mb-6 text-sm text-gray-500">
    Cadastrando um plano em <span class="font-semibold text-gray-700"><%= @escola.nome %></span>
  </p>

  <%= render "form" %>
</div>