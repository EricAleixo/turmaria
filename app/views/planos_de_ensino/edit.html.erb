<!-- app/views/planos_de_ensino/edit.html.erb -->

<div class="px-4 py-8 sm:px-6 lg:px-8">
  <%= link_to escola_plano_de_ensino_path(@escola, @plano_de_ensino), class: "mb-4 inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
    Voltar para o plano
  <% end %>

  <h1 class="mb-1 text-2xl font-bold text-gray-800">Editar Plano de Ensino</h1>
  <p class="mb-6 text-sm text-gray-500">
    <%= @plano_de_ensino.professor.nome %> · <%= @plano_de_ensino.disciplina.nome %> · <%= @plano_de_ensino.turma.nome %>
  </p>

  <%= render "form" %>
</div>