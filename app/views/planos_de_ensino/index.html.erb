<!-- app/views/planos_de_ensino/index.html.erb -->

<div class="px-4 py-8 sm:px-6 lg:px-8">

  <!-- Cabeçalho -->
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <%= link_to escola_path(@escola), class: "mb-2 inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Voltar para <%= @escola.nome %>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-800">Planos de Ensino</h1>
      <p class="mt-1 text-sm text-gray-500">Planos cadastrados em <span class="font-semibold text-gray-700"><%= @escola.nome %></span></p>
    </div>
    <%= link_to new_escola_plano_de_ensino_path(@escola), class: "btn border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600 rounded-lg" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo Plano
    <% end %>
  </div>

  <!-- Cards de resumo -->
  <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
    <%= link_to escola_planos_de_ensino_path(@escola), class: "rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md" do %>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Total</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <p class="text-2xl font-bold text-gray-800"><%= @total_planos %></p>
    <% end %>

    <%= link_to escola_planos_de_ensino_path(@escola, status: "publicado"), class: "rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md" do %>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Publicados</span>
        <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
      </div>
      <p class="text-2xl font-bold text-gray-800"><%= @total_publicados %></p>
    <% end %>

    <%= link_to escola_planos_de_ensino_path(@escola, status: "em_elaboracao"), class: "rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md" do %>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Em elaboração</span>
        <span class="h-2.5 w-2.5 rounded-full bg-blue-500"></span>
      </div>
      <p class="text-2xl font-bold text-gray-800"><%= @total_em_elaboracao %></p>
    <% end %>

    <%= link_to escola_planos_de_ensino_path(@escola, status: "rascunho"), class: "rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md" do %>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Rascunhos</span>
        <span class="h-2.5 w-2.5 rounded-full bg-gray-400"></span>
      </div>
      <p class="text-2xl font-bold text-gray-800"><%= @total_rascunhos %></p>
    <% end %>
  </div>

  <!-- Filtros -->
  <div class="mb-6 rounded-xl border border-gray-100 bg-white p-5 shadow-lg">
    <%= form_with url: escola_planos_de_ensino_path(@escola), method: :get, local: true do %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">

        <!-- Busca -->
        <div class="lg:col-span-2">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Buscar</label>
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <input type="text" name="q" value="<%= params[:q] %>" placeholder="Professor ou ementa..."
                   class="h-10 w-full rounded-lg border border-gray-300 bg-white pl-9 pr-3 text-sm text-gray-700 placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20" />
          </div>
        </div>

        <!-- Professor -->
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Professor</label>
          <div class="relative">
            <select name="professor_id" onchange="this.form.submit()"
                    class="h-10 w-full appearance-none rounded-lg border border-gray-300 bg-white pl-3 pr-9 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20">
              <option value="">Todos</option>
              <% @professores_filtro.each do |p| %>
                <option value="<%= p.id %>" <%= "selected" if params[:professor_id].to_s == p.id.to_s %>><%= p.nome %></option>
              <% end %>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <!-- Turma -->
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Turma</label>
          <div class="relative">
            <select name="turma_id" onchange="this.form.submit()"
                    class="h-10 w-full appearance-none rounded-lg border border-gray-300 bg-white pl-3 pr-9 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20">
              <option value="">Todas</option>
              <% @turmas_filtro.each do |t| %>
                <option value="<%= t.id %>" <%= "selected" if params[:turma_id].to_s == t.id.to_s %>><%= t.nome %></option>
              <% end %>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <!-- Disciplina -->
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Disciplina</label>
          <div class="relative">
            <select name="disciplina_id" onchange="this.form.submit()"
                    class="h-10 w-full appearance-none rounded-lg border border-gray-300 bg-white pl-3 pr-9 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20">
              <option value="">Todas</option>
              <% @disciplinas_filtro.each do |d| %>
                <option value="<%= d.id %>" <%= "selected" if params[:disciplina_id].to_s == d.id.to_s %>><%= d.nome %></option>
              <% end %>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <!-- Status -->
        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">Status</label>
          <div class="relative">
            <select name="status" onchange="this.form.submit()"
                    class="h-10 w-full appearance-none rounded-lg border border-gray-300 bg-white pl-3 pr-9 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20">
              <option value="">Todos</option>
              <% PlanoDeEnsino.statuses.each_key do |s| %>
                <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.humanize %></option>
              <% end %>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <button type="submit" class="hidden">Filtrar</button>
      </div>
    <% end %>

    <!-- Chips de filtro ativo -->
    <% filtros_ativos = [] %>
    <% filtros_ativos << ["\"#{params[:q]}\"", escola_planos_de_ensino_path(@escola, request.query_parameters.except("q"))] if params[:q].present? %>
    <% filtros_ativos << [@professores_filtro.find { |p| p.id.to_s == params[:professor_id] }&.nome, escola_planos_de_ensino_path(@escola, request.query_parameters.except("professor_id"))] if params[:professor_id].present? %>
    <% filtros_ativos << [@turmas_filtro.find { |t| t.id.to_s == params[:turma_id] }&.nome, escola_planos_de_ensino_path(@escola, request.query_parameters.except("turma_id"))] if params[:turma_id].present? %>
    <% filtros_ativos << [@disciplinas_filtro.find { |d| d.id.to_s == params[:disciplina_id] }&.nome, escola_planos_de_ensino_path(@escola, request.query_parameters.except("disciplina_id"))] if params[:disciplina_id].present? %>
    <% filtros_ativos << [params[:status]&.humanize, escola_planos_de_ensino_path(@escola, request.query_parameters.except("status"))] if params[:status].present? %>

    <% if filtros_ativos.any? %>
      <div class="mt-3 flex flex-wrap items-center gap-2 border-t border-gray-100 pt-3">
        <span class="text-xs font-semibold text-gray-400">Filtros ativos:</span>
        <% filtros_ativos.each do |(label, remove_path)| %>
          <%= link_to remove_path, class: "inline-flex items-center gap-1 rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700 hover:bg-blue-100 transition-colors" do %>
            <%= label %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          <% end %>
        <% end %>
        <%= link_to "Limpar tudo", escola_planos_de_ensino_path(@escola), class: "text-xs font-semibold text-gray-400 hover:text-gray-600 ml-1" %>
      </div>
    <% end %>
  </div>

  <!-- Tabela -->
  <div class="overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
    <% if @planos_de_ensino.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Professor</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Disciplina / Turma</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Bimestre</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Status</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Atualizado</th>
              <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-white">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @planos_de_ensino.each do |plano| %>
              <% cor = plano.disciplina.cor_nome.presence || "#9CA3AF" %>
              <tr class="transition-colors hover:bg-emerald-50/50">
                <td class="whitespace-nowrap px-6 py-4">
                  <%= link_to escola_plano_de_ensino_path(@escola, plano), class: "flex items-center space-x-3 group" do %>
                    <% if plano.professor.foto.attached? %>
                      <div class="h-9 w-9 rounded-full overflow-hidden border border-gray-300 shrink-0">
                        <%= image_tag plano.professor.foto.variant(resize_to_fill: [36, 36]), class: "object-cover w-full h-full" %>
                      </div>
                    <% else %>
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-500 text-white text-sm font-semibold shadow-sm border border-blue-400 shrink-0">
                        <%= plano.professor.nome[0].upcase %>
                      </div>
                    <% end %>
                    <span class="text-sm font-medium text-gray-900 group-hover:text-blue-600 group-hover:underline"><%= plano.professor.nome %></span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-6 py-4">
                  <div class="flex items-center gap-2">
                    <span class="h-2.5 w-2.5 rounded-full shrink-0" style="background-color: <%= cor %>;"></span>
                    <div>
                      <p class="text-sm font-semibold text-gray-800"><%= plano.disciplina.nome %></p>
                      <p class="text-xs text-gray-500">Turma <%= plano.turma.nome %> · <%= plano.turma.serie %>º ano</p>
                    </div>
                  </div>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= plano.bimestre %>º Bim.</td>
                <td class="whitespace-nowrap px-6 py-4">
                  <% status_classes = {
                       "rascunho" => "bg-gray-100 text-gray-800",
                       "em_elaboracao" => "bg-blue-100 text-blue-800",
                       "publicado" => "bg-emerald-100 text-emerald-800"
                     } %>
                  <% status_dot = { "rascunho" => "bg-gray-400", "em_elaboracao" => "bg-blue-500", "publicado" => "bg-emerald-500" } %>
                  <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-medium <%= status_classes[plano.status] %>">
                    <span class="h-1.5 w-1.5 rounded-full <%= status_dot[plano.status] %>"></span>
                    <%= plano.status_humanizado %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500"><%= plano.updated_at.strftime("%d/%m/%Y") %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium">
                  <div class="flex justify-end space-x-3">
                    <%= link_to escola_plano_de_ensino_path(@escola, plano), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700", title: "Ver" do %>
                      <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_plano_de_ensino_path(@escola, plano), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800", title: "Editar" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= delete_button_with_modal(
                        path: escola_plano_de_ensino_path(@escola, plano),
                        modal_id: dom_id(plano, :delete),
                        title: "Excluir plano de ensino",
                        message: "Tem certeza que deseja excluir este plano de ensino",
                        item_name: "#{plano.disciplina.nome} - #{plano.turma.nome}",
                        btn_class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800"
                      ) %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Paginação -->
      <% if @total_filtrado > PlanosDeEnsinoController::PER_PAGE %>
        <% total_paginas = (@total_filtrado.to_f / PlanosDeEnsinoController::PER_PAGE).ceil %>
        <% primeiro = (@page - 1) * PlanosDeEnsinoController::PER_PAGE + 1 %>
        <% ultimo = [primeiro + PlanosDeEnsinoController::PER_PAGE - 1, @total_filtrado].min %>
        <div class="flex flex-col gap-3 border-t border-gray-200 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs text-gray-400">Mostrando <%= primeiro %>–<%= ultimo %> de <%= @total_filtrado %> planos</p>
          <div class="flex items-center gap-1">
            <%= link_to url_for(request.query_parameters.merge(page: @page - 1)),
                  class: "rounded-lg p-1.5 text-sm #{@page <= 1 ? 'text-gray-300 pointer-events-none' : 'text-gray-500 hover:bg-gray-50'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
              </svg>
            <% end %>
            <% (1..total_paginas).each do |p| %>
              <%= link_to p, url_for(request.query_parameters.merge(page: p)),
                    class: "px-3 py-1.5 rounded-lg text-sm #{p == @page ? 'bg-blue-500 text-white font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
            <% end %>
            <%= link_to url_for(request.query_parameters.merge(page: @page + 1)),
                  class: "rounded-lg p-1.5 text-sm #{@page >= total_paginas ? 'text-gray-300 pointer-events-none' : 'text-gray-500 hover:bg-gray-50'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="py-16 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum plano encontrado</h3>
        <p class="mt-1 text-sm text-gray-500">
          <% if params[:q].present? || params[:professor_id].present? || params[:turma_id].present? || params[:disciplina_id].present? || params[:status].present? %>
            Tente ajustar os filtros ou <%= link_to "limpar a busca", escola_planos_de_ensino_path(@escola), class: "text-blue-600 font-semibold hover:underline" %>.
          <% else %>
            Os professores ainda não cadastraram planos de ensino nesta escola.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>