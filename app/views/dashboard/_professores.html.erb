            <p class="text-gray-500">Nenhum dado de presença semanal disponível.</p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Bottom Section %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <%# My Classes %>
      <div class="bg-white rounded-2xl shadow-xl">
        <div class="p-6 border-b border-gray-200">
          <div class="flex items-center gap-3">
            <div class="bg-indigo-100 p-3 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-indigo-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-800">Minhas Turmas</h3>
              <p class="text-gray-600 text-sm">O que você está lecionando</p>
            </div>
          </div>
        </div>
        
        <div class="p-6 max-h-96 overflow-y-auto">
          <% if @disciplinas_e_turmas&.any? %>
            <% @disciplinas_e_turmas.each_with_index do |item, index| %>
              <div class="flex items-center justify-between p-4 rounded-xl hover:bg-green-50 transition-colors <%= 'mb-3' unless index == @disciplinas_e_turmas.length - 1 %>">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-emerald-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-md">
                    <%= item[:turma].to_s[0] || 'T' %>
                  </div>
                  <div>
                    <div class="font-semibold text-gray-800 text-lg"><%= item[:disciplina] %></div>
                    <div class="text-sm text-gray-500">Turma: <%= item[:turma] %></div>
                  </div>
                </div>
                
                <%= link_to 'Gerenciar', professor_turma_disciplinas_path(item[:turma_id], disciplina_id: item[:disciplina_id], target: :nota), class: "text-green-600 hover:text-green-800 font-semibold text-sm transition-colors" %>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-gray-300 mx-auto mb-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              <p class="text-gray-500">Nenhuma disciplina ou turma atribuída.</p>
            </div>
          <% end %>
        </div>
      </div>

      <%# Performance Chart %>
      <div class="bg-white rounded-2xl shadow-xl p-6">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-blue-100 p-3 rounded-xl">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-blue-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-800">Desempenho por Disciplina</h3>
            <p class="text-gray-600 text-sm">Média de notas</p>
          </div>
        </div>
        
        <% if @grafico_desempenho_disciplinas && @grafico_desempenho_disciplinas[:labels]&.any? %>
          <div class="h-80">
            <canvas id="disciplinesPerformanceChart"></canvas>
          </div>
        <% else %>
          <div class="h-80 flex items-center justify-center">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-gray-300 mx-auto mb-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
              </svg>
              <p class="text-gray-500">Nenhum dado de desempenho disponível.</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
let disciplinesPerformanceChart;

function initializeProfessorCharts() {
  if (disciplinesPerformanceChart) disciplinesPerformanceChart.destroy();

  const perfCtx = document.getElementById('disciplinesPerformanceChart');
  const perfData = <%= raw (@grafico_desempenho_disciplinas || {}).to_json %>;

  if (perfCtx && perfData.labels && perfData.data) {
    disciplinesPerformanceChart = new Chart(perfCtx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: perfData.labels,
        datasets: [{
          label: 'Média de Notas',
          data: perfData.data,
          backgroundColor: [
            'rgba(16, 185, 129, 0.8)',
            'rgba(59, 130, 246, 0.8)',
            'rgba(168, 85, 247, 0.8)',
            'rgba(249, 115, 22, 0.8)',
          ],
          borderColor: [
            'rgb(16, 185, 129)',
            'rgb(59, 130, 246)',
            'rgb(168, 85, 247)',
            'rgb(249, 115, 22)',
          ],
          borderWidth: 2,
          borderRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { 
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(0, 0, 0, 0.8)',
            padding: 12,
            titleFont: { size: 14 },
            bodyFont: { size: 13 },
            borderColor: 'rgba(255, 255, 255, 0.1)',
            borderWidth: 1
          }
        },
        scales: {
          y: { 
            beginAtZero: true, 
            max: 10,
            grid: {
              color: 'rgba(0, 0, 0, 0.05)'
            },
            ticks: {
              font: { size: 12 }
            },
            title: { 
              display: true, 
              text: 'Média de Nota (0-10)',
              font: { size: 13, weight: 'bold' }
            } 
          },
          x: {
            grid: {
              display: false
            },
            ticks: {
              font: { size: 12 }
            }
          }
        }
      }
    });
  }
}

document.addEventListener('DOMContentLoaded', initializeProfessorCharts);
document.addEventListener('turbo:load', initializeProfessorCharts);

document.addEventListener('turbo:before-cache', function() {
  if (disciplinesPerformanceChart) disciplinesPerformanceChart.destroy();
});
</script>