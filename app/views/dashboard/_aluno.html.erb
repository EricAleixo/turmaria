<div class="p-8">
  
  <% aluno = current_aluno %>
  
  <h1 class="text-3xl font-bold text-purple-700 mb-6">
    👋 Bem-vindo(a) ao seu Portal, <%= aluno.nome.split.first %>!
  </h1>

  <% if aluno.turma.present? %>
    <div class="alert shadow-lg mb-6 bg-purple-50 text-purple-800 border-l-4 border-purple-500">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current flex-shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>
          Você está matriculado(a) na Turma: **<%= aluno.turma.nome %>** (<%= aluno.turma.ano_letivo.nome %>).
        </span>
      </div>
    </div>
  <% else %>
    <div class="alert shadow-lg mb-6 bg-yellow-50 text-yellow-800 border-l-4 border-yellow-500">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.332 16c-.77 1.333.192 3 1.732 3z" /></svg>
        <span>Atenção: Você ainda não foi associado a nenhuma turma.</span>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
    
    <%= link_to '#', class: "card w-full bg-base-100 shadow-xl hover:shadow-2xl transition duration-300 transform hover:scale-[1.02] border-t-4 border-purple-500" do %>
      <div class="card-body">
        <h2 class="card-title text-purple-600">Minhas Notas</h2>
        <p class="text-gray-500">Visualize seu desempenho em todas as disciplinas e bimestres.</p>
        <div class="card-actions justify-end">
          <button class="btn btn-sm btn-outline btn-info">Ver Detalhes</button>
        </div>
      </div>
    <% end %>

    <%= link_to '#', class: "card w-full bg-base-100 shadow-xl hover:shadow-2xl transition duration-300 transform hover:scale-[1.02] border-t-4 border-purple-500" do %>
      <div class="card-body">
        <h2 class="card-title text-purple-600">Minha Frequência</h2>
        <p class="text-gray-500">Acompanhe suas presenças, faltas e o percentual de frequência.</p>
        <div class="card-actions justify-end">
          <button class="btn btn-sm btn-outline btn-info">Ver Detalhes</button>
        </div>
      </div>
    <% end %>

    <%= link_to '#', class: "card w-full bg-base-100 shadow-xl hover:shadow-2xl transition duration-300 transform hover:scale-[1.02] border-t-4 border-purple-500" do %>
      <div class="card-body">
        <h2 class="card-title text-purple-600">Meu Perfil</h2>
        <p class="text-gray-500">Dados cadastrais e informações pessoais.</p>
        <div class="card-actions justify-end">
          <button class="btn btn-sm btn-outline btn-info">Ver Detalhes</button>
        </div>
      </div>
    <% end %>
    
  </div>
</div>