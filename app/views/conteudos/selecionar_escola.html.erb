<div class="min-h-screen bg-gray-100 py-8 px-4">
  <div class="max-w-9xl mx-auto">
    <!-- Cabeçalho -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">Conteúdos por Escola</h1>
      <p class="text-gray-600">Explore os conteúdos cadastrados em cada escola</p>
    </div>
    
    <!-- Grid de Cards de Escolas -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @escolas.each do |escola| %>
        <% total_conteudos = escola.conteudos.count %>
        <% conteudos_por_bimestre = escola.conteudos.group(:bimestre).count %>
        <% conteudos_por_tipo = escola.conteudos.group(:tipo).count %>
        <% disciplinas_count = escola.conteudos.joins(:disciplina).distinct.count(:disciplina_id) %>
        
        <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-300">
          <!-- Header do Card -->
          <div class="p-6 border-b border-gray-200">
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1">
                <h3 class="font-semibold text-gray-800 text-lg mb-1"><%= escola.nome %></h3>
                <span class="inline-block px-3 py-1 text-xs rounded-full <%= escola.tipo == 'publica' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                  <%= escola.tipo_humanizado %>
                </span>
              </div>
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 ml-3">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-600">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
            </div>
            
            <!-- Estatísticas da Escola -->
            <div class="flex items-center gap-4 text-sm text-gray-600 mt-4 flex-wrap">
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <span><%= total_conteudos %> <%= total_conteudos == 1 ? 'conteúdo' : 'conteúdos' %></span>
              </div>
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
                <span><%= disciplinas_count %> <%= disciplinas_count == 1 ? 'disciplina' : 'disciplinas' %></span>
              </div>
            </div>
          </div>
          
          <!-- Lista de Conteúdos -->
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <h4 class="text-sm font-semibold text-gray-700">Conteúdos Recentes:</h4>
              <% if escola.conteudos.any? %>
                <%= link_to escola_conteudos_path(escola), class: "text-xs font-medium text-green-600 hover:text-green-700 flex items-center gap-1 transition-colors" do %>
                  <span>Ver todos</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                <% end %>
              <% end %>
            </div>
            
            <% if escola.conteudos.any? %>
              <% conteudos_visiveis = escola.conteudos.order(created_at: :desc).limit(3) %>
              <div class="space-y-2">
                <% conteudos_visiveis.each do |conteudo| %>
                  <div class="flex items-start justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors border-l-4 border-green-500">
                    <div class="flex items-start gap-3 flex-1 min-w-0">
                      <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-600">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-800 truncate"><%= conteudo.titulo %></div>
                        <div class="text-xs text-gray-500 flex items-center gap-2 mt-1 flex-wrap">
                          <% if conteudo.bimestre.present? %>
                            <span class="px-2 py-0.5 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">
                              <%= conteudo.bimestre %>º Bim
                            </span>
                          <% end %>
                          <% if conteudo.disciplina.present? %>
                            <span class="px-2 py-0.5 bg-purple-100 text-purple-700 rounded-full text-xs font-medium">
                              <%= conteudo.disciplina.nome %>
                            </span>
                          <% end %>
                          <% if conteudo.tipo.present? %>
                            <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full text-xs font-medium">
                              <%= Conteudo.tipos.key(conteudo.tipo).to_s.titleize %>
                            </span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                    <%= link_to escola_conteudo_path(escola, conteudo), class: "ml-3 px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-medium rounded-lg transition-colors flex-shrink-0" do %>
                      Ver
                    <% end %>
                  </div>
                <% end %>
                
                <!-- Distribuição por Bimestre -->
                <% if conteudos_por_bimestre.any? %>
                  <div class="mt-4 space-y-2">
                    <h5 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Distribuição por Bimestre:</h5>
                    <% conteudos_por_bimestre.sort.each do |bimestre, count| %>
                      <div class="flex items-center justify-between px-3 py-2 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg border-l-4 border-blue-400">
                        <span class="text-sm font-medium text-gray-700">
                          <%= bimestre.present? ? "#{bimestre}º Bimestre" : "Sem bimestre" %>
                        </span>
                        <span class="text-xs font-bold text-blue-600 bg-white px-2 py-1 rounded-full shadow-sm">
                          <%= count %>
                        </span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
                
                <!-- Card Total de Conteúdos -->
                <div class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 rounded-lg border-2 border-green-200 mt-4">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-600">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                        </svg>
                      </div>
                      <div>
                        <div class="font-semibold text-gray-800">Total de Conteúdos</div>
                        <div class="text-xs text-gray-600">
                          <%= disciplinas_count %> <%= disciplinas_count == 1 ? 'disciplina' : 'disciplinas' %>
                        </div>
                      </div>
                    </div>
                    <div class="text-2xl font-bold text-green-600">
                      <%= total_conteudos %>
                    </div>
                  </div>
                </div>
                
                <!-- Card "Ver Mais Conteúdos" quando há mais de 3 -->
                <% if escola.conteudos.count > 3 %>
                  <% conteudos_restantes = escola.conteudos.count - 3 %>
                  <%= link_to escola_conteudos_path(escola), class: "block" do %>
                    <div class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 rounded-lg border-2 border-dashed border-green-200 hover:border-green-400 hover:shadow-md transition-all duration-300 group">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                          <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-600">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                            </svg>
                          </div>
                          <div>
                            <div class="font-semibold text-gray-800 group-hover:text-green-700 transition-colors">
                              Mais <%= conteudos_restantes %> <%= conteudos_restantes == 1 ? 'conteúdo' : 'conteúdos' %>
                            </div>
                            <div class="text-xs text-gray-600">Clique para ver todos</div>
                          </div>
                        </div>
                        <div class="flex items-center gap-2">
                          <span class="text-xs font-medium text-green-600 bg-green-100 px-3 py-1 rounded-full">
                            <%= total_conteudos %> total
                          </span>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-600 group-hover:translate-x-1 transition-transform">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-6">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-gray-300 mx-auto mb-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <p class="text-gray-500 text-sm mb-3">Nenhum conteúdo cadastrado</p>
                <%= link_to "Cadastrar Conteúdo", new_escola_conteudo_path(escola), class: "inline-block px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-lg transition-colors" %>
              </div>
            <% end %>
          </div>
          
          <!-- Footer do Card -->
          <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
            <%= link_to escola_path(escola), class: "text-green-600 hover:text-green-800 text-sm font-medium flex items-center justify-center gap-1" do %>
              <span>Ver detalhes da escola</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Mensagem quando não há escolas -->
    <% if @escolas.empty? %>
      <div class="bg-white rounded-lg shadow-sm p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-gray-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-800 mb-2">Nenhuma escola cadastrada</h3>
        <p class="text-gray-600 mb-6">Comece criando sua primeira escola no sistema</p>
        <%= link_to new_escola_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span>Criar Primeira Escola</span>
        <% end %>
      </div>
    <% end %>
    
    <!-- Botão de Voltar -->
    <div class="mt-8 text-center">
      <%= link_to dashboard_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-gray-50 text-gray-700 font-medium rounded-lg shadow-sm transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        <span>Voltar ao Dashboard</span>
      <% end %>
    </div>
  </div>
</div>