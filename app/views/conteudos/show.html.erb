<div class="min-h-screen bg-gray-100">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-4 sm:mb-6">
    <div class="px-3 sm:px-4 lg:px-6 py-3 sm:py-4">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-3 lg:gap-4">
        <!-- Título e breadcrumbs -->
        <div class="flex-1 min-w-0 w-full lg:w-auto">
          <h1 class="text-lg sm:text-xl lg:text-2xl font-bold text-gray-900 break-words mb-2">
            Conteúdo - <%= @conteudo.titulo %>
          </h1>
          
          <!-- Breadcrumbs -->
          <div class="text-xs sm:text-sm overflow-x-auto">
            <ul class="flex flex-nowrap gap-2 pb-1">
              <% if @conteudo.escola.present? %>
                <li>
                  <%= link_to @conteudo.escola.nome, escola_path(@conteudo.escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200 truncate max-w-[100px] sm:max-w-[150px] md:max-w-none inline-block" %>
                </li>
                <li class="text-gray-400 flex-shrink-0">/</li>
              <% end %>
              <% if @escola.present? && (current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin)) %>
                <li>
                  <%= link_to "Conteúdos da Escola", escola_conteudos_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200 whitespace-nowrap" %>
                </li>
                <li class="text-gray-400 flex-shrink-0">/</li>
              <% end %>
              <% if @escola.present? && (current_user.is_a?(Professor)) %>
                <li>
                  <%= link_to "", professor_turma_conteudos_path(@conteudo.turma), class: "text-green-600 hover:text-green-800 transition-colors duration-200 whitespace-nowrap" %>
                </li>
                <li class="text-gray-400 flex-shrink-0">/</li>
              <% end %>
              <li class="text-gray-600 truncate max-w-[120px] sm:max-w-[180px] md:max-w-none"><%= @conteudo.titulo %></li>
            </ul>
          </div>
        </div>

        <!-- Botões -->
        <% if current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin) %>
          <div class="flex flex-wrap gap-2 w-full lg:w-auto">
            <% if current_user.is_a?(Admin) && @conteudo.escola_id == current_user.escolas.pluck(:id).first %>
              <%= link_to new_escola_conteudo_path(@conteudo.escola),
                          class: "bg-green-500 hover:bg-green-600 text-white px-3 sm:px-4 py-2 rounded-lg text-sm sm:text-base font-medium flex items-center justify-center gap-1 sm:gap-2 transition-all hover:shadow-lg hover:scale-105 flex-1 sm:flex-none" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <span class="hidden sm:inline">Novo Conteúdo</span>
                <span class="sm:hidden">Novo</span>
              <% end %>

            <% elsif current_user.is_a?(SuperAdmin) %>
              <% if @conteudo.escola.present? %>
                <%= link_to new_escola_conteudo_path(@conteudo.escola),
                            class: "bg-green-500 hover:bg-green-600 text-white px-3 sm:px-4 py-2 rounded-lg text-sm sm:text-base font-medium flex items-center justify-center gap-1 sm:gap-2 transition-all hover:shadow-lg hover:scale-105 flex-1 sm:flex-none" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  <span class="hidden sm:inline">Novo Conteúdo</span>
                  <span class="sm:hidden">Novo</span>
                <% end %>
              <% else %>
                <%= link_to escolas_path,
                            class: "bg-green-500 hover:bg-green-600 text-white px-3 sm:px-4 py-2 rounded-lg text-sm sm:text-base font-medium flex items-center justify-center gap-1 sm:gap-2 transition-all hover:shadow-lg hover:scale-105 flex-1 sm:flex-none" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  <span class="hidden sm:inline">Novo Conteúdo</span>
                  <span class="sm:hidden">Novo</span>
                <% end %>
              <% end %>
            <% end %>

            <% if @escola.present? && (current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin)) %>
              <%= link_to edit_escola_conteudo_path(@escola, @conteudo),
                          class: "bg-yellow-500 hover:bg-yellow-600 text-white px-3 sm:px-4 py-2 rounded-lg text-sm sm:text-base font-medium flex items-center justify-center gap-1 sm:gap-2 transition-all hover:shadow-lg hover:scale-105 flex-1 sm:flex-none" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                </svg>
                <span class="hidden sm:inline">Editar Conteúdo</span>
                <span class="sm:hidden">Editar</span>
              <% end %>
            <% else %>
              <%= link_to edit_professor_conteudo_path(@conteudo),
                          class: "bg-yellow-500 hover:bg-yellow-600 text-white px-3 sm:px-4 py-2 rounded-lg text-sm sm:text-base font-medium flex items-center justify-center gap-1 sm:gap-2 transition-all hover:shadow-lg hover:scale-105 flex-1 sm:flex-none" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                </svg>
                <span class="hidden sm:inline">Editar Conteúdo</span>
                <span class="sm:hidden">Editar</span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Conteúdo -->
  <div class="px-3 sm:px-4 lg:px-6 pb-6">
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-6 sm:mb-8">
      <!-- Header do Card -->
      <div class="bg-gradient-to-r from-blue-500 to-green-300 px-4 sm:px-6 py-3 sm:py-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6 text-white flex-shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
        </svg>
        <h2 class="text-lg sm:text-xl font-bold text-white">Informações do Conteúdo</h2>
      </div>

      <!-- Grid de Informações -->
      <div class="p-4 sm:p-6 lg:p-8 grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 lg:gap-8">
        <!-- Card de Informações -->
        <div class="bg-white rounded-lg shadow-lg p-4 sm:p-6 space-y-3 sm:space-y-4">
          <div>
            <% if @conteudo.disciplina.present? %>
              <p class="text-base sm:text-lg font-bold text-indigo-600 break-words"><%= @conteudo.disciplina.nome %></p>
            <% else %>
              <p class="text-base sm:text-lg text-gray-400 italic">Sem disciplina</p>
            <% end %>
          </div>

          <% if current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin) %>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wide">Professor responsável</p>
              <p class="text-base sm:text-lg font-bold text-indigo-600 break-words"><%= @conteudo.professor&.nome || "Não atribuído" %></p>
            </div>
          <% end %>

          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wide">Bimestre</p>
            <p class="text-base sm:text-lg font-bold text-indigo-600"><%= @conteudo.bimestre || "N/A" %></p>
          </div>

          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wide">Descrição</p>
            <div class="prose max-w-none text-sm sm:text-base text-gray-700 break-words">
              <%= @conteudo.descricao || "Sem descrição disponível" %>
            </div>
          </div>
        </div>

        <!-- Card de Conteúdo -->
        <div class="bg-white rounded-lg shadow-lg p-4 sm:p-6">
          <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-3">Conteúdo</h3>
          <div class="prose max-w-none text-gray-700">
            <div id="conteudo-visualizado" class="prose-conteudo prose max-w-none text-sm sm:text-base lg:text-lg text-gray-800 leading-relaxed">
              <%= markdown(@conteudo.markdown) %>
            </div>
          </div>
        </div>

        <!-- Tabela de Materiais -->
        <% if @conteudo.materiais.attached? %>
          <div class="col-span-full mt-4 sm:mt-6">
            <!-- Mobile: Cards -->
            <div class="block lg:hidden space-y-3">
              <% @conteudo.materiais.each do |arquivo| %>
                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                  <div class="flex items-start gap-3 mb-3">
                    <% case arquivo.content_type %>
                    <% when /pdf/ %>
                      <div class="w-10 h-10 bg-red-50 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                        </svg>
                      </div>
                    <% when /word|docx|msword/ %>
                      <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                        </svg>
                      </div>
                    <% when /image/ %>
                      <div class="w-10 h-10 bg-purple-50 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    <% end %>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900 break-words"><%= arquivo.filename.to_s %></p>
                      <p class="text-xs text-gray-500 mt-1">
                        <%= arquivo.filename.extension.upcase %> • <%= number_to_human_size(arquivo.byte_size) %>
                      </p>
                    </div>
                  </div>
                  <div class="flex gap-2">
                    <%= link_to rails_blob_path(arquivo, disposition: "attachment"), class: "flex-1 btn btn-sm bg-teal-500 hover:bg-teal-600 text-white border-0", title: "Baixar" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 12v8m0 0l-4-4m4 4l4-4m-4-8V4" />
                      </svg>
                      Baixar
                    <% end %>
                    <% if @escola.present? && (current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin)) %>
                      <%= link_to remove_material_conteudo_path(@conteudo, arquivo_id: arquivo.id),
                                  data: { turbo_method: :delete, turbo_confirm: 'Tem certeza que deseja remover este arquivo?' },
                                  class: "btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0",
                                  title: "Remover" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                      <% end %>
                    <% else %>
                      <%= link_to remove_material_professor_conteudo_path(@conteudo, arquivo_id: arquivo.id),
                                  data: { turbo_method: :delete, turbo_confirm: 'Tem certeza que deseja remover este arquivo?' },
                                  class: "btn btn-sm bg-red-600 hover:bg-red-700 text-white border-0",
                                  title: "Remover" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>

            <!-- Desktop: Tabela -->
            <div class="hidden lg:block overflow-x-auto rounded-xl">
              <table class="w-full">
                <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white rounded-tl-xl">Arquivo</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Tipo</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Tamanho</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white rounded-tr-xl">Ações</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                  <% @conteudo.materiais.each do |arquivo| %>
                    <tr class="transition-colors hover:bg-emerald-50/50">
                      <td class="whitespace-nowrap px-6 py-4 flex items-center gap-3">
                        <% case arquivo.content_type %>
                        <% when /pdf/ %>
                          <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center">
                            <svg class="w-4 h-4 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                            </svg>
                          </div>
                        <% when /word|docx|msword/ %>
                          <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                            </svg>
                          </div>
                        <% when /image/ %>
                          <div class="w-8 h-8 bg-purple-50 rounded-lg flex items-center justify-center">
                            <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                          </div>
                        <% end %>
                        <span class="text-gray-800 font-medium truncate max-w-[200px]"><%= arquivo.filename.to_s %></span>
                      </td>
                      <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700 capitalize">
                        <%= arquivo.filename.extension %>
                      </td>
                      <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                        <%= number_to_human_size(arquivo.byte_size) %>
                      </td>
                      <td class="whitespace-nowrap px-6 py-4 text-sm font-medium flex gap-3">
                        <%= link_to rails_blob_path(arquivo, disposition: "attachment"), class: "rounded-full p-1 text-teal-500 hover:bg-teal-100/50 hover:text-teal-700 transition-colors", title: "Baixar" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 12v8m0 0l-4-4m4 4l4-4m-4-8V4" />
                          </svg>
                        <% end %>
                        <% if @escola.present? && (current_user.is_a?(Admin) || current_user.is_a?(SuperAdmin)) %>
                          <%= link_to remove_material_conteudo_path(@conteudo, arquivo_id: arquivo.id),
                                      data: { turbo_method: :delete, turbo_confirm: 'Tem certeza que deseja remover este arquivo?' },
                                      class: "rounded-full p-1 text-red-600 hover:bg-red-100/50 hover:text-red-800 transition-colors",
                                      title: "Remover" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                          <% end %>
                        <% else %>
                          <%= link_to remove_material_professor_conteudo_path(@conteudo, arquivo_id: arquivo.id),
                                      data: { turbo_method: :delete, turbo_confirm: 'Tem certeza que deseja remover este arquivo?' },
                                      class: "rounded-full p-1 text-red-600 hover:bg-red-100/50 hover:text-red-800 transition-colors",
                                      title: "Remover" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
/* ============================================
   ESTILOS RICH TEXT PARA VISUALIZAÇÃO (TIPTAP)
   ============================================ */

.prose-conteudo {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 1.05rem;
  line-height: 1.75;
  color: #374151;
  word-break: break-word;
}

@media (max-width: 640px) {
  .prose-conteudo {
    font-size: 0.95rem;
  }
}

.prose-conteudo h1,
.prose-conteudo h2,
.prose-conteudo h3,
.prose-conteudo h4,
.prose-conteudo h5,
.prose-conteudo h6 {
  font-weight: 700;
  line-height: 1.3;
  color: #111827;
  scroll-margin-top: 4rem;
}

.prose-conteudo h1 { font-size: 1.75rem; margin-top: 2rem; margin-bottom: 1rem; }
.prose-conteudo h2 { font-size: 1.5rem; margin-top: 1.75rem; margin-bottom: 0.875rem; }
.prose-conteudo h3 { font-size: 1.25rem; margin-top: 1.25rem; margin-bottom: 0.75rem; }
.prose-conteudo h4 { font-size: 1.1rem; margin-top: 1rem; margin-bottom: 0.5rem; }

@media (min-width: 1024px) {
  .prose-conteudo h1 { font-size: 2rem; }
  .prose-conteudo h2 { font-size: 1.6rem; }
  .prose-conteudo h3 { font-size: 1.3rem; }
}

.prose-conteudo p {
  margin-top: 0.75em;
  margin-bottom: 0.75em;
}

.prose-conteudo strong {
  font-weight: 600;
  color: #111827;
}

.prose-conteudo em {
  font-style: italic;
}

.prose-conteudo s {
  text-decoration: line-through;
  color: #6b7280;
}

.prose-conteudo code {
  background-color: #f3f4f6;
  color: #e11d48;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9em;
  padding: 2px 5px;
  border-radius: 4px;
}

.prose-conteudo pre {
  background-color: #1e1e1e;
  color: #f3f4f6;
  padding: 1rem;
  border-radius: 0.75rem;
  overflow-x: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9rem;
  line-height: 1.6;
}

.prose-conteudo blockquote {
  border-left: 4px solid #14b8a6;
  padding-left: 1rem;
  color: #4b5563;
  font-style: italic;
  margin: 1.5rem 0;
  background-color: #f9fafb;
