<div class="bg-gradient-to-br from-white shadow-xl hover:shadow-2xl transition-all duration-300 rounded-lg relative cursor-pointer p-4"
     style="background: linear-gradient(to bottom right, white 0%, <%= conteudo.cor %>33 60%, <%= conteudo.cor %>55 100%);">
  
  <div class="flex justify-between items-start">
    <div>
      <h2 class="card-title text-slate-700 transition-colors duration-300 cursor-pointer">
        <%= conteudo.titulo %>
      </h2>

      <div class="flex flex-wrap gap-2 mt-2">
        <span class="badge badge-sm bg-gradient-to-r from-blue-500 to-green-400 text-white border-0 font-bold">
          <%= conteudo.materia || "Sem matéria" %>
        </span>
        <span class="badge badge-sm bg-gradient-to-r from-yellow-500 to-orange-400 text-white border-0 font-bold">
          <%= conteudo.bimestre || "Bimestre não informado" %>
        </span>

        <% if current_user.admin? %>
          <span class="badge badge-sm bg-gray-500 text-white border-0 font-bold">
            <%= conteudo.professor.nome %>
          </span>
        <% end %>
      </div>
    </div>

    <div class="dropdown dropdown-end z-50">
      <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
        </svg>
      </label>
      <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
        <li>
          <%= link_to conteudo_path(conteudo), data: { turbo: false } do %>
            Ver
          <% end %>
        </li>

        <% if current_user.admin? || conteudo.professor == current_user.professor %>
          <li>
            <%= link_to edit_conteudo_path(conteudo), data: { turbo: false } do %>
              Editar
            <% end %>
          </li>
          <li>
            <%= button_to conteudo_path(conteudo), method: :delete, data: { confirm: "Deseja excluir este conteúdo?" } do %>
              Excluir
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
