<div class="min-h-screen flex items-center justify-center bg-base-100">
  <div class="w-full min-h-screen sm:min-h-auto sm:max-w-md sm:rounded-2xl sm:shadow-lg p-2.5 sm:p-6 bg-white flex flex-col justify-center">
    
    <!-- Logo -->
    <div class="flex items-center justify-center mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
           viewBox="0 0 24 24" stroke-width="1.5"
           stroke="currentColor"
           class="w-8 h-8 text-gray-800 mr-3">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 
                 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 
                 60.46 60.46 0 0 0-.491-6.347m-15.482 
                 0a50.636 50.636 0 0 0-2.658-.813A59.906 
                 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 
                 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 
                 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 
                 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 
                 0-1.5.75.75 0 0 0 0 1.5Zm0 
                 0v-3.675A55.378 55.378 0 0 1 
                 12 8.443m-7.007 11.55A5.981 
                 5.981 0 0 0 6.75 15.75v-1.5" />
      </svg>
      <h1 class="text-2xl font-bold text-gray-800">TURMARIA</h1>
    </div>

    <!-- Tabs -->
    <div role="tablist" class="tabs tabs-boxed mb-6">
      
      <input type="radio" name="login_tabs" role="tab"
             class="tab text-green-500 checked:bg-green-500 checked:text-white"
             aria-label="Administradores"
             checked="checked" />

      <div role="tabpanel" class="tab-content p-6">
        <h2 class="text-lg font-semibold mb-4 text-green-500">
          Login Administrativo
        </h2>

        <%= form_for(resource, as: resource_name, url: user_session_path(resource_name), html: { class: "space-y-4", data: { turbo: false } }) do |f| %>

          <%= f.email_field :email,
            placeholder: "E-mail",
            class: "input input-bordered w-full focus:outline-none focus:border-green-400" %>

          <%= f.password_field :password,
            placeholder: "Senha",
            class: "input input-bordered w-full focus:outline-none focus:border-green-400" %>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center space-x-2">
              <%= f.check_box :remember_me, class: "checkbox checkbox-success" %>
              <%= f.label :remember_me, "Salvar senha?", class: "text-sm text-gray-600 cursor-pointer" %>
            </div>
          <% end %>

          <%= f.submit "Entrar", class: "btn bg-green-500 text-white w-full" %>
        <% end %>

        <div class="mt-4 text-sm text-center">
          <%= render "devise/shared/links" %>
        </div>
      </div>

      <input type="radio" name="login_tabs" role="tab"
             class="tab text-green-500 checked:bg-green-500 checked:text-white"
             aria-label="Aluno" />

      <div role="tabpanel" class="tab-content p-6">
        <h2 class="text-lg font-semibold mb-4 text-green-500">
          Login do Aluno
        </h2>

        <%= form_for(resource, as: :aluno, url: aluno_session_path, html: { class: "space-y-4" }) do |f| %>

          <%= f.text_field :matricula,
            placeholder: "Matrícula",
            class: "input input-bordered w-full focus:outline-none focus:border-green-400" %>

          <%= f.password_field :password,
            placeholder: "Senha",
            class: "input input-bordered w-full focus:outline-none focus:border-green-400" %>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center space-x-2">
              <%= f.check_box :remember_me, class: "checkbox checkbox-success" %>
              <%= f.label :remember_me, "Salvar senha?", class: "text-sm text-gray-600 cursor-pointer" %>
            </div>
          <% end %>

          <%= f.submit "Entrar", class: "btn bg-green-500 text-white w-full" %>
        <% end %>
      </div>

    </div>
  </div>
</div>
