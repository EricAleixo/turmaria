<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title>SistemaAcademico</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# 🛑 COMEÇO DO NOVO LAYOUT DO DRAWER 🛑 %>
    <div class="drawer lg:drawer-open min-h-screen">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      
      <%# === LÓGICA CONDICIONAL PARA RENDERIZAR A SIDEBAR CORRETA === %>
      <% if current_any_user.present? %>
        <div class="drawer-side z-20">
          <label for="my-drawer" class="drawer-overlay"></label>
          
          <% if current_any_user.is_a?(SuperAdmin) %>
            <%= render 'shared/super_admin_sidebar' %>
          <% elsif current_any_user.is_a?(Aluno) %>
            <%= render 'shared/aluno_sidebar' %>
          <% elsif current_any_user.is_a?(Professor) %>
            <%= render 'shared/professor_sidebar' %>
          <% elsif current_any_user.is_a?(Admin) %>
            <%= render 'shared/admin_sidebar' %>
          <% end %>

        </div>
      <% end %>
      
      <%# CONTEÚDO PRINCIPAL E CABEÇALHO %>
      <div class="drawer-content flex flex-col min-h-screen">
        
        <header class="bg-white text-black p-2 flex justify-between items-center h-18
                       sm:p-2
                       md:p-7 h-20 shadow-sm border-b border-gray-200">
          <div class="flex w-full items-center justify-between space-x-0
                      md:space-x-2">
            <div class="flex items-center space-x-3">
              <%# Só mostra o botão hambúrguer se for Professor e em tela pequena %>
              <% if current_professor.present? %>
                <div class="lg:hidden">
                  <label for="my-drawer" class="btn btn-square btn-ghost">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                  </label>
                </div>
              <% end %>
              
              <div class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                class="size-7
                      sm:size-11
                      md:size-13">
                  <path d="M11.7 2.805a.75.75 0 0 1 .6 0A60.65 60.65 0 0 1 22.83 8.72a.75.75 0 0 1-.231 1.337 49.948 49.948 0 0 0-9.902 3.912l-.003.002c-.114.06-.227.119-.34.18a.75.75 0 0 1-.707 0A50.88 50.88 0 0 0 7.5 12.173v-.224c0-.131.067-.248.172-.311a54.615 54.615 0 0 1 4.653-2.52.75.75 0 0 0-.65-1.352 56.123 56.123 0 0 0-4.78 2.589 1.858 1.858 0 0 0-.859 1.228 49.803 49.803 0 0 0-4.634-1.527.75.75 0 0 1-.231-1.337A60.653 60.653 0 0 1 11.7 2.805Z" />
                  <path d="M13.06 15.473a48.45 48.45 0 0 1 7.666-3.282c.134 1.414.22 2.843.255 4.284a.75.75 0 0 1-.46.711 47.87 47.87 0 0 0-8.105 4.342.75.75 0 0 1-.832 0 47.87 47.87 0 0 0-8.104-4.342.75.75 0 0 1-.461-.71c.035-1.442.121-2.87.255-4.286.921.304 1.83.634 2.726.99v1.27a1.5 1.5 0 0 0-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.66a6.727 6.727 0 0 0 .551-1.607 1.5 1.5 0 0 0 .14-2.67v-.645a48.549 48.549 0 0 1 3.44 1.667 2.25 2.25 0 0 0 2.12 0Z" />
                  <path d="M4.462 19.462c.42-.419.753-.89 1-1.395.453.214.902.435 1.347.662a6.742 6.742 0 0 1-1.286 1.794.75.75 0 0 1-1.06-1.06Z" />
                </svg>
                <%= link_to root_path do%>
                  <h1 class="text-xl font-bold md:text-4xl transition-colors duration-300 hover:text-primary
                              sm:text-3xl
                              lg:text-4xl">Turmaria</h1>
                <% end %>
              </div>
            </div>
            
            <nav class="flex space-x-3.5 items-center md:space-x-7">
              <% if current_any_user.present? && current_page?(root_path) %>

              <% end %>
              <% if current_any_user.present? %>
                <%= link_to dashboard_link_path, class: "btn bg-green-600 text-white shadow-none d-flex align-items-center gap-2" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                  </svg>
                  Dashboard
                <% end %>
                <div class="flex-none">
                <div class="flex items-center space-x-4">
                  <div class="text-right hidden sm:block">
                    <p class="text-sm font-medium text-gray-900">
                      <%= current_any_user&.nome.present? ? current_any_user.nome : current_user_type %>
                    </p>
                    <div class="flex items-center justify-end space-x-2">
                      <p class="text-xs text-gray-500"><%= current_user_type %></p>
                      <% if current_admin&.escolas&.first.present? %>
                        <div class="badge badge-xs bg-green-100 text-green-700 border-green-200">
                          <%= current_admin.escolas.first.nome %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                  
                  <div class="avatar placeholder">
                    <div class="bg-green-500 text-white rounded-full w-10 h-10 relative">
                      <span class="text-sm font-bold absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                        <% if current_any_user&.nome.present? %>
                          <%= current_any_user.nome.first.upcase %>
                        <% elsif current_any_user&.email.present? %>
                          <%= current_any_user.email.first.upcase %>
                        <% else %>
                          U
                        <% end %>
                      </span>
                    </div>
                  </div>

                  <!-- Dropdown Menu -->
                   <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-green-50 hover:bg-green-100 text-green-600 border border-green-200">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
                      </svg>
                    </div>

                    <div tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
                      <div class="flex items-center gap-3 px-3 py-2 border-b border-gray-100">
                        <div class="avatar placeholder">
                          <div class="bg-green-500 text-white rounded-full w-8 h-8 relative">
                            <span class="text-xs font-bold absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                              <% if current_any_user&.nome.present? %>
                                <%= current_any_user.nome.first.upcase %>
                              <% elsif current_any_user&.email.present? %>
                                <%= current_any_user.email.first.upcase %>
                              <% else %>
                                U
                              <% end %>
                            </span>
                          </div>
                        </div>
                        <div>
                          <p class="text-sm font-medium text-gray-900">
                            <%= current_any_user&.nome.present? ? current_any_user.nome : current_user_type %>
                          </p>
                          <p class="text-xs text-gray-500"><%= current_any_user&.email %></p>
                        </div>
                      </div>

                      <!-- Link: Meu Perfil -->
                      <%= link_to profile_path, class: "w-full flex items-center gap-2 px-3 py-2 rounded-md hover:bg-green-50 text-gray-700 hover:text-green-700 focus:bg-green-50 active:bg-green-100 transition-colors duration-150" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        <span class="flex-1 text-left">Meu Perfil</span>
                      <% end %>

                      <!-- Link: Configurações -->
                      <%= link_to "settings_path", class: "w-full flex items-center gap-2 px-3 py-2 rounded-md hover:bg-green-50 text-gray-700 hover:text-green-700 focus:bg-green-50 active:bg-green-100 transition-colors duration-150" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        <span class="flex-1 text-left">Configurações</span>
                      <% end %>

                      <div class="divider my-1"></div>

                      <!-- Botão: Sair -->
                      <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-2 px-3 py-2 rounded-md hover:bg-red-50 text-red-600 focus:bg-red-50 active:bg-red-100 cursor-pointer transition-colors duration-150" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                        </svg>
                        <span class="flex-1 text-left">Sair</span>
                      <% end %>
                    </div>
                  </div>

                </div>
                </div>
                
              <% else %>
                <%= link_to new_user_session_path, class: "btn text-white bg-green-500 shadow-none d-flex align-items-center gap-2" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 16l-4-4m0 0l4-4m-4 4h14m-6 4v1a2 2 0 002 2h3a2 2 0 002-2v-1m-7-8V7a2 2 0 012-2h3a2 2 0 012 2v1" />
                  </svg>
                  Entrar
                <% end %>
              <% end %>
            </nav>
          </div>
        </header>

        <main class="flex-grow p-0">
          <% if notice.present? %>
            <div role="alert" class="alert alert-success alert-soft w-[80%] text-lg mx-auto mb-4">
              <span><%= notice %></span>
            </div>
          <% end %>
          <% if alert.present? %>
            <div role="alert" class="alert alert-warning alert-soft w-[80%] text-lg mx-auto mb-4">
              <span><%= alert %></span>
            </div>
          <% end %>
          <%= yield %>
        </main>
        
        <footer class="w-full bg-gray-900 text-white flex flex-col items-center justify-center p-5 ">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" 
                class="size-8 text-white 
                       md: size-10
                       lg:size-12">
            <path d="M11.7 2.805a.75.75 0 0 1 .6 0A60.65 60.65 0 0 1 22.83 8.72a.75.75 0 0 1-.231 1.337 49.948 49.948 0 0 0-9.902 3.912l-.003.002c-.114.06-.227.119-.34.18a.75.75 0 0 1-.707 0A50.88 50.88 0 0 0 7.5 12.173v-.224c0-.131.067-.248.172-.311a54.615 54.615 0 0 1 4.653-2.52.75.75 0 0 0-.65-1.352 56.123 56.123 0 0 0-4.78 2.589 1.858 1.858 0 0 0-.859 1.228 49.803 49.803 0 0 0-4.634-1.527.75.75 0 0 1-.231-1.337A60.653 60.653 0 0 1 11.7 2.805Z" />
            <path d="M13.06 15.473a48.45 48.45 0 0 1 7.666-3.282c.134 1.414.22 2.843.255 4.284a.75.75 0 0 1-.46.711 47.87 47.87 0 0 0-8.105 4.342.75.75 0 0 1-.832 0 47.87 47.87 0 0 0-8.104-4.342.75.75 0 0 1-.461-.71c.035-1.442.121-2.87.255-4.286.921.304 1.83.634 2.726.99v1.27a1.5 1.5 0 0 0-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.66a6.727 6.727 0 0 0 .551-1.607 1.5 1.5 0 0 0 .14-2.67v-.645a48.549 48.549 0 0 1 3.44 1.667 2.25 2.25 0 0 0 2.12 0Z" />
            <path d="M4.462 19.462c.42-.419.753-.89 1-1.395.453.214.902.435 1.347.662a6.742 6.742 0 0 1-1.286 1.794.75.75 0 0 1-1.06-1.06Z" />
          </svg>
          <p class="text-sm text-white font-semibold mt-2
                     sm:text-base
                       lg:text-lg">© 2025 Turmaria. Todos os direitos reservados.</p>
          <div class="mt-2
                       md:mt-4">
            <nav class="space-x-2
                          md:space-x-5">
              <a href="#" class="text-sm text-white hover:underline hover:text-blue-500 transition-colors duration-400
                                  md:text-base">Serviços</a>
              <a href="#" class="text-sm text-white hover:underline hover:text-blue-500 transition-colors duration-400
                                  md:text-base">Sobre Nós</a>
              <a href="#" class="text-sm text-white hover:underline hover:text-blue-500 transition-colors duration-400
                                  md:text-base">Contatos</a>
            </nav>
        </footer>
      </div>
    </div>
    <%# 🛑 FIM DO NOVO LAYOUT DO DRAWER 🛑 %>
  </body>
</html>
