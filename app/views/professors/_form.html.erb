<%= form_with(model: @professor, class: "bg-white rounded-lg shadow-sm border border-gray-200") do |form| %>
<%= hidden_field_tag :escola_id, params[:escola_id] %>
  <% if @professor.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800">Erro ao salvar!</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @professor.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">
      <%= @professor.persisted? ? "Editar Professor" : "Novo Professor" %>
    </h2>
    <p class="mt-1 text-sm text-gray-600">
      <%= @professor.persisted? ? "Atualize as informações abaixo." : "Preencha os dados do professor abaixo." %>
    </p>
  </div>

  <div class="px-6 py-6">
    <div class="mb-8">
      <h3 class="text-base font-medium text-gray-900 mb-4">Informações Básicas</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Campos de texto -->
        <div>
          <%= form.label :nome, "Nome *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :nome, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "Ex: João da Silva", required: true %>
        </div>

        <div>
          <%= form.label :email, "E-mail *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "exemplo@dominio.com", required: true %>
        </div>

        <div>
          <%= form.label :password, "Senha *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.password_field :password, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "••••••••", required: !@professor.persisted? %>
        </div>

        <div>
          <%= form.label :cpf, "CPF *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :cpf, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "000.000.000-00", required: true %>
        </div>

        <div>
          <%= form.label :telefone, "Telefone", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :telefone, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "(00) 90000-0000" %>
        </div>

        <!-- Dropdown Tipo de Professor -->
        <div>
          <%= dropdown(form: form, method: :tipo_professor, select_id: "tipo_professor_select", collection: [["Contratado","contratado"],["Concursado","concursado"]], placeholder: "Selecione o Tipo", hidden_field_id: "tipo_hidden") %>

        </div>

          <%= dropdown(form: form, method: :formacao, select_id: "formacao_select", collection: [["Doutorado","doutorado"],["Mestrado","mestrado"],["Pós graduado","pos_graduado"],["Graduado","graduado"]], placeholder: "Selecione a Formação", hidden_field_id: "formacao_hidden ") %>


        <div>

        </div>
      </div>
    </div>
  </div>

  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
    <div class="flex justify-between">
      <%= link_to "Cancelar", professors_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      <%= form.submit @professor.persisted? ? "Atualizar Professor" : "Criar Professor", class: "bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  </div>
<% end %>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const dropdownConfigs = [
    {optionClass: "escola-option", hiddenId: "escola_hidden", labelId: "escola_label"},
    {optionClass: "tipo-option", hiddenId: "tipo_hidden", labelId: "tipo_label"},
    {optionClass: "formacao-option", hiddenId: "formacao_hidden", labelId: "formacao_label"}
  ];

  dropdownConfigs.forEach(d => {
    document.querySelectorAll("." + d.optionClass).forEach(option => {
      option.addEventListener("click", e => {
        e.preventDefault();
        document.getElementById(d.hiddenId).value = option.dataset.value;
        document.getElementById(d.labelId).textContent = option.textContent;
        option.closest("details").removeAttribute("open");
      });
    });
  });

  // Fecha dropdowns ao clicar fora
  document.addEventListener("click", e => {
    document.querySelectorAll("details.dropdown").forEach(detail => {
      if (!detail.contains(e.target)) {
        detail.removeAttribute("open");
      }
    });
  });
});
</script>
