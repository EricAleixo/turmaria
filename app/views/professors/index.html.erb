<%= content_for :page_title, "Professores" %>

<div class="min-h-screen bg-gray-100">
  <!-- Dashboard Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <div>
          <% if @escola %>
            <h1 class="text-2xl font-bold text-gray-900">Professores - <%= @escola.nome %></h1>
          <% else %>
            <h1 class="text-2xl font-bold text-gray-900">Todos os Professores</h1>
          <% end %>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li>
                <%= link_to "Escolas", escolas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %>
              </li>
              <% if @escola %>
                <li>
                  <%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %>
                </li>
              <% end %>
              <li class="text-gray-600">Professores</li>
            </ul>
          </div>
        </div>

        <!-- Botões para telas sm e maiores -->
        <div class="hidden sm:flex gap-3">
          <% if @escola %>
            <%= link_to new_escola_professor_path(@escola), class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Novo Professor
            <% end %>
          <% else %>
            <%= link_to new_professor_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Novo Professor
            <% end %>
          <% end %>

          <%= link_to escolas_path, class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            Ver Escolas
          <% end %>
        </div>

        <!-- Dropdown para telas menores que sm -->
        <div class="sm:hidden dropdown dropdown-end">
          <label tabindex="0" class="btn btn-ghost btn-circle">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
          <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52 mt-2 border border-gray-200">
            <li>
              <% if @escola %>
                <%= link_to "Novo Professor", new_escola_professor_path(@escola) %>
              <% else %>
                <%= link_to "Novo Professor", new_professor_path %>
              <% end %>
            </li>
            <li>
              <%= link_to "Ver Escolas", escolas_path %>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Success Alert -->
    <% if notice.present? %>
      <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded-lg">
        <div class="flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-green-700 font-medium"><%= notice %></span>
        </div>
      </div>
    <% end %>

    <!-- Statistics Card -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Total de Professores</p>
          <p class="text-3xl font-bold text-green-600"><%= @professores&.count || 0 %></p>
        </div>
        <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-green-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Search & Filters -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Buscar e Filtrar</h3>
      
      <%= form_with url: professors_path, method: :get, data: { turbo_frame: "professors" }, class: 'space-y-4' do |form| %>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="flex-1">
            <%= form.text_field :busca, placeholder: "Buscar por nome do professor...", value: params[:busca], class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
          </div>

          <div class="flex gap-3 flex-shrink-0">
            <label for="filtro-modal" class="bg-gray-50 hover:bg-gray-100 border border-gray-300 text-gray-700 px-4 py-2 rounded-lg font-medium transition-colors cursor-pointer flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
              </svg>
              Filtros
            </label>

            <%= link_to "Limpar", professors_path, class: "bg-white hover:bg-gray-50 border border-gray-300 text-gray-700 px-4 py-2 rounded-lg font-medium transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Filters Modal -->
    <% c1 = [["Concursado", "concursado"], ["Contratado", "contratado"]] %>
    <% c2 = [["Todos os professores", ""], ["Mestres", "mestrado"], ["Doutores", "doutorado"], ["Pós-graduados", "pos_graduados"], ["Graduados", "graduados"]] %>

    <input type="checkbox" id="filtro-modal" class="modal-toggle">
    <div class="modal">
      <div class="modal-box w-full max-w-2xl bg-white border border-gray-200 shadow-lg">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-bold text-xl text-gray-800">Filtrar professores</h3>
          <label for="filtro-modal" class="btn btn-sm btn-circle absolute right-2 top-2">✕</label>
        </div>

        <%= form_with url: professors_path, method: :get, html: { id: "filtro-form" }, data: { turbo_frame: "professors" } do |form| %>
          <div class="space-y-6">
            <div>
              <h4 class="font-semibold text-gray-700 mb-3">Tipo de Vínculo</h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <% c1.each do |label, value| %>
                  <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-50 p-3 rounded-lg border border-gray-200 transition-colors">
                    <input type="checkbox" name="filtros[]" value="<%= value %>" class="checkbox checkbox-success">
                    <span class="text-sm font-medium text-gray-800"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <div>
              <h4 class="font-semibold text-gray-700 mb-3">Nível de Formação</h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <% c2.each do |label, value| %>
                  <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-50 p-3 rounded-lg border border-gray-200 transition-colors">
                    <input type="checkbox" name="filtros[]" value="<%= value %>" class="checkbox checkbox-success">
                    <span class="text-sm font-medium text-gray-800"><%= label %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>

          <div class="flex gap-3 mt-6 pt-4 border-t border-gray-200">
            <%= form.submit "Aplicar Filtros", class: "flex-1 bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
            <label for="filtro-modal" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-2 rounded-lg font-medium transition-colors text-center cursor-pointer">Cancelar</label>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Content: turbo frame -->
      <% if @professores.blank? %>
        <!-- Empty State -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
          <div class="max-w-md mx-auto">
            <div class="h-24 w-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Nenhum professor encontrado</h3>
            <p class="text-gray-600 mb-6">Não existem professores cadastrados para esta escola ou filtros.</p>
            <% if @escola %>
              <%= link_to new_escola_professor_path(@escola), class: "inline-flex items-center bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg font-medium transition-colors shadow-sm" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Adicionar Primeiro Professor
              <% end %>
            <% else %>
              <%= link_to new_professor_path, class: "inline-flex items-center bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg font-medium transition-colors shadow-sm" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Adicionar Primeiro Professor
              <% end %>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Desktop Table -->
        <div class="hidden md:block bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <table class="table w-full">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-200">
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Professor</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Disciplinas</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Escola</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Formação</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Tipo</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Ações</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @professores.each do |professor| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <div class="flex-shrink-0 h-10 w-10">
                <% if professor.foto&.attached? %>
                  <%= image_tag professor.foto.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full object-cover" %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-green-600 flex items-center justify-center">
                    <span class="text-white font-semibold text-sm"><%= professor.nome.first.upcase %></span>
                  </div>
                <% end %>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-900"><%= professor.nome %></div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4">
            <div class="flex flex-wrap gap-1">
              <%= disciplinas_badges(professor) || "-" %>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="text-sm text-gray-900">
              <%= link_to professor.escola.nome, escola_path(professor.escola), class: "text-blue-600 hover:text-blue-800 font-medium" if professor.escola.present? %>
              <%= "-" unless professor.escola.present? %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="text-sm text-gray-900"><%= professor.formacao&.humanize&.titleize || "-" %></span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="text-sm text-gray-900"><%= professor.tipo_professor&.titleize || "-" %></span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex gap-2">
              <%= link_to professor_path(professor), class: "text-green-600 hover:text-green-900 transition-colors", title: "Ver professor" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              <% end %>

              <%= link_to edit_professor_path(professor), class: "text-yellow-600 hover:text-yellow-900 transition-colors", title: "Editar professor" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                </svg>
              <% end %>

              <%= button_to professor_path(professor), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este professor?" }, class: "text-red-600 hover:text-red-900 transition-colors", title: "Deletar professor" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="grid grid-cols-1 gap-4 md:hidden">
  <% @professores.each do |professor| %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="p-4">
        <div class="flex justify-between items-start gap-3 mb-4">
          <div class="flex items-center gap-3 min-w-0 flex-1">
            <div class="flex-shrink-0">
              <% if professor.foto&.attached? %>
                <%= image_tag professor.foto.variant(resize_to_fill: [48, 48]), class: "h-12 w-12 rounded-full object-cover" %>
              <% else %>
                <div class="h-12 w-12 rounded-full bg-green-600 flex items-center justify-center">
                  <span class="text-white font-semibold"><%= professor.nome.first.upcase %></span>
                </div>
              <% end %>
            </div>
            <div class="min-w-0 flex-1">
              <h2 class="font-semibold text-gray-900 text-sm break-words"><%= professor.nome %></h2>
              <div class="flex flex-col gap-1 mt-1">
                <span class="text-xs text-gray-600">
                  <span class="font-medium">Escola:</span> 
                  <% if professor.escola.present? %>
                    <%= link_to professor.escola.nome, escola_path(professor.escola), class: "text-blue-600 hover:text-blue-800" %>
                  <% else %>
                    Não informada
                  <% end %>
                </span>
                <span class="text-xs text-gray-600"><%= professor.tipo_professor&.titleize || "Não informado" %></span>
                <span class="text-xs text-gray-600"><%= professor.formacao&.titleize || "Não informada" %></span>
              </div>
            </div>
          </div>

          <div class="dropdown dropdown-end flex-shrink-0">
            <label tabindex="0" class="btn btn-sm btn-ghost btn-circle">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
              </svg>
            </label>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-lg w-48 border border-gray-200">
              <li>
                <%= link_to professor_path(professor), data: { turbo: false }, class: "text-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Ver professor
                <% end %>
              </li>
              <li>
                <%= link_to edit_professor_path(professor), data: { turbo: false }, class: "text-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                  </svg>
                  Editar professor
                <% end %>
              </li>
              <li>
                <%= button_to professor_path(professor), method: :delete, data: { confirm: "Deseja excluir este professor?" }, class: "text-sm text-red-600" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                  </svg>
                  Excluir professor
                <% end %>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-3 mt-3">
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Disciplinas</p>
            <div class="flex flex-wrap gap-1">
              <% if professor.disciplinas.any? %>
                <%= disciplinas_badges(professor) %>
              <% else %>
                <span class="text-sm text-gray-500">Sem disciplinas</span>
              <% end %>
            </div>
          </div>
          <div class="bg-gradient-to-br from-blue-100 to-blue-200/80 border border-blue-300/50 rounded-xl p-4 text-center shadow-sm">
            <div class="flex items-center justify-center mb-2">
              <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <p class="text-xs font-medium text-blue-800 uppercase tracking-wide">Materias</p>
            <p class="text-sm font-semibold text-gray-900 mt-1">Sem materias</p>
          </div>
        </div>

        <div class="flex justify-center space-x-2 pt-4 border-t border-blue-200/50">
          <%= link_to professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105", data: { turbo: false } do %>
            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            Ver
          <% end %>
          <%= link_to edit_professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105", data: { turbo: false } do %>
            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Editar
          <% end %>
          <%= button_to professor_path(professor), method: :delete,
            data: { confirm: "Tem certeza que deseja excluir esta professor?" },
            class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105",
            form: { data: { turbo_frame: "_top" } } do %>
            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            Excluir
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<% end %>
</div>

<!-- Script: search debounce + modal/apply hook -->
<script>
  document.addEventListener("turbo:load", () => {
    const searchInput = document.querySelector('form input[name="busca"]');
    if (searchInput) {
      let timeout;
      searchInput.addEventListener("input", () => {
        clearTimeout(timeout);
        timeout = setTimeout(() => {
          const form = searchInput.closest("form");
          if (form) form.requestSubmit();
        }, 300);
      });
    }

    // Modal apply button
    const applyButton = document.querySelector('.modal .bg-green-600');
    if (applyButton) {
      applyButton.addEventListener("click", (e) => {
        const form = document.getElementById("filtro-form");
        if (form) form.requestSubmit();
        const modalCheckbox = document.getElementById("filtro-modal");
        if (modalCheckbox) modalCheckbox.checked = false;
      });
    }
  });
</script>