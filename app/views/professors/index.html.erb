<%# app/views/professors/index.html.erb (CÓDIGO COMPLETO COM DRAWER E PAGINAÇÃO E BUSCA POR PÁGINA) %>

<%= content_for :page_title, "Professores" %>

<%#====================================================%>
<%# 1. ESTRUTURA PRINCIPAL: DRAWER (FILTRO LATERAL) %>
<%#====================================================%>
<%# drawer-end: abre da direita para a esquerda %>
<div class="drawer drawer-end min-h-screen bg-gradient-to-br from-slate-50 via-green-50 to-teal-50">
  
  <%# Checkbox oculta que controla o estado do drawer. ID: 'filtro-drawer' %>
  <input id="filtro-drawer" type="checkbox" class="drawer-toggle" />
  
  <%#========================================%>
  <%# 2. CONTEÚDO PRINCIPAL (Lista de Professores) %>
  <%#========================================%>
  <div class="drawer-content flex flex-col items-center">
    <div class="w-full p-8">
      
      <main class="w-full max-w-7xl mx-auto">
        
        <%# Breadcrumbs %>
        <div class="breadcrumbs text-sm mb-6">
          <ul class="bg-white/60 backdrop-blur-sm rounded-full px-6 py-3 shadow-lg border border-white/20">
            <li><%= link_to "Escolas", escolas_path, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %></li>
            <% if @escola %>
              <li><%= link_to @escola.nome, escola_path(@escola), class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %></li>
            <% end %>
            <li class="text-slate-500 font-medium">Professores</li>
          </ul>
        </div>
        
        <%# Notice %>
        <% if notice.present? %>
          <div class="alert bg-gradient-to-r from-green-600 to-green-700 text-white border-0 shadow-xl mb-6 rounded-2xl">
            <i class="fa-solid fa-circle-check shrink-0 h-6 w-6"></i>
            <span class="font-medium"><%= notice %></span>
          </div>
        <% end %>

        <div class="bg-white/80 backdrop-blur-sm p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-white/20">
          
          <%# HEADER COM TÍTULO E BOTÕES %>
          <div class="bg-gradient-to-r from-blue-500 to-green-500 text-white rounded-2xl p-6 mb-8 shadow-xl">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              <div class="flex flex-col items-start space-y-2 flex-grow min-w-0">
                <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold break-words">
                  <% if @escola %>
                    Professores da Escola <%= @escola.nome %>
                  <% else %>
                    Todos os Professores
                  <% end %>
                </h1>
                <div class="badge badge-lg bg-blue-400 text-white border-white/30 font-semibold">
                  <%= @professores&.total_count || 0 %> <%= (@professores&.total_count || 0) == 1 ? 'professor' : 'professores' %>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto flex-shrink-0">
                
                <%# Botão para abrir o FILTRO LATERAL (Drawer) %>
                <label for="filtro-drawer" class="btn btn-sm sm:btn-md bg-white text-blue-600 hover:bg-gray-100 border-0 shadow-lg hover:scale-105 transition-all duration-300 font-semibold whitespace-nowrap text-xs sm:text-sm">
                  <i class="fa-solid fa-filter mr-1"></i> Filtros
                </label>
                
                <%# BOTÃO "NOVO PROFESSOR" %>
                <%= link_to (@escola ? new_escola_professor_path(@escola) : new_professor_path), class: "btn btn-sm sm:btn-md bg-white text-blue-600 hover:bg-green-50 border-0 shadow-lg hover:scale-105 transition-all duration-300 whitespace-nowrap text-xs sm:text-sm" do %>
                  <i class="fa-solid fa-plus"></i>
                  <span class="hidden sm:inline">Novo Professor</span>
                  <span class="sm:hidden">Novo</span>
                <% end %>

                <%# BOTÃO "ESCOLAS" %>
                <%= link_to escolas_path, class: "btn btn-sm sm:btn-md bg-white text-blue-600 hover:bg-gray-100 border-0 shadow-lg hover:scale-105 transition-all duration-300 font-semibold whitespace-nowrap text-xs sm:text-sm" do %>
                  <i class="fa-solid fa-school"></i>
                  Escolas
                <% end %>
              </div>
            </div>
          </div>
          
        
          <%# ---------------------------------------------------------------------- %>
          <%# --- SEÇÃO 3: LISTAGEM DE PROFESSORES (Turbo Frame) --- %>
          <%# ---------------------------------------------------------------------- %>

          <!-- Search & Filters -->
          <div class="mb-6">
            <%= form_with url: professors_path, method: :get, data: { turbo_frame: "professors" }, class: 'flex flex-col sm:flex-row gap-3 items-stretch sm:items-end' do |form| %>
              <div class="flex-1 min-w-0">
                <%= form.text_field :busca, placeholder: "Buscar por nome do professor...", value: params[:busca], class: "input input-bordered w-full bg-gray-50 border-gray-300 focus:border-green-600 focus:ring-green-600" %>
              </div>

              <div class="flex gap-3 flex-shrink-0">
                <label for="filtro-modal" class="btn bg-gray-50 border-gray-300 text-gray-700 hover:bg-green-600 hover:text-white flex-1 sm:flex-initial sm:w-32 justify-center">
                  Filtros
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </label>

                <%= link_to "Limpar", professors_path, class: "bg-white hover:bg-gray-50 border border-gray-300 text-gray-700 px-4 py-2 rounded-lg font-medium transition-colors" %>
              </div>
            <% end %>
          </div>

          <!-- Filters modal (keeps previous options) -->
          <% c1 = [["Concursado", "concursado"], ["Contratado", "contratado"]] %>
