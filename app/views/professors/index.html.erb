          <input type="checkbox" id="filtro-modal" class="modal-toggle">
          <div class="modal">
            <div class="modal-box  overflow-y-auto bg-white border border-gray-200 shadow-lg">
              <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-xl text-gray-800">Filtrar professores</h3>
                <label for="filtro-modal" class="btn btn-sm btn-circle absolute right-2 top-2">✕</label>
              </div>

              <%= form_with url: professors_path, method: :get, html: { id: "filtro-form" }, data: { turbo_frame: "professors" } do |form| %>
