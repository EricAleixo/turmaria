                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <% c1.each do |label, value| %>
                      <label class="flex items-start gap-3 cursor-pointer hover:bg-gray-50 p-3 rounded-lg border border-gray-100 w-full">
                        <input type="checkbox" name="filtros[]" value="<%= value %>" class="checkbox checkbox-success mt-1 flex-shrink-0">
                        <span class="text-sm font-medium text-gray-800 break-words min-w-0 flex-1"><%= label %></span>
                      </label>
                    <% end %>
                  </div>
                </div>

