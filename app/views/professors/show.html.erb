<div class="min-h-screen bg-gray-100">
  <!--Header-->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-4 sm:px-6 py-4">
      <div class="flex flex-col gap-4">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Professor - <%= @professor.nome %></h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <% if @escola %>
                <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <% end %>
              <li><%= link_to "Professores", escola_professors_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li class="text-gray-600"><%= @professor.nome %></li>
            </ul>
          </div>
        </div>

        <div class="flex gap-3 flex-wrap">
          <%= link_to escola_professor_turmas_path(@escola, @professor), class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
            Gerenciar Turmas
          <% end %>

          <%= link_to new_professor_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo professor
          <% end %>

          <%= link_to edit_professor_path(@professor), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Editar Professor
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Professor info -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
      <!-- Header com gradiente -->
      <div class="bg-gradient-to-r from-blue-500 to-green-300 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
          </svg>
          Perfil do Professor
        </h2>
      </div>

      <div class="p-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <div class="lg:col-span-2 space-y-6">
            <%= badge_formacao(@professor.formacao) %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% if @professor.telefone.present? %>
              <%= contato_card(
                    titulo: "Telefone",
                    valor: @professor.telefone,
                    cor: "blue",
                    icone_svg: '<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.email.present? %>
              <%= contato_card(
                    titulo: "Email",
                    valor: @professor.email,
                    cor: "yellow",
                    icone_svg: '<svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.cpf.present? %>
              <%= contato_card(
                    titulo: "CPF",
                    valor: @professor.cpf,
                    cor: "green",
                    icone_svg:'<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.endereco_completo.present? %>
              <%= contato_card(
                    titulo: "Endereco",
                    valor: @professor.endereco_completo,
                    cor: "gray",
                    icone_svg:'<svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>
          </div>

          <div class="bg-white rounded-lg shadow-lg p-6">
            <% if @professor.coordenador.present? %>
              <div class="text-center">
                <div class="mx-auto mb-4 w-20 h-20 bg-gradient-to-br from-blue-500 to-green-300 rounded-full flex items-center justify-center shadow-lg">
                  <span class="text-2xl font-bold text-white">
                    <%= @professor.coordenador.nome.first.upcase %>
                  </span>
                </div>
                <div class="space-y-2">
                  <h4 class="text-lg font-bold text-gray-900">
                    <%= @professor.coordenador.nome %>
                  </h4>
                  <% if @professor.coordenador.email.present? %>
                    <p class="text-sm text-gray-600 flex items-center justify-center">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      <%= @professor.coordenador.email %>
                    </p>
                  <% end %>
                  <div class="mt-3">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <div class="w-2 h-2 bg-green-400 rounded-full mr-1"></div>
                      Ativo
                    </span>
                  </div>
                </div>

                <div class="mt-4 pt-4 border-t border-indigo-200 grid grid-cols-2 gap-4 text-center">
                  <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wide">Turmas</p>
                    <p class="text-lg font-bold text-indigo-600"><%= @escola.turmas.count %></p>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wide">Alunos</p>
                    <p class="text-lg font-bold text-indigo-600"><%= @escola.alunos.count %></p>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="text-center py-8">
                <div class="mx-auto mb-4 w-20 h-20 bg-gray-300 rounded-full flex items-center justify-center">
                  <svg class="w-10 h-10 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <p class="text-sm text-gray-500 mb-3">Nenhum coordenador atribuído</p>
                <button class="text-xs bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full hover:bg-indigo-200 transition-colors">
                  Atribuir Coordenador
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabela de Disciplinas -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 mt-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="text-xl font-semibold text-gray-800">Disciplinas do Professor</h3>
          <p class="text-sm text-gray-500">Selecione as disciplinas que <%= @professor.nome %> leciona.</p>
        </div>
      </div>
    
      <%= form_with url: update_disciplinas_professor_path(@professor), method: :patch, class: "space-y-6" do %>
        <div class="overflow-hidden border border-gray-200 rounded-lg shadow-sm">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">Selecionar</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome da Disciplina</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
  <% @disciplinas_por_area.each do |area, disciplinas| %>
    <!-- Cabeçalho da Seção -->
    <tr class="bg-gradient-to-r from-gray-50 to-gray-100">
      <td colspan="3" class="px-6 py-3">
        <div class="flex items-center gap-3">
          <%= badge_direita(disciplinas.first) || "Não definida" %>
          <span class="text-xs text-gray-500 font-medium">
            <%= disciplinas.size %> <%= disciplinas.size == 1 ? 'disciplina' : 'disciplinas' %>
          </span>
        </div>
      </td>
    </tr>
    
    <!-- Disciplinas da Área -->
    <% disciplinas.each_with_index do |disciplina, index| %>
      <tr class="hover:bg-green-50 transition-colors duration-150 <%= 'border-b-2 border-gray-200' if index == disciplinas.size - 1 %>">
        <!-- Checkbox -->
        <td class="px-6 py-4 text-center">
          <%= check_box_tag "disciplina_ids[]", disciplina.id, @professor.disciplina_ids.include?(disciplina.id),
              class: "h-5 w-5 appearance-none rounded border border-green-400 cursor-pointer checked:bg-green-600 checked:border-green-600 relative checked:after:content-[''] checked:after:absolute checked:after:top-1 checked:after:left-2 checked:after:w-1 checked:after:h-2 checked:after:border-r-2 checked:after:border-b-2 checked:after:border-white checked:after:rotate-45 transition-all" %>
        </td>

        <!-- Nome -->
        <td class="px-6 py-4 text-sm font-medium transition-colors duration-300"
            data-disciplina-id="<%= disciplina.id %>"
            data-cor-nome="<%= disciplina.cor_nome || '#111' %>"
            style="color: <%= @professor.disciplina_ids.include?(disciplina.id) ? (disciplina.cor_nome || '#111') : 'inherit' %>;">
          <%= disciplina.nome %>
        </td>
        
        <!-- Coluna vazia para manter estrutura -->
        <td class="px-6 py-4"></td>
      </tr>
    <% end %>
  <% end %>
</tbody>


          </table>
        </div>
    
        <div class="flex justify-end">
          <%= submit_tag "Salvar alterações", class: "cursor-pointer inline-flex items-center px-6 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg shadow-sm transition-all duration-200" %>
        </div>
      <% end %>
    </div>
    <!-- Tabela de Conteúdos -->
<div class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 mt-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h3 class="text-xl font-semibold text-gray-800">Conteúdos do Professor</h3>
      <p class="text-sm text-gray-500"><%= @conteudos.count %> conteúdos cadastrados</p>
    </div>
  </div>

  <% if @conteudos.any? %>
    <% conteudos_por_disciplina = @conteudos.group_by(&:disciplina) %>
    <% conteudos_por_disciplina.sort_by { |disciplina, _| disciplina&.area_disciplina&.nome || "Sem área" }.each do |disciplina, conteudos| %>
      <% if disciplina %>
        <!-- Cabeçalho da Área -->
        <% area = disciplina.area_disciplina %>
        <% if area && (conteudos_por_disciplina.keys.first(conteudos_por_disciplina.keys.index(disciplina) + 1).none? { |d| d&.area_disciplina == area } || disciplina == conteudos_por_disciplina.keys.first) %>
          <div class="mt-6 mb-4 flex items-center gap-3">
            <div class="flex-grow h-px" style="background: linear-gradient(to right, <%= area.cor || '#ccc' %>, transparent);"></div>
            <div class="badge badge-lg font-bold text-white px-4 py-3" style="background-color: <%= area.cor || '#6b7280' %>;">
              <%= area.nome %>
            </div>
            <div class="flex-grow h-px" style="background: linear-gradient(to left, <%= area.cor || '#ccc' %>, transparent);"></div>
          </div>
        <% end %>

        <!-- Header da Disciplina -->
        <div class="mb-2 mt-4">
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: <%= disciplina.cor_nome %>15; border-left: 4px solid <%= disciplina.cor_nome %>;">
            <div class="w-3 h-3 rounded-full" style="background-color: <%= disciplina.cor_nome %>;"></div>
            <span class="font-semibold text-lg" style="color: <%= disciplina.cor_nome %>;">
              <%= disciplina.nome %>
            </span>
            <span class="badge badge-sm" style="background-color: <%= disciplina.cor_nome %>30; color: <%= disciplina.cor_nome %>;">
              <%= conteudos.count %> <%= conteudos.count == 1 ? 'conteúdo' : 'conteúdos' %>
            </span>
          </div>
        </div>

        <!-- Tabela de Conteúdos da Disciplina -->
        <div class="overflow-x-auto rounded-lg shadow-sm mb-6">
          <table class="table">
            <thead style="background-color: <%= disciplina.cor_nome %>08;">
              <tr>
                <th class="font-semibold" style="color: <%= disciplina.cor_nome %>;">Título</th>
                <th class="text-center font-semibold" style="color: <%= disciplina.cor_nome %>;">Bimestre</th>
                <th class="font-semibold" style="color: <%= disciplina.cor_nome %>;">Descrição</th>
                <th class="text-center font-semibold" style="color: <%= disciplina.cor_nome %>;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% conteudos.each do |conteudo| %>
                <tr class="hover border-l-4 transition-all duration-200" style="border-left-color: <%= disciplina.cor_nome %>40;">
                  <td class="font-medium">
                    <%= conteudo.titulo %>
                  </td>
                  <td class="text-center">
                    <div class="badge badge-outline font-semibold" style="border-color: <%= disciplina.cor_nome %>; color: <%= disciplina.cor_nome %>;">
                      <%= conteudo.bimestre %>º
                    </div>
                  </td>
                  <td class="text-sm text-gray-600">
                    <%= truncate(conteudo.descricao, length: 80) if conteudo.descricao.present? %>
                  </td>
                  <td>
                    <div class="flex items-center justify-center gap-2">
                      <%= link_to escola_conteudo_path(@professor.escola,conteudo), 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-blue-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        <span class="text-blue-500 font-medium">Ver</span>
                      <% end %>
                      <%= link_to edit_conteudo_path(conteudo), 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-orange-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-orange-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                        <span class="text-orange-500 font-medium">Editar</span>
                      <% end %>
                      <%= button_to conteudo_path(conteudo), 
                          method: :delete, 
                          data: { turbo_confirm: "Tem certeza?" }, 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-red-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-red-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        <span class="text-red-500 font-medium">Excluir</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <!-- Conteúdos sem disciplina -->
        <div class="mb-2 mt-6">
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 border-l-4 border-gray-400">
            <div class="w-3 h-3 rounded-full bg-gray-400"></div>
            <span class="font-semibold text-lg text-gray-600">Sem Disciplina</span>
            <span class="badge badge-sm bg-gray-200 text-gray-600">
              <%= conteudos.count %> <%= conteudos.count == 1 ? 'conteúdo' : 'conteúdos' %>
            </span>
          </div>
        </div>
        
        <div class="overflow-x-auto rounded-lg shadow-sm mb-6">
          <table class="table">
            <thead class="bg-gray-50">
              <tr>
                <th class="font-semibold text-gray-600">Título</th>
                <th class="text-center font-semibold text-gray-600">Bimestre</th>
                <th class="font-semibold text-gray-600">Descrição</th>
                <th class="text-center font-semibold text-gray-600">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% conteudos.each do |conteudo| %>
                <tr class="hover border-l-4 border-gray-300 transition-all duration-200">
                  <td class="font-medium">
                    <%= conteudo.titulo %>
                  </td>
                  <td class="text-center">
                    <div class="badge badge-outline border-gray-400 text-gray-600 font-semibold">
                      <%= conteudo.bimestre %>º
                    </div>
                  </td>
                  <td class="text-sm text-gray-600">
                    <%= truncate(conteudo.descricao, length: 80) if conteudo.descricao.present? %>
                  </td>
                  <td>
                    <div class="flex items-center justify-center gap-2">
                      <%= link_to conteudo_path(conteudo), 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-blue-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        <span class="text-blue-500 font-medium">Ver</span>
                      <% end %>
                      <%= link_to edit_conteudo_path(conteudo), 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-orange-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-orange-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                        <span class="text-orange-500 font-medium">Editar</span>
                      <% end %>
                      <%= button_to conteudo_path(conteudo), 
                          method: :delete, 
                          data: { turbo_confirm: "Tem certeza?" }, 
                          class: "btn btn-ghost btn-sm gap-2 hover:bg-red-50 transition-all duration-200" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-red-500">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        <span class="text-red-500 font-medium">Excluir</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-center py-8">Nenhum conteúdo cadastrado.</p>
  <% end %>
</div>
<!-- Termina aqui -->

  </div>
</div>



<script>
  document.addEventListener("turbo:load", () => {
    document.querySelectorAll('input[type="checkbox"][name="conteudo_ids[]"]').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const td = document.querySelector(`td[data-conteudo-id='${checkbox.value}']`);
        if (!td) return;

        const cor = checkbox.checked ? td.dataset.corNome || '#111' : 'inherit';
        td.style.color = cor;
      });
    });
  });
</script>
