<div class="min-h-screen bg-gray-100">
  <!--Header-->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-4 sm:px-6 py-4">
      <div class="flex flex-col gap-4">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Professor - <%= @professor.nome %></h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li><%= link_to "Professores", professors_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <% if @escola %>
                <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <% end %>
              <li class="text-gray-600"><%= @professor.nome %></li>
            </ul>
          </div>
        </div>

        <div class="flex gap-3 flex-wrap">
          <%= link_to professor_professor_turmas_path(@professor), class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
            Gerenciar Turmas
          <% end %>

          <%= link_to new_professor_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo professor
          <% end %>

          <%= link_to edit_professor_path(@professor), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Editar Professor
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Professor info -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
      <!-- Header com gradiente -->
      <div class="bg-gradient-to-r from-blue-500 to-green-300 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
          </svg>
          Perfil do Professor
        </h2>
      </div>

      <div class="p-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <div class="lg:col-span-2 space-y-6">
            <%= badge_formacao(@professor.formacao) %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% if @professor.telefone.present? %>
              <%= contato_card(
                    titulo: "Telefone",
                    valor: @professor.telefone,
                    cor: "blue",
                    icone_svg: '<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.email.present? %>
              <%= contato_card(
                    titulo: "Email",
                    valor: @professor.email,
                    cor: "yellow",
                    icone_svg: '<svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.cpf.present? %>
              <%= contato_card(
                    titulo: "CPF",
                    valor: @professor.cpf,
                    cor: "green",
                    icone_svg:'<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>

            <% if @professor.endereco_completo.present? %>
              <%= contato_card(
                    titulo: "Endereco",
                    valor: @professor.endereco_completo,
                    cor: "gray",
                    icone_svg:'<svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                                </svg>'.html_safe
                  ) %>
            <% end %>
          </div>

          <div class="bg-white rounded-lg shadow-lg p-6">
            <% if @professor.coordenador.present? %>
              <div class="text-center">
                <div class="mx-auto mb-4 w-20 h-20 bg-gradient-to-br from-blue-500 to-green-300 rounded-full flex items-center justify-center shadow-lg">
                  <span class="text-2xl font-bold text-white">
                    <%= @professor.coordenador.nome.first.upcase %>
                  </span>
                </div>
                <div class="space-y-2">
                  <h4 class="text-lg font-bold text-gray-900">
                    <%= @professor.coordenador.nome %>
                  </h4>
                  <% if @professor.coordenador.email.present? %>
                    <p class="text-sm text-gray-600 flex items-center justify-center">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      <%= @professor.coordenador.email %>
                    </p>
                  <% end %>
                  <div class="mt-3">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <div class="w-2 h-2 bg-green-400 rounded-full mr-1"></div>
                      Ativo
                    </span>
                  </div>
                </div>

                <div class="mt-4 pt-4 border-t border-indigo-200 grid grid-cols-2 gap-4 text-center">
                  <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wide">Turmas</p>
                    <p class="text-lg font-bold text-indigo-600"><%= @escola.turmas.count %></p>
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wide">Alunos</p>
                    <p class="text-lg font-bold text-indigo-600"><%= @escola.alunos.count %></p>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="text-center py-8">
                <div class="mx-auto mb-4 w-20 h-20 bg-gray-300 rounded-full flex items-center justify-center">
                  <svg class="w-10 h-10 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <p class="text-sm text-gray-500 mb-3">Nenhum coordenador atribuído</p>
                <button class="text-xs bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full hover:bg-indigo-200 transition-colors">
                  Atribuir Coordenador
                </button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabela de Disciplinas -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 mt-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="text-xl font-semibold text-gray-800">Disciplinas do Professor</h3>
          <p class="text-sm text-gray-500">Selecione as disciplinas que <%= @professor.nome %> leciona.</p>
        </div>
      </div>
    
      <%= form_with url: update_disciplinas_professor_path(@professor), method: :patch, class: "space-y-6" do %>
        <div class="overflow-hidden border border-gray-200 rounded-lg shadow-sm">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">Selecionar</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome da Disciplina</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Área</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
  <% @disciplinas_por_area.each do |area, disciplinas| %>
    <!-- Cabeçalho da Seção -->
    <tr class="bg-gradient-to-r from-gray-50 to-gray-100">
      <td colspan="3" class="px-6 py-3">
        <div class="flex items-center gap-3">
          <%= badge_direita(disciplinas.first) || "Não definida" %>
          <span class="text-xs text-gray-500 font-medium">
            <%= disciplinas.size %> <%= disciplinas.size == 1 ? 'disciplina' : 'disciplinas' %>
          </span>
        </div>
      </td>
    </tr>
    
    <!-- Disciplinas da Área -->
    <% disciplinas.each_with_index do |disciplina, index| %>
      <tr class="hover:bg-green-50 transition-colors duration-150 <%= 'border-b-2 border-gray-200' if index == disciplinas.size - 1 %>">
        <!-- Checkbox -->
        <td class="px-6 py-4 text-center">
          <%= check_box_tag "disciplina_ids[]", disciplina.id, @professor.disciplina_ids.include?(disciplina.id),
              class: "h-5 w-5 appearance-none rounded border border-green-400 cursor-pointer checked:bg-green-600 checked:border-green-600 relative checked:after:content-[''] checked:after:absolute checked:after:top-1 checked:after:left-2 checked:after:w-1 checked:after:h-2 checked:after:border-r-2 checked:after:border-b-2 checked:after:border-white checked:after:rotate-45 transition-all" %>
        </td>

        <!-- Nome -->
        <td class="px-6 py-4 text-sm font-medium transition-colors duration-300"
            data-disciplina-id="<%= disciplina.id %>"
            data-cor-nome="<%= disciplina.cor_nome || '#111' %>"
            style="color: <%= @professor.disciplina_ids.include?(disciplina.id) ? (disciplina.cor_nome || '#111') : 'inherit' %>;">
          <%= disciplina.nome %>
        </td>
        
        <!-- Coluna vazia para manter estrutura -->
        <td class="px-6 py-4"></td>
      </tr>
    <% end %>
  <% end %>
</tbody>


          </table>
        </div>
    
        <div class="flex justify-end">
          <%= submit_tag "Salvar alterações", class: "inline-flex items-center px-6 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg shadow-sm transition-all duration-200" %>
        </div>
      <% end %>
    </div>
    <!-- Tabela de Conteúdos -->
<div class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 mt-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h3 class="text-xl font-semibold text-gray-800">Conteúdos do Professor</h3>
      <p class="text-sm text-gray-500">Selecione os conteúdos que <%= @professor.nome %> leciona.</p>
    </div>
  </div>

  <%= form_with url: update_conteudos_professor_path(@professor), method: :patch, class: "space-y-6" do %>
    <div class="overflow-hidden border border-gray-200 rounded-lg shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-20">Selecionar</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Título do Conteúdo</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Disciplina</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-100">
          <% @conteudos_por_disciplina.each do |disciplina, conteudos| %>
            <tbody class="group hover:bg-green-50 transition">
              <% conteudos.each do |conteudo| %>
                <tr class="transition">
                  <!-- Checkbox -->
                  <td class="px-6 py-4 text-center">
                    <%= check_box_tag "conteudo_ids[]", conteudo.id, @professor.conteudo_ids.include?(conteudo.id),
                        class: "h-5 w-5 appearance-none rounded border border-green-400 cursor-pointer checked:bg-green-600 checked:border-green-600 relative checked:after:content-[''] checked:after:absolute checked:after:top-1 checked:after:left-2 checked:after:w-1 checked:after:h-2 checked:after:border-r-2 checked:after:border-b-2 checked:after:border-white checked:after:rotate-45" %>
                  </td>

                  <!-- Nome -->
                  <td class="px-6 py-4 text-sm font-medium transition-colors duration-300"
                      data-conteudo-id="<%= conteudo.id %>"
                      data-cor-nome="<%= conteudo.disciplina&.cor_nome || '#111' %>"
                      style="color: <%= @professor.conteudo_ids.include?(conteudo.id) ? (conteudo.disciplina&.cor_nome || '#111') : 'inherit' %>;">
                    <%= conteudo.titulo %>
                  </td>
                  
                  <!-- Disciplina -->
                  <% if conteudo == conteudos.first %>
                    <td class="px-6 py-4" rowspan="<%= conteudos.size %>">
                      <% if disciplina.present? %>
                        <%= badge_conteudo(conteudo) %>
                      <% else %>
                        
                          Sem disciplina

                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-end">
      <%= submit_tag "Salvar alterações", class: "inline-flex items-center px-6 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg shadow-sm transition-all duration-200" %>
    </div>
  <% end %>
</div>
  </div>

  
</div>



<script>
  document.addEventListener("turbo:load", () => {
    document.querySelectorAll('input[type="checkbox"][name="conteudo_ids[]"]').forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const td = document.querySelector(`td[data-conteudo-id='${checkbox.value}']`);
        if (!td) return;

        const cor = checkbox.checked ? td.dataset.corNome || '#111' : 'inherit';
        td.style.color = cor;
      });
    });
  });
</script>
