<%= content_for :title, @titulo_pagina %>

<div class="max-w-5xl mx-auto">
  
  <%# Link de Voltar - Com ênfase no verde %>
  <div class="mb-8">
    <% back_path = @content.material? ? aluno_meus_materiais_path : aluno_minhas_atividades_e_path %>
    <%= link_to back_path, class: "flex items-center text-lg font-medium text-green-700 hover:text-green-800 transition duration-150 group" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 mr-2 transition duration-150 group-hover:-translate-x-1">
        <path fill-rule="evenodd" d="M12.5 1.5a.75.75 0 0 0-1.06 0l-7.5 7.5a.75.75 0 0 0 0 1.06l7.5 7.5a.75.75 0 1 0 1.06-1.06L5.81 11.25H22.5a.75.75 0 0 0 0-1.5H5.81l6.75-6.75a.75.75 0 0 0 0-1.06Z" clip-rule="evenodd" />
      </svg>
      Voltar para <%= @content.material? ? 'Materiais de Estudo' : 'Atividades' %>
    <% end %>
  </div>

  <div class="bg-white p-10 rounded-3xl shadow-2xl border border-gray-100">
    
    <%# Header e Meta-informações (Melhor visual) %>
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 pb-4 border-b border-green-100">
      <div class="flex items-center mb-4 md:mb-0">
        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold text-white bg-green-600 shadow-md">
          <%= @content.material? ? 'MATERIAL' : 'ATIVIDADE' %>
        </span>
        <div class="ml-4 text-sm font-medium">
          <span class="text-gray-500">Bimestre:</span> 
          <span class="text-green-600 font-extrabold text-lg"><%= @content.bimestre %>º</span>
        </div>
      </div>
      <div class="text-sm text-gray-600 font-medium bg-green-50 px-4 py-2 rounded-lg border border-green-200">
        Disciplina: <span class="text-gray-900 font-semibold"><%= @content.disciplina.nome %></span>
      </div>
    </div>
    
    <%# Título e Descrição %>
    <h1 class="text-5xl font-extrabold text-gray-900 mb-6 leading-snug">
      <%= @content.titulo %>
    </h1>
    
    <div class="prose max-w-none text-gray-700 leading-relaxed text-lg">
      <%# Renderiza o Markdown (Se você estiver usando uma biblioteca como 'Redcarpet' ou 'Kramdown', pode ser necessário adaptar aqui) %>
      <%= simple_format(@content.descricao) %>
      <% if @content.markdown.present? %>
        <h2 class="text-2xl font-extrabold text-green-700 mt-10 mb-4 pt-4 border-t border-green-100">Conteúdo Detalhado:</h2>
        <%= @content.markdown %> <%# Se for Markdown, ele será renderizado como texto puro, ou você pode usar um helper aqui %>
      <% end %>
    </div>
    
    <%# Se houver arquivos anexados %>
    <% if @content.materiais.attached? %>
      <h2 class="text-2xl font-bold text-gray-800 mt-12 mb-5 pt-6 border-t border-gray-200">
        📎 Arquivos Anexados (<%= @content.materiais.count %>)
      </h2>
      <div class="space-y-4">
        <% @content.materiais.each do |material| %>
          <div class="flex items-center justify-between p-5 bg-gray-50 rounded-xl border border-gray-200 hover:bg-green-50 transition duration-200 shadow-sm">
            <div class="flex items-center truncate">
              <%# Ícone de Arquivo %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-green-600 mr-4 flex-shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              
              <span class="font-semibold text-gray-800 truncate text-base">
                <%= material.filename.to_s %>
              </span>
              <span class="ml-4 text-sm text-gray-500 flex-shrink-0">
                (<%= number_to_human_size(material.byte_size) %>)
              </span>
            </div>
            
            <%= link_to "Baixar", rails_blob_path(material, disposition: "attachment"), 
              class: "ml-4 bg-green-500 text-white text-base font-semibold py-2.5 px-6 rounded-xl hover:bg-green-600 transition duration-200 flex-shrink-0 shadow-md" %>
          </div>
        <% end %>
      </div>
    <% end %>
    
  </div>
</div>