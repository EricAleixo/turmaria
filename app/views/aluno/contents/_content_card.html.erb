<%# app/views/aluno/contents/_content_card.html.erb %>
<%# Recebe 'content' como local: { content: Conteudo } %>
<%# Definindo cores com base no bimestre para alternância visual %>
<%# Mantive a lógica de alternância, mas mudei as cores para usar mais o verde e um complemento vibrante %>
<% is_even_bimestre = content.bimestre.to_i % 2 == 0 %>
<%# Gradiente alternando entre Verde e Azul (próximo ao original 'red-500') %>
<% header_class = is_even_bimestre ? "bg-gradient-to-r from-teal-500 to-green-500" : "bg-gradient-to-r from-green-600 to-emerald-700" %>
<% button_class = is_even_bimestre ? "bg-green-500 hover:bg-teal-600" : "bg-green-700 hover:bg-emerald-800" %>
<% text_color_class = is_even_bimestre ? "text-teal-600" : "text-green-700" %>


<div class="bg-white rounded-3xl shadow-xl overflow-hidden transform hover:scale-[1.03] transition-all duration-300 border border-gray-100 hover:shadow-2xl">

  <%# Header Colorido com Ícone e Disciplina (com Gradiente) %>
  <div class="<%#= header_class %> h-24 flex items-center p-5 text-white bg-gradient-to-r from-green-600 to-green-700">
    <%# Ícone NOVO para Disciplina/Material (Ícone de Pasta) %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 mr-4 flex-shrink-0 opacity-90 text-white">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
    </svg>

    <div>
      <p class="text-xs font-semibold text-white/80 uppercase tracking-widest mb-0.5">
        <%= content.material? ? 'Material' : 'Atividade' %>
      </p>
      <p class="text-xl font-bold text-white leading-tight">
        <%= content.disciplina.nome %>
      </p>
    </div>
  </div>

  <div class="p-6">
    <h3 class="text-2xl font-extrabold text-gray-900 mb-2 leading-snug">
      <%= content.titulo %>
    </h3>
    <p class="text-sm text-gray-600 mb-5 line-clamp-3 min-h-[4rem]">
      <%= content.descricao %>
    </p>

    <div class="border-t border-gray-100 pt-4 space-y-2">
      <%# Bloco: Exibe o Bimestre com cor de destaque %>
      <div class="flex justify-between items-center text-base">
        <span class="font-semibold text-gray-500 flex items-center">
          <%# Ícone NOVO para Bimestre (Ícone de Copiar/Duplicar) %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2 <%= text_color_class %>">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v8.25A2.25 2.25 0 0 0 6 16.5h2.25m8.25-8.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-7.5A2.25 2.25 0 0 1 8.25 18v-1.5m8.25-8.25h-6a2.25 2.25 0 0 0-2.25 2.25v6" />
          </svg>
          Bimestre
        </span>
        <span class="text-gray-900 font-extrabold text-2xl">
          <%= content.bimestre %>º
        </span>
      </div>
    </div>
  </div>
  <%# Botão de Ação: Ver Conteúdo com cor alternada %>
  <%= link_to "Acessar", aluno_conteudo_path(content), class: "block w-full text-center py-4 text-white font-bold text-lg uppercase tracking-wider transition-colors #{button_class} shadow-inner" %>
</div>