<%# Define o título da página usando a variável carregada no controller %>
<%= content_for :page_title, @titulo_pagina %>

<div class="bg-gradient-to-br from-indigo-50 via-gray-50 to-gray-100 min-h-screen p-4 sm:p-8">
  <div class="w-full max-w-7xl mx-auto">
    <div class="bg-white p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-indigo-100">
      
      <div class="mb-8 border-b-2 border-indigo-200 pb-4 flex justify-between items-center flex-wrap">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-indigo-700 flex items-center">
          <%# Ícone principal: Professor/Pessoa %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 w-8 h-8 mr-2 text-indigo-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
          Meus Professores
        </h1>
        
        <%# Exibe Série + Turma Corrigido %>
        <span class="text-lg font-semibold text-gray-600 mt-2 sm:mt-0">
          Turma Atual: 
          <%= if @turma_atual
                "#{@turma_atual.serie} ° #{@turma_atual.nome}"
              else
                'Nenhuma'
              end
          %>
        </span>
      </div>

      <%# --- Lógica para Ausência de Dados vs. Tabela --- %>
      <% if @professores_da_turma.present? %>
        
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Lista de Professores da Turma</h2>
        
        <div class="overflow-x-auto shadow-xl rounded-xl">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr class="bg-indigo-600 text-white text-left text-sm uppercase tracking-wider">
                <%# ✅ ORDEM ALTERADA: PROFESSOR -> DISCIPLINA -> CONTATO -> TELEFONE %>
                <th class="px-6 py-3 rounded-tl-xl">Professor(a)</th>
                <th class="px-6 py-3">Disciplina(s)</th>
                <th class="px-6 py-3">Contato (Email)</th>
                <th class="px-6 py-3 rounded-tr-xl">Telefone</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
              <% @professores_da_turma.each do |professor| %>
                <tr class="hover:bg-indigo-50 transition duration-150 ease-in-out">
                  
                  <%# 1. ✅ AGORA É O NOME DO PROFESSOR (Com Foto) %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-3">
                      <div class="avatar flex-shrink-0">
                        <%# Lógica para exibir a foto do professor ou um placeholder %>
                        <% if professor.foto&.attached? %>
                          <div class="w-12 h-12 rounded-full">
                            <%= image_tag professor.foto.variant(resize_to_fill: [48, 48]), class: "rounded-full object-cover w-12 h-12" %>
                          </div>
                        <% else %>
                          <%# Placeholder com a inicial do nome (40px) %>
                          <div class="avatar placeholder bg-gradient-to-br from-indigo-500 to-purple-500 text-white rounded-full w-10 h-10 font-bold flex-shrink-0 relative">
                            <span class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-base"><%= professor.nome.first.upcase %></span>
                          </div>
                        <% end %>
                      </div>
                      <span class="text-lg font-bold text-indigo-800">
                        <%= professor.nome %>
                      </span>
                    </div>
                  </td>
                  
                  <%# 2. ✅ AGORA É A DISCIPLINA(S) %>
                  <td class="px-6 py-4">
                    <% if professor.disciplinas.present? %>
                      <% professor.disciplinas.each do |disciplina| %>
                        <% cor_disciplina = disciplina.try(:cor_nome) || disciplina.try(:cor) || '#10B981' %>
                        
                        <%# Filtra para exibir apenas as disciplinas associadas à Turma Atual %>
                        <% if disciplina.turmas.include?(@turma_atual) %>
                          <div class="mb-1">
                            <span class="font-semibold text-base" style="color: <%= cor_disciplina %>;">
                              <%= disciplina.nome %>
                            </span>
                          </div>
                        <% end %>
                      <% end %>
                    <% else %>
                      <span class="text-sm text-gray-500 italic">Sem disciplinas cadastradas</span>
                    <% end %>
                  </td>

                  <%# 3. CONTATO (EMAIL) %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <a href="mailto:<%= professor.email %>" class="text-indigo-600 hover:text-indigo-900 font-medium">
                      <%= professor.email %>
                    </a>
                  </td>
                  
                  <%# 4. TELEFONE %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-700">
                      <%= professor.telefone.presence || 'Não Informado' %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

      <% else %>
        
        <%# ESTADO VAZIO %>
        <div class="text-center py-16 bg-indigo-50 rounded-xl border-2 border-dashed border-indigo-200">
          <div class="max-w-md mx-auto">
            <div class="text-6xl mb-4 text-indigo-400 flex justify-center">
              <%# Ícone de Professor/Pessoa, maior e centralizado %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-16 w-16 h-16 text-indigo-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            <% if @turma_atual.nil? %>
              <h3 class="text-2xl font-bold text-slate-700 mb-2">Você não está associado a uma turma.</h3>
              <p class="text-slate-500">Peça ao administrador para te associar a uma turma para ver seus professores.</p>
            <% else %>
              <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum professor encontrado para esta turma.</h3>
              <p class="text-slate-500">A lista de professores para a turma <%= @turma_atual.nome %> será atualizada pelo administrador.</p>
            <% end %>
          </div>
        </div>

      <% end %>

    </div>
  </div>
</div>