<%= content_for :page_title, @titulo_pagina %>
<div class="bg-gradient-to-br from-indigo-50 via-gray-50 to-gray-100 min-h-screen p-4 sm:p-8">
  <div class="w-full max-w-7xl mx-auto">
    <div class="bg-white p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-indigo-100">
      
      <div class="mb-8 border-b-2 border-indigo-200 pb-4 flex justify-between items-center flex-wrap">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-indigo-700 flex items-center">
          <%# Ícone principal no cabeçalho %>
          <svg class="w-8 h-8 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          Minha Frequência
        </h1>
        <div class="text-lg font-semibold text-gray-600 mt-2 sm:mt-0">
          <div>
            <span class="text-gray-500">Série:</span>
            <span>
              <%= @turma_atual ? "#{@turma_atual.serie}°" : 'Nenhuma' %>
            </span>
          </div>

          <div>
            <span class="text-gray-500">Turma:</span>
            <span>
              <%= @turma_atual ? @turma_atual.nome : 'Nenhuma' %>
            </span>
          </div>
        </div>
      </div>

      <%# --- Lógica para Ausência de Dados vs. Tabela --- %>
      <% if @registros_frequencia.present? %>
        
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Histórico de Chamadas</h2>
        
        <div class="overflow-x-auto shadow-xl rounded-xl mb-12">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr class="bg-indigo-600 text-white text-left text-sm uppercase tracking-wider">
                <%# ORDEM ALTERADA: DISCIPLINA -> TURMA -> STATUS -> DATA %>
                <th class="px-6 py-3 rounded-tl-xl">Disciplina</th>
                <th class="px-6 py-3">Turma</th>
                <th class="px-6 py-3 text-center">Status</th>
                <th class="px-6 py-3 text-center rounded-tr-xl">Data da Aula</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
              <% @registros_frequencia.each do |registro| %>
                <tr class="hover:bg-indigo-50 transition duration-150 ease-in-out">
                  <% freq = registro.frequencia %>
                  <% disciplina = freq&.disciplina %>
                  
                  <%# 1. DISCIPLINA (Texto com a cor da disciplina) %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% cor_disciplina = disciplina.try(:cor_nome) || disciplina.try(:cor) || '#10B981' %>
                    <span class="font-semibold" style="color: <%= cor_disciplina %>;">
                      <%= disciplina&.nome || 'N/A' %>
                    </span>
                  </td>
                  
                  <%# 2. TURMA (Com badge intermediário) %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center text-base font-extrabold px-2.5 py-0.5 rounded-full bg-purple-600 text-white">
                      <%= freq&.turma&.nome || 'N/A' %>
                    </span>
                  </td>

                  <%# 3. STATUS (Com estilo intermediário, cor condicional) %>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <span class="inline-flex items-center text-base font-extrabold px-2.5 py-0.5 rounded-full <%= registro.status_cor %>">
                      <%= registro.status_humanizado %>
                    </span>
                  </td>
                  
                  <%# 4. DATA DA AULA (Com badge intermediário - ULTIMA COLUNA) %>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <span class="inline-flex items-center text-base font-extrabold px-2.5 py-0.5 rounded-full bg-indigo-600 text-white">
                      <%= freq&.data_aula&.strftime('%d/%m/%Y') || 'N/A' %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <%# ---------------------------------------------------- %>
        <%# 🆕 NOVO BLOCO DE FREQUÊNCIA POR DISCIPLINA (Resumo no Rodapé) 🆕 %>
        <%# ---------------------------------------------------- %>
        <% if @frequencia_por_disciplina.present? %>
          <div class="mt-8 pt-6 border-t-2 border-indigo-200">
            <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center">
                <svg class="w-6 h-6 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /></svg>
                Resumo Percentual por Disciplina
            </h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <% @frequencia_por_disciplina.each do |freq| %>
                
                <%# Lógica de cores baseada no percentual de presença %>
                <% status_cor = case freq[:percentual]
                  when 75.0..100.0 then 'bg-green-600 text-white' # Acima de 75% é Verde
                  when 50.0..74.9 then 'bg-yellow-500 text-gray-900' # Entre 50% e 74.9% é Amarelo
                  else 'bg-red-600 text-white' # Abaixo de 50% é Vermelho
                end %>

                <div class="bg-gray-50 p-5 rounded-xl shadow-md border border-gray-200">
                  
                  <%# Nome da Disciplina com cor customizada %>
                  <h3 class="text-lg font-bold mb-2 truncate" style="color: <%= freq[:cor] %>;">
                    <%= freq[:nome] %>
                  </h3>
                  
                  <%# Badge de Percentual de Destaque %>
                  <div class="text-3xl font-extrabold <%= status_cor %> inline-block px-3 py-1 rounded-lg shadow-sm">
                    <%= "#{freq[:percentual]}%" %>
                  </div>

                  <%# Detalhes Menores %>
                  <p class="text-sm text-gray-600 mt-3">
                    <span class="font-bold text-green-700"><%= freq[:total_presencas] %></span> Presenças
                  </p>
                  <p class="text-sm text-gray-600">
                    <span class="font-bold text-red-700"><%= freq[:total_aulas] - freq[:total_presencas] %></span> Faltas (<%= freq[:total_aulas] %> Aulas no Total)
                  </p>

                </div>
              <% end %>
            </div>
          </div>
        <% end %>
        <%# ---------------------------------------------------- %>

      <% else %>
        
        <%# ESTADO VAZIO: AGORA USANDO O MESMO ÍCONE SVG %>
        <div class="text-center py-16 bg-indigo-50 rounded-xl border-2 border-dashed border-indigo-200">
          <div class="max-w-md mx-auto">
            <div class="text-6xl mb-4 text-indigo-400 flex justify-center">
              <%# Ícone de calendário/frequência, maior e centralizado %>
              <svg class="w-16 h-16 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum registro de frequência encontrado.</h3>
            <p class="text-slate-500">O histórico de presença e faltas será atualizado aqui após o registro das aulas pelos professores.</p>
            <p class="text-sm text-gray-400 mt-4">Lembre-se: Somente faltas não justificadas afetam a sua contagem total.</p>
          </div>
        </div>

      <% end %>

    </div>
  </div>
</div>