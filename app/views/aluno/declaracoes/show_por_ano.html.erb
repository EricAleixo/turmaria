<div class="declaracao-container min-h-screen p-8 max-w-3xl mx-auto bg-white shadow-xl border border-gray-300 flex flex-col">

  <%# --- BOTÕES DE AÇÃO --- %>
  <div class="mb-6 flex justify-end gap-3 print-hide">
    <%= link_to 'Baixar PDF', por_ano_aluno_declaracoes_path(@ano_letivo, format: :pdf),
        class: "flex items-center px-4 py-2 bg-green-600 text-white font-medium rounded-lg shadow-md hover:bg-green-700 transition duration-150" %>

    <button onclick="window.print()"
            class="cursor-pointer flex items-center px-4 py-2 bg-gray-500 text-white font-medium rounded-lg shadow-md hover:bg-gray-600 transition duration-150">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z" />
      </svg>
      Imprimir
    </button>
  </div>

  <div class="text-center mb-8">
    <p class="font-bold uppercase text-sm text-gray-700">Estado da Paraíba</p>
    <p class="font-bold uppercase text-sm text-gray-700">Secretaria de Estado da Educação</p>
    <p class="font-bold uppercase text-sm text-gray-800 mt-1"><%= @aluno.escola.nome %></p>
  </div>

  <h1 class="text-center text-2xl font-extrabold text-gray-800 uppercase tracking-widest mb-8 border-b-2 border-gray-400 pb-3">
    Declaração
  </h1>

  <%# --- CORPO DO TEXTO --- %>
  <div class="font-serif text-[15px] leading-relaxed text-gray-900">
    <p class="mb-5 text-justify">
      Declaramos, para os devidos fins, que o(a) aluno(a) <strong><%= @aluno.nome %></strong>,
      matrícula nº <strong><%= @aluno.matricula %></strong>, encontra-se regularmente matriculado(a)
      nesta instituição de ensino no <strong><%= @turma.serie %>º Ano</strong>, turma
      <strong><%= @turma.nome %></strong>, turno <strong><%= @turma.turno.capitalize %></strong>,
      referente ao ano letivo de <strong><%= @ano_letivo.ano %></strong>.
    </p>

    <p class="mb-5 text-justify">
      Informamos ainda que o(a) referido(a) estudante possui vínculo ativo com esta unidade escolar
      e frequenta regularmente as atividades acadêmicas.
    </p>

    <p class="mb-5 text-justify">
      A presente declaração é emitida a pedido do(a) interessado(a), para os fins que se fizerem necessários.
    </p>

    <p>
      Emitida em <%= Time.zone.now.strftime('%d/%m/%Y') %>.
    </p>
  </div>

  <%# --- ESPAÇADOR: empurra a assinatura para o rodapé da página --- %>
  <div class="flex-grow"></div>

  <%# --- ASSINATURA E CÓDIGO (fixos no fim) --- %>
  <div class="font-serif text-[15px] text-gray-900">
    <div class="text-center mb-2">
      <p class="border-t border-gray-800 w-72 mx-auto pt-2 text-sm">Direção Escolar</p>
      <p class="text-sm text-gray-600"><%= @aluno.escola.nome %></p>
    </div>

    <div class="flex items-end justify-between mt-10 print-hide-code">
      <div class="text-xs text-gray-500">
        <p>Código de Autenticidade: <%= @declaracao.codigo_autenticidade %></p>
        <p>Verifique em: <%= validar_declaracao_curta_url(codigo: @declaracao.codigo_curto) %></p>
      </div>

      <div class="flex-shrink-0">
        <%= raw RQRCode::QRCode.new(
              validar_declaracao_curta_url(codigo: @declaracao.codigo_curto)
            ).as_svg(
              module_size: 3,
              use_path: true,
              svg_attributes: { class: "w-20 h-20" }
            ) %>
      </div>
    </div>
  </div>
</div>

<%# --- ESTILOS DE IMPRESSÃO (mesmo padrão do boletim) --- %>
<style>
  @media print {
    .print-hide { display: none !important; }
    body > * { visibility: hidden; }
    .declaracao-container {
      visibility: visible !important;
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      max-width: 100% !important;
      width: 100% !important;
      box-shadow: none !important;
      border: none !important;
      padding: 0 !important;
      margin: 0 !important;
    }
  }
</style>