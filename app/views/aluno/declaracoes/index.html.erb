<div class="container mx-auto p-4 md:p-8">
  <h2 class="flex items-center text-3xl font-extrabold mb-8 text-gray-800 border-b-4 border-green-600/50 pb-3">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-green-600 mr-3">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
    </svg>
    Declarações Escolares
  </h2>

  <% if @anos_letivos.any? %>
    <p class="text-lg text-gray-600 mb-6">Selecione um ano letivo abaixo para emitir sua declaração de matrícula referente ao período.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      <% @anos_letivos.each do |ano_letivo| %>
        <% declaracao_existente = @declaracoes_por_ano[ano_letivo.id] %>
        <div class="group p-6 bg-white border border-gray-200 rounded-xl shadow-lg hover:shadow-2xl hover:border-green-500 transition duration-300 ease-in-out">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8 text-green-600 group-hover:text-green-800 mr-4 flex-shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <span class="font-bold text-xl text-gray-800 group-hover:text-green-600 transition-colors">
                  Ano Letivo: <%= ano_letivo.ano %>
                </span>
                <p class="text-sm text-gray-500 mt-1">
                  Período: <%= ano_letivo.data_inicio.year %> a <%= ano_letivo.data_fim.year %>
                </p>
              </div>
            </div>

            <% if declaracao_existente %>
              <span class="text-[10px] font-semibold uppercase tracking-wide bg-green-100 text-green-700 px-2 py-1 rounded-full flex-shrink-0">
                Emitida
              </span>
            <% end %>
          </div>

          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <%= link_to por_ano_aluno_declaracoes_path(ano_letivo),
                class: "flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Visualizar
            <% end %>

            <%= link_to por_ano_aluno_declaracoes_path(ano_letivo, format: :pdf),
                class: "flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-semibold text-white bg-green-600 rounded-lg shadow-md hover:bg-green-700 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <%= declaracao_existente ? "Baixar Novamente" : "Emitir" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <% elsif @declaracoes.empty? %>
    <%# Sem boletim E sem declaração nenhuma ainda %>
    <div class="p-8 bg-yellow-50 border-t-4 border-yellow-500 text-yellow-800 rounded-lg shadow-md mb-10">
      <div class="flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.398 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <h3 class="font-bold text-xl mb-1">Nenhum Registro Disponível</h3>
          <p class="text-base">
            <% if current_aluno.turma.present? %>
              Não encontramos boletins associados à sua matrícula ainda, mas você pode emitir uma declaração de matrícula referente ao seu vínculo atual.
            <% else %>
              Não encontramos matrícula ativa associada ao seu cadastro neste momento. Entre em contato com a secretaria da escola para verificar sua situação.
            <% end %>
          </p>
        </div>
      </div>

      <% if current_aluno.turma.present? %>
        <div class="mt-6 pt-4 border-t border-yellow-200">
          <%= link_to por_ano_aluno_declaracoes_path(current_aluno.turma.ano_letivo),
              class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-green-600 rounded-lg shadow-md hover:bg-green-700 transition" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Declarar Matrícula Atual (<%= current_aluno.turma.ano_letivo.ano %>)
          <% end %>
        </div>
      <% end %>
    </div>

  <% else %>
    <%# Sem boletim, mas já existe alguma declaração emitida %>
    <div class="p-6 bg-green-50 border-t-4 border-green-500 text-green-800 rounded-lg shadow-sm mb-10 flex items-center gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-sm">
        Você ainda não possui boletins lançados, mas já emitiu declaração(ões) de matrícula — confira abaixo no histórico.
      </p>
    </div>
  <% end %>

  <%# --- HISTÓRICO DE DECLARAÇÕES JÁ EMITIDAS --- %>
  <% if @declaracoes.any? %>
    <h3 class="text-xl font-bold text-gray-800 mb-4">Histórico de Emissões</h3>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-600 uppercase text-xs">
            <th class="text-left px-4 py-3">Ano Letivo</th>
            <th class="text-left px-4 py-3">Código de Autenticidade</th>
            <th class="text-left px-4 py-3">Emitida em</th>
            <th class="text-right px-4 py-3">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @declaracoes.each do |declaracao| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-800">
                <%= declaracao.ano_letivo.ano %>
              </td>
              <td class="px-4 py-3 text-gray-500 font-mono text-xs">
                <%= declaracao.codigo_autenticidade %>
              </td>
              <td class="px-4 py-3 text-gray-500">
                <%= declaracao.emitido_em.strftime('%d/%m/%Y às %H:%M') %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "Ver / Baixar", por_ano_aluno_declaracoes_path(declaracao.ano_letivo),
                    class: "text-green-600 hover:text-green-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>