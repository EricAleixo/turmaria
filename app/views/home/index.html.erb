<section class="relative w-full overflow-hidden py-20 px-6 lg:px-16" style="background: radial-gradient(circle at 95% 10%, rgba(134,210,172,0.35) 0%, transparent 40%), linear-gradient(160deg, #eef3fb 0%, #f4f8ff 60%, #edfaf4 100%);">

  <div class="absolute bottom-10 left-10 grid grid-cols-4 gap-2.5 opacity-25 pointer-events-none">
    <% 16.times do %><span class="w-1.5 h-1.5 rounded-full bg-blue-400 block"></span><% end %>
  </div>

  <div class="relative z-10 mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

    <!-- COL 1: TEXT -->
