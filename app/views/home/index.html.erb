              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 11-12.728 0M12 3v9"/>
              </svg>
            </span>
            Alertas de ausência
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ROW 3: DESEMPENHO -->
