        <span data-aos="fade-right"
              class="inline-flex items-center gap-2 text-emerald-600 text-xs font-bold tracking-[0.18em] uppercase w-fit">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l5-5 4 4 9-10"/>
          </svg>
          Desempenho
        </span>
        <h2 data-aos="fade-right" data-aos-delay="100"
            class="text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">
          Acompanhe a evolução<br>
          acadêmica com relatórios claros.
        </h2>
        <div data-aos="fade-right" data-aos-delay="150"
             class="w-10 h-1 rounded-full bg-emerald-500"></div>
        <p data-aos="fade-right" data-aos-delay="200"
           class="text-gray-500 text-base leading-relaxed max-w-sm">
          Visualize notas, médias e progresso dos alunos em gráficos intuitivos e completos.
        </p>
        <div data-aos="fade-right" data-aos-delay="300"
             class="flex flex-wrap gap-6 mt-2">
          <div class="flex items-center gap-2 text-gray-700 text-sm font-medium">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"/>
              </svg>
            </span>
            Notas por disciplina
          </div>
          <div class="flex items-center gap-2 text-gray-700 text-sm font-medium">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </span>
            Gráficos de evolução
          </div>
          <div class="flex items-center gap-2 text-gray-700 text-sm font-medium">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
            </span>
            Relatórios exportáveis
          </div>
        </div>
      </div>

      <div data-aos="fade-left" data-aos-delay="150"
           class="w-full overflow-hidden">
        <div class="overflow-hidden w-full aspect-[16/10] rounded-2xl bg-gray-800/10 border-4 border-gray-700/20">
            <video
                class="w-full h-full object-cover object-top block"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                aria-label="Demonstração do painel do Turmaria"
              >
                <source src="<%= asset_path '/media/dashboards.mp4' %>" type="video/mp4">
              </video>
            </div>
        <div class="mx-auto mt-1 h-3 w-2/3 rounded-b-xl bg-gray-300/60"></div>
      </div>

    </div>
  </div>

</section>


<%# ══════════════════════════════════════════════════ %>
<%# COMUNICAÇÃO                                        %>
<%# ══════════════════════════════════════════════════ %>
<section id="contato" class="relative w-full overflow-hidden py-20 px-6 lg:px-16" style="background: radial-gradient(circle at 95% 10%, rgba(134,210,172,0.35) 0%, transparent 40%), linear-gradient(160deg, #eef3fb 0%, #f4f8ff 60%, #edfaf4 100%);">
  <div class="absolute bottom-10 left-10 grid grid-cols-4 gap-2.5 opacity-20 pointer-events-none">
    <% 16.times do %>
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 block"></span>
    <% end %>
  </div>

  <div class="absolute top-12 right-24 grid grid-cols-5 gap-2 opacity-15 pointer-events-none">
    <% 10.times do %>
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 block"></span>
    <% end %>
  </div>

  <div class="relative z-10 mx-auto max-w-2xl flex flex-col gap-8">

    <!-- Badge -->
    <div class="flex justify-center">
      <span class="inline-flex items-center gap-2 bg-white border border-gray-200 shadow-sm text-blue-600 text-xs font-bold tracking-[0.18em] uppercase rounded-full px-4 py-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Fale conosco
      </span>
    </div>

    <!-- Heading -->
    <div class="text-center flex flex-col gap-2">
      <h2 class="text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">
        Como podemos<br>
        <span class="text-blue-600">te ajudar</span> hoje?
      </h2>
      <p class="text-gray-500 text-base leading-relaxed mt-1">
        Escolha o que você precisa e entraremos em contato o quanto antes.
      </p>
    </div>

    <!-- Form Card -->
    <%= form_with url: "", method: :post, data: { controller: "contact-form" }, class: "bg-white rounded-2xl shadow-lg p-6 lg:p-8 flex flex-col gap-6" do |f| %>

      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <!-- Assunto -->
      <div class="flex flex-col gap-2">
        <span class="text-sm font-semibold text-gray-700">Assunto</span>
        <div class="flex gap-3" data-contact-form-target="subjectGroup">

          <label class="subject-btn flex-1 flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-600 font-semibold text-sm px-4 py-3 rounded-xl bg-white cursor-pointer transition-all has-[:checked]:bg-blue-500 has-[:checked]:text-white has-[:checked]:border-blue-500">
            <%= f.radio_button :subject, "solicitar_acesso", class: "sr-only", data: { action: "change->contact-form#updateSubject" } %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            Solicitar acesso
          </label>

          <label class="subject-btn flex-1 flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-600 font-semibold text-sm px-4 py-3 rounded-xl bg-white cursor-pointer transition-all has-[:checked]:bg-emerald-500 has-[:checked]:text-white has-[:checked]:border-emerald-500">
            <%= f.radio_button :subject, "conhecer_sistema", class: "sr-only", data: { action: "change->contact-form#updateSubject" } %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.347.347A3 3 0 0112 18a3 3 0 01-2.121-.879l-.347-.347z"/>
            </svg>
            Conhecer o sistema
          </label>

        </div>
      </div>

      <!-- Título -->
      <div class="flex flex-col gap-2">
        <%= f.label :title, "Título", class: "text-sm font-semibold text-gray-700" %>
        <%= f.text_field :title,
            placeholder: "Ex: Quero acessar o Turmaria para minha escola",
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 bg-gray-50 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition" %>
      </div>

      <!-- Método de contato -->
      <div class="flex flex-col gap-2" data-contact-form-target="contactMethodWrapper">
        <span class="text-sm font-semibold text-gray-700">Como prefere receber o contato?</span>

        <div class="flex gap-2 p-1 bg-gray-100 rounded-xl w-fit">
          <label class="contact-tab cursor-pointer text-xs font-semibold px-4 py-2 rounded-lg text-gray-700 transition-all has-[:checked]:bg-slate-800 has-[:checked]:text-white">
            <%= radio_button_tag :contact_method, "email", true, class: "sr-only", data: { action: "change->contact-form#updateContactMethod" } %>
            E-mail
          </label>
          <label class="contact-tab cursor-pointer text-xs font-semibold px-4 py-2 rounded-lg text-gray-700 transition-all has-[:checked]:bg-slate-800 has-[:checked]:text-white">
            <%= radio_button_tag :contact_method, "phone", false, class: "sr-only", data: { action: "change->contact-form#updateContactMethod" } %>
            WhatsApp / Telefone
          </label>
        </div>

        <div class="relative">
          <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" data-contact-form-target="contactIcon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </span>
          <%= f.email_field :contact_value,
              placeholder: "seu@email.com",
              data: { contact_form_target: "contactInput" },
              class: "w-full border border-gray-200 rounded-xl pl-10 pr-4 py-3 text-sm text-gray-800 placeholder-gray-400 bg-gray-50 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition" %>
        </div>
      </div>

      <!-- Mensagem -->
      <div class="flex flex-col gap-2">
        <%= f.label :message, "Mensagem", class: "text-sm font-semibold text-gray-700" %>
        <%= f.text_area :message,
            rows: 4,
            placeholder: "Conte um pouco mais sobre o que você precisa...",
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 placeholder-gray-400 bg-gray-50 resize-none focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition" %>
        <span class="text-xs text-gray-400">Quanto mais detalhes, mais rápido conseguimos te ajudar.</span>
      </div>

      <!-- Submit -->
      <%= f.submit "Enviar mensagem",
          data: { contact_form_target: "submitBtn" },
          class: "w-full bg-blue-500 hover:bg-blue-600 text-white font-bold text-sm px-6 py-4 rounded-xl cursor-pointer transition hover:-translate-y-0.5 hover:shadow-lg mt-1" %>

    <% end %>

    <!-- Trust line -->
    <div class="flex items-center justify-center gap-6 flex-wrap">
      <span class="flex items-center gap-1.5 text-gray-400 text-xs">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Seus dados estão seguros
      </span>
      <span class="flex items-center gap-1.5 text-gray-400 text-xs">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Respondemos em até 1 dia útil
      </span>
      <span class="flex items-center gap-1.5 text-gray-400 text-xs">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Sem spam, prometemos
      </span>
    </div>

  </div>
</section>

<%# ══════════════════════════════════════════════════ %>
<%# CTA                                                %>
<%# ══════════════════════════════════════════════════ %>
<section class="w-full bg-white py-12 px-6 lg:px-16">
  <div data-aos="zoom-in"
       class="relative mx-auto rounded-3xl overflow-hidden px-8 py-20 text-center"
       style="background: linear-gradient(135deg, #3b82f6 0%, #38bdf8 40%, #34d399 100%);">

    <div class="absolute top-10 left-10 grid grid-cols-5 gap-2 opacity-30 pointer-events-none">
      <% 20.times do %><span class="w-1.5 h-1.5 rounded-full bg-white block"></span><% end %>
    </div>
    <div class="absolute -bottom-10 -left-8 w-52 h-52 opacity-20 pointer-events-none"
         style="background: white; border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%; transform: rotate(-15deg);"></div>
    <div class="absolute top-6 right-8 w-28 h-28 rounded-full border-2 border-white/30 pointer-events-none"></div>
    <div class="absolute top-12 right-14 w-14 h-14 rounded-full border border-white/20 pointer-events-none"></div>
    <div class="absolute bottom-8 right-10 grid grid-cols-5 gap-2 opacity-20 pointer-events-none">
      <% 20.times do %><span class="w-1.5 h-1.5 rounded-full bg-white block"></span><% end %>
    </div>

    <div class="relative z-10 flex flex-col items-center gap-8">

      <h2 data-aos="fade-up"
          class="text-4xl lg:text-5xl font-extrabold text-white leading-tight">
        Pronto para
        <span style="text-decoration: underline; text-decoration-color: rgba(255,255,255,0.45); text-underline-offset: 6px; text-decoration-thickness: 3px;">modernizar</span>
        sua
        <span style="text-decoration: underline; text-decoration-color: rgba(255,255,255,0.45); text-underline-offset: 6px; text-decoration-thickness: 3px;">escola</span>?
      </h2>

      <p data-aos="fade-up" data-aos-delay="100"
         class="text-white/90 text-lg leading-relaxed max-w-xl">
        Leve a gestão acadêmica da sua escola para outro nível com o Turmaria.<br>
        Mais eficiência, organização e resultados para alunos, professores e gestores.
      </p>

      <div data-aos="fade-up" data-aos-delay="200"
           class="flex flex-wrap items-center justify-center gap-4">
        <button type="button"
           onclick="scrollToContact('solicitar_acesso')"
           class="inline-flex items-center gap-3 bg-white text-blue-600 font-bold text-base px-8 py-4 rounded-2xl shadow-lg hover:shadow-xl hover:bg-gray-50 transition-all cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
          </svg>
          Solicitar acesso
        </button>
        <button type="button"
           onclick="scrollToContact('conhecer_sistema')"
           class="inline-flex items-center gap-2 bg-transparent text-white font-semibold text-base px-8 py-4 rounded-2xl border-2 border-white/60 hover:bg-white/10 transition-all cursor-pointer">
          Fale conosco
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>
      </div>

      <div data-aos="fade-up" data-aos-delay="300"
           class="flex flex-wrap items-center justify-center gap-0 mt-2 divide-x divide-white/30">
        <div class="flex items-center gap-2 text-white/90 text-sm font-medium px-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Sem instalação
        </div>
        <div class="flex items-center gap-2 text-white/90 text-sm font-medium px-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 001.7-9.71A4.5 4.5 0 0013.5 4a4.5 4.5 0 00-4.36 3.36A4 4 0 003 11.5"/>
          </svg>
          Acesso em qualquer lugar
        </div>
        <div class="flex items-center gap-2 text-white/90 text-sm font-medium px-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 11-12.728 0M12 3v9"/>
          </svg>
          Suporte especializado
        </div>
      </div>

    </div>
  </div>
</section>