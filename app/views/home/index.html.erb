<section class="relative w-full overflow-hidden py-20 px-6 lg:px-16" style="background: radial-gradient(circle at 8% 10%, rgba(91,141,239,0.55) 0%, rgba(91,141,239,0) 35%), radial-gradient(circle at 95% 90%, rgba(86,210,150,0.55) 0%, rgba(86,210,150,0) 40%), linear-gradient(135deg, #6e9bf2 0%, #eef3f0 48%, #8fe3b8 100%);">

  <div class="absolute -top-24 -left-24 w-[420px] h-[420px] bg-blue-400/40 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-72 h-72 bg-blue-300/25 rounded-full blur-3xl pointer-events-none rotate-45"></div>
  <div class="absolute -bottom-24 right-0 w-[520px] h-[520px] bg-green-300/45 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

    <div class="flex flex-col gap-7">

      <div data-aos="fade-up"
           class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-sm border border-white/60 shadow-sm rounded-full px-4 py-2 w-fit">
        <span class="w-2 h-2 rounded-full bg-green-500"></span>
        <span class="text-sm font-medium text-gray-700">Sistema completo para gestão escolar</span>
      </div>

      <h1 data-aos="fade-up" data-aos-delay="100"
          class="text-5xl lg:text-6xl font-extrabold text-gray-900 leading-[1.08] tracking-tight">
        Gestão escolar<br>
        moderna em<br>
        uma <span class="text-blue-600">única</span> <span class="bg-gradient-to-r from-emerald-400 to-emerald-500 bg-clip-text text-transparent">plataforma</span>
      </h1>

      <p data-aos="fade-up" data-aos-delay="200"
         class="text-lg text-gray-500 max-w-md leading-relaxed">
        Controle alunos, professores, frequência, notas, matrículas e comunicação com praticidade e segurança.
      </p>

      <div data-aos="fade-up" data-aos-delay="300"
           class="flex flex-wrap gap-4 mt-1">
        <button class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 transition-colors text-white font-semibold px-6 py-3.5 rounded-xl shadow-lg shadow-blue-500/30">
          Solicitar demonstração
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
        <button class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 transition-colors text-gray-800 font-semibold px-6 py-3.5 rounded-xl border border-gray-200 shadow-sm">
          <span class="flex items-center justify-center w-5 h-5 rounded-full bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </span>
          Conhecer funcionalidades
        </button>
      </div>

      <div data-aos="fade-up" data-aos-delay="400"
           class="flex flex-wrap gap-8 mt-6">
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-emerald-100 text-emerald-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Segurança e<br>conformidade</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-blue-100 text-blue-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Acesso em<br>qualquer lugar</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-teal-100 text-teal-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Economize tempo<br>e recursos</span>
        </div>
      </div>

    </div>

    <div data-aos="fade-left" data-aos-delay="200"
         class="relative w-full self-stretch">
      <div class="w-full h-[94%] bg-gray-100 rounded-2xl shadow-2xl shadow-black/40 p-3 flex items-center justify-center">
        <%= image_tag "dashboard-mockup.png", class: "w-full h-fit object-contain object-top rounded-xl block", alt: "Painel do Turmaria" %>
      </div>
    </div>

  </div>
</section>


