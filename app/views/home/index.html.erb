        <span class="text-sm font-medium text-gray-700">Sistema completo para gestão escolar</span>
      </div>

      <h1 data-aos="fade-up" data-aos-delay="100"
          class="text-5xl lg:text-6xl font-extrabold text-gray-900 leading-[1.08] tracking-tight">
        Gestão escolar<br>
        moderna em<br>
        uma <span class="text-blue-600">única</span> <span class="bg-gradient-to-r from-emerald-400 to-emerald-500 bg-clip-text text-transparent">plataforma</span>
      </h1>

      <p data-aos="fade-up" data-aos-delay="200"
         class="text-lg text-gray-500 max-w-md leading-relaxed">
        Controle alunos, professores, frequência, notas e matrículas, com praticidade e segurança.
      </p>

            <div data-aos="fade-up" data-aos-delay="300"
        class="flex flex-wrap gap-3 mt-1">
        <button type="button" onclick="scrollToContact('solicitar_acesso')"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 transition-colors text-white font-semibold px-6 py-3.5 rounded-xl shadow-lg shadow-blue-500/30 cursor-pointer">
          Solicitar acesso
        </button>
        <button type="button" onclick="scrollToContact('conhecer_sistema')"
          class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 transition-colors text-gray-800 font-semibold px-6 py-3.5 rounded-xl border border-gray-200 shadow-sm cursor-pointer">
          Fale conosco
        </button>
      </div>

      <div data-aos="fade-up" data-aos-delay="400"
           class="flex flex-wrap gap-8 mt-6">
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-emerald-100 text-emerald-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Segurança e<br>conformidade</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-blue-100 text-blue-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Acesso em<br>qualquer lugar</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-11 h-11 rounded-full bg-teal-100 text-teal-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          <span class="text-sm font-medium text-gray-700 leading-tight">Economize tempo<br>e recursos</span>
        </div>
      </div>

    </div>

    <%# ── Coluna direita: MacBook mockup ── %>
    <div data-aos="fade-left" data-aos-delay="200"
         class="flex items-center justify-center px-4 sm:px-6 lg:px-0">

      <%# Wrapper único que agrupa tela + base em coluna %>
      <div class="flex flex-col items-center w-full max-w-[566px]">

        <%# — Tela (bezel) — %>
        <div class="relative w-full border-[8px] border-gray-800 bg-gray-800 rounded-t-xl shadow-2xl">

          <%# Webcam %>
          <div class="absolute -top-[6px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-gray-600 z-10"></div>

          <%# Barra de URL %>
          <div class="flex items-center gap-1.5 px-2 py-1.5 bg-gray-900">
            <%# Bolinhas %>
            <span class="w-2 h-2 rounded-full bg-red-500 flex-shrink-0"></span>
            <span class="w-2 h-2 rounded-full bg-yellow-400 flex-shrink-0"></span>
            <span class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span>
            <%# Campo de URL %>
            <div class="flex-1 flex items-center gap-1.5 bg-gray-700 rounded px-2 py-0.5 mx-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              <span class="text-gray-300 font-mono truncate" style="font-size: 9px;">app.turmaria.com</span>
            </div>
          </div>

          <%# Vídeo %>
          <div class="overflow-hidden rounded-b-[2px] bg-slate-100" style="aspect-ratio: 16/10;">
            <video
              class="w-full h-full object-cover object-top block"
              autoplay muted loop playsinline preload="metadata"
              aria-label="Demonstração do painel do Turmaria"
            >
              <source src="<%= asset_path '/media/hero.mp4' %>" type="video/mp4">
            </video>
          </div>
        </div>

        <%# — Palmrest (base fina) — %>
        <div class="relative w-[115%] h-[21px] bg-gray-800 rounded-b-xl">
          <%# Recuo de abertura %>
          <div class="absolute left-1/2 -translate-x-1/2 top-0 w-[94px] h-[6px] bg-gray-700 rounded-b-lg"></div>
        </div>

        <%# — Sombra no chão — %>
        <div class="w-[90%] h-3 bg-black/15 blur-md rounded-full mt-1"></div>

      </div>
    </div>

  </div>
</section>

