<%# BENEFÍCIOS                                         %>
<%# ══════════════════════════════════════════════════ %>
<section class="relative w-full overflow-hidden bg-white py-24 px-6 lg:px-16">

  <div class="absolute top-0 left-0 w-72 h-72 bg-blue-100/60 rounded-full blur-3xl pointer-events-none -translate-x-1/3 -translate-y-1/4"></div>
