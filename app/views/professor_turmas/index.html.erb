<div class="min-h-screen bg-gray-100">
  <!--Header-->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Gerenciar Turmas - <%= @professor.nome %></h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li><%= link_to "Professores", escola_professors_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li><%= link_to @professor.nome, escola_professor_path(@escola, @professor), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li class="text-gray-600">Gerenciar Turmas</li>
            </ul>
          </div>
        <div class="flex gap-3">
          <%= link_to escola_professor_path(@escola, @professor), class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2 inline">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Voltar
          <% end %>
        </div>
        </div>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Associar Nova Turma -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
      <div class="bg-gradient-to-r from-blue-500 to-green-300 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Associar a Nova Turma
        </h2>
      </div>

      <div class="p-6">
        <% if @turmas_disponiveis.any? %>
          <%= form_with url: professor_turmas_path(@professor), method: :post, local: true, class: "flex flex-col md:flex-row gap-4 items-end" do |form| %>
            <div class="flex-1 w-full">
              <%= form.label :turma_id, "Selecione uma turma:", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.select :turma_id, 
                  options_from_collection_for_select(@turmas_disponiveis, :id, :nome_completo), 
                  { prompt: "Escolha uma turma..." },
                  { class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" } %>
            </div>
            <%= form.submit "Associar", class: "bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors w-full md:w-auto" %>
          <% end %>
        <% else %>
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-blue-500 shrink-0 w-6 h-6 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-blue-700">Todas as turmas disponíveis já estão associadas a este professor.</span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Turmas Associadas -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
      <div class="bg-gradient-to-r from-green-500 to-green-400 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
          </svg>
          Turmas Associadas
        </h2>
      </div>

      <div class="p-6">
        <% if @turmas_associadas.any? %>
          <!-- Tabela para Desktop -->
          <div class="hidden md:block overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 border-b-2 border-gray-200">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Turma</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Escola</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Série</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Turno</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alunos</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @turmas_associadas.each do |turma| %>
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm font-medium text-gray-900"><%= turma.nome %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-600"><%= turma.escola.nome %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-600"><%= turma.serie %></div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                        <%= turma.turno.humanize %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                        <%= turma.alunos.count %> alunos
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                      <div class="flex gap-2">
                        <%= link_to escola_turma_path(turma.escola, turma), class: "text-blue-600 hover:text-blue-900 transition-colors" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          </svg>
                        <% end %>
                        
                        <%= link_to professor_professor_turma_path(@professor, turma.professor_turmas.find_by(professor: @professor)), 
                            method: :delete,
                            data: { 
                              confirm: "Tem certeza que deseja remover #{@professor.nome} da turma #{turma.nome}?" 
                            },
                            class: "text-red-500 hover:text-red-700 transition-colors" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                          </svg>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Cards para Mobile -->
          <div class="md:hidden space-y-4">
            <% @turmas_associadas.each do |turma| %>
              <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-3">
                  <div>
                    <h3 class="text-lg font-bold text-gray-900"><%= turma.nome %></h3>
                    <p class="text-sm text-gray-600"><%= turma.escola.nome %></p>
                  </div>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">
                    <%= turma.turno.humanize %>
                  </span>
                </div>

                <div class="space-y-2 mb-4">
                  <div class="flex items-center text-sm">
                    <span class="text-gray-500 w-20">Série:</span>
                    <span class="text-gray-900 font-medium"><%= turma.serie %></span>
                  </div>
                  <div class="flex items-center text-sm">
                    <span class="text-gray-500 w-20">Alunos:</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                      <%= turma.alunos.count %> alunos
                    </span>
                  </div>
                </div>

                <div class="flex gap-2 pt-3 border-t border-gray-100">
                  <%= link_to escola_turma_path(turma.escola, turma), class: "flex-1 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-center flex items-center justify-center" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Ver
                  <% end %>
                  
                  <%= link_to professor_professor_turma_path(@professor, turma.professor_turmas.find_by(professor: @professor)), 
                      method: :delete,
                      data: { 
                        confirm: "Tem certeza que deseja remover #{@professor.nome} da turma #{turma.nome}?" 
                      },
                      class: "flex-1 bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-center flex items-center justify-center" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                    Remover
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-yellow-500 shrink-0 h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <span class="text-yellow-700">Este professor ainda não está associado a nenhuma turma.</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>