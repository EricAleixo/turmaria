<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
<script>
/* =====================================================
   BOOTSTRAP SEGURO (TURBO + DOM)
===================================================== */
(function () {
  function init() {
    initUploads();
    initFotoUpload();
    initMasks();
  }

  document.addEventListener("turbo:load", init);
})();

/* =====================================================
   UPLOAD DE DOCUMENTOS (SEM MODAL)
===================================================== */
function openDocumentModal(type) {
  const inputMap = {
    cpf_documento: "cpf_documento-upload",
    comprovante: "comprovante-upload",
    historico: "historico-upload"
  };

  const inputId = inputMap[type];
  if (!inputId) return;

  const input = document.getElementById(inputId);
  if (!input) return;

  input.click();
}

function initUploads() {
  bindUpload("cpf_documento-upload", "cpf_documento-files-list", 2);
  bindUpload("comprovante-upload", "comprovante-files-list", 2);
  bindUpload("historico-upload", "historico-files-list", 1);
}

function bindUpload(inputId, listId, maxFiles) {
  const input = document.getElementById(inputId);
  const list = document.getElementById(listId);

  if (!input || !list) return;

  input.addEventListener("change", () => {
    // 🔥 CLONA os arquivos atuais
    const files = Array.from(input.files);

    // 🔥 LIMPA o input imediatamente
    input.value = "";

    // 🔥 valida quantidade REAL
    if (files.length > maxFiles) {
      alert(`Máximo permitido: ${maxFiles} arquivo(s).`);
      list.innerHTML = "";
      return;
    }

    renderFileList(list, files);
  });
}

function renderFileList(container, files) {
  container.innerHTML = "";

  files.forEach(file => {
    const div = document.createElement("div");
    div.className = "p-2 border-b text-sm text-gray-700";
    div.textContent = `📎 ${file.name}`;
    container.appendChild(div);
  });
}

/* =====================================================
   FOTO DO ALUNO (SEM MODAL)
===================================================== */
function openFotoModal() {
  const input = document.getElementById("foto-upload");
  if (input) input.click();
}

function initFotoUpload() {
  const input = document.getElementById("foto-upload");
  const list = document.getElementById("foto-files-list");

  if (!input || !list) return;

  input.addEventListener("change", () => {
    if (input.files.length > 1) {
      alert("Apenas 1 foto é permitida.");
      input.value = "";
      list.innerHTML = "";
      return;
    }

    renderFileList(list, Array.from(input.files));
  });
}

/* =====================================================
   MÁSCARAS (IMask BLINDADO)
===================================================== */
function initMasks() {
  if (typeof IMask === "undefined") {
    console.warn("IMask não carregado — máscaras ignoradas");
    return;
  }

  const cpf = document.getElementById("aluno_cpf");
  if (cpf) {
    IMask(cpf, { mask: "000.000.000-00" });
  }

  const telAluno = document.getElementById("aluno_telefone");
  if (telAluno) {
    IMask(telAluno, { mask: "(00) 00000-0000" });
  }

  const telResp1 = document.getElementById("aluno_telefone_responsavel_1");
  if (telResp1) {
    IMask(telResp1, { mask: "(00) 00000-0000" });
  }

  const telResp2 = document.getElementById("aluno_telefone_responsavel_2");
  if (telResp2) {
    IMask(telResp2, { mask: "(00) 00000-0000" });
  }
}
</script>
