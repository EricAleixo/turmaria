<%
  form_url = @turma ? [@escola, @turma, @aluno] : [@escola, @aluno]
  editing = local_assigns[:editing]
%>

<%= form_with(model: form_url, class: "bg-white p-8 rounded-lg shadow-md max-w-4xl mx-auto", html: {multipart: true} , id: "student-form", data: { controller: "student-form" }) do |form| %>

  <%= form.hidden_field :escola_id, value: @escola.id %>
  
  <% if @turma %>
    <%= form.hidden_field :turma_id, value: @turma.id %>
  <% end %>

  <div class="alert alert-error mb-4 hidden" id="error-alert">
    <div>
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span>
        <h3 class="font-bold">Erro ao salvar!</h3>
        <ul id="error-list" class="list-disc list-inside">
        </ul>
      </span>
    </div>
  </div>

  <div id="step-1" class="form-step">
    <div class="flex justify-between items-center mb-6 border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-700">
        <%= editing ? "Editar Aluno - Etapa 1" : "Novo Aluno - Etapa 1" %>
      </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-control w-full">
        <label for="aluno_nome" class="label label-text text-gray-600 font-semibold">Nome do Aluno</label>
        <%= form.text_field :nome, class: "input input-bordered w-full", placeholder: "Ex: Francisco Ittalo Pessoa" %>
      </div>
      <div class="form-control w-full">
      <%= form.label :data_nascimento, "Data de Nascimento", class: "label label-text text-gray-600 font-semibold" %>
      <div class="relative">
        <%= form.text_field :data_nascimento, 
            class: "border border-gray-300 rounded-md px-4 py-2 cursor-pointer hover:border-black focus:border-black focus:outline-none w-full pr-10 datepicker-field text-black peer", 
            placeholder: "", 
            autocomplete: "off" %>
        <span class="absolute left-4 top-2 text-gray-400 pointer-events-none peer-focus:opacity-0 peer-valid:opacity-0 transition !text-black">
          Selecione a data
        </span>
        <svg class="absolute right-3 top-1/2 transform -translate-y-1/2 h-5 w-5 text-gray-600 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <div class="form-control w-full">
        <label for="aluno_cpf" class="label label-text text-gray-600 font-semibold">CPF do Aluno</label>
        <%= form.text_field :cpf, class: "input input-bordered w-full", placeholder: "000.000.000-00" %>
      </div>
      <div class="form-control w-full">
        <label for="aluno_rg" class="label label-text text-gray-600 font-semibold">RG do Aluno</label>
        <%= form.text_field :rg, class: "input input-bordered w-full" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <div class="form-control w-full">
        <label for="aluno_telefone" class="label label-text text-gray-600 font-semibold">Telefone</label>
        <%= form.text_field :telefone, class: "input input-bordered w-full", placeholder: "(00) 00000-0000" %>
      </div>
      <div class="form-control w-full">
        <label for="aluno_email" class="label label-text text-gray-600 font-semibold">Email</label>
        <%= form.email_field :email, class: "input input-bordered w-full" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
<%= dropdown(
      form: form,
      method: :cidade_id,
      select_id: "professor_cidade_id_select",
      collection: Cidade.all.order(:nome),
      label_field: :nome_com_estado,
      value_field: :id,
      placeholder: "Selecione a cidade",
      hidden_field_id: "professor_cidade_id",
      
    ) %>
   
    </div>

    <div class="flex justify-between mt-6">
      <a href="#" class="btn btn-ghost">Voltar</a>
      <div class="flex gap-2">
        <button type="submit" class="btn bg-green-500 hover:bg-green-600 text-white">
          Salvar
        </button>
        <button type="button" id="next-step-1" class="btn btn-primary text-white w-28 flex items-center justify-center gap-1">
          Próximo
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="step-2" class="form-step hidden">
    <div class="flex justify-between items-center mb-6 border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-700">
        <%= editing ? "Editar Aluno - Etapa 2" : "Novo Aluno - Etapa 2" %>
      </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="form-control w-full">
 <%= dropdown(
      form: form,
      method: :sexo,
      select_id: "aluno_sexo_select",
      collection: [
        ["Masculino", "Masculino"],
        ["Feminino",  "Feminino"],
        ["Outro",     "Outro"]
      ],
      placeholder: "Selecione",
      hidden_field_id: "aluno_sexo"
    ) %>

  </div>

  <div class="form-control w-full">
<%= dropdown(
      form: form,
      method: :cor,
      select_id: "aluno_cor_select",
      collection: [
        ["Branca", "Branca"],
        ["Preta", "Preta"],
        ["Parda", "Parda"],
        ["Amarela", "Amarela"],
        ["Indígena", "Indígena"],
        ["Não declarada", "Não declarada"]
      ],
      placeholder: "Selecione",
      hidden_field_id: "aluno_cor"
    ) %>

  </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
<%= dropdown(
      form: form,
      method: :tipo_sanguinio,
      select_id: "aluno_tipo_sanguinio_select",
      collection: [
        ["A+","A+"],["A-","A-"],["B+","B+"],["B-","B-"],
        ["AB+","AB+"],["AB-","AB-"],["O+","O+"],["O-","O-"]
      ],
      placeholder: "Selecione",
      hidden_field_id: "aluno_tipo_sanguinio",
      label: "Tipo sanguíneo"
    ) %>
    </div>
    
    <div class="form-control w-full mt-4">
      <label class="label label-text text-gray-600 mb-2">Portador de Necessidade (PCD)</label>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        <label class="label cursor-pointer">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox" }, "Nenhuma", nil %>
          <span class="label-text">Nenhuma</span> 
        </label>
        <label class="label cursor-pointer">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox" }, "Visual", nil %>
          <span class="label-text">Visual</span> 
        </label>
        <label class="label cursor-pointer">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox" }, "Auditiva", nil %>
          <span class="label-text">Auditiva</span> 
        </label>
        <label class="label cursor-pointer">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox" }, "Motora", nil %>
          <span class="label-text">Motora</span> 
        </label>
        <label class="label cursor-pointer">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox" }, "Intelectual", nil %>
          <span class="label-text">Intelectual</span> 
        </label>
        <label class="label cursor-pointer" for="outro-checkbox">
          <%= form.check_box :necessidades_especiais_tipo, { multiple: true, class: "checkbox checkbox-primary necessidade-checkbox", id: "outro-checkbox" }, "Outro(a)", nil %>
          <span class="label-text">Outro(a)</span>
        </label> 
      </div>
    </div>
    
    <div id="outra-necessidade-field" class="form-control w-full mt-4 <%= 'hidden' unless @aluno.necessidades_especiais_tipo.present? && @aluno.necessidades_especiais_tipo.include?('Outro(a)') %>">
      <label for="aluno_observacoes_pcd" class="label label-text text-gray-600 font-semibold">Observações</label>
      <%= form.text_area :observacoes_pcd, class: "textarea textarea-bordered w-full", placeholder: "Insira observações adicionais sobre a necessidade do aluno." %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <div class="form-control w-full">
        <label for="aluno_responsavel_1" class="label label-text text-gray-600 font-semibold">Nome Responsável 1</label>
        <%= form.text_field :responsavel_1, class: "input input-bordered w-full" %>
      </div>
      <div class="form-control w-full">
        <label for="aluno_responsavel_2" class="label label-text text-gray-600 font-semibold">Nome Responsável 2</label>
        <%= form.text_field :responsavel_2, class: "input input-bordered w-full" %>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <div class="form-control w-full">
        <label for="aluno_telefone_responsavel_1" class="label label-text text-gray-600 font-semibold">Telefone Responsável 1</label>
        <%= form.text_field :telefone_responsavel_1, class: "input input-bordered w-full", placeholder: "(00) 00000-0000" %>
      </div>
      <div class="form-control w-full">
        <label for="aluno_telefone_responsavel_2" class="label label-text text-gray-600 font-semibold">Telefone Responsável 2</label>
        <%= form.text_field :telefone_responsavel_2, class: "input input-bordered w-full", placeholder: "(00) 00000-0000" %>
      </div>
    </div>
    <div class="flex justify-between mt-6">
      <button type="button" id="prev-step-2" class="btn btn-ghost w-28 flex items-center justify-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Anterior
      </button>
      <div class="flex gap-2">
        <button type="submit" class="btn bg-green-500 hover:bg-green-600 text-white">
          Salvar
        </button>
        <button type="button" id="next-step-2" class="btn btn-primary text-white w-28 flex items-center justify-center gap-1">
          Próximo
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="step-3" class="form-step hidden">
    <div class="flex justify-between items-center mb-6 border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-700">
        <%= editing ? "Editar Aluno - Etapa 3" : "Novo Aluno - Etapa 3" %>
      </h1>
      <p class="text-xs text-gray-400">Campos opcionais</p>
    </div>

    <div id="upload-error-message" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4 hidden" role="alert">
      <span class="block sm:inline"></span>
    </div>

    <div class="bg-gray-50 p-4 rounded-lg mb-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-lg font-bold text-gray-700">Foto do Aluno</h3>
        <button type="button" class="btn btn-sm btn-primary text-white cursor-pointer" onclick="openFotoModal()">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
          </svg>
          Anexar
        </button>
      </div>
      <p class="text-gray-500 mb-2 text-sm">Envie uma foto do aluno. (Máximo 1 arquivo)</p>
      <%= form.file_field :foto, class: "hidden", id: "foto-upload", accept: "image/*" %>
      <div id="foto-files-list" class="mt-4 border rounded-lg"></div>
    </div>

    <div class="bg-gray-50 p-4 rounded-lg mb-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-lg font-bold text-gray-700">Upload de CPF</h3>
        <button type="button" class="btn btn-sm btn-primary text-white cursor-pointer" onclick="openDocumentModal('cpf_documento')">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
          </svg>
          Anexar
        </button>
      </div>
      <p class="text-gray-500 mb-2 text-sm">Envie a frente e o verso do documento. (Máximo 2 arquivos)</p>
      <%= form.file_field :cpf_documento, multiple: true, class: "hidden", id: "cpf_documento-upload", accept: "image/*,.pdf" %>
      <div id="cpf_documento-files-list" class="mt-4 border rounded-lg"></div>
    </div>

    <div class="bg-gray-50 p-4 rounded-lg mb-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-lg font-bold text-gray-700">Upload de Comprovante de Residência</h3>
        <button type="button" class="btn btn-sm btn-primary text-white cursor-pointer" onclick="openDocumentModal('comprovante')">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
          </svg>
          Anexar
        </button>
      </div>
      <p class="text-gray-500 mb-2 text-sm">Envie a frente e o verso do documento. (Máximo 2 arquivos)</p>
      <%= form.file_field :comprovante_residencia, multiple: true, class: "hidden", id: "comprovante-upload", accept: "image/*,.pdf" %>
      <div id="comprovante-files-list" class="mt-4 border rounded-lg"></div>
    </div>

    <div class="bg-gray-50 p-4 rounded-lg mb-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-lg font-bold text-gray-700">Histórico Acadêmico</h3>
        <button type="button" class="btn btn-sm btn-primary text-white cursor-pointer" onclick="openDocumentModal('historico')">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
          </svg>
          Anexar
        </button>
      </div>
      <p class="text-gray-500 mb-2 text-sm">Envie o documento assinado. (Máximo 1 arquivo)</p>
      <%= form.file_field :historico_academico, class: "hidden", id: "historico-upload", accept: "image/*,.pdf" %>
      <div id="historico-files-list" class="mt-4 border rounded-lg"></div>
    </div>

    <!-- Modal de Foto com Crop -->
    <dialog id="foto-modal" class="modal">
      <div class="modal-box max-w-2xl">
        <h3 class="font-bold text-lg mb-4">Anexar Foto do Aluno</h3>
        
        <div id="foto-upload-area" class="upload-area border-2 border-dashed rounded-lg p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mx-auto mb-3 text-gray-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
          </svg>
          <p class="text-gray-500 mb-2">Arraste e solte a foto aqui ou</p>
          <label for="foto-upload" class="btn btn-outline mt-2 cursor-pointer">Escolher arquivo</label>
        </div>

        <div id="foto-crop-area" class="hidden mt-4">
          <div class="mb-4">
            <p class="text-sm text-gray-600 mb-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
              <strong>Ajuste a área circular para enquadrar o rosto do aluno</strong>
            </p>
            <div class="relative bg-gray-100 rounded-lg overflow-hidden" style="max-height: 450px;">
              <img id="foto-preview" src="" alt="Preview" class="max-w-full">
            </div>
            <div class="mt-3 flex items-center justify-center gap-2 text-xs text-gray-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
              </svg>
              Clique e arraste para mover a imagem • Use a roda do mouse para zoom
            </div>
          </div>
          <div class="flex gap-2 justify-end">
            <button type="button" class="btn btn-ghost" onclick="resetFotoModal()">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
              Trocar foto
            </button>
            <button type="button" class="btn btn-success text-white" onclick="confirmFotoCrop()">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              Confirmar recorte
            </button>
          </div>
        </div>

        <div class="modal-action">
          <button type="button" class="btn" onclick="closeFotoModal()">Fechar</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button type="button" onclick="closeFotoModal()">close</button>
      </form>
    </dialog>

    <!-- Modal Genérico para Documentos -->
    <dialog id="document-modal" class="modal">
      <div class="modal-box max-w-xl">
        <h3 class="font-bold text-lg mb-4" id="document-modal-title">Anexar Documento</h3>
        
        <div id="document-upload-area" class="upload-area border-2 border-dashed rounded-lg p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mx-auto mb-3 text-gray-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          <p class="text-gray-500 mb-2" id="document-modal-description">Arraste e solte seus arquivos aqui ou</p>
          <label id="document-modal-label" class="btn btn-outline mt-2 cursor-pointer">Escolher arquivos</label>
        </div>

        <div id="document-preview-area" class="hidden mt-4">
          <p class="text-sm font-semibold text-gray-700 mb-2">Arquivos selecionados:</p>
          <div id="document-preview-list" class="space-y-2"></div>
          <div class="flex gap-2 justify-end mt-4">
            <button type="button" class="btn btn-ghost" onclick="resetDocumentModal()">Trocar arquivos</button>
            <button type="button" class="btn btn-success text-white" onclick="confirmDocumentUpload()">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              Confirmar
            </button>
          </div>
        </div>

        <div class="modal-action">
          <button type="button" class="btn" onclick="closeDocumentModal()">Fechar</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button onclick="closeDocumentModal()">close</button>
      </form>
    </dialog>

    <div class="flex justify-between mt-6">
      <button type="button" id="prev-step-3" class="btn btn-ghost w-28 flex items-center justify-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Anterior
      </button>
      <button type="submit" class="btn bg-green-500 hover:bg-green-600 text-white" id="submit-btn">
        <%= editing ? "Salvar Alterações" : "Criar Aluno" %>
      </button>
    </div>
  </div>
<% end %>

