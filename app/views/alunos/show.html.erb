<input type="checkbox" id="historico-modal" class="modal-toggle" />
<div class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Documento: Histórico Acadêmico</h3>
    <div class="py-4">
      <% if @aluno.historico_academico_url.present? %>
