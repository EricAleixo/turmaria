<% content_for :title, "Detalhes do Aluno" %>

<div class="drawer lg:drawer-open bg-gray-100 min-h-screen">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    
    <div class="w-full p-4">
      <div class="flex items-center mb-6 lg:hidden">
        <label for="my-drawer" class="btn btn-square btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <h1 class="text-xl font-bold ml-2">Detalhes do Aluno</h1>
      </div>

      <main class="w-full max-w-4xl mx-auto">
        <% if notice.present? %>
          <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
        <% end %>

        <div class="text-sm breadcrumbs mb-4">
          <ul>
            <li><%= link_to "Escolas", escolas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li><%= link_to @turma.nome, escola_turma_path(@escola, @turma), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li class="text-gray-600"><%= @aluno.nome %></li>
          </ul>
        </div>
        
        <h1 class="font-bold text-4xl mb-6"><%= @aluno.nome %></h1>

        <div class="bg-white rounded-xl shadow-xl p-8 mb-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div>
                <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Data de Nascimento</h3>
                <p class="text-lg text-gray-800"><%= @aluno.data_nascimento.present? ? @aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></p>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Escola</h3>
                <p class="text-lg text-gray-800"><%= @escola.nome %></p>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Turma</h3>
                <p class="text-lg text-gray-800"><%= @turma.nome %> - <%= @turma.turno.humanize %></p>
              </div>
            </div>
          </div>
          
          <div class="mt-8">
            <h3 class="text-xl font-bold text-green-600 mb-4">Ações</h3>
            <div class="flex flex-col md:flex-row gap-4">
              <%= link_to "Editar Aluno", edit_escola_turma_aluno_path(@escola, @turma, @aluno), class: "btn bg-yellow-500 hover:bg-yellow-600 text-white transition-all duration-300" %>
              <%= button_to "Excluir Aluno", escola_turma_aluno_path(@escola, @turma, @aluno), method: :delete, class: "btn bg-red-600 hover:bg-red-500 text-white transition-all duration-300", data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } %>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 mt-8">
          <%= link_to "Editar este aluno", edit_escola_turma_aluno_path(@escola, @turma, @aluno), class: "btn bg-yellow-500 hover:bg-yellow-600 text-white shadow-lg transition-all duration-300" %>
          <%= link_to "Voltar para alunos", escola_turma_alunos_path(@escola, @turma), class: "btn bg-green-500 hover:bg-green-600 text-white shadow-lg transition-all duration-300" %>
          <%= button_to "Excluir este aluno", escola_turma_aluno_path(@escola, @turma, @aluno), method: :delete, class: "btn bg-red-600 hover:bg-red-500 text-white shadow-lg transition-all duration-300", data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } %>
        </div>
      </main>
    </div>
  </div>
  
  <%= render 'shared/super_admin_sidebar' %>
</div>

<input type="checkbox" id="cpf-modal" class="modal-toggle" />
<div class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Documento: CPF</h3>
    <div class="py-4">
      <% if @aluno.cpf_url.present? %>
        <%= link_to "Abrir PDF", @aluno.cpf_url, target: "_blank", class: "link link-hover text-blue-500" %>
      <% else %>
        <p class="text-gray-500">CPF: Não enviado</p>
      <% end %>
    </div>
    <div class="modal-action">
      <label for="cpf-modal" class="btn">Fechar</label>
    </div>
  </div>
</div>

