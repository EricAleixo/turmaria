<% content_for :title, "Detalhes do Aluno" %>

<div class="drawer lg:drawer-open bg-gray-100">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />
  
  <div class="drawer-content flex flex-col">
    <div class="w-full p-6">

      <div class="text-sm breadcrumbs mb-4">
          <ul>
            <li><%= link_to "Escolas", escolas_menager_paths, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <% if @turma %>
              <li><%= link_to @turma.nome, escola_turma_path(@escola, @turma), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li><%= link_to "Alunos", escola_turma_alunos_path(@escola, @turma), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <% else %>
              <li><%= link_to "Alunos", escola_alunos_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <% end %>
            <li class="text-gray-600"><%= @aluno.nome %></li>
          </ul>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <div class="flex items-center mb-6">
          <div class="flex items-center">
            <%= link_to escola_alunos_path(@escola), class: "flex items-center text-green-600 hover:text-green-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Voltar para Alunos
            <% end %>
          </div>

          <% if @aluno.turma.present? %>
            <%= link_to escola_turma_path(@escola, @aluno.turma), class: "ml-4 flex items-center text-green-600 hover:text-green-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.5 13a3.5 3.5 0 11-7 0 3.5 3.5 0 017 0z" />
              </svg>
              Ir para Turma
            <% end %>
          <% end %>
        </div>

        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Detalhes do Aluno</h1>
          <p class="text-gray-600">Visualize e gerencie as informações completas do aluno</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <div class="flex flex-col items-center text-center">
              <div class="avatar placeholder mb-4">
              <% if @aluno.foto.attached? %>
                <%= image_tag @aluno.foto, class: "rounded-full w-24 h-24 ring-4 ring-green-500/20 object-cover" %>
              <% else %>
                <div class="bg-green-500 text-white rounded-full w-24 h-24 relative ring-4 ring-green-500/20">
                  <span class="text-3xl font-bold absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                    <%= @aluno.nome.present? ? @aluno.nome.first.upcase : 'A' %>
                  </span>
                </div>
              <% end %>
            </div>
              <h2 class="text-2xl font-bold text-gray-900 mb-2">
                <%= @aluno.nome.presence || 'Nome não informado' %>
              </h2>
              <p class="text-gray-600 mb-4">ID: <%= @aluno.id.to_s.first(8) %></p>
              
              <div class="flex items-center gap-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Usuário Ativo
              </div>
            </div>
          </div>
          
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              Informações de Contato
            </h3>
            
            <div class="space-y-4">
              
              <!-- Seção: Dados Pessoais -->
              <div class="mb-6">
                <h4 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3 flex items-center gap-2">
                  <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                  Dados Pessoais
                </h4>
                
                <div class="space-y-3">
                  <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg border border-blue-200 hover:shadow-md transition-all">
                    <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-blue-800 block">Email</span>
                      <p class="text-blue-900 font-semibold break-all"><%= @aluno.email.presence || 'Não informado' %></p>
                    </div>
                    <% if @aluno.email.present? %>
                      <a href="mailto:<%= @aluno.email %>" class="p-2 text-blue-600 hover:bg-blue-200 rounded-lg transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    <% end %>
                  </div>
                  
                  <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-green-50 to-green-100 rounded-lg border border-green-200 hover:shadow-md transition-all">
                    <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                      </svg>
                    </div>
                    <div class="flex-1">
                      <span class="text-sm font-medium text-green-800 block">Telefone</span>
                      <p class="text-green-900 font-semibold"><%= @aluno.telefone.presence || 'Não informado' %></p>
                    </div>
                    <% if @aluno.telefone.present? %>
                      <a href="tel:<%= @aluno.telefone %>" class="p-2 text-green-600 hover:bg-green-200 rounded-lg transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                        </svg>
                      </a>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Divisor -->
              <div class="border-t border-gray-200 my-6"></div>
              
              <!-- Seção: Responsáveis -->
              <div>
                <h4 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3 flex items-center gap-2">
                  <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
                  Responsáveis
                </h4>
                
                <div class="space-y-4">
                  
                  <!-- Responsável 1 - Card Agrupado -->
                  <% if @aluno.responsavel_1.present? || @aluno.telefone_responsavel_1.present? %>
                    <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl border-2 border-purple-200 overflow-hidden">
                      <!-- Cabeçalho do Responsável -->
                      <div class="bg-purple-500 text-white p-3 sm:p-4">
                        <div class="flex items-center gap-2 sm:gap-3">
                          <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                          </div>
                          <div class="flex-1 min-w-0">
                            <h5 class="font-bold text-base sm:text-lg">Responsável Principal</h5>
                            <p class="text-purple-100 font-medium text-sm sm:text-base truncate"><%= @aluno.responsavel_1.presence || 'Nome não informado' %></p>
                          </div>
                          <div class="flex items-center gap-1 bg-white/20 px-2 py-1 rounded-full text-xs font-medium flex-shrink-0">
                            <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                            <span class="hidden sm:inline">Primário</span>
                            <span class="sm:hidden">1º</span>
                          </div>
                        </div>
                      </div>
                      
                      <!-- Informações de Contato -->
                      <div class="p-3 sm:p-4">
                        <!-- Layout Mobile - Empilhado -->
                        <div class="sm:hidden space-y-3">
                          <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg">
                            <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center flex-shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                              </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                              <span class="text-sm font-medium text-purple-800 block">Telefone</span>
                              <p class="text-purple-900 font-semibold"><%= @aluno.telefone_responsavel_1.presence || 'Não informado' %></p>
                            </div>
                            <% if @aluno.telefone_responsavel_1.present? %>
                              <a href="tel:<%= @aluno.telefone_responsavel_1 %>" class="p-2 text-purple-600 hover:bg-purple-200 rounded-lg transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                                </svg>
                              </a>
                            <% end %>
                          </div>
                        </div>
                        
                        <!-- Layout Desktop - Lado a Lado -->
                        <div class="hidden sm:flex sm:items-center sm:gap-4">
                          <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg flex-1">
                            <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center flex-shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                              </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                              <span class="text-sm font-medium text-purple-800 block">Telefone</span>
                              <p class="text-purple-900 font-semibold"><%= @aluno.telefone_responsavel_1.presence || 'Não informado' %></p>
                            </div>
                            <% if @aluno.telefone_responsavel_1.present? %>
                              <a href="tel:<%= @aluno.telefone_responsavel_1 %>" class="p-2 text-purple-600 hover:bg-purple-200 rounded-lg transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                                </svg>
                              </a>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                  
                  <!-- Responsável 2 - Card Agrupado -->
                  <% if @aluno.responsavel_2.present? || @aluno.telefone_responsavel_2.present? %>
                    <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-xl border-2 border-indigo-200 overflow-hidden">
                      <!-- Cabeçalho do Responsável -->
                      <div class="bg-indigo-500 text-white p-3 sm:p-4">
                        <div class="flex items-center gap-2 sm:gap-3">
                          <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                          </div>
                          <div class="flex-1 min-w-0">
                            <h5 class="font-bold text-base sm:text-lg">Responsável Secundário</h5>
                            <p class="text-indigo-100 font-medium text-sm sm:text-base truncate"><%= @aluno.responsavel_2.presence || 'Nome não informado' %></p>
                          </div>
                          <div class="flex items-center gap-1 bg-white/20 px-2 py-1 rounded-full text-xs font-medium flex-shrink-0">
                            <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
                            <span class="hidden sm:inline">Secundário</span>
                            <span class="sm:hidden">2º</span>
                          </div>
                        </div>
                      </div>
                      
                      <!-- Informações de Contato -->
                      <div class="p-3 sm:p-4">
                        <!-- Layout Mobile - Empilhado -->
                        <div class="sm:hidden space-y-3">
                          <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg">
                            <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center flex-shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                              </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                              <span class="text-sm font-medium text-indigo-800 block">Telefone</span>
                              <p class="text-indigo-900 font-semibold"><%= @aluno.telefone_responsavel_2.presence || 'Não informado' %></p>
                            </div>
                            <% if @aluno.telefone_responsavel_2.present? %>
                              <a href="tel:<%= @aluno.telefone_responsavel_2 %>" class="p-2 text-indigo-600 hover:bg-indigo-200 rounded-lg transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                                </svg>
                              </a>
                            <% end %>
                          </div>
                        </div>
                        
                        <!-- Layout Desktop - Lado a Lado -->
                        <div class="hidden sm:flex sm:items-center sm:gap-4">
                          <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg flex-1">
                            <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center flex-shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                              </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                              <span class="text-sm font-medium text-indigo-800 block">Telefone</span>
                              <p class="text-indigo-900 font-semibold"><%= @aluno.telefone_responsavel_2.presence || 'Não informado' %></p>
                            </div>
                            <% if @aluno.telefone_responsavel_2.present? %>
                              <a href="tel:<%= @aluno.telefone_responsavel_2 %>" class="p-2 text-indigo-600 hover:bg-indigo-200 rounded-lg transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                                </svg>
                              </a>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
              <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center mr-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              Dados Acadêmicos
            </h3>
            
            <div class="space-y-6">
              <!-- Turma Atual -->
              <div class="p-4 bg-gradient-to-r from-amber-50 to-amber-100 rounded-xl border border-amber-200">
                <h4 class="text-sm font-semibold text-amber-800 uppercase tracking-wide mb-3 flex items-center gap-2">
                  <div class="w-2 h-2 bg-amber-500 rounded-full"></div>
                  Turma Atual
                </h4>
                
                <% if @aluno.turma.present? %>
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-amber-500 rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    </div>
                    <div class="flex-1">
                      <h5 class="text-lg font-bold text-amber-900"><%= @aluno.turma.nome %></h5>
                      <p class="text-amber-700"><%= @aluno.turma.ano_letivo.ano %></p>
                    </div>
                    <%= link_to escola_turma_path(@escola, @aluno.turma), class: "btn btn-sm bg-amber-500 hover:bg-amber-600 text-white border-none" do %>
                      Ver Turma
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    <% end %>
                  </div>
                <% else %>
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-gray-300 rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    </div>
                    <div class="flex-1">
                      <h5 class="text-lg font-bold text-gray-500">Sem Turma</h5>
                      <p class="text-gray-400">Aluno não alocado em nenhuma turma</p>
                    </div>
                    <button class="btn btn-sm bg-amber-500 hover:bg-amber-600 text-white border-none">
                      Alocar
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                      </svg>
                    </button>
                  </div>
                <% end %>
              </div>
              
              <!-- Necessidades Especiais -->
              <div class="p-4 bg-gradient-to-r from-purple-50 to-purple-100 rounded-xl border border-purple-200">
                <h4 class="text-sm font-semibold text-purple-800 uppercase tracking-wide mb-3 flex items-center gap-2">
                  <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
                  Necessidades Especiais
                </h4>
                
                <% if @aluno.necessidades_especiais_tipo.present? %>
                  <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-purple-500 rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <h5 class="text-lg font-bold text-purple-900">Necessidades Identificadas</h5>
                        <div class="badge badge-sm bg-purple-200 text-purple-800 border-none">Requer Atenção</div>
                      </div>
                      <p class="text-purple-700 whitespace-pre-line"><%= @aluno.necessidades_especiais_tipo %></p>
                    </div>
                  </div>
                <% else %>
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-gray-300 rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    <div class="flex-1">
                      <h5 class="text-lg font-bold text-gray-500">Nenhuma Necessidade Especial</h5>
                      <p class="text-gray-400">Não foram registradas necessidades especiais</p>
                    </div>
                  </div>
                <% end %>
              </div>
              
              <!-- Documentos -->
              <div class="p-4 bg-gradient-to-r from-blue-50 to-blue-100 rounded-xl border border-blue-200">
                <h4 class="text-sm font-semibold text-blue-800 uppercase tracking-wide mb-3 flex items-center gap-2">
                  <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                  Documentos
                </h4>
                
                <div class="space-y-3">
                  <!-- Comprovante de Residência -->
                  <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg hover:shadow-md transition-all">
                    <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-blue-800 block">Comprovante de Residência</span>
                      <% if @aluno.comprovante_residencia_url.present? %>
                        <%= link_to @aluno.comprovante_residencia_url, target: "_blank", class: "text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1" do %>
                          Ver PDF
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        <% end %>
                      <% else %>
                        <p class="text-red-500 font-medium">Não enviado</p>
                      <% end %>
                    </div>
                    <button class="btn btn-xs bg-blue-500 hover:bg-blue-600 text-white border-none" onclick="document_modal_comprovante.showModal()">
                      <% if @aluno.comprovante_residencia_url.present? %>
                        Atualizar
                      <% else %>
                        Enviar
                      <% end %>
                    </button>
                  </div>
                  
                  <!-- Histórico Acadêmico -->
                  <div class="flex items-center gap-3 p-3 bg-white/60 rounded-lg hover:shadow-md transition-all">
                    <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-blue-800 block">Histórico Acadêmico</span>
                      <% if @aluno.historico_academico_url.present? %>
                        <%= link_to @aluno.historico_academico_url, target: "_blank", class: "text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1" do %>
                          Ver PDF
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        <% end %>
                      <% else %>
                        <p class="text-red-500 font-medium">Não enviado</p>
                      <% end %>
                    </div>
                    <button class="btn btn-xs bg-blue-500 hover:bg-blue-600 text-white border-none" onclick="document_modal_historico.showModal()">
                      <% if @aluno.historico_academico_url.present? %>
                        Atualizar
                      <% else %>
                        Enviar
                      <% end %>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Modais de Documentos -->
        <dialog id="document_modal_comprovante" class="modal">
          <div class="modal-box">
            <h3 class="font-bold text-lg mb-4">Comprovante de Residência</h3>
            <p class="mb-4">Faça upload do comprovante de residência do aluno (formato PDF).</p>
            
            <% if @aluno.turma.present? %>
              <%= form_with(model: @aluno, url: escola_turma_aluno_path(@escola, @aluno.turma, @aluno), method: :patch, class: "space-y-4") do |f| %>
                <div class="form-control w-full">
                  <%= f.file_field :comprovante_residencia, class: "file-input file-input-bordered w-full", accept: "application/pdf" %>
                </div>
                
                <div class="modal-action">
                  <button type="button" class="btn" onclick="document_modal_comprovante.close()">Cancelar</button>
                  <%= f.submit "Enviar Documento", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% else %>
              <p>Aluno ainda não está vinculado a nenhuma turma.</p>
            <% end %>

          </div>
          <form method="dialog" class="modal-backdrop">
            <button>Fechar</button>
          </form>
        </dialog>
        
        <dialog id="document_modal_historico" class="modal">
          <div class="modal-box">
            <h3 class="font-bold text-lg mb-4">Histórico Acadêmico</h3>
            <p class="mb-4">Faça upload do histórico acadêmico do aluno (formato PDF).</p>
            
           <% if @aluno.turma.present? %>
              <%= form_with(model: @aluno, url: escola_turma_aluno_path(@escola, @aluno.turma, @aluno), method: :patch, class: "space-y-4") do |f| %>
                <div class="form-control w-full">
                  <%= f.file_field :historico, class: "file-input file-input-bordered w-full", accept: "application/pdf" %>
                </div>
                
                <div class="modal-action">
                  <button type="button" class="btn" onclick="document_modal_historico.close()">Cancelar</button>
                  <%= f.submit "Enviar Documento", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% else %>
              <p>Aluno ainda não está vinculado a nenhuma turma.</p>
            <% end %>

          </div>
          <form method="dialog" class="modal-backdrop">
            <button>Fechar</button>
          </form>
        </dialog>
        <div class="w-full bg-gradient-to-br from-slate-50 to-gray-100 rounded-xl p-6 border-2 border-gray-200 shadow-xl">
  <!-- Cabeçalho da Seção -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-green-600 rounded-xl flex items-center justify-center shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-gray-900">Informações Pessoais</h3>
        <p class="text-sm text-gray-600">Dados completos do estudante</p>
      </div>
    </div>
    
    <!-- Botões de Ação -->
    <div class="flex items-center gap-2">
      <%= link_to edit_escola_aluno_path(@escola, @aluno), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white border-none shadow-md transition-all hover:shadow-lg" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="hidden sm:inline">Editar</span>
      <% end %>
      
      <%= link_to escola_aluno_path(@escola, @aluno), method: :delete, data: { confirm: "Tem certeza que deseja excluir este aluno? Esta ação não pode ser desfeita." }, class: "btn btn-sm bg-red-500 hover:bg-red-600 text-white border-none shadow-md transition-all hover:shadow-lg" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        <span class="hidden sm:inline">Excluir</span>
      <% end %>
    </div>
  </div>

  <!-- Credenciais de Acesso - Destaque Especial -->
  <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-xl p-6 mb-6 shadow-lg border-2 border-blue-200">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
        </svg>
      </div>
      <div>
        <h4 class="text-gray-800 font-bold text-lg">Credenciais de Acesso ao Sistema</h4>
        <p class="text-gray-600 text-sm">Informações utilizadas pelo aluno para login</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Matrícula (Login) -->
      <div class="bg-white rounded-lg p-4 border-2 border-blue-200 hover:border-blue-300 hover:shadow-md transition-all">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-blue-700 uppercase tracking-wider flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Matrícula (Login)
          </span>
          <div class="badge badge-sm bg-green-500 text-white border-none font-bold">Usuário</div>
        </div>
        <div class="flex items-center gap-2">
          <p class="text-2xl font-bold text-gray-800 truncate flex-1"><%= @aluno.matricula.presence || 'Não definida' %></p>
          <button onclick="navigator.clipboard.writeText('<%= @aluno.matricula %>')" class="btn btn-xs bg-blue-500 hover:bg-blue-600 text-white border-none" title="Copiar matrícula">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
          <button onclick="regenerate_matricula_modal.showModal()" class="btn btn-xs bg-purple-500 hover:bg-purple-600 text-white border-none" title="Gerar nova matrícula">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Senha -->
      <div class="bg-white rounded-lg p-4 border-2 border-blue-200 hover:border-blue-300 hover:shadow-md transition-all">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-blue-700 uppercase tracking-wider flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Senha
          </span>
          <div class="badge badge-sm bg-amber-500 text-white border-none font-bold">Protegida</div>
        </div>
        <div class="flex items-center gap-2">
          <p class="text-xl font-bold text-gray-800">••••••••</p>
          <%= link_to "Redefinir Senha", "#", class: "btn btn-xs bg-amber-500 hover:bg-amber-600 text-white border-none ml-auto", onclick: "reset_password_modal.showModal(); return false;" %>
        </div>
      </div>
    </div>
    
    <!-- Alerta de Segurança -->
    <div class="mt-4 bg-amber-50 rounded-lg p-3 border border-amber-200">
      <div class="flex items-start gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <p class="text-xs text-amber-800">
          <strong class="font-semibold">Atenção:</strong> Estas credenciais são confidenciais. Apenas compartilhe com o aluno ou responsáveis autorizados.
        </p>
      </div>
    </div>
  </div>

  <!-- Grid de Informações -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Data de Nascimento -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Data de Nascimento</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.data_nascimento.present? ? l(@aluno.data_nascimento, format: :long) : 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- Idade -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Idade</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.idade.present? ? "#{@aluno.idade} anos" : 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- CPF -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-cyan-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">CPF</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.cpf.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- RG -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">RG</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.rg.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Sexo -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Sexo</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.sexo.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Cor/Raça -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Cor/Raça</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.cor.presence || 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- Tipo Sanguíneo -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Tipo Sanguíneo</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.tipo_sanguinio.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Cidade -->
    <% if @aluno.cidade.present? %>
      <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Cidade</span>
            <p class="text-base font-bold text-gray-900 truncate"><%= @aluno.cidade.nome rescue 'Não informada' %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Observações PCD (se existir) -->
  <% if @aluno.observacoes_pcd.present? %>
    <div class="mt-6 bg-white rounded-lg p-4 border-l-4 border-purple-500">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <h4 class="text-sm font-semibold text-purple-800 uppercase tracking-wide mb-2">Observações sobre PCD</h4>
          <p class="text-gray-700 whitespace-pre-line leading-relaxed"><%= @aluno.observacoes_pcd %></p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Rodapé com informações de cadastro -->
  <div class="mt-6 pt-4 border-t border-gray-300">
    <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-gray-500">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Cadastrado em: <strong><%= l(@aluno.created_at, format: :short) %></strong></span>
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span>Última atualização: <strong><%= l(@aluno.updated_at, format: :short) %></strong></span>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Redefinição de Senha -->
<dialog id="reset_password_modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-xl mb-2 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
      Redefinir Senha do Aluno
    </h3>
    <p class="text-gray-600 mb-4">Digite uma nova senha para <strong><%= @aluno.nome %></strong></p>
    
    <%= form_with(model: @aluno, url: escola_aluno_path(@escola, @aluno), method: :patch, class: "space-y-4") do |f| %>
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-semibold">Nova Senha</span>
        </label>
        <%= f.password_field :password, class: "input input-bordered w-full", placeholder: "Digite a nova senha", autocomplete: "new-password" %>
      </div>
      
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-semibold">Confirmar Nova Senha</span>
        </label>
        <%= f.password_field :password_confirmation, class: "input input-bordered w-full", placeholder: "Confirme a nova senha", autocomplete: "new-password" %>
      </div>
      
      <div class="alert alert-warning">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span class="text-sm">A senha será alterada imediatamente. Informe o aluno sobre a nova senha.</span>
      </div>
      
      <div class="modal-action">
        <button type="button" class="btn" onclick="reset_password_modal.close()">Cancelar</button>
        <%= f.submit "Redefinir Senha", class: "btn btn-warning" %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>Fechar</button>
  </form>
</dialog>

<!-- Modal de Regeneração de Matrícula -->
<dialog id="regenerate_matricula_modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-xl mb-2 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Gerar Nova Matrícula
    </h3>
    <p class="text-gray-600 mb-4">Tem certeza que deseja gerar uma nova matrícula para <strong><%= @aluno.nome %></strong>?</p>
    
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
      <div class="flex items-start">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-600 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <h4 class="font-semibold text-yellow-800 mb-1">Atenção!</h4>
          <ul class="text-sm text-yellow-700 space-y-1 list-disc list-inside">
            <li>A matrícula atual será <strong>substituída permanentemente</strong></li>
            <li>O aluno precisará usar a <strong>nova matrícula para fazer login</strong></li>
            <li>Esta ação <strong>não pode ser desfeita</strong></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 rounded-lg p-4 mb-4 border border-blue-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-gray-600 font-medium uppercase tracking-wide mb-1">Matrícula Atual</p>
          <p class="text-lg font-bold text-gray-800"><%= @aluno.matricula.presence || 'Não definida' %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        <div>
          <p class="text-xs text-gray-600 font-medium uppercase tracking-wide mb-1">Nova Matrícula</p>
          <p class="text-lg font-bold text-purple-600">Será gerada automaticamente</p>
        </div>
      </div>
    </div>
    
    <%= form_with(url: regenerate_matricula_escola_aluno_path(@escola, @aluno), method: :patch, class: "space-y-4") do |f| %>
      <div class="modal-action">
        <button type="button" class="btn" onclick="regenerate_matricula_modal.close()">Cancelar</button>
        <%= f.submit "Confirmar e Gerar Nova Matrícula", class: "btn bg-purple-500 hover:bg-purple-600 text-white border-none" %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>Fechar</button>
  </form>
</dialog>
      </main>
    </div>
  </div>
</div>