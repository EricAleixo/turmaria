<% content_for :title, "Detalhes do Aluno" %>

<div class="drawer lg:drawer-open bg-gray-100">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />
  
  <div class="drawer-content flex flex-col">
    <div class="w-full p-6">
      <div class="flex items-center mb-6 lg:hidden">
        <label for="my-drawer" class="btn btn-square btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <h1 class="text-xl font-bold ml-2">Dashboard</h1>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <div class="flex items-center mb-6">
          <div class="flex items-center">
            <%= link_to escola_alunos_path(@escola), class: "flex items-center text-green-600 hover:text-green-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Voltar para Alunos
            <% end %>
          </div>

          <% if @aluno.turma.present? %>
            <%= link_to escola_turma_path(@escola, @aluno.turma), class: "ml-4 flex items-center text-green-600 hover:text-green-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.5 13a3.5 3.5 0 11-7 0 3.5 3.5 0 017 0z" />
              </svg>
              Ir para Turma
            <% end %>
          <% end %>
        </div>

        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Detalhes do Aluno</h1>
          <p class="text-gray-600">Visualize e gerencie as informações completas do aluno</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <div class="flex flex-col items-center text-center">
              <div class="avatar placeholder mb-4">
                <div class="bg-green-500 text-white rounded-full w-24 h-24 relative ring-4 ring-green-500/20">
                  <span class="text-3xl font-bold absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                    <%= @aluno.nome.present? ? @aluno.nome.first.upcase : 'A' %>
                  </span>
                </div>
              </div>
              
              <h2 class="text-2xl font-bold text-gray-900 mb-2">
                <%= @aluno.nome.presence || 'Nome não informado' %>
              </h2>
              <p class="text-gray-600 mb-4">ID: <%= @aluno.id.to_s.first(8) %></p>
              
              <div class="flex items-center gap-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Usuário Ativo
              </div>
            </div>
          </div>
          
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Contato
            </h3>
            <div class="space-y-4">
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  Email
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.email.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                  </svg>
                  Telefone
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.telefone.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  Responsável 1
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.responsavel_1.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                  </svg>
                  Telefone Responsável 1
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.telefone_responsavel_1.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  Responsável 2
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.responsavel_2.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" />
                  </svg>
                  Telefone Responsável 2
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.telefone_responsavel_2.presence || 'Não informado' %></p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg flex flex-col justify-between">
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Ações
              </h3>
              
              <div class="space-y-3">
                <% if @turma %>
                  <%= link_to "Editar Aluno", edit_escola_turma_aluno_path(@escola, @turma, @aluno), class: "w-full btn bg-yellow-500 hover:bg-yellow-600 text-white border-none" %>
                  <%= link_to "Excluir Aluno", escola_turma_aluno_path(@escola, @turma, @aluno), 
                    data: { 
                      confirm: "Tem certeza que deseja excluir este aluno?",
                      turbo_method: :delete 
                    }, 
                    class: "w-full btn bg-red-500 hover:bg-red-600 text-white border-none" %>
                <% else %>
                  <%= link_to "Editar Aluno", edit_escola_aluno_path(@escola, @aluno), class: "w-full btn bg-yellow-500 hover:bg-yellow-600 text-white border-none" %>
                  <%= link_to "Excluir Aluno", escola_aluno_path(@escola, @aluno), 
                    data: { 
                      confirm: "Tem certeza que deseja excluir este aluno?",
                      turbo_method: :delete 
                    }, 
                    class: "w-full btn bg-red-500 hover:bg-red-600 text-white border-none" %>
                <% end %>
              </div>
            </div>
            
            <div class="mt-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Informações
              </h3>
              
              <div class="space-y-4">
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">ID do Aluno</span>
                  <span class="text-gray-900 font-mono text-sm">#<%= @aluno.id.to_s.first(8) %></span>
                </div>
                
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">Membro desde</span>
                  <span class="text-gray-900"><%= @aluno.created_at.strftime("%d/%m/%Y %H:%M") %></span>
                </div>
                
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">Última atualização</span>
                  <span class="text-gray-900"><%= @aluno.updated_at.strftime("%d/%m/%Y %H:%M") %></span>
                </div>
                
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">Status</span>
                  <span class="badge badge-success text-white">Ativo</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Informações Adicionais
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-4 gap-x-8">
            <div class="space-y-2">
              <h4 class="text-md font-semibold text-gray-600 uppercase tracking-wide">Dados Pessoais</h4>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h8m-9 4h9m-11 4h13a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  Idade
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.idade.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" />
                  </svg>
                  CPF
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.cpf.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" />
                  </svg>
                  RG
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.rg.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                  Sexo
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.sexo.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 21h-2a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2v12a2 2 0 01-2 2z" />
                  </svg>
                  Cor
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.cor.presence || 'Não informado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.5C12 4.568 10.432 3 8.5 3S5 4.568 5 6.5c0 3.5 7 12.5 7 12.5s7-9 7-12.5C19 4.568 17.432 3 15.5 3S12 4.568 12 6.5z" />
                  </svg>
                  Tipo Sanguíneo
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.tipo_sanguinio.presence || 'Não informado' %></p>
              </div>
            </div>

            <div class="space-y-2">
              <h4 class="text-md font-semibold text-gray-600 uppercase tracking-wide">Dados Acadêmicos</h4>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 1.956-1.077 3.5-3 3.5s-3-1.544-3-3.5m6 0C12 9.044 10.923 7.5 9 7.5S6 9.044 6 11m6 0H6m0 0a3 3 0 00-3 3v2a3 3 0 003 3h6a3 3 0 003-3v-2a3 3 0 00-3-3m-6 0H6z" />
                  </svg>
                  Turma
                </span>
                <p class="text-gray-900 font-medium"><%= @aluno.turma.present? ? @aluno.turma.nome : 'Não alocado' %></p>
              </div>
              <div>
                <span class="text-gray-500 text-base flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                  </svg>
                  Escola
                </span>
                <p class="text-gray-900 font-medium"><%= @escola.nome %></p>
              </div>
              
              <%# Código para Necessidades Especiais %>
              <div class="mt-8">
                <h4 class="text-md font-semibold text-gray-600 uppercase tracking-wide">Necessidades Especiais</h4>
                <% if @aluno.necessidades_especiais_tipo.present? || @aluno.observacoes_pcd.present? %>
                  <% if @aluno.necessidades_especiais_tipo.present? %>
                    <div>
                      <span class="text-gray-500 text-base flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-gray-400">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                        Tipo
                      </span>
                      <div class="flex flex-wrap gap-2 mt-2">
                        <% @aluno.necessidades_especiais_tipo.each do |tipo| %>
                          <span class="badge badge-info text-white"><%= tipo %></span>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div>
                      <span class="text-gray-500 text-base flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-gray-400">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                        Tipo
                      </span>
                      <span class="text-gray-900 font-medium">Nenhuma</span>
                    </div>
                  <% end %>
                  
                  <% if @aluno.observacoes_pcd.present? %>
                    <div class="mt-4">
                      <span class="text-gray-500 text-base flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.832 4.432c.325 2.053 2.553 3.5 4.832 3.5s4.507-1.447 4.832-3.5m0 0a1 1 0 001.336-1.336 1 1 0 00-1.336-1.336 1 1 0 00-1.336 1.336 1 1 0 001.336 1.336zm-4.832 0a1 1 0 001.336-1.336 1 1 0 00-1.336-1.336 1 1 0 00-1.336 1.336 1 1 0 001.336 1.336z" />
                        </svg>
                        Observações
                      </span>
                      <p class="text-gray-900 font-medium whitespace-pre-wrap mt-1"><%= @aluno.observacoes_pcd %></p>
                    </div>
