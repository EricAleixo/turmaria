                          <span class="inline-flex items-center gap-1 px-2 py-1 bg-red-100 text-red-600 rounded-full text-xs font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                            Não enviado
                          </span>
                        </div>
                      <% end %>
                    </div>
                    <button class="btn btn-xs bg-cyan-500 hover:bg-cyan-600 text-white border-none whitespace-nowrap w-full sm:w-auto shadow-md hover:shadow-lg transition-all" onclick="document_modal_cpf.showModal()">
                      <% if @aluno.cpf_documento.attached? %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        Atualizar
                      <% else %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                        Enviar
                      <% end %>
                    </button>
                  </div>
                </div>
                
                <!-- Alerta de Documentos Pendentes -->
                <% 
                  documentos_pendentes = []
                  documentos_pendentes << "Comprovante de Residência" unless @aluno.comprovante_residencia.attached?
                  documentos_pendentes << "Histórico Acadêmico" unless @aluno.historico_academico.attached?
                  documentos_pendentes << "Documento CPF" unless @aluno.cpf_documento.attached?
                %>
                
                <% if documentos_pendentes.any? %>
                  <div class="mt-4 bg-amber-50 rounded-lg p-3 border border-amber-200">
                    <div class="flex items-start gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                      </svg>
                      <div class="flex-1">
                        <p class="text-xs font-semibold text-amber-800 mb-1">
                          <%= documentos_pendentes.size %> documento(s) pendente(s)
                        </p>
                        <p class="text-xs text-amber-700">
                          <%= documentos_pendentes.to_sentence %>
                        </p>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <div class="mt-4 bg-green-50 rounded-lg p-3 border border-green-200">
                    <div class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <p class="text-xs font-semibold text-green-800">
                        Todos os documentos foram enviados
                      </p>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- ========================================== -->
              <!-- MODAIS DE VISUALIZAÇÃO -->
              <!-- ========================================== -->

                  <!-- Modal Preview - Comprovante de Residência -->
                  <dialog id="modal_comprovante_preview" class="modal">
                    <div class="modal-box w-11/12 max-w-5xl h-[90vh] flex flex-col">
                      <div class="flex items-center justify-between mb-4 pb-3 border-b border-gray-200">
                        <h3 class="font-bold text-xl flex items-center gap-2">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                          </svg>
                          Comprovante de Residência
                        </h3>
                        <button onclick="modal_comprovante_preview.close()" class="btn btn-sm btn-circle btn-ghost">✕</button>
                      </div>

                      <% if @aluno.comprovante_residencia.attached? %>
                        <div class="flex-1 overflow-auto space-y-4">
                          <% @aluno.comprovante_residencia.each_with_index do |arquivo, index| %>
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                              <div class="flex items-center justify-between mb-3">
                                <span class="text-sm font-semibold text-gray-700">
                                  Arquivo <%= index + 1 %> de <%= @aluno.comprovante_residencia.count %>
                                </span>
                                <%= link_to "Baixar", url_for(arquivo), target: "_blank", class: "btn btn-sm btn-outline gap-2" %>
                              </div>
                              
                              <div class="w-full h-[60vh] border rounded-md overflow-hidden bg-white">
                                <iframe
                                  src="<%= url_for(arquivo) %>"
                                  class="w-full h-full"
                                  frameborder="0">
                                </iframe>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <div class="flex-1 flex items-center justify-center">
                          <div class="text-center p-8">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            <h4 class="text-xl font-bold text-gray-700 mb-2">Nenhum documento anexado</h4>
                            <p class="text-gray-500 mb-4">Ainda não há comprovante de residência cadastrado</p>
                            <button onclick="modal_comprovante_preview.close(); document_modal_comprovante.showModal()" class="btn btn-primary">
                              Enviar Documento
                            </button>
                          </div>
                        </div>
                      <% end %>
                    </div>
                    <form method="dialog" class="modal-backdrop">
                      <button>Fechar</button>
                    </form>
                  </dialog>

                <!-- Modal Preview - Histórico Acadêmico -->
                <dialog id="modal_historico_preview" class="modal">
                  <div class="modal-box w-11/12 max-w-5xl h-[90vh] flex flex-col">
                    <div class="flex items-center justify-between mb-4 pb-3 border-b border-gray-200">
                      <h3 class="font-bold text-xl flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Histórico Acadêmico
                      </h3>
                      <button onclick="modal_historico_preview.close()" class="btn btn-sm btn-circle btn-ghost">✕</button>
                    </div>

                    <% if @aluno.historico_academico.attached? %>
                      <div class="flex-1 overflow-auto">
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                          <div class="flex items-center justify-between mb-3">
                            <span class="text-sm font-semibold text-gray-700">Documento do Histórico</span>
                            <%= link_to "Baixar", url_for(@aluno.historico_academico), target: "_blank", class: "btn btn-sm btn-outline gap-2" %>
                          </div>
                          
                          <div class="w-full h-[70vh] border rounded-md overflow-hidden bg-white">
                            <iframe
                              src="<%= url_for(@aluno.historico_academico) %>"
                              class="w-full h-full"
                              frameborder="0">
                            </iframe>
                          </div>
                        </div>
                      </div>
                    <% else %>
                      <div class="flex-1 flex items-center justify-center">
                        <div class="text-center p-8">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                          </svg>
                          <h4 class="text-xl font-bold text-gray-700 mb-2">Nenhum documento anexado</h4>
                          <p class="text-gray-500 mb-4">Ainda não há histórico acadêmico cadastrado</p>
                          <button onclick="modal_historico_preview.close(); document_modal_historico.showModal()" class="btn btn-primary">
                            Enviar Documento
                          </button>
                        </div>
                      </div>
                    <% end %>
                  </div>
                  <form method="dialog" class="modal-backdrop">
                    <button>Fechar</button>
                  </form>
                </dialog>

              <!-- Modal Preview - CPF Documento -->
              <dialog id="modal_cpf_preview" class="modal">
                <div class="modal-box w-11/12 max-w-5xl h-[90vh] flex flex-col">
                  <div class="flex items-center justify-between mb-4 pb-3 border-gray-200">
                    <h3 class="font-bold text-xl flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                      </svg>
                      Documento CPF
                    </h3>
                    <button onclick="modal_cpf_preview.close()" class="btn btn-sm btn-circle btn-ghost">✕</button>
                  </div>

                  <% if @aluno.cpf_documento.attached? %>
                    <div class="flex-1 overflow-auto space-y-4">
                      <% @aluno.cpf_documento.each_with_index do |arquivo, index| %>
                        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                          <div class="flex items-center justify-between mb-3">
                            <span class="text-sm font-semibold text-gray-700">
                              Arquivo <%= index + 1 %> de <%= @aluno.cpf_documento.count %>
                            </span>
                            <%= link_to "Baixar", url_for(arquivo), target: "_blank", class: "btn btn-sm btn-outline gap-2" %>
                          </div>
                          
                          <div class="w-full h-[60vh] border rounded-md overflow-hidden bg-white">
                            <iframe
                              src="<%= url_for(arquivo) %>"
                              class="w-full h-full"
                              frameborder="0">
                            </iframe>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="flex-1 flex items-center justify-center">
                      <div class="text-center p-8">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <h4 class="text-xl font-bold text-gray-700 mb-2">Nenhum documento anexado</h4>
                        <p class="text-gray-500 mb-4">Ainda não há documento CPF cadastrado</p>
                        <button onclick="modal_cpf_preview.close(); document_modal_cpf.showModal()" class="btn btn-primary">
                          Enviar Documento
                        </button>
                      </div>
                    </div>
                  <% end %>
                </div>
                <form method="dialog" class="modal-backdrop">
                  <button>Fechar</button>
                </form>
              </dialog>
            </div>
          </div>
        </div>
        
        <!-- Modais de Documentos -->
        <dialog id="document_modal_comprovante" class="modal">
          <div class="modal-box w-11/12 max-w-4xl">
            <h3 class="font-bold text-lg mb-4">Comprovante de Residência</h3>

            <% if @aluno.comprovante_residencia.attached? %>
               <% comprovante = @aluno.comprovante_residencia.first %>

                <div class="w-full h-[70vh] border rounded-md overflow-hidden">
                  <iframe
                    src="<%= url_for(comprovante) %>"
                    class="w-full h-full"
                    frameborder="0">
                  </iframe>
            </div>

            <div class="modal-action">
              <%= link_to "Baixar PDF",
                url_for(comprovante),
                target: "_blank",
                class: "btn btn-outline" %>

              <button type="button" class="btn" onclick="document_modal_comprovante.close()">
                Fechar
              </button>
            </div>

          <% else %>
            <p class="mb-4 text-sm text-gray-600">
              Nenhum comprovante de residência foi enviado ainda.
            </p>

            <% if @aluno.turma.present? %>
              <%= form_with(
                model: @aluno,
                url: escola_turma_aluno_path(@escola, @aluno.turma, @aluno),
                method: :patch,
                class: "space-y-4"
              ) do |f| %>

                <div class="form-control w-full">
                  <%= f.file_field :comprovante_residencia,
                    multiple: true,
                    accept: "application/pdf",
                    class: "file-input file-input-bordered w-full" %>
                </div>

                <div class="modal-action">
                  <button type="button" class="btn" onclick="document_modal_comprovante.close()">
                    Cancelar
                  </button>
                  <%= f.submit "Enviar Documento", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% end %>
          <% end %>
  </div>

        <form method="dialog" class="modal-backdrop">
          <button>Fechar</button>
        </form>
      </dialog>

        
        <dialog id="document_modal_historico" class="modal">
          <div class="modal-box">
            <h3 class="font-bold text-lg mb-4">Histórico Acadêmico</h3>
            <p class="mb-4">Faça upload do histórico acadêmico do aluno (formato PDF).</p>
            
           <% if @aluno.turma.present? %>
              <%= form_with(model: @aluno, url: escola_turma_aluno_path(@escola, @aluno.turma, @aluno), method: :patch, class: "space-y-4") do |f| %>
                <div class="form-control w-full">
                  <%= f.file_field :historico_academico, class: "file-input file-input-bordered w-full", accept: "application/pdf" %>
                </div>
                
                <div class="modal-action">
                  <button type="button" class="btn" onclick="document_modal_historico.close()">Cancelar</button>
                  <%= f.submit "Enviar Documento", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% else %>
              <p>Aluno ainda não está vinculado a nenhuma turma.</p>
            <% end %>

          </div>
          <form method="dialog" class="modal-backdrop">
            <button>Fechar</button>
          </form>
        </dialog>

        <!-- Modal de Upload - CPF Documento -->
        <dialog id="document_modal_cpf" class="modal">
          <div class="modal-box">
            <h3 class="font-bold text-lg mb-4">Documento CPF</h3>
            <p class="mb-4">Faça upload do documento CPF do aluno (formato PDF).</p>
            
            <% if @aluno.turma.present? %>
              <%= form_with(model: @aluno, url: escola_turma_aluno_path(@escola, @aluno.turma, @aluno), method: :patch, class: "space-y-4") do |f| %>
                <div class="form-control w-full">
                  <%= f.file_field :cpf_documento, multiple: true, class: "file-input file-input-bordered w-full", accept: "application/pdf" %>
                </div>
                
                <div class="modal-action">
                  <button type="button" class="btn" onclick="document_modal_cpf.close()">Cancelar</button>
                  <%= f.submit "Enviar Documento", class: "btn btn-primary" %>
                </div>
              <% end %>
            <% else %>
              <p>Aluno ainda não está vinculado a nenhuma turma.</p>
            <% end %>

          </div>
          <form method="dialog" class="modal-backdrop">
            <button>Fechar</button>
          </form>
        </dialog>
        <div class="w-full bg-gradient-to-br from-slate-50 to-gray-100 rounded-xl p-6 border-2 border-gray-200 shadow-xl">
  <!-- Cabeçalho da Seção -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-green-600 rounded-xl flex items-center justify-center shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-gray-900">Informações Pessoais</h3>
        <p class="text-sm text-gray-600">Dados completos do estudante</p>
      </div>
    </div>
    
    <!-- Botões de Ação -->
    <div class="flex items-center gap-2">
      <%= link_to edit_escola_aluno_path(@escola, @aluno), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white border-none shadow-md transition-all hover:shadow-lg" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="hidden sm:inline">Editar</span>
      <% end %>
      
      <%= link_to escola_aluno_path(@escola, @aluno), method: :delete, data: { confirm: "Tem certeza que deseja excluir este aluno? Esta ação não pode ser desfeita." }, class: "btn btn-sm bg-red-500 hover:bg-red-600 text-white border-none shadow-md transition-all hover:shadow-lg" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        <span class="hidden sm:inline">Excluir</span>
      <% end %>
    </div>
  </div>

  <!-- Credenciais de Acesso - Destaque Especial -->
  <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-xl p-4 md:p-6 mb-6 shadow-lg border-2 border-blue-200 overflow-hidden">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-4">
    <div class="w-10 h-10 md:w-12 md:h-12 bg-blue-500 rounded-xl flex items-center justify-center shadow-md flex-shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-7 md:w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
      </svg>
    </div>
    <div class="flex-1 min-w-0 w-full">
      <h4 class="text-gray-800 font-bold text-base md:text-lg break-words">Credenciais de Acesso ao Sistema</h4>
      <p class="text-gray-600 text-xs md:text-sm break-words">Informações utilizadas pelo aluno para login</p>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 overflow-hidden">
    <!-- Matrícula (Login) -->
    <div class="bg-white rounded-lg p-3 md:p-4 border-2 border-blue-200 hover:border-blue-300 hover:shadow-md transition-all overflow-hidden">
      <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
        <span class="text-xs font-semibold text-blue-700 uppercase tracking-wide flex items-center gap-1 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="whitespace-nowrap">Matrícula</span>
        </span>
        <div class="badge badge-sm bg-green-500 text-white border-none font-bold whitespace-nowrap flex-shrink-0">Usuário</div>
      </div>
      <div class="flex items-center gap-2 overflow-hidden">
        <p class="text-base md:text-xl lg:text-2xl font-bold text-gray-800 truncate flex-1 min-w-0"><%= @aluno.matricula.presence || 'Não definida' %></p>
        <div class="flex gap-1 flex-shrink-0">
          <button onclick="navigator.clipboard.writeText('<%= @aluno.matricula %>')" class="btn btn-xs bg-blue-500 hover:bg-blue-600 text-white border-none p-1 md:p-2" title="Copiar">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
          <button onclick="regenerate_matricula_modal.showModal()" class="btn btn-xs bg-purple-500 hover:bg-purple-600 text-white border-none p-1 md:p-2" title="Gerar">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </button>
        </div>
      </div>
    </div>
    
    <!-- Senha -->
    <div class="bg-white rounded-lg p-3 md:p-4 border-2 border-blue-200 hover:border-blue-300 hover:shadow-md transition-all overflow-hidden">
      <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
        <span class="text-xs font-semibold text-blue-700 uppercase tracking-wide flex items-center gap-1 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <span class="whitespace-nowrap">Senha</span>
        </span>
        <div class="badge badge-sm bg-amber-500 text-white border-none font-bold whitespace-nowrap flex-shrink-0">Protegida</div>
      </div>
      <div class="flex items-center gap-2 overflow-hidden">
        <p class="text-base md:text-lg lg:text-xl font-bold text-gray-800 flex-1">••••••••</p>
        <%= link_to "Redefinir", "#", class: "btn btn-xs bg-amber-500 hover:bg-amber-600 text-white border-none whitespace-nowrap flex-shrink-0 text-xs", onclick: "reset_password_modal.showModal(); return false;" %>
      </div>
    </div>
  </div>
  
  <!-- Alerta de Segurança -->
  <div class="mt-4 bg-amber-50 rounded-lg p-3 border border-amber-200 overflow-hidden">
    <div class="flex items-start gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <p class="text-xs text-amber-800 break-words flex-1 min-w-0">
        <strong class="font-semibold">Atenção:</strong> Estas credenciais são confidenciais. Apenas compartilhe com o aluno ou responsáveis autorizados.
      </p>
    </div>
  </div>
</div>

  <!-- Grid de Informações -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Data de Nascimento -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Data de Nascimento</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.data_nascimento.present? ? l(@aluno.data_nascimento, format: :long) : 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- Idade -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
