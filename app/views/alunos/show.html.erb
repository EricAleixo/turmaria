          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Idade</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.idade.present? ? "#{@aluno.idade} anos" : 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- CPF -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-cyan-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">CPF</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.cpf.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- RG -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">RG</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.rg.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Sexo -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Sexo</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.sexo.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Cor/Raça -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Cor/Raça</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.cor.presence || 'Não informada' %></p>
        </div>
      </div>
    </div>

    <!-- Tipo Sanguíneo -->
    <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Tipo Sanguíneo</span>
          <p class="text-base font-bold text-gray-900"><%= @aluno.tipo_sanguinio.presence || 'Não informado' %></p>
        </div>
      </div>
    </div>

    <!-- Cidade -->
    <% if @aluno.cidade.present? %>
      <div class="bg-white rounded-lg p-4 border border-gray-200 hover:shadow-md transition-all">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <span class="text-xs font-medium text-gray-600 uppercase tracking-wide block">Cidade</span>
            <p class="text-base font-bold text-gray-900 truncate"><%= @aluno.cidade.nome rescue 'Não informada' %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Observações PCD (se existir) -->
  <% if @aluno.observacoes_pcd.present? %>
    <div class="mt-6 bg-white rounded-lg p-4 border-l-4 border-purple-500">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <h4 class="text-sm font-semibold text-purple-800 uppercase tracking-wide mb-2">Observações sobre PCD</h4>
          <p class="text-gray-700 whitespace-pre-line leading-relaxed"><%= @aluno.observacoes_pcd %></p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Rodapé com informações de cadastro -->
  <div class="mt-6 pt-4 border-t border-gray-300">
    <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-gray-500">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Cadastrado em: <strong><%= l(@aluno.created_at, format: :short) %></strong></span>
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span>Última atualização: <strong><%= l(@aluno.updated_at, format: :short) %></strong></span>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Redefinição de Senha -->
<dialog id="reset_password_modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-xl mb-2 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
      Redefinir Senha do Aluno
    </h3>
    <p class="text-gray-600 mb-4">Digite uma nova senha para <strong><%= @aluno.nome %></strong></p>
    
    <%= form_with(model: @aluno, url: escola_aluno_path(@escola, @aluno), method: :patch, class: "space-y-4") do |f| %>
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-semibold">Nova Senha</span>
        </label>
        <%= f.password_field :password, class: "input input-bordered w-full", placeholder: "Digite a nova senha", autocomplete: "new-password" %>
      </div>
      
      <div class="form-control w-full">
        <label class="label">
          <span class="label-text font-semibold">Confirmar Nova Senha</span>
        </label>
        <%= f.password_field :password_confirmation, class: "input input-bordered w-full", placeholder: "Confirme a nova senha", autocomplete: "new-password" %>
      </div>
      
      <div class="alert alert-warning">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span class="text-sm">A senha será alterada imediatamente. Informe o aluno sobre a nova senha.</span>
      </div>
      
      <div class="modal-action">
        <button type="button" class="btn" onclick="reset_password_modal.close()">Cancelar</button>
        <%= f.submit "Redefinir Senha", class: "btn btn-warning" %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>Fechar</button>
  </form>
</dialog>

<!-- Modal de Regeneração de Matrícula -->
<dialog id="regenerate_matricula_modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-xl mb-2 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Gerar Nova Matrícula
    </h3>
    <p class="text-gray-600 mb-4">Tem certeza que deseja gerar uma nova matrícula para <strong><%= @aluno.nome %></strong>?</p>
    
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
      <div class="flex items-start">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-600 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <h4 class="font-semibold text-yellow-800 mb-1">Atenção!</h4>
          <ul class="text-sm text-yellow-700 space-y-1 list-disc list-inside">
            <li>A matrícula atual será <strong>substituída permanentemente</strong></li>
            <li>O aluno precisará usar a <strong>nova matrícula para fazer login</strong></li>
            <li>Esta ação <strong>não pode ser desfeita</strong></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 rounded-lg p-4 mb-4 border border-blue-200">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-gray-600 font-medium uppercase tracking-wide mb-1">Matrícula Atual</p>
          <p class="text-lg font-bold text-gray-800"><%= @aluno.matricula.presence || 'Não definida' %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        <div>
          <p class="text-xs text-gray-600 font-medium uppercase tracking-wide mb-1">Nova Matrícula</p>
          <p class="text-lg font-bold text-purple-600">Será gerada automaticamente</p>
        </div>
      </div>
    </div>
    
    <%= form_with(url: regenerate_matricula_escola_aluno_path(@escola, @aluno), method: :patch, class: "space-y-4") do |f| %>
      <div class="modal-action">
        <button type="button" class="btn" onclick="regenerate_matricula_modal.close()">Cancelar</button>
        <%= f.submit "Confirmar e Gerar Nova Matrícula", class: "btn bg-purple-500 hover:bg-purple-600 text-white border-none" %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>Fechar</button>
  </form>
</dialog>
      <!-- ========================================== -->
      <!-- SEÇÃO: DESEMPENHO ACADÊMICO -->
      <!-- ========================================== -->
      <% if @aluno.turma.present? && (@boletim_disciplinas.present? || @frequencia_por_disciplina.present?) %>
        <div class="w-full mt-8">
          <div class="bg-gradient-to-br from-indigo-50 to-purple-100 rounded-xl p-6 border-2 border-indigo-200 shadow-xl">
            <!-- Cabeçalho da Seção -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                </div>
                <div>
                  <h2 class="text-2xl font-bold text-gray-900">Desempenho Acadêmico</h2>
                  <p class="text-sm text-gray-600">Notas e frequências do ano letivo <%= @turma.ano_letivo.ano %></p>
                </div>
              </div>
            </div>

            <!-- ========================================== -->
            <!-- TABELA 1: NOTAS BIMESTRAIS -->
            <!-- ========================================== -->
            <% if @boletim_disciplinas.present? %>
              <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
                <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-4">
                  <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Boletim de Notas
                  </h3>
                </div>

                <div class="overflow-x-auto">
                  <table class="table w-full">
                    <thead class="bg-gray-100">
                      <tr>
                        <th class="text-left text-sm font-bold text-gray-700 p-4 whitespace-nowrap">Disciplina</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">1º Bim</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">2º Bim</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">3º Bim</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">4º Bim</th>
                        <th class="text-center text-sm font-bold text-indigo-700 p-4 whitespace-nowrap bg-indigo-50">Média Anual</th>
                        <th class="text-center text-sm font-bold text-purple-700 p-4 whitespace-nowrap bg-purple-50">Situação</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @boletim_disciplinas.each do |disciplina, avaliacoes_ordenadas| %>
                        <% 
                          # Organizar notas por bimestre
                          notas_por_bimestre = avaliacoes_ordenadas.index_by(&:bimestre)
                          
                          # Calcular média anual (soma das notas dos 4 bimestres / 4)
                          notas_array = (1..4).map { |bim| notas_por_bimestre[bim]&.nota_bimestre_final || 0.0 }
                          media_anual = notas_array.sum / 4.0
                          
                          # Determinar cor da média
                          media_class = if media_anual >= 6.0
                            'text-green-700 font-bold'
                          elsif media_anual >= 5.0
                            'text-yellow-600 font-bold'
                          else
                            'text-red-600 font-bold'
                          end
                          
                          # Determinar situação
                          situacao = if media_anual >= 6.0
                            { texto: 'Aprovado', class: 'badge-success' }
                          elsif media_anual >= 5.0
                            { texto: 'Recuperação', class: 'badge-warning' }
                          else
                            { texto: 'Reprovado', class: 'badge-error' }
                          end
                        %>
                        <tr class="hover:bg-gray-50 transition-colors border-b border-gray-200">
                          <td class="p-4">
                            <div class="flex items-center gap-2">
                              <div class="w-2 h-2 bg-indigo-500 rounded-full"></div>
                              <span class="font-semibold text-gray-800"><%= disciplina.nome %></span>
                            </div>
                          </td>
                          
                          <!-- Notas dos 4 Bimestres -->
                          <% (1..4).each do |bimestre| %>
                            <% nota = notas_por_bimestre[bimestre]&.nota_bimestre_final %>
                            <td class="text-center p-4">
                              <% if nota.present? %>
                                <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg <%= nota >= 6.0 ? 'bg-green-100 text-green-700' : nota >= 5.0 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %> font-bold text-base">
                                  <%= number_with_precision(nota, precision: 1) %>
                                </span>
                              <% else %>
                                <span class="text-gray-400 font-medium">—</span>
                              <% end %>
                            </td>
                          <% end %>
                          
                          <!-- Média Anual -->
                          <td class="text-center p-4 bg-indigo-50">
                            <span class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-indigo-200 <%= media_class %> text-lg">
                              <%= number_with_precision(media_anual, precision: 1) %>
                            </span>
                          </td>
                          
                          <!-- Situação -->
                          <td class="text-center p-4 bg-purple-50">
                            <span class="badge <%= situacao[:class] %> badge-lg font-bold">
                              <%= situacao[:texto] %>
                            </span>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>

                <!-- Rodapé com Legenda -->
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
                  <div class="flex flex-wrap items-center gap-4 text-xs text-gray-600">
                    <div class="flex items-center gap-2">
                      <div class="w-4 h-4 bg-green-100 rounded border border-green-300"></div>
                      <span>≥ 6.0 (Aprovado)</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="w-4 h-4 bg-yellow-100 rounded border border-yellow-300"></div>
                      <span>5.0 - 5.9 (Recuperação)</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="w-4 h-4 bg-red-100 rounded border border-red-300"></div>
                      <span>< 5.0 (Reprovado)</span>
                    </div>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-lg mb-6">
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <div>
                    <h4 class="font-bold text-yellow-800 mb-1">Notas não disponíveis</h4>
                    <p class="text-yellow-700 text-sm">Ainda não há notas lançadas para este aluno no ano letivo atual.</p>
                  </div>
                </div>
              </div>
            <% end %>

            <!-- ========================================== -->
            <!-- TABELA 2: FREQUÊNCIAS -->
            <!-- ========================================== -->
            <% if @frequencia_por_disciplina.present? %>
              <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <div class="bg-gradient-to-r from-green-500 to-emerald-600 px-6 py-4">
                  <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Registro de Frequência
                  </h3>
                </div>

                <div class="overflow-x-auto">
                  <table class="table w-full">
                    <thead class="bg-gray-100">
                      <tr>
                        <th class="text-left text-sm font-bold text-gray-700 p-4 whitespace-nowrap">Disciplina</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">Total de Aulas</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">Presenças</th>
                        <th class="text-center text-sm font-bold text-gray-700 p-4 whitespace-nowrap">Faltas</th>
                        <th class="text-center text-sm font-bold text-emerald-700 p-4 whitespace-nowrap bg-emerald-50">Frequência (%)</th>
                        <th class="text-center text-sm font-bold text-purple-700 p-4 whitespace-nowrap bg-purple-50">Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @frequencia_por_disciplina.each do |disciplina_id, dados_freq| %>
                        <% 
                          disciplina = Disciplina.find(disciplina_id)
                          total_aulas = dados_freq[:total_aulas]
                          total_faltas = dados_freq[:total_faltas]
                          total_presencas = total_aulas - total_faltas
                          frequencia_percentual = total_aulas > 0 ? ((total_presencas.to_f / total_aulas) * 100).round(1) : 0.0
                          
                          # Determinar status e cor
                          status = if frequencia_percentual >= 75.0
                            { texto: 'Regular', class: 'badge-success', icon: 'check' }
                          elsif frequencia_percentual >= 60.0
                            { texto: 'Atenção', class: 'badge-warning', icon: 'alert' }
                          else
                            { texto: 'Crítico', class: 'badge-error', icon: 'x' }
                          end
                          
                          freq_class = if frequencia_percentual >= 75.0
                            'text-green-700 font-bold'
                          elsif frequencia_percentual >= 60.0
                            'text-yellow-600 font-bold'
                          else
                            'text-red-600 font-bold'
                          end
                        %>
                        <tr class="hover:bg-gray-50 transition-colors border-b border-gray-200">
                          <td class="p-4">
                            <div class="flex items-center gap-2">
                              <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                              <span class="font-semibold text-gray-800"><%= disciplina.nome %></span>
                            </div>
                          </td>
                          
                          <!-- Total de Aulas -->
                          <td class="text-center p-4">
                            <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-blue-100 text-blue-700 font-bold text-base">
                              <%= total_aulas %>
                            </span>
                          </td>
                          
                          <!-- Presenças -->
                          <td class="text-center p-4">
                            <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-green-100 text-green-700 font-bold text-base">
                              <%= total_presencas %>
                            </span>
                          </td>
                          
                          <!-- Faltas -->
                          <td class="text-center p-4">
                            <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-red-100 text-red-700 font-bold text-base">
                              <%= total_faltas %>
                            </span>
                          </td>
                          
                          <!-- Frequência (%) -->
                          <td class="text-center p-4 bg-emerald-50">
                            <div class="flex flex-col items-center gap-1">
                              <span class="inline-flex items-center justify-center w-16 h-16 rounded-lg bg-emerald-200 <%= freq_class %> text-lg">
                                <%= frequencia_percentual %>%
                              </span>
                              <div class="w-full bg-gray-200 rounded-full h-2 max-w-[100px]">
                                <div class="<%= frequencia_percentual >= 75 ? 'bg-green-500' : frequencia_percentual >= 60 ? 'bg-yellow-500' : 'bg-red-500' %> h-2 rounded-full transition-all" style="width: <%= [frequencia_percentual, 100].min %>%"></div>
                              </div>
                            </div>
                          </td>
                          
                          <!-- Status -->
                          <td class="text-center p-4 bg-purple-50">
                            <span class="badge <%= status[:class] %> badge-lg font-bold flex items-center gap-1 mx-auto w-fit">
                              <% if status[:icon] == 'check' %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                              <% elsif status[:icon] == 'alert' %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                              <% else %>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                              <% end %>
                              <%= status[:texto] %>
                            </span>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>

                <!-- Rodapé com Informações -->
                <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
                  <div class="flex flex-wrap items-center gap-6">
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span><strong>Frequência mínima exigida:</strong> 75%</span>
                    </div>
                    <div class="flex items-center gap-4 text-xs text-gray-600">
                      <div class="flex items-center gap-2">
                        <div class="w-4 h-4 bg-green-100 rounded border border-green-300"></div>
                        <span>≥ 75% (Regular)</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-4 h-4 bg-yellow-100 rounded border border-yellow-300"></div>
                        <span>60-74% (Atenção)</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="w-4 h-4 bg-red-100 rounded border border-red-300"></div>
                        <span>< 60% (Crítico)</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-lg">
                <div class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <div>
                    <h4 class="font-bold text-yellow-800 mb-1">Frequências não disponíveis</h4>
                    <p class="text-yellow-700 text-sm">Ainda não há registros de frequência para este aluno no ano letivo atual.</p>
                  </div>
                </div>
              </div>
            <% end %>

          </div>
        </div>
      <% end %>
      </main>
    </div>
  </div>
</div>
