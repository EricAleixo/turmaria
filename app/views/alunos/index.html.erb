<%= content_for :page_title, "Alunos" %>
<div class="drawer lg:drawer-open bg-gradient-to-br from-slate-50 via-emerald-50 to-teal-50 min-h-screen">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    
    <div class="w-full p-4">
      <!-- Mobile Header with Gradient -->
      <div class="flex items-center mb-6 lg:hidden bg-gradient-to-r from-emerald-600 to-teal-600 text-white rounded-2xl p-4 shadow-lg">
        <label for="my-drawer" class="btn btn-square btn-ghost text-white hover:bg-white/20">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <% if @turma %>
          <h1 class="text-xl font-bold ml-2">Alunos - <%= @turma.nome %></h1>
        <% elsif @escola %>
          <h1 class="text-xl font-bold ml-2">Alunos - <%= @escola.nome %></h1>
        <% else %>
          <h1 class="text-xl font-bold ml-2">Todos os alunos</h1>
        <% end %>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <!-- Enhanced Breadcrumbs -->
        <div class="breadcrumbs text-sm mb-6">
          <ul class="bg-white/60 backdrop-blur-sm rounded-full px-6 py-3 shadow-lg border border-white/20">
            <li><%= link_to "Escolas", escolas_path, class: "text-emerald-600 hover:text-emerald-800 font-medium transition-colors" %></li>
            <% if @escola%>
              <li><%= link_to @escola.nome, escola_path(@escola), class: "text-emerald-600 hover:text-emerald-800 font-medium transition-colors" %></li>
            <%end%>
            <% if @turma %>
              <li><%= link_to @turma.nome, escola_turma_path(@escola, @turma), class: "text-emerald-600 hover:text-emerald-800 font-medium transition-colors" %></li>
            <% end %>
            <li class="text-slate-500 font-medium">Alunos</li>
          </ul>
        </div>

        <!-- Success Alert with Gradient -->
        <% if notice.present? %>
          <div class="alert bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 shadow-xl mb-6 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="font-medium"><%= notice %></span>
          </div>
        <% end %>

        <!-- Premium Card Container -->
       <div class="bg-white/80 backdrop-blur-sm p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-white/20">
  <div class="bg-gradient-to-r from-blue-500 to-green-300 text-white rounded-2xl p-6 mb-8 shadow-xl">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      
      <div class="flex flex-col items-start space-y-2 flex-grow">
        <h1 class="text-2xl lg:text-4xl font-bold">
          <% if @turma %>
            Alunos da Turma <%= @turma.nome %>
          <% elsif @escola %>
            Alunos da Escola <%= @escola.nome %>
          <% else %>
            Todos os Alunos
          <% end %>
        </h1>
        <div class="badge badge-lg bg-white/20 text-white border-white/30">
          <%= @alunos.count %> <%= @alunos.count == 1 ? 'aluno' : 'alunos' %>
        </div>
      </div>

      <div class="flex flex-row gap-3 flex-shrink-0">
        <% if @escola %>
          <%= link_to new_escola_aluno_path(@escola), class: "btn btn-md bg-white text-blue-600 hover:bg-blue-50 border-0 shadow-lg hover:scale-105 transition-all duration-300" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo Aluno
          <% end %>
        <% end %>
        <%= link_to escolas_path, class: "btn btn-md bg-blue-600 text-white hover:bg-blue-700 border-0 shadow-lg hover:scale-105 transition-all duration-300" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          Escolas
        <% end %>
      </div> 
    </div>
  </div>
          
          <% if @alunos.empty? %>
            <!-- Enhanced Empty State -->
            <div class="text-center py-16 bg-gradient-to-br from-slate-50 to-blue-50 rounded-3xl border-2 border-dashed border-slate-200">
              <div class="max-w-md mx-auto">
                <div class="text-6xl mb-4">👨‍🎓</div>
                <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum aluno encontrado</h3>
                <p class="text-slate-500 mb-6">Não existem alunos cadastrados para esta escola ou turma.</p>
                <% if @escola %>
                  <%= link_to new_escola_aluno_path(@escola), class: "btn btn-lg bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 rounded-full" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mr-2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Adicionar Aluno
                  <% end %>
                <% end %>
              </div>
            </div>
          <% else %>
            <!-- Tabela para desktop -->
            <div class="hidden md:block overflow-x-auto">
              <table class="table w-full shadow-xl rounded-xl overflow-hidden">
                <thead>
                  <tr class="bg-gradient-to-r from-blue-500 to-green-300 text-white">
                    <th class="rounded-tl-xl">Nome</th>
                    <th>Escola</th>
                    <th>Nascimento</th>
                    <th>Matrícula</th>
                    <th>Status</th>
                    <th>Turma</th>
                    <th class="rounded-tr-xl">Ações</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  <% @alunos.each do |aluno| %>
                    <% if aluno.turma.present? %>
                      <tr class="hover:bg-blue-50 transition-all duration-300 border-b border-gray-200 group">
                        <td class="py-4">
                          <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                              <div class="bg-gradient-to-br from-blue-400 to-green-300 text-white rounded-full w-10 h-10 relative font-bold">
                                <span class="absolute top-1/2 left-1/2 -translate-1/2"><%= aluno.nome.first.upcase %></span>
                              </div>
                            </div>
                            <span class="font-bold text-slate-700"><%= aluno.nome %></span>
                          </div>
                        </td>
                        <td>
                          <div class="badge badge-lg bg-gradient-to-r from-blue-400 to-green-300 text-white border-0 font-medium">
                            Escola
                          </div>
                        </td>
                        <td class="text-slate-600 font-medium"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></td>
                        <td>
                            <div class="badge badge-outline badge-lg border-blue-300 text-blue-600 font-mono 
                            max-w-xs overflow-hidden whitespace-nowrap text-ellipsis">
                            <%= aluno.matricula.present? ? aluno.matricula : "Matrícula" %>
                            </div>
                        </td>
                        <td>
                          <div class="badge badge-lg bg-gradient-to-r from-blue-400 to-green-300 text-white border-0 shadow-lg font-bold">
                            Alocado 
                          </div>
                        </td>
                        <td class="text-slate-600 font-medium"><%= aluno.turma.nome %></td>
                        <td>
                          <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                            <%= link_to escola_turma_aluno_path(aluno.escola, aluno.turma, aluno), class: "btn btn-sm btn-circle bg-gradient-to-r from-blue-500 to-green-300 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Ver aluno" do %>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                              </svg>
                            <% end %>
                            <%= link_to edit_escola_turma_aluno_path(aluno.escola, aluno.turma, aluno), class: "btn btn-sm btn-circle bg-gradient-to-r from-amber-500 to-orange-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Editar aluno" do %>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                              </svg>
                            <% end %>
                            <%= button_to escola_turma_aluno_path(aluno.escola, aluno.turma, aluno), method: :delete, class: "btn btn-sm btn-circle bg-gradient-to-r from-red-500 to-pink-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Excluir aluno", data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } do %>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                              </svg>
                            <% end %>
                          </div>
                        </td>
                      </tr>
                    <% else %>
                      <tr class="hover:bg-blue-50 transition-all duration-300 border-b border-gray-200 group">
                      <td class="py-4">
                          <div class="flex items-center gap-3">
                              <div class="avatar placeholder">
                                  <div class="bg-gradient-to-br from-slate-400 to-gray-500 text-white rounded-full w-10 h-10 relative font-bold">
                                      <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"><%= aluno.nome.first.upcase %></span>
                                  </div>
                              </div>
                              <span class="font-bold text-slate-700"><%= aluno.nome %></span>
                          </div>
                      </td>

                      <td class="max-w-xs overflow-hidden whitespace-nowrap text-ellipsis">
                          <div class="badge badge-lg bg-gradient-to-r from-slate-400 to-gray-500 text-white border-0 font-medium">
                              <%= aluno.escola.present? ? aluno.escola.nome : "Sem Escola" %>
                          </div>
                      </td>

                      <td class="text-slate-600 font-medium max-w-[150px] overflow-hidden whitespace-nowrap text-ellipsis">
                          <%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %>
                      </td>

                      <td class="max-w-[150px] overflow-hidden whitespace-nowrap text-ellipsis">
                          <div class="badge badge-outline badge-lg border-slate-300 text-slate-600 font-mono">
                              <%= aluno.matricula.present? ? aluno.matricula : "Matrícula" %>
                          </div>
                      </td>

                      <td>
                          <div>
                            <div class="badge badge-lg bg-gradient-to-r from-slate-500 to-gray-600 text-white border-0 shadow-lg font-bold max-w-xs overflow-hidden whitespace-nowrap text-ellipsis">
                                Não Alocado
                            </div>
                          </div>
                      </td>
                      <td class="text-slate-400 font-medium max-w-[150px] overflow-hidden whitespace-nowrap text-ellipsis">Sem turma</td>
                      
                      <td>
                          <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                              <% if aluno.escola.present? %>
                                  <%= link_to escola_aluno_path(aluno.escola, aluno), class: "btn btn-sm btn-circle bg-gradient-to-r from-blue-500 to-green-300 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Ver aluno" do %>
                                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                      </svg>
                                  <% end %>
                                  <%= link_to edit_escola_aluno_path(aluno.escola, aluno), class: "btn btn-sm btn-circle bg-gradient-to-r from-amber-500 to-orange-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Editar aluno" do %>
                                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                      </svg>
                                  <% end %>
                                  <%= button_to escola_aluno_path(aluno.escola, aluno), method: :delete, class: "btn btn-sm btn-circle bg-gradient-to-r from-red-500 to-pink-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Excluir aluno", data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } do %>
                                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                      </svg>
                                  <% end %>
                              <% else %>
                                  <div class="badge badge-ghost text-slate-400">
                                      Sem escola
                                  </div>
                              <% end %>
                          </div>
                      </td>
                  </tr>
                    <% end %>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <!-- Cards para mobile -->
            <div class="grid grid-cols-1 gap-4 md:hidden">
              <% @alunos.each do |aluno| %>
                <% if aluno.turma.present? %>
                  <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden border border-blue-100">
                    <div class="card-body p-4">
                      <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                          <div class="avatar placeholder">
                            <div class="bg-gradient-to-br from-blue-400 to-green-300 text-white rounded-full w-10 h-10 relative font-bold">
                                <span class="absolute top-1/2 left-1/2 -translate-1/2"><%= aluno.nome.first.upcase %></span>
                              </div>
                          </div>
                          <div>
                            <h2 class="card-title text-slate-700"><%= aluno.nome %></h2>
                            <div class="badge badge-lg bg-gradient-to-r from-blue-400 to-green-300 text-white border-0 shadow-lg font-bold mt-1">
                              Alocado
                            </div>
                          </div>
                        </div>
                        <div class="dropdown dropdown-end">
                          <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                            </svg>
                          </label>
                          <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                            <li>
                              <%= link_to escola_turma_aluno_path(aluno.escola, aluno.turma, aluno) do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Ver aluno
                              <% end %>
                            </li>
                            <li>
                              <%= link_to edit_escola_turma_aluno_path(aluno.escola, aluno.turma, aluno) do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                </svg>
                                Editar aluno
                              <% end %>
                            </li>
                            <li>
                              <%= button_to escola_turma_aluno_path(aluno.escola, aluno.turma, aluno), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                                Excluir aluno
                              <% end %>
                            </li>
                          </ul>
                        </div>
                      </div>
                      
                      <div class="divider my-2"></div>
                      
                      <div class="grid grid-cols-2 gap-2 text-sm">
                        <div>
                          <span class="text-slate-500">Escola:</span>
                          <div class="badge badge-sm bg-gradient-to-r from-blue-400 to-green-300 text-white border-0 font-medium">
                            Escola
                          </div>
                        </div>
                        <div>
                          <span class="text-slate-500">Turma:</span>
                          <span class="font-medium text-slate-700"><%= aluno.turma.nome %></span>
                        </div>
                        <div>
                          <span class="text-slate-500">Nascimento:</span>
                          <span class="font-medium text-slate-700"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></span>
                        </div>
                        <div>
                          <span class="text-slate-500">Matrícula:</span>
                          <div class="badge badge-outline badge-sm border-blue-300 text-blue-600 font-mono">
                            <%= aluno.matricula.present? ? truncate(aluno.matricula, length: 12) : "Matrícula" %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden border border-slate-200">
                    <div class="card-body p-4">
                      <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                          <div class="avatar placeholder">
                            <div class="bg-gradient-to-br from-slate-400 to-gray-500 text-white rounded-full w-10 h-10 relative font-bold">
                              <span class="absolute top-1/2 left-1/2 -translate-1/2"><%= aluno.nome.first.upcase %></span>
                            </div>
                          </div>
                          <div>
                            <h2 class="card-title text-slate-700"><%= aluno.nome %></h2>
                            <div class="badge badge-lg bg-gradient-to-r from-slate-500 to-gray-600 text-white border-0 shadow-lg font-bold mt-1">
                              Não Alocado
                            </div>
                          </div>
                        </div>
                        <div class="dropdown dropdown-end">
                          <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                            </svg>
                          </label>
                          <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                            <% if aluno.escola.present? %>
                              <li>
                                <%= link_to escola_aluno_path(aluno.escola, aluno) do %>
                                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                  </svg>
                                  Ver aluno
                                <% end %>
                              </li>
                              <li>
                                <%= link_to edit_escola_aluno_path(aluno.escola, aluno) do %>
                                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                  </svg>
                                  Editar aluno
                                <% end %>
                              </li>
                              <li>
                                <%= button_to escola_aluno_path(aluno.escola, aluno), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este aluno?" } do %>
                                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                  </svg>
                                  Excluir aluno
                                <% end %>
                              </li>
                            <% else %>
                              <li>
                                <div class="text-slate-400 px-2 py-1">
                                  Sem escola
                                </div>
                              </li>
                            <% end %>
                          </ul>
                        </div>
                      </div>
                      
                      <div class="divider my-2"></div>
                      
                      <div class="grid grid-cols-2 gap-2 text-sm">
                        <div>
                          <span class="text-slate-500">Escola:</span>
                          <div class="badge badge-sm bg-gradient-to-r from-slate-400 to-gray-500 text-white border-0 font-medium">
                            Escola
                          </div>
                        </div>
                        <div>
                          <span class="text-slate-500">Turma:</span>
                          <span class="font-medium text-slate-400">Sem turma</span>
                        </div>
                        <div>
                          <span class="text-slate-500">Nascimento:</span>
                          <span class="font-medium text-slate-700"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></span>
                        </div>
                        <div>
                          <span class="text-slate-500">Matrícula:</span>
                          <div class="badge badge-outline badge-sm border-slate-300 text-slate-600 font-mono">
                            <%= aluno.matricula.present? ? truncate(aluno.matricula, length: 12) : "Matrícula" %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </main>
    </div>
  </div>
</div>