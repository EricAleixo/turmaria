<!-- app/views/administradores/_foto_field.html.erb -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />

<div class="form-control">
  <label class="label">
    <span class="label-text text-gray-900 font-medium">Foto do Perfil</span>
  </label>

  <div class="flex items-center gap-4">
    <div class="avatar">
      <div class="w-16 h-16 rounded-full bg-green-500 text-white flex items-center justify-center overflow-hidden relative" id="current-avatar">
        <% if @admin&.foto&.attached? %>
          <img src="<%= url_for(@admin.foto.variant(resize_to_fill: [64, 64])) %>" id="cropped-preview" class="w-16 h-16 rounded-full object-cover" />
          <span id="current-initial" class="hidden text-xl font-bold"><%= @admin&.nome&.first&.upcase || "A" %></span>
        <% else %>
          <img id="cropped-preview" class="w-16 h-16 rounded-full object-cover hidden" />
          <span id="current-initial" class="text-xl font-bold absolute top-1/2 left-1/2 -translate-1/2">
            <%= @admin&.nome&.first&.upcase || "A" %>
          </span>
        <% end %>
      </div>
    </div>

    <div class="flex-1">
      <button type="button" id="open-upload-modal-btn" class="cursor-pointer px-4 py-2 border rounded-md bg-white hover:bg-gray-50">
        Alterar foto
      </button>
      <div class="text-xs text-gray-500 mt-1">JPG, PNG ou GIF (máx. 2MB)</div>
    </div>
  </div>

  <input type="file" id="foto-input" accept="image/png,image/jpeg,image/jpg,image/gif" class="hidden" />
</div>

<!-- Modal Upload -->
<div id="upload-modal" class="fixed top-0 left-0 right-0 bottom-0 z-99 hidden items-center justify-center bg-black/40" style="position: fixed !important; margin: 0 !important;">
  <div class="bg-white rounded-xl w-[92%] max-w-3xl p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Anexar Foto do Administrador</h3>

    <div id="upload-stage" class="border-2 border-dashed rounded-xl p-6 text-center bg-gray-50 transition-all hover:border-blue-300 hover:bg-blue-50">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-22 text-gray-700 mx-auto">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H6.911a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661Z" />
    </svg>

      <p class="text-gray-500 mb-2">Arraste e solte a foto aqui ou</p>
      <button type="button" id="choose-file-btn" class="cursor-pointer px-4 py-2 border rounded-md bg-white hover:bg-gray-50">Escolher arquivo</button>
      <p class="text-sm text-gray-400 mt-3">JPG, PNG ou GIF (máx. 2MB)</p>
    </div>

    <div class="mt-4 flex justify-end">
      <button type="button" id="close-upload-modal-btn" class="btn">Fechar</button>
    </div>
  </div>
</div>

<!-- Modal Crop -->
<div id="crop-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl w-[92%] max-w-4xl p-6">
    <div class="flex items-center gap-3 mb-4">
      <h3 class="text-lg font-bold text-gray-900">Ajuste a área circular para enquadrar o rosto do administrador</h3>
    </div>

    <div class="relative bg-gray-100 rounded-lg overflow-hidden" style="height:420px;">
      <img id="admin-foto-preview" src="" alt="Preview" class="max-w-full mx-auto object-contain h-full" />
    </div>

    <div class="mt-3 text-xs text-gray-500 flex items-center justify-center gap-2">
      Clique e arraste para mover a imagem • Use a roda do mouse para zoom
    </div>

    <div class="mt-4 flex justify-end gap-2">
      <button type="button" id="trocar-foto-btn" class="px-4 py-2 border rounded-md bg-white hover:bg-gray-50">Trocar foto</button>
      <button type="button" id="confirmar-recorte-btn" class="px-4 py-2 rounded-md bg-green-500 text-white hover:bg-green-600">Confirmar recorte</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<style>
.cropper-view-box,
.cropper-face {
  border: none !important;
  box-shadow: none !important;
  outline: none !important;
  border-radius: 50% !important;
}
</style>

<script>
(function() {
  'use strict';
  
  let cropper = null;
  let currentFile = null;
  let initialized = false;

  function waitForActiveStorage(callback, maxAttempts = 20) {
    let attempts = 0;
    const checkInterval = setInterval(() => {
      attempts++;
      if (window.ActiveStorage && window.ActiveStorage.DirectUpload) {
        clearInterval(checkInterval);
        callback();
      } else if (attempts >= maxAttempts) {
        clearInterval(checkInterval);
        console.error('ActiveStorage não carregou após', maxAttempts, 'tentativas');
        alert('Erro: Sistema de upload não está disponível. Recarregue a página.');
      }
    }, 100);
  }

  function initPhotoUpload() {
    if (initialized) return;
    initialized = true;

    const openUploadBtn = document.getElementById('open-upload-modal-btn');
    const uploadModal = document.getElementById('upload-modal');
    const closeUploadModalBtn = document.getElementById('close-upload-modal-btn');
    const chooseFileBtn = document.getElementById('choose-file-btn');
    const fotoInput = document.getElementById('foto-input');

    const cropModal = document.getElementById('crop-modal');
    const cropImage = document.getElementById('admin-foto-preview');
    const confirmarBtn = document.getElementById('confirmar-recorte-btn');
    const trocarBtn = document.getElementById('trocar-foto-btn');

    const previewImg = document.getElementById('cropped-preview');
    const initialSpan = document.getElementById('current-initial');
    const uploadStage = document.getElementById('upload-stage');

    if (!openUploadBtn) return;

    const show = el => { 
      if (el) {
        el.classList.remove('hidden'); 
        el.classList.add('flex'); 
      }
    };
    
    const hide = el => { 
      if (el) {
        el.classList.add('hidden'); 
        el.classList.remove('flex'); 
      }
    };

    const form = document.querySelector('form[action*="administradores"]') || document.querySelector('form');

    console.log('Formulário encontrado:', form);

    // Preview inicial
    if (previewImg && previewImg.src && previewImg.src.trim() !== "" && !previewImg.src.includes('data:')) {
      previewImg.classList.remove('hidden');
      if (initialSpan) initialSpan.classList.add('hidden');
    } else {
      if (previewImg) previewImg.classList.add('hidden');
      if (initialSpan) initialSpan.classList.remove('hidden');
    }

    // Event listeners
    openUploadBtn.addEventListener('click', (e) => {
      e.preventDefault();
      show(uploadModal);
    });

    closeUploadModalBtn.addEventListener('click', (e) => {
      e.preventDefault();
      hide(uploadModal);
      if (fotoInput) fotoInput.value = '';
    });

    chooseFileBtn.addEventListener('click', (e) => { 
      e.preventDefault(); 
      if (fotoInput) fotoInput.click(); 
    });

    // Drag & drop
    if (uploadStage) {
      ['dragenter','dragover'].forEach(ev => {
        uploadStage.addEventListener(ev, (e) => { 
          e.preventDefault(); 
          uploadStage.classList.add('bg-blue-50'); 
        });
      });

      ['dragleave','drop'].forEach(ev => {
        uploadStage.addEventListener(ev, (e) => { 
          e.preventDefault(); 
          uploadStage.classList.remove('bg-blue-50'); 
        });
      });

      uploadStage.addEventListener('drop', (e) => {
        if (e.dataTransfer.files[0]) {
          handleSelectedFile(e.dataTransfer.files[0]);
        }
      });
    }

    if (fotoInput) {
      fotoInput.addEventListener('change', (e) => {
        if (e.target.files[0]) {
          handleSelectedFile(e.target.files[0]);
        }
      });
    }

    function validateFile(file) {
      const allowed = ['image/png','image/jpeg','image/jpg','image/gif'];
      if (!allowed.includes(file.type)) { 
        alert('Formato inválido. Use JPG, PNG ou GIF.'); 
        return false; 
      }
      if (file.size > 2*1024*1024) { 
        alert('Arquivo muito grande (máx 2MB).'); 
        return false; 
      }
      return true;
    }

    function handleSelectedFile(file) {
      if (!file || !validateFile(file)) { 
        if (fotoInput) fotoInput.value = ''; 
        return; 
      }

      hide(uploadModal);
      show(cropModal);

      const previewUrl = URL.createObjectURL(file);
      currentFile = { file, preview: previewUrl };
      
      if (cropImage) {
        // Limpa cropper anterior se existir
        if (cropper) {
          cropper.destroy();
          cropper = null;
        }

        cropImage.src = previewUrl;

        // Aguarda imagem carregar E inicializa o Cropper imediatamente
        cropImage.onload = function() {
          // Pequeno delay para garantir que a imagem foi renderizada
          setTimeout(() => {
            cropper = new Cropper(cropImage, {
              aspectRatio: 1,
              viewMode: 1,
              autoCropArea: 0.9,
              background: false,
              guides: false,
              dragMode: 'move',
              zoomOnWheel: true,
              responsive: true,
              ready: function() {
                console.log('✅ Cropper inicializado e pronto!');
              }
            });
          }, 100);
        };
      }
    }

    if (trocarBtn) {
      trocarBtn.addEventListener('click', (e) => {
        e.preventDefault();
        
        if (cropper) {
          cropper.destroy();
          cropper = null;
        }
        
        if (currentFile && currentFile.preview) {
          URL.revokeObjectURL(currentFile.preview);
        }
        
        currentFile = null;
        
        if (fotoInput) fotoInput.value = '';
        
        hide(cropModal);
        show(uploadModal);
      });
    }

    if (confirmarBtn) {
      confirmarBtn.addEventListener('click', (e) => {
        e.preventDefault();
        
        // Verifica se o cropper está inicializado e pronto
        if (!cropper || !cropper.ready) {
          // Aguarda um pouco caso o cropper ainda esteja inicializando
          setTimeout(() => {
            if (!cropper || !cropper.ready) {
              alert('O editor de imagem ainda está carregando. Aguarde um momento e tente novamente.');
              return;
            }
            // Verifica se ActiveStorage está disponível
            waitForActiveStorage(() => {
              processUpload();
            });
          }, 500);
          return;
        }

        // Verifica se ActiveStorage está disponível
        waitForActiveStorage(() => {
          processUpload();
        });
      });
    }

    function processUpload() {
      // Validação final do cropper
      if (!cropper || !cropper.ready) {
        alert('Editor de imagem não está pronto. Tente novamente.');
        return;
      }

      confirmarBtn.disabled = true; 
      confirmarBtn.textContent = 'Enviando...';

      try {
        cropper.getCroppedCanvas({ width: 800, height: 800 }).toBlob((blob) => {
          if (!blob) {
            confirmarBtn.disabled = false; 
            confirmarBtn.textContent = 'Confirmar recorte';
            alert('Erro ao processar a imagem. Tente novamente.');
            return;
          }

          const fileForUpload = new File([blob], `admin_foto_${Date.now()}.png`, { type: 'image/png' });

          const uploadUrl = '/rails/active_storage/direct_uploads';
          const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
          
          console.log('CSRF Token:', csrfToken);
          console.log('Upload URL:', uploadUrl);
          console.log('Arquivo:', fileForUpload);

          const uploader = new ActiveStorage.DirectUpload(
            fileForUpload, 
            uploadUrl, 
            { 
              directUploadWillStoreFileWithXHR: (xhr) => {
                xhr.setRequestHeader('X-CSRF-Token', csrfToken);
              }
            }
          );

          uploader.create((error, blob) => {
            confirmarBtn.disabled = false; 
            confirmarBtn.textContent = 'Confirmar recorte';
            
            if (error) {
              console.error('Erro no upload:', error);
              alert('Erro ao enviar a foto: ' + (error.message || JSON.stringify(error)));
              return;
            }

            console.log('✅ Upload bem-sucedido! Blob:', blob);
            console.log('✅ Signed ID:', blob.signed_id);

            // Remove input hidden anterior se existir
            let hidden = form?.querySelector('input[name="admin[foto]"]');
            if (hidden) {
              console.log('Removendo input anterior com valor:', hidden.value);
              hidden.remove();
            }

            // Cria novo input hidden com signed_id
            hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = 'admin[foto]';
            hidden.value = blob.signed_id;
            
            if (form) {
              form.appendChild(hidden);
              console.log('✅ Input hidden adicionado ao form:', hidden.name, '=', hidden.value);
              console.log('✅ Formulário atual:', form.outerHTML.substring(0, 200));
            } else {
              console.error('❌ Formulário não encontrado!');
            }

            const previewUrl = URL.createObjectURL(fileForUpload);

            // Atualiza preview no formulário
            if (previewImg) {
              previewImg.src = previewUrl;
              previewImg.classList.remove('hidden');
            }
            if (initialSpan) {
              initialSpan.classList.add('hidden');
            }

            // Atualiza preview do card lateral (se existir)
            const previewAvatar = document.getElementById('preview-avatar');
            if (previewAvatar) {
              previewAvatar.innerHTML = '';
              
              const newImg = document.createElement('img');
              newImg.src = previewUrl;
              newImg.alt = 'Foto';
              newImg.className = 'w-full h-full object-cover';
              newImg.id = 'preview-photo';
              previewAvatar.appendChild(newImg);
              
              document.dispatchEvent(new CustomEvent('admin-photo:uploaded', {
                detail: { url: previewUrl }
              }));
            }

            // Atualiza o avatar do formulário
            const currentAvatar = document.getElementById('current-avatar');
            if (currentAvatar) {
              const currentPreview = currentAvatar.querySelector('#cropped-preview');
              const currentInitial = currentAvatar.querySelector('#current-initial');
              
              if (currentPreview) {
                currentPreview.src = previewUrl;
                currentPreview.classList.remove('hidden');
              }
              if (currentInitial) {
                currentInitial.classList.add('hidden');
              }
            }

            // Limpeza
            if (cropper) {
              cropper.destroy();
              cropper = null;
            }
            
            if (currentFile && currentFile.preview) {
              URL.revokeObjectURL(currentFile.preview);
            }
            
            currentFile = null;
            
            if (fotoInput) fotoInput.value = '';

            hide(cropModal);
            
            console.log('✅ Upload concluído com sucesso!');
          });
        }, 'image/png');
      } catch (error) {
        confirmarBtn.disabled = false; 
        confirmarBtn.textContent = 'Confirmar recorte';
        console.error('Erro ao processar recorte:', error);
        alert('Erro ao processar a imagem. Tente novamente.');
      }
    }
  }

  // Inicializa quando DOM estiver pronto
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPhotoUpload);
  } else {
    initPhotoUpload();
  }

  // Suporte para Turbo
  document.addEventListener('turbo:load', () => {
    initialized = false;
    initPhotoUpload();
  });
})();
</script>