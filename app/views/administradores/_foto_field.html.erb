<!-- app/views/administradores/_foto_field.html.erb -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />

<div class="form-control">
  <label class="label">
    <span class="label-text text-gray-900 font-medium">Foto do Perfil</span>
  </label>

  <div class="flex items-center gap-4">
    <div class="avatar">
      <div class="w-16 h-16 rounded-full bg-green-500 text-white relative overflow-hidden" id="current-avatar">
        <% if @admin&.foto&.attached? %>
          <%= image_tag @admin.foto.variant(resize_to_fill: [64, 64]), id: "cropped-preview", class: "w-16 h-16 rounded-full object-cover" %>
          <span id="current-initial" class="hidden"></span>
        <% else %>
          <span class="text-xl font-bold absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" id="current-initial">
            <%= @admin&.nome&.first&.upcase || "A" %>
          </span>
          <img id="cropped-preview" class="w-16 h-16 rounded-full hidden object-cover" />
        <% end %>
      </div>
    </div>

    <div class="flex-1">
      <button type="button" id="open-upload-modal-btn" class="px-4 py-2 border rounded-md bg-white hover:bg-gray-50">
        Alterar foto
      </button>
      <div class="text-xs text-gray-500 mt-1">JPG, PNG ou GIF (máx. 2MB)</div>
    </div>
  </div>

  <input type="file" id="foto-input" accept="image/png,image/jpeg,image/jpg,image/gif" class="hidden" />
</div>

<!-- Modal Upload -->
<div id="upload-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl w-[92%] max-w-3xl p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Anexar Foto do Administrador</h3>

    <div id="upload-stage" class="border-2 border-dashed rounded-xl p-6 text-center bg-gray-50 transition-all hover:border-blue-300 hover:bg-blue-50">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15v4a2 2 0 002 2h14a2 2 0 002-2v-4M4 12l4-4 4 4m4-4l4 4" />
      </svg>
      <p class="text-gray-500 mb-2">Arraste e solte a foto aqui ou</p>
      <button id="choose-file-btn" class="px-4 py-2 border rounded-md bg-white hover:bg-gray-50">Escolher arquivo</button>
      <p class="text-sm text-gray-400 mt-3">JPG, PNG ou GIF (máx. 2MB)</p>
    </div>

    <div class="mt-4 flex justify-end">
      <button id="close-upload-modal-btn" class="btn">Fechar</button>
    </div>
  </div>
</div>

<!-- Modal Crop -->
<div id="crop-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl w-[92%] max-w-4xl p-6">
    <div class="flex items-center gap-3 mb-4">
      <h3 class="text-lg font-bold text-gray-900">Ajuste a área circular para enquadrar o rosto do administrador</h3>
    </div>

    <div class="relative bg-gray-100 rounded-lg overflow-hidden" style="height:420px;">
      <img id="admin-foto-preview" src="" alt="Preview" class="max-w-full mx-auto object-contain h-full" />
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 flex items-center justify-center">
      </div>
    </div>

    <div class="mt-3 text-xs text-gray-500 flex items-center justify-center gap-2">
      Clique e arraste para mover a imagem • Use a roda do mouse para zoom
    </div>

    <div class="mt-4 flex justify-end gap-2">
      <button id="trocar-foto-btn" type="button" class="px-4 py-2 border rounded-md bg-white hover:bg-gray-50">Trocar foto</button>
      <button id="confirmar-recorte-btn" type="button" class="px-4 py-2 rounded-md bg-green-500 text-white">Confirmar recorte</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<style>
.cropper-view-box,
.cropper-face {
  border: none !important;
  box-shadow: none !important;
  outline: none !important;
  border-radius: 50% !important;
}
</style>

<script>
document.addEventListener('turbo:load', () => {

  const openUploadBtn = document.getElementById('open-upload-modal-btn');
  const uploadModal = document.getElementById('upload-modal');
  const closeUploadModalBtn = document.getElementById('close-upload-modal-btn');
  const chooseFileBtn = document.getElementById('choose-file-btn');
  const fotoInput = document.getElementById('foto-input');

  const cropModal = document.getElementById('crop-modal');
  const cropImage = document.getElementById('admin-foto-preview');
  const confirmarBtn = document.getElementById('confirmar-recorte-btn');
  const trocarBtn = document.getElementById('trocar-foto-btn');

  const previewImg = document.getElementById('cropped-preview');
  const initialSpan = document.getElementById('current-initial');
  const uploadStage = document.getElementById('upload-stage');

  if (!openUploadBtn) return;

  let cropper = null;
  let currentFile = null;

  const show = el => { el.classList.remove('hidden'); el.classList.add('flex'); };
  const hide = el => { el.classList.add('hidden'); el.classList.remove('flex'); };

  const form = document.querySelector('form');

  if (form) {
    form.addEventListener('submit', (e) => {
      const hiddenInput = form.querySelector('input[name="admin[foto]"]');
      if (hiddenInput && !hiddenInput.value) {
        e.preventDefault();
        alert('Por favor, finalize o upload da foto antes de criar o administrador.');
      }
    });
  }

  // Inicial preview
  if (previewImg.src && previewImg.src.trim() !== "") {
    previewImg.classList.remove('hidden');
    initialSpan.classList.add('hidden');
  } else {
    previewImg.classList.add('hidden');
    initialSpan.classList.remove('hidden');
  }

  openUploadBtn.addEventListener('click', () => show(uploadModal));
  closeUploadModalBtn.addEventListener('click', () => hide(uploadModal));
  chooseFileBtn.addEventListener('click', e => { e.preventDefault(); fotoInput.click(); });

  // Drag & drop
  ['dragenter','dragover'].forEach(ev => uploadStage.addEventListener(ev, e => { e.preventDefault(); uploadStage.classList.add('bg-blue-50'); }));
  ['dragleave','drop'].forEach(ev => uploadStage.addEventListener(ev, e => { e.preventDefault(); uploadStage.classList.remove('bg-blue-50'); }));
  uploadStage.addEventListener('drop', e => handleSelectedFile(e.dataTransfer.files[0]));
  fotoInput.addEventListener('change', e => handleSelectedFile(e.target.files[0]));

  function validateFile(file) {
    const allowed = ['image/png','image/jpeg','image/jpg','image/gif'];
    if (!allowed.includes(file.type)) { alert('Formato inválido.'); return false; }
    if (file.size > 2*1024*1024) { alert('Arquivo muito grande (máx 2MB).'); return false; }
    return true;
  }

  function handleSelectedFile(file) {
    if (!file || !validateFile(file)) { fotoInput.value=''; return; }

    hide(uploadModal);
    show(cropModal);

    const previewUrl = URL.createObjectURL(file);
    currentFile = { file, preview: previewUrl };
    cropImage.src = previewUrl;

    if (cropper) cropper.destroy();
    cropper = new Cropper(cropImage, {
      aspectRatio: 1,
      viewMode: 1,
      autoCropArea: 0.9,
      background: false,
      guides: false,
      dragMode: 'move',
      zoomOnWheel: true
    });
  }

  trocarBtn.addEventListener('click', () => {
    if (cropper) cropper.destroy();
    if (currentFile) URL.revokeObjectURL(currentFile.preview);
    cropper = null; currentFile = null;
    fotoInput.value=''; hide(cropModal); show(uploadModal);
  });

  confirmarBtn.addEventListener('click', () => {
    if (!cropper) return alert('Nenhum recorte disponível.');
    confirmarBtn.disabled = true; confirmarBtn.textContent = 'Enviando...';

    cropper.getCroppedCanvas({ width:800, height:800 }).toBlob(blob => {
      const fileForUpload = new File([blob], `admin_foto_${Date.now()}.png`, { type:'image/png' });

      if (!window.ActiveStorage || !window.ActiveStorage.DirectUpload) {
        alert('ActiveStorage não inicializado!');
        confirmarBtn.disabled = false; confirmarBtn.textContent='Confirmar recorte';
        return;
      }

      const form = cropModal.closest('form') || document.querySelector('form');
      const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      const uploader = new ActiveStorage.DirectUpload(fileForUpload, '/rails/active_storage/direct_uploads', token);

      uploader.create((error, blob) => {
        confirmarBtn.disabled=false; 
        confirmarBtn.textContent='Confirmar recorte';
        if (error) return alert('Erro ao enviar a foto: '+(error.message||error));

        // --- ALTERAÇÃO AQUI: envia apenas o signed_id correto ---
        let hidden = form.querySelector('input[name="admin[foto]"]');
        if (hidden) hidden.remove();

        hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'admin[foto]';
        hidden.value = blob.signed_id; // <<< O segredo: só signed_id
        form.appendChild(hidden);

        // Atualiza preview
        previewImg.src = URL.createObjectURL(fileForUpload);
        previewImg.classList.remove('hidden');
        initialSpan.classList.add('hidden');

        // Limpeza
        cropper.destroy(); cropper=null;
        if (currentFile) URL.revokeObjectURL(currentFile.preview);
        currentFile=null; fotoInput.value='';

        hide(cropModal);

        // Opcional: submeter o form automaticamente
        // form.submit();
      });
    }, 'image/png');
  });
});
</script>
