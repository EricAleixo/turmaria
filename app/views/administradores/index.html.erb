<!-- Header -->
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 p-2">
  <div>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Administradores</h1>
    <p class="text-gray-600">Gerencie os administradores do sistema</p>
  </div>
  <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
    <!-- View Toggle Buttons -->
    <div class="join w-full sm:w-auto">
      <button id="card-view-btn" class="join-item btn btn-sm bg-green-500 hover:bg-green-600 text-white border-none flex-1 sm:flex-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>
        Cards
      </button>
      <button id="table-view-btn" class="join-item btn btn-sm btn-ghost border-gray-300 flex-1 sm:flex-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 0 1-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0 1 12 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M13.125 12h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125M20.625 12c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5M12 14.625v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 14.625c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m0 1.5v-1.5m0 0c0-.621.504-1.125 1.125-1.125m0 0h7.5" />
        </svg>
        Tabela
      </button>
    </div>
    <%= link_to new_administradore_path, class: "btn bg-green-500 hover:bg-green-600 text-white border-none w-full sm:w-auto" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo Administrador
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 p-2">
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-600 text-sm">Total de Administradores</p>
        <p class="text-2xl font-bold text-gray-900"><%= @administradores.count %></p>
      </div>
      <div class="bg-blue-100 p-3 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-600 text-sm">Ativos</p>
        <p class="text-2xl font-bold text-gray-900"><%= @administradores.where.not(confirmed_at: nil).count %></p>
      </div>
      <div class="bg-green-100 p-3 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-600 text-sm">Pendentes</p>
        <p class="text-2xl font-bold text-gray-900"><%= @administradores.where(confirmed_at: nil).count %></p>
      </div>
      <div class="bg-yellow-100 p-3 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
      </div>
    </div>
  </div>
</div>

<% if @administradores.present? %>
  <!-- Card View -->
  <div id="card-view" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 px-2">
    <% @administradores.each do |admin| %>
      <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg hover:shadow-xl transition-shadow">
        <!-- User Header -->
        <div class="flex items-center gap-4 mb-4">
          <div class="avatar placeholder">
            <div class="w-12 h-12 rounded-full bg-green-500 flex items-center justify-center text-white font-bold relative overflow-hidden">
            <% if admin.foto.attached? %>
              <%= image_tag admin.foto.variant(resize_to_fill: [48, 48]), class: "w-full h-full object-cover rounded-full" %>
            <% else %>
              <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-lg">
                <%= admin.nome.present? ? admin.nome.first.upcase : admin.email.first.upcase %>
              </span>
            <% end %>
          </div>
          </div>
          <div class="flex-1">
            <h3 class="text-gray-900 font-bold text-lg">
              <%= admin.nome.present? ? admin.nome : 'Nome não informado' %>
            </h3>
            <p class="text-gray-600 text-sm">Administrador</p>
          </div>
        </div>

        <!-- User Info -->
        <div class="space-y-3 mb-6">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <span class="text-gray-700 text-sm"><%= admin.email %></span>
          </div>
          
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
            <span class="text-gray-700 text-sm">Criado em <%= admin.created_at.strftime("%d/%m/%Y") %></span>
          </div>

          <div class="flex items-center gap-2">
            <% if admin.confirmed_at.present? %>
              <div class="flex items-center gap-2 bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                Confirmado
              </div>
            <% else %>
              <div class="flex items-center gap-2 bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full text-xs">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
                Pendente
              </div>
            <% end %>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-2">
          <%= link_to administradore_path(admin), class: "flex-1 btn btn-sm bg-blue-600 hover:bg-blue-700 text-white border-none" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          <% end %>
          
          <%= link_to edit_administradore_path(admin), class: "flex-1 btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white border-none" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
          <% end %>
          
          <%= delete_button_with_modal(
            path: administradore_path(admin),
            modal_id: dom_id(admin, :delete),
            title: "Remover administrador",
            message: "Tem certeza que deseja remover este administrador",
            item_name: admin.nome,
            btn_class: "btn btn-sm bg-red-600 hover:bg-red-700 text-white border-none"
          ) %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Table View (Hidden by default) -->
  <div id="table-view" class="hidden">
    <div class="bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden px-2">
      <table class="table w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="text-left text-gray-900 font-semibold">Administrador</th>
            <th class="text-left text-gray-900 font-semibold">Email</th>
            <th class="text-left text-gray-900 font-semibold">Status</th>
            <th class="text-left text-gray-900 font-semibold">Criado em</th>
            <th class="text-center text-gray-900 font-semibold">Ações</th>
          </tr>
        </thead>
    <tbody>
        <% @administradores.each do |admin| %>
          <tr class="hover:bg-gray-50 border-b border-gray-100">
            <td class="py-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full overflow-hidden flex items-center justify-center <%= admin.foto.attached? ? 'bg-gray-200' : 'bg-green-500' %>">
                  <% if admin.foto.attached? %>
                    <%= image_tag admin.foto.variant(resize_to_fill: [40, 40]), class: "w-full h-full object-cover" %>
                  <% else %>
                    <span class="text-white font-bold text-lg">
                      <%= admin.nome.present? ? admin.nome.first.upcase : admin.email.first.upcase %>
                    </span>
                  <% end %>
                </div>
                <div>
                  <div class="font-bold text-gray-900">
                    <%= admin.nome.present? ? admin.nome : 'Nome não informado' %>
                  </div>
                  <div class="text-sm text-gray-500">Administrador</div>
                </div>
              </div>
            </td>
            <td class="py-4">
              <span class="text-gray-700"><%= admin.email %></span>
            </td>
            <td class="py-4">
              <% if admin.confirmed_at.present? %>
                <div class="flex items-center gap-2 bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs w-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Confirmado
                </div>
              <% else %>
                <div class="flex items-center gap-2 bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full text-xs w-fit">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                </svg>
                  Pendente
                </div>
              <% end %>
            </td>
            <td class="py-4">
              <span class="text-gray-700"><%= admin.created_at.strftime("%d/%m/%Y") %></span>
            </td>
            <td class="py-4">
              <div class="flex justify-center gap-2">
                <%= link_to administradore_path(admin), class: "btn btn-sm bg-blue-600 hover:bg-blue-700 text-white border-none" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                <% end %>
                
                <%= link_to edit_administradore_path(admin), class: "btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white border-none" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                <% end %>
                
                <%= delete_button_with_modal(
                  path: administradore_path(admin),
                  modal_id: dom_id(admin, :delete),
                  title: "Remover administrador",
                  message: "Tem certeza que deseja remover este administrador",
                  item_name: admin.nome,
                  btn_class: "btn btn-sm bg-red-600 hover:bg-red-700 text-white border-none"
                ) %>

              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
      </table>
    </div>
  </div>
<% else %>
  <!-- Empty State -->
  <div class="bg-white rounded-xl p-12 border border-gray-200 shadow-lg text-center px-2">
    <div class="max-w-md mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656.126-1.283.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <h3 class="text-xl font-bold text-gray-900 mb-2">Nenhum administrador encontrado</h3>
      <p class="text-gray-600 mb-6">Comece criando o primeiro administrador do sistema.</p>
      <%= link_to new_administradore_path, class: "btn bg-green-500 hover:bg-green-600 text-white border-none" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        Criar Primeiro Administrador
      <% end %>
    </div>
  </div>
<% end %>

<script>
  // Função para inicializar os botões de visualização
  function initializeViewButtons() {
    const cardViewBtn = document.getElementById('card-view-btn');
    const tableViewBtn = document.getElementById('table-view-btn');
    const cardView = document.getElementById('card-view');
    const tableView = document.getElementById('table-view');
    
    if (!cardViewBtn || !tableViewBtn || !cardView || !tableView) {
      console.warn('Elementos de visualização não encontrados');
      return;
    }

    cardViewBtn.addEventListener('click', function() {
      // Show card view
      cardView.classList.remove('hidden');
      tableView.classList.add('hidden');
      
      // Update button styles
      cardViewBtn.classList.remove('btn-ghost', 'border-gray-300');
      cardViewBtn.classList.add('bg-green-500', 'hover:bg-green-600', 'text-white', 'border-none');
      
      tableViewBtn.classList.remove('bg-green-500', 'hover:bg-green-600', 'text-white', 'border-none');
      tableViewBtn.classList.add('btn-ghost', 'border-gray-300');
    });

    tableViewBtn.addEventListener('click', function() {
      // Show table view
      cardView.classList.add('hidden');
      tableView.classList.remove('hidden');
      
      // Update button styles
      tableViewBtn.classList.remove('btn-ghost', 'border-gray-300');
      tableViewBtn.classList.add('bg-green-500', 'hover:bg-green-600', 'text-white', 'border-none');
      
      cardViewBtn.classList.remove('bg-green-500', 'hover:bg-green-600', 'text-white', 'border-none');
      cardViewBtn.classList.add('btn-ghost', 'border-gray-300');
    });
    
    console.log('Botões de visualização inicializados com sucesso');
  }

  // Inicializa os botões quando o DOM estiver pronto
  document.addEventListener('DOMContentLoaded', initializeViewButtons);
  
  // Força a inicialização imediata caso o DOM já esteja carregado
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(initializeViewButtons, 1);
  }
</script>