<!-- Header with back button -->
<div class="flex items-center mb-6">
  <%= link_to administradore_path(@admin), class: "flex items-center text-blue-600 hover:text-blue-700 transition-colors" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    Voltar aos Detalhes
  <% end %>
</div>

<!-- Main title -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Editar Administrador</h1>
  <p class="text-gray-600">Atualize as informações da conta de administrador</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Form Card -->
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex items-center gap-3 mb-6">
      <div class="bg-yellow-100 p-3 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900">Editar Informações</h2>
        <p class="text-gray-600 text-sm">Atualize os dados do administrador</p>
      </div>
    </div>
    
    <%= form_with model: @admin, url: administradore_path(@admin), local: true, html: { class: "space-y-6", multipart: true } do |form| %>
      <div class="space-y-4">
        <!-- Photo Upload -->
        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-900 font-medium">Foto do Perfil</span>
          </label>
          <div class="flex items-center gap-4">
            <div class="avatar">
              <div class="w-16 h-16 rounded-full bg-green-500 text-white relative" id="current-avatar">
                <span class="text-xl font-bold absolute top-1/2 left-1/2 -translate-1/2">
                  <%= @admin.nome.present? ? @admin.nome.first.upcase : @admin.email.first.upcase %>
                </span>
              </div>
            </div>
            <div class="flex-1">
              <%= form.file_field :foto, 
                  class: "file-input file-input-bordered w-full bg-white border-gray-300 focus:border-yellow-500", 
                  accept: "image/*",
                  id: "foto-input" %>
              <div class="text-xs text-gray-500 mt-1">JPG, PNG ou GIF (máx. 2MB)</div>
            </div>
          </div>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-900 font-medium">Nome Completo</span>
          </label>
          <%= form.text_field :nome, 
              class: "input input-bordered w-full bg-white border-gray-300 text-gray-900 focus:border-yellow-500", 
              required: true, 
              id: "nome-input" %>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-900 font-medium">Email</span>
          </label>
          <%= form.email_field :email, 
              class: "input input-bordered w-full bg-white border-gray-300 text-gray-900 focus:border-yellow-500", 
              required: true, 
              id: "email-input" %>
        </div>

        <div class="divider">
          <span class="text-gray-600">Alterar Senha (opcional)</span>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-900 font-medium">Nova Senha</span>
          </label>
          <%= form.password_field :password, 
              class: "input input-bordered w-full bg-white border-gray-300 text-gray-900 focus:border-yellow-500", 
              placeholder: "Deixe em branco para não alterar" %>
          <label class="label">
            <span class="label-text-alt text-gray-500">Deixe em branco se não quiser alterar a senha</span>
          </label>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-900 font-medium">Confirmar Nova Senha</span>
          </label>
          <%= form.password_field :password_confirmation, 
              class: "input input-bordered w-full bg-white border-gray-300 text-gray-900 focus:border-yellow-500", 
              placeholder: "Confirme a nova senha" %>
        </div>
      </div>

      <div class="divider"></div>

      <div class="flex gap-3">
        <%= form.submit "Atualizar Administrador", 
            class: "flex-1 btn bg-yellow-500 hover:bg-yellow-600 text-white border-none font-medium" %>
        <%= link_to administradore_path(@admin), 
            class: "btn btn-ghost text-gray-600 hover:text-gray-800 border-gray-300 hover:border-gray-400" do %>
          Cancelar
        <% end %>
      </div>

      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <%= link_to administradores_path, 
            class: "flex-1 btn btn-ghost text-gray-600 hover:text-gray-800 border-gray-300 hover:border-gray-400" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Voltar à Lista
        <% end %>
        <%= button_to administradore_path(@admin), method: :delete, 
            class: "btn bg-red-600 hover:bg-red-700 text-white border-none",
            data: { 
              confirm: "Tem certeza que deseja excluir este administrador?"
            } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Excluir
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Preview Card -->
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex items-center gap-3 mb-6">
      <div class="bg-blue-100 p-3 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </div>
      <div>
        <h3 class="text-xl font-bold text-gray-900">Pré-visualização</h3>
        <p class="text-gray-600 text-sm">Como o perfil aparecerá após as alterações</p>
      </div>
    </div>
    
    <!-- User Profile Preview -->
    <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
      <div class="flex items-center gap-4 mb-6">
        <div class="avatar placeholder">
          <div class="bg-green-500 text-white rounded-full w-16 h-16 relative ring-4 ring-green-500/20 transition-all duration-300" id="preview-avatar">
            <span class="text-xl font-bold absolute top-1/2 left-1/2 -translate-1/2" id="preview-initial">
              <%= @admin.nome.present? ? @admin.nome.first.upcase : @admin.email.first.upcase %>
            </span>
          </div>
        </div>
        <div>
          <div class="font-bold text-lg text-gray-900" id="preview-name">
            <%= @admin.nome.present? ? @admin.nome : 'Nome do Administrador' %>
          </div>
          <div class="text-sm text-gray-600">Administrador</div>
        </div>
      </div>
      
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-gray-700" id="preview-email"><%= @admin.email %></span>
        </div>
        
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <% if @admin.confirmed_at.present? %>
            <div class="flex items-center gap-2 bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Confirmado
            </div>
          <% else %>
            <div class="flex items-center gap-2 bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full text-xs">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01" />
              </svg>
              Pendente
            </div>
          <% end %>
        </div>
        
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 4v10m6-10v10m-6-4h6" />
          </svg>
          <span class="text-gray-700">Criado em <%= @admin.created_at.strftime("%d/%m/%Y") %></span>
        </div>
      </div>
    </div>
    
    <!-- Warning Alert -->
    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div class="text-sm text-yellow-700">
          <p class="font-medium mb-1">Atenção:</p>
          <ul class="space-y-1 text-yellow-600">
            <li>• Alterações no email podem exigir nova confirmação</li>
            <li>• Deixe a senha em branco para não alterá-la</li>
            <li>• O administrador será notificado das alterações</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const nomeInput = document.getElementById('nome-input');
  const emailInput = document.getElementById('email-input');
  const previewName = document.getElementById('preview-name');
  const previewEmail = document.getElementById('preview-email');
  const previewInitial = document.getElementById('preview-initial');

  function updatePreview() {
    const nome = nomeInput.value || 'Nome do Administrador';
    const email = emailInput.value || 'email@exemplo.com';
    const initial = nome.charAt(0).toUpperCase() || 'A';
    
    previewName.textContent = nome;
    previewEmail.textContent = email;
    if (previewInitial) {
      previewInitial.textContent = initial;
    }
  }

  nomeInput.addEventListener('input', updatePreview);
  emailInput.addEventListener('input', updatePreview);
});
</script>
