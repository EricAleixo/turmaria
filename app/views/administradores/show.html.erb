<div class="flex items-center mb-6">
  <%= link_to administradores_path, class: "flex items-center text-blue-600 hover:text-blue-700 transition-colors" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    Voltar aos Usuários
  <% end %>
</div>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Detalhes do Usuário</h1>
  <p class="text-gray-600">Visualize e gerencie as informações do usuário</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <div class="flex flex-col items-center text-center">
      <div class="avatar mb-4">
        <% if @admin.foto.attached? %>
          <div class="w-24 h-24 rounded-full ring-4 ring-green-500/20 overflow-hidden">
            <%= image_tag @admin.foto,
                  class: "w-full h-full object-cover",
                  alt: @admin.nome || @admin.email %>
          </div>
        <% else %>
          <div class="avatar placeholder">
            <div class="bg-green-500 text-white rounded-full w-24 h-24 relative ring-4 ring-green-500/20">
              <span class="text-3xl font-bold absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                <%= @admin.nome.present? ? @admin.nome.first.upcase : @admin.email.first.upcase %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        <%= @admin.nome.present? ? @admin.nome : 'Nome não informado' %>
      </h2>
      <p class="text-gray-600 mb-4">ID: <%= @admin.id.first(8) %></p>
      
      <% if @admin.confirmed_at.present? %>
        <div class="flex items-center gap-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Usuário Aprovado
        </div>
      <% else %>
        <div class="flex items-center gap-2 bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01" />
          </svg>
          Pendente Confirmação
        </div>
      <% end %>

      <div class="flex items-center gap-2 text-purple-600 text-sm">
      </div>
    </div>
  </div>

  <!-- User Information Card -->
  <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
    <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      Informações do Usuário
    </h3>

    <div class="space-y-6">
      <!-- Dados Pessoais -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="text-blue-600 font-medium">Dados Pessoais</span>
        </div>
        <div class="ml-7 space-y-2">
          <div>
            <span class="text-gray-500 text-sm">Nome</span>
            <p class="text-gray-900 font-medium">
              <%= @admin.nome.present? ? @admin.nome : 'Não informado' %>
            </p>
          </div>
        </div>
      </div>

      <!-- Dados Acadêmicos -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-purple-600 font-medium">Dados Acadêmicos</span>
        </div>
        <div class="ml-7 space-y-2">
          <div>
            <span class="text-gray-500 text-sm">Email</span>
            <p class="text-gray-900 font-medium"><%= @admin.email %></p>
          </div>
          <div>
            <span class="text-gray-500 text-sm">Cargo</span>
            <p class="text-gray-900 font-medium">Administrador</p>
          </div>
          <div>
            <span class="text-gray-500 text-sm">Turma</span>
            <p class="text-gray-900 font-medium">Sistema</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions and Info Panel -->
  <div class="space-y-6">
    <!-- Actions Card -->
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
      <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Ações
      </h3>
      
      <div class="space-y-3">
        <%= link_to edit_administradore_path(@admin), class: "w-full btn bg-yellow-500 hover:bg-yellow-600 text-white border-none" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Editar Usuário
        <% end %>
        
        <%= button_to administradore_path(@admin), method: :delete, 
            class: "w-full btn bg-red-500 hover:bg-red-600 text-white border-none",
            data: { 
              confirm: "Tem certeza que deseja excluir este usuário?"
            } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Excluir Usuário
        <% end %>
        
        <%= link_to administradores_path, class: "w-full btn btn-ghost text-gray-600 hover:text-gray-800 border-gray-300 hover:border-gray-400" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Voltar à Lista
        <% end %>
      </div>
    </div>

    <!-- Information Card -->
    <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
      <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Informações
      </h3>
      
      <div class="space-y-4">
        <div class="flex justify-between items-center">
          <span class="text-gray-600">ID do Usuário</span>
          <span class="text-gray-900 font-mono text-sm">#<%= @admin.id.first(8) %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-gray-600">Membro desde</span>
          <span class="text-gray-900"><%= @admin.created_at.strftime("%d/%m/%Y %H:%M") %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-gray-600">Última atualização</span>
          <span class="text-gray-900"><%= @admin.updated_at.strftime("%d/%m/%Y %H:%M") %></span>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-gray-600">Status</span>
          <% if @admin.confirmed_at.present? %>
            <span class="text-green-600 font-medium">Ativo</span>
          <% else %>
            <span class="text-yellow-600 font-medium">Pendente</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
