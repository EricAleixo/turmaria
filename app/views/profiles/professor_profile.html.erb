<% content_for :title, "Perfil de #{@user.nome}" %>

<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
  <div class="container mx-auto px-4 py-6 max-w-6xl">

    <%# Header Card com Banner %>
    <div class="bg-white shadow-2xl rounded-3xl overflow-hidden mb-6">
      
      <%# Banner com gradiente %>
      <div class="h-40 md:h-48 relative" style="background: linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%);">
        
        <%# Botão de Editar %>
        <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
          <%= link_to edit_profile_path, class: "btn btn-circle btn-sm md:btn-md bg-white hover:bg-gray-50 border-0 shadow-xl transition-all hover:scale-110" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-green-600 w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>

          <% end %>
        </div>

        <%# Padrão decorativo %>
        <div class="absolute inset-0 opacity-10">
          <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <circle cx="20" cy="20" r="2" fill="white"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)"/>
          </svg>
        </div>
      </div>
      
      <%# Conteúdo do Perfil - ABAIXO DO BANNER %>
      <div class="px-4 md:px-10 py-6 md:py-8">
        
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
          <%# Avatar %>
          <div class="avatar flex-shrink-0">
            <div class="w-24 h-24 md:w-32 md:h-32 rounded-3xl shadow-2xl bg-gradient-to-br from-green-400 to-emerald-600 relative">
              <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                <%= image_tag @user.foto.variant(resize_to_fill: [128, 128]), class: "object-cover h-full w-full rounded-3xl" %>
              <% else %>
                <span class="text-4xl md:text-5xl font-bold text-white absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                  <%= @user.nome.present? ? @user.nome.first.upcase : 'P' %>
                </span>
              <% end %>
            </div>
          </div>

          <%# Informações Principais %>
          <div class="flex-grow">
            <h1 class="text-2xl md:text-4xl font-bold text-gray-800 mb-2"><%= @user.nome %></h1>
            <div class="flex flex-wrap items-center gap-3 md:gap-4 text-gray-600 mb-3">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-xs md:text-sm"><%= @user.email %></span>
              </div>
              <% if @user.telefone.present? %>
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-xs md:text-sm"><%= @user.telefone %></span>
                </div>
              <% end %>
            </div>
            <div class="flex flex-wrap gap-2">
              <% if @user.formacao.present? %>
                <div class="badge badge-md md:badge-lg bg-green-100 text-green-700 border-0 gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path d="M12 14l9-5-9-5-9 5 9 5z" />
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                  </svg>
                  <%= @user.formacao.humanize.capitalize %>
                </div>
              <% end %>
              <% if @user.respond_to?(:escola) && @user.escola %>
                <div class="badge badge-md md:badge-lg bg-blue-100 text-blue-700 border-0 gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                  </svg>
                  <%= @user.escola.nome %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
      </div>
    </div>

    <%# Estatísticas Rápidas %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      
      <%# Total de Notas %>
      <% if @user.respond_to?(:total_notas_cadastradas) %>
        <div class="bg-white rounded-2xl p-5 shadow-lg hover:shadow-xl transition-shadow border-l-4 border-yellow-500">
          <div class="flex items-center justify-between mb-3">
            <div class="bg-yellow-100 p-3 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.92L12 17.77 5.82 21.06 7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @user.total_notas_cadastradas %></h3>
          <p class="text-gray-600 text-sm font-medium">Notas Lançadas</p>
        </div>
      <% end %>

      <%# Escola %>
      <% if @user.respond_to?(:escola) && @user.escola %>
        <div class="bg-white rounded-2xl p-5 shadow-lg hover:shadow-xl transition-shadow border-l-4 border-amber-600">
          <div class="flex items-center justify-between mb-3">
            <div class="bg-amber-100 p-3 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
              </svg>
            </div>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-1 truncate"><%= @user.escola.nome %></h3>
          <p class="text-gray-600 text-sm font-medium">Escola</p>
        </div>
      <% end %>

      <%# Frequências %>
      <% if @user.respond_to?(:total_frequencias_cadastradas) %>
        <div class="bg-white rounded-2xl p-5 shadow-lg hover:shadow-xl transition-shadow border-l-4 border-pink-500">
          <div class="flex items-center justify-between mb-3">
            <div class="bg-pink-100 p-3 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @user.total_frequencias_cadastradas %></h3>
          <p class="text-gray-600 text-sm font-medium">Frequências Reg.</p>
        </div>
      <% end %>

      <%# Disciplinas %>
      <% if @user.respond_to?(:disciplinas) %>
        <div class="bg-white rounded-2xl p-5 shadow-lg hover:shadow-xl transition-shadow border-l-4 border-purple-500">
          <div class="flex items-center justify-between mb-3">
            <div class="bg-purple-100 p-3 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @user.disciplinas.count %></h3>
          <p class="text-gray-600 text-sm font-medium">Disciplinas</p>
        </div>
      <% end %>

    </div>

    <%# Minhas Disciplinas %>
    <% if @user.respond_to?(:disciplinas) && @user.disciplinas.any? %>
      <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8 mb-6">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-green-400 to-emerald-600 p-4 rounded-2xl shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-800">Minhas Disciplinas</h2>
            <p class="text-gray-600">Disciplinas que você leciona</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @user.disciplinas.each do |disciplina| %>
            <%
              # Define cores baseadas na área quando não tem cor própria
              cores_padrao = {
                'exatas' => '#3b82f6',
                'humanas' => '#f59e0b', 
                'linguagens' => '#8b5cf6',
                'natureza' => '#10b981'
              }
              
              # Usa a cor da disciplina ou cor padrão baseada na área
              disciplina_cor = disciplina.cor.presence || cores_padrao[disciplina.area] || '#6b7280'
            %>
            
            <div class="group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 cursor-pointer" 
                 style="background: linear-gradient(135deg, <%= disciplina_cor %> 0%, <%= disciplina_cor %>dd 100%);">
              
              <%# Padrão de fundo %>
              <div class="absolute inset-0 opacity-10">
                <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <pattern id="pattern-<%= disciplina.id %>" width="20" height="20" patternUnits="userSpaceOnUse">
                      <circle cx="10" cy="10" r="1.5" fill="white"/>
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#pattern-<%= disciplina.id %>)"/>
                </svg>
              </div>

              <div class="relative p-6">
                <%# Ícone da Área %>
                <div class="flex items-start justify-between mb-4">
                  <div class="p-3 rounded-xl" style="background-color: rgba(0, 0, 0, 0.2);">
                    <% case disciplina.area %>
                    <% when 'exatas' %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: rgba(255, 255, 255, 0.95);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                      </svg>
                    <% when 'humanas' %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: rgba(255, 255, 255, 0.95);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    <% when 'linguagens' %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: rgba(255, 255, 255, 0.95);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                      </svg>
                    <% when 'natureza' %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: rgba(255, 255, 255, 0.95);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                      </svg>
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: rgba(255, 255, 255, 0.95);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                      </svg>
                    <% end %>
                  </div>
                  
                  <div class="badge badge-sm border-0" style="background-color: rgba(0, 0, 0, 0.2); color: rgba(255, 255, 255, 0.95);">
                    <%= disciplina.area&.humanize || 'Geral' %>
                  </div>
                </div>

                <%# Nome da Disciplina %>
                <h3 class="text-xl font-bold mb-2 group-hover:scale-105 transition-transform" style="color: rgba(255, 255, 255, 0.95);">
                  <%= disciplina.nome %>
                </h3>

                <%# Info Extra %>
                <div class="flex items-center justify-between text-sm" style="color: rgba(255, 255, 255, 0.9);">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <span>Alunos</span>
                  </div>
                  <% if disciplina.cor_nome.present? %>
                    <span class="text-xs px-2 py-1 rounded-full" style="background-color: rgba(0, 0, 0, 0.2); color: rgba(255, 255, 255, 0.95);"><%= disciplina.cor_nome %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Informações Adicionais %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <%# Sobre Mim %>
      <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-blue-400 to-blue-600 p-4 rounded-2xl shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Sobre Mim</h2>
            <p class="text-gray-600">Informações pessoais</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl">
            <div class="bg-green-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Nome Completo</p>
              <p class="text-gray-800 font-medium"><%= @user.nome %></p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl">
            <div class="bg-blue-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">E-mail</p>
              <p class="text-gray-800 font-medium"><%= @user.email %></p>
            </div>
          </div>

          <% if @user.cpf.present? %>
            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl">
              <div class="bg-purple-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">CPF</p>
                <p class="text-gray-800 font-medium"><%= @user.cpf %></p>
              </div>
            </div>
          <% end %>

          <% if @user.telefone.present? %>
            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl">
              <div class="bg-teal-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Telefone</p>
                <p class="text-gray-800 font-medium"><%= @user.telefone %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Atividade Recente %>
      <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-purple-400 to-purple-600 p-4 rounded-2xl shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Atividade Recente</h2>
            <p class="text-gray-600">Últimas ações</p>
          </div>
        </div>

        <div class="space-y-3">
          <% if @user.respond_to?(:total_notas_cadastradas) && @user.total_notas_cadastradas > 0 %>
            <div class="flex items-center gap-4 p-4 bg-yellow-50 rounded-xl border-l-4 border-yellow-500">
              <div class="bg-yellow-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.92L12 17.77 5.82 21.06 7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div class="flex-grow">
                <p class="font-semibold text-gray-800">Notas Cadastradas</p>
                <p class="text-sm text-gray-600"><%= @user.total_notas_cadastradas %> registros no sistema</p>
              </div>
            </div>
          <% end %>

          <% if @user.respond_to?(:total_frequencias_cadastradas) && @user.total_frequencias_cadastradas > 0 %>
            <div class="flex items-center gap-4 p-4 bg-pink-50 rounded-xl border-l-4 border-pink-500">
              <div class="bg-pink-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="font-semibold text-gray-800">Frequências Registradas</p>
                <p class="text-sm text-gray-600"><%= @user.total_frequencias_cadastradas %> chamadas realizadas</p>
              </div>
            </div>
          <% end %>

          <% if @user.respond_to?(:disciplinas) && @user.disciplinas.any? %>
            <div class="flex items-center gap-4 p-4 bg-green-50 rounded-xl border-l-4 border-green-500">
              <div class="bg-green-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="font-semibold text-gray-800">Lecionando Disciplinas</p>
                <p class="text-sm text-gray-600"><%= @user.disciplinas.count %> disciplinas ativas</p>
              </div>
            </div>
          <% end %>

          <% unless @user.respond_to?(:total_notas_cadastradas) && @user.total_notas_cadastradas > 0 %>
            <div class="text-center py-8">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              <p class="text-gray-500">Nenhuma atividade recente</p>
            </div>
          <% end %>
        </div>
      </div>

    </div>

  </div>
</div>