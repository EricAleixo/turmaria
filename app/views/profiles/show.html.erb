<% content_for :title, "Meu Perfil - #{@user.nome}" %>

<div class="drawer lg:drawer-open bg-gray-100">
  <div class="drawer-content flex flex-col">
    <div class="w-full p-6">
      
      <main class="w-full max-w-7xl mx-auto">
        
        <div class="flex items-center mb-6 justify-end">
          <%= link_to edit_profile_path, class: "btn bg-amber-500 hover:bg-amber-600 text-white border-none" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
            Editar Perfil
          <% end %>
        </div>

        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Detalhes do Meu Perfil</h1>
          <p class="text-gray-600">Informações de login e dados pessoais</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg">
            <div class="flex flex-col items-center text-center">
              
              <div class="avatar placeholder mb-4">
                <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                  <%= image_tag @user.foto.variant(resize_to_fill: [96, 96]), class: "rounded-full w-24 h-24 ring-4 ring-green-500/20 object-cover" %>
                <% else %>
                  <div class="bg-green-500 text-white rounded-full w-24 h-24 relative ring-4 ring-green-500/20">
                    <span class="text-3xl font-bold absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                      <%= @user.nome.present? ? @user.nome.first.upcase : 'U' %>
                    </span>
                  </div>
                <% end %>
              </div>
              
              <h2 class="text-2xl font-bold text-gray-900 mb-1">
                <%= @user.nome.presence || 'Nome não informado' %>
              </h2>
              <p class="text-gray-600 mb-4">
                Tipo de Usuário: 
                <span class="font-bold text-green-700"><%= @user.class.model_name.human %></span>
              </p>
              
              <div class="flex items-center gap-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Usuário Ativo
              </div>
            </div>
          </div>
          
          <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-lg lg:col-span-2">
            <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              Informações de Contato e Login
            </h3>
            
            <div class="space-y-4">
              
              <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg border border-blue-200">
                <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <span class="text-sm font-medium text-blue-800 block">Email</span>
                  <p class="text-blue-900 font-semibold break-all"><%= @user.email.presence || 'Não informado' %></p>
                </div>
              </div>
              
              <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-green-50 to-green-100 rounded-lg border border-green-200">
                <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.986.986l.51 2.551a1 1 0 01-.225.961l-1.528 1.528a11.058 11.058 0 005.15 5.15l1.528-1.528a1 1 0 01.961-.225l2.551.51a1 1 0 01.986.986V19a2 2 0 01-2 2h-1C9.754 21 3 14.246 3 6V5z" /></svg>
                </div>
                <div class="flex-1">
                  <span class="text-sm font-medium text-green-800 block">Telefone</span>
                  <p class="text-green-900 font-semibold"><%= @user.telefone.presence || 'Não informado' %></p>
                </div>
              </div>

              <% if @user.is_a?(Aluno) %>
              
                <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-purple-50 to-purple-100 rounded-lg border border-purple-200">
                  <div class="w-8 h-8 bg-purple-500 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-4 10h.01M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  </div>
                  <div class="flex-1">
                    <span class="text-sm font-medium text-purple-800 block">Data de Nascimento</span>
                    <p class="text-purple-900 font-semibold">
                      <%= @user.data_nascimento.present? ? l(@user.data_nascimento) : 'Não informada' %>
                    </p>
                  </div>
                </div>

              <% elsif @user.is_a?(Professor) %>

                <div class="flex items-start gap-3 p-3 bg-gradient-to-r from-amber-50 to-amber-100 rounded-lg border border-amber-200">
                  <div class="w-8 h-8 bg-amber-500 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4v2m0 2a2 2 0 100 4m0-4v2m0 2a2 2 0 100 4m0-4v2m0 2a2 2 0 100 4m0-4v2" /></svg>
                  </div>
                  <div class="flex-1">
                    <span class="text-sm font-medium text-amber-800 block">Formação</span>
                    <p class="text-amber-900 font-semibold">
                      <%= @user.formacao.presence || 'Não informada' %>
                    </p>
                  </div>
                </div>

              <% end %>
            </div>
          </div>
          
        </div>
      </main>
    </div>
  </div>
</div>