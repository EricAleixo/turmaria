<% content_for :title, "Perfil de #{@user.nome}" %>

<div class="bg-gray-100 min-h-screen font-sans">
  <div class="max-w-4xl mx-auto">

    <div class="bg-white shadow-lg rounded-b-xl pb-4">
      
      <div class="h-36 bg-green-500 relative rounded-b-[2rem]">
        
        <div class="absolute top-4 right-4 z-20">
          <%= link_to edit_profile_path, class: "btn btn-sm btn-circle bg-white text-green-500 border-0 hover:bg-gray-100 transition shadow-lg" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H10v-1.828l6.386-6.386z" /></svg>
          <% end %>
        </div>
      </div>
      
      <div class="px-4 md:px-8 -mt-20 relative z-10 flex flex-col items-start"> 
        
        <div class="avatar relative mr-4 mb-4">
          <div class="w-24 h-24 md:w-28 md:h-28 rounded-full ring-4 ring-white shadow-2xl bg-gray-300">
            <% if @user.respond_to?(:foto) && @user.foto.attached? %>
              <%= image_tag @user.foto.variant(resize_to_fill: [112, 112]), class: "object-cover h-full w-full rounded-full" %>
            <% else %>
              <span class="text-4xl md:text-5xl font-bold text-gray-600 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                <%= @user.nome.present? ? @user.nome.first.upcase : 'U' %>
              </span>
            <% end %>
          </div>
        </div>

        <div class="flex-grow"> 
          <h1 class="text-2xl font-bold text-gray-800 leading-tight"><%= @user.nome %></h1>
          <p class="text-sm text-gray-500 mb-2"><%= @user.email %></p>
        </div>
      </div>
      
    </div>

    <div class="pt-4"> 
      <% if @user.is_a?(Professor) || @user.is_a?(Aluno) %>
        
        <div class="grid grid-cols-2 gap-4">
          
          <% if @user.respond_to?(:total_notas_cadastradas) %>
            <%= card_metric(
              '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-star-fill"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.92L12 17.77 5.82 21.06 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
              'bg-yellow-500',
              @user.total_notas_cadastradas,
              @user.is_a?(Professor) ? 'Notas Cadastradas' : 'Balance'
            ) %>
          <% end %>

          <% if @user.respond_to?(:escola) && @user.escola %>
            <%= card_metric(
              # NOVO ÍCONE: SVG da Escola (Super Admin Sidebar)
              '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>',
              'bg-amber-600',
              @user.escola.nome,
              'Escola/Level'
            ) %>
          <% end %>
          
          <% if @user.respond_to?(:total_frequencias_cadastradas) %>
            <%= card_metric(
              # NOVO ÍCONE: SVG da Frequência (Professor Sidebar)
              '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
              'bg-pink-400',
              @user.total_frequencias_cadastradas,
              @user.is_a?(Professor) ? 'Frequências Reg.' : 'Current League'
            ) %>
          <% end %>

          <% if @user.is_a?(Professor) || @user.is_a?(Aluno) %>
            <%= card_metric(
              '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-zap-fill"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
              'bg-yellow-400',
              @user.is_a?(Professor) ? @user.formacao.humanize.capitalize : (@user.idade || 'N/A'),
              @user.is_a?(Professor) ? 'Formação' : 'Total XP/Idade'
            ) %>
          <% end %>

        </div>
        
      <% else %>
        <div class="mt-4 pb-4">
          <div class="alert alert-info shadow-lg bg-green-500 text-white border-none">
            <div>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current flex-shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span>Este é um perfil de <%= @user.class.to_s.humanize %>. Apenas informações administrativas e básicas são exibidas.</span>
            </div>
          </div>
        </div>
      <% end %>
      
    </div>
  </div>
</div>