<% content_for :title, "Painel do Super Administrador" %>

<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
  <div class="container mx-auto px-4 py-6 max-w-7xl">

    <%# Header Card - SuperAdmin %>
    <div class="bg-white shadow-lg rounded-3xl overflow-hidden mb-6 relative border border-green-100">
      
      <%# Padrão decorativo sutil %>
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="super-grid" width="50" height="50" patternUnits="userSpaceOnUse">
              <circle cx="25" cy="25" r="2" fill="#10b981"/>
              <circle cx="0" cy="0" r="1" fill="#10b981"/>
              <circle cx="50" cy="50" r="1" fill="#10b981"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#super-grid)"/>
        </svg>
      </div>

      <%# Botão de Editar %>
      <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
        <%= link_to edit_profile_path, class: "btn btn-circle btn-sm md:btn-md bg-green-50 hover:bg-green-100 border border-green-200 shadow-sm transition-all hover:scale-110" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-green-600 w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
          </svg>
        <% end %>
      </div>

      <div class="relative px-6 md:px-10 py-8 md:py-12">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          
          <%# Avatar com badge SuperAdmin %>
          <div class="relative flex-shrink-0">
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-3xl shadow-md bg-gradient-to-br from-green-400 to-emerald-500 relative ring-4 ring-green-100">
              <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                <%= image_tag @user.foto.variant(resize_to_fill: [144, 144]), class: "object-cover h-full w-full rounded-3xl" %>
              <% else %>
                <span class="text-5xl md:text-6xl font-bold text-white absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                  <%= @user.nome.present? ? @user.nome.first.upcase : 'S' %>
                </span>
              <% end %>
            </div>
            
            <%# Badge SuperAdmin %>
            <div class="absolute -bottom-2 -right-2 bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl px-3 py-1 shadow-md">
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="text-xs font-bold text-white">SUPER</span>
              </div>
            </div>
          </div>

          <%# Informações %>
          <div class="flex-grow">
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl md:text-5xl font-black text-gray-800">
                <%= @user.nome.present? ? @user.nome : 'Super Administrador' %>
              </h1>
              <div class="badge badge-lg bg-green-50 text-green-700 border border-green-200 font-bold gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Acesso Total
              </div>
            </div>
            
            <p class="text-gray-600 text-lg mb-4">Controle total do sistema</p>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-700">
              <div class="flex items-center gap-2 bg-green-50 border border-green-100 rounded-xl px-4 py-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-sm font-medium"><%= @user.email %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Dashboard Stats %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      
      <%# Total de Escolas %>
      <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-blue-500 group">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-blue-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
        </div>
        <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= Escola.count %></h3>
        <p class="text-gray-600 text-sm font-medium">Escolas no Sistema</p>
      </div>

      <%# Total de Professores %>
      <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-green-500 group">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-green-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
        </div>
        <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= Professor.count %></h3>
        <p class="text-gray-600 text-sm font-medium">Professores Ativos</p>
      </div>

      <%# Total de Alunos %>
      <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-emerald-500 group">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-emerald-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
        </div>
        <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= Aluno.count %></h3>
        <p class="text-gray-600 text-sm font-medium">Alunos Matriculados</p>
      </div>

      <%# Total de Administradores %>
      <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-teal-500 group">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-teal-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
        </div>
        <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= Admin.count %></h3>
        <p class="text-gray-600 text-sm font-medium">Administradores</p>
      </div>

    </div>

    <%# Main Content Grid %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <%# Informações da Conta %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Informações da Conta</h2>
            <p class="text-gray-600">Dados do super administrador</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-green-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Nome</p>
              <p class="text-gray-800 font-medium"><%= @user.nome.present? ? @user.nome : 'Não definido' %></p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-green-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">E-mail</p>
              <p class="text-gray-800 font-medium"><%= @user.email %></p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-green-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Tipo de Conta</p>
              <p class="text-gray-800 font-medium">Super Administrador</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-green-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Membro desde</p>
              <p class="text-gray-800 font-medium"><%= @user.created_at.strftime('%d/%m/%Y') %></p>
            </div>
          </div>
        </div>
      </div>

      <%# Permissões e Acesso %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Permissões de Acesso</h2>
            <p class="text-gray-600">Controle total do sistema</p>
          </div>
        </div>

        <div class="space-y-3">
          <% permissions = [
            { icon: 'school', title: 'Gerenciar Escolas', desc: 'Criar, editar e excluir escolas' },
            { icon: 'users', title: 'Gerenciar Usuários', desc: 'Administrar todos os tipos de usuários' },
            { icon: 'shield', title: 'Gerenciar Admins', desc: 'Criar e gerenciar administradores' },
            { icon: 'settings', title: 'Configurações do Sistema', desc: 'Acesso total às configurações' },
            { icon: 'database', title: 'Backup e Dados', desc: 'Gerenciar backups e exportações' },
            { icon: 'chart', title: 'Relatórios Globais', desc: 'Visualizar estatísticas completas' }
          ] %>

          <% permissions.each do |perm| %>
            <div class="flex items-center gap-4 p-4 bg-green-50 rounded-xl border border-green-100 hover:bg-green-100 transition-all">
              <div class="flex-shrink-0">
                <div class="bg-green-100 p-2 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <div class="flex-grow">
                <p class="font-semibold text-gray-800"><%= perm[:title] %></p>
                <p class="text-sm text-gray-600"><%= perm[:desc] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    </div>

    <%# Ações Rápidas %>
    <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md mt-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-800">Ações Rápidas</h2>
          <p class="text-gray-600">Acessos diretos às principais funções</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="group bg-green-50 hover:bg-green-100 border border-green-100 rounded-2xl p-5 transition-all hover:scale-105">
          <div class="flex items-center gap-3 mb-3">
            <div class="bg-green-100 p-3 rounded-xl group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-800">Gerenciar Escolas</h3>
          </div>
          <p class="text-sm text-gray-600">Adicionar e administrar escolas do sistema</p>
        </div>

        <div class="group bg-green-50 hover:bg-green-100 border border-green-100 rounded-2xl p-5 transition-all hover:scale-105">
          <div class="flex items-center gap-3 mb-3">
            <div class="bg-green-100 p-3 rounded-xl group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-800">Gerenciar Usuários</h3>
          </div>
          <p class="text-sm text-gray-600">Administrar professores, alunos e admins</p>
        </div>

        <div class="group bg-green-50 hover:bg-green-100 border border-green-100 rounded-2xl p-5 transition-all hover:scale-105">
          <div class="flex items-center gap-3 mb-3">
            <div class="bg-green-100 p-3 rounded-xl group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-800">Ver Relatórios</h3>
          </div>
          <p class="text-sm text-gray-600">Visualizar estatísticas e relatórios globais</p>
        </div>
      </div>
    </div>
  </div>
</div>