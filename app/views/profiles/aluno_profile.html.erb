<% content_for :title, "Meu Perfil" %>

<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
  <div class="container mx-auto px-4 py-6 max-w-7xl">

    <%# Header Card - Aluno %>
    <div class="bg-white shadow-lg rounded-3xl overflow-hidden mb-6 relative border border-green-100">
      
      <%# Padrão decorativo sutil %>
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="aluno-grid" width="50" height="50" patternUnits="userSpaceOnUse">
              <circle cx="25" cy="25" r="2" fill="#10b981"/>
              <circle cx="0" cy="0" r="1" fill="#10b981"/>
              <circle cx="50" cy="50" r="1" fill="#10b981"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#aluno-grid)"/>
        </svg>
      </div>

      <%# Botão de Editar %>
      <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
        <%= link_to edit_profile_path, class: "btn btn-circle btn-sm md:btn-md bg-green-50 hover:bg-green-100 border border-green-200 shadow-sm transition-all hover:scale-110" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-green-600 w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
          </svg>
        <% end %>
      </div>

      <div class="relative px-6 md:px-10 py-8 md:py-12">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          
          <%# Avatar com badge Aluno %>
          <div class="relative flex-shrink-0">
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-3xl shadow-md bg-gradient-to-br from-green-400 to-emerald-500 relative ring-4 ring-green-100">
              <% if @user.foto_url.present? %>
                <%= image_tag @user.foto_url, class: "object-cover h-full w-full rounded-3xl" %>
              <% else %>
                <span class="text-5xl md:text-6xl font-bold text-white absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                  <%= @user.nome.present? ? @user.nome.first.upcase : 'A' %>
                </span>
              <% end %>
            </div>
            
            <%# Badge Aluno %>
            <div class="absolute -bottom-2 -right-2 bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl px-3 py-1 shadow-md">
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z" />
                </svg>
                <span class="text-xs font-bold text-white">ALUNO</span>
              </div>
            </div>
          </div>

          <%# Informações %>
          <div class="flex-grow">
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl md:text-5xl font-black text-gray-800">
                <%= @user.nome.present? ? @user.nome : 'Aluno' %>
              </h1>
              <div class="badge badge-lg bg-green-50 text-green-700 border border-green-200 font-bold gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z" />
                </svg>
                Estudante
              </div>
            </div>
            
            <% if @turma.present? %>
              <p class="text-gray-600 text-lg mb-4"><%= @turma.nome %> - <%= @escola.nome %></p>
            <% elsif @escola.present? %>
              <p class="text-gray-600 text-lg mb-4"><%= @escola.nome %></p>
            <% else %>
              <p class="text-gray-600 text-lg mb-4">Aluno</p>
            <% end %>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-700">
              <% if @user.matricula.present? %>
                <div class="flex items-center gap-2 bg-white border border-green-200 rounded-xl px-4 py-2 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                  </svg>
                  <span class="text-sm font-medium">Matrícula: <%= @user.matricula %></span>
                </div>
              <% end %>
              
              <% if @user.idade.present? %>
                <div class="flex items-center gap-2 bg-white border border-green-200 rounded-xl px-4 py-2 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span class="text-sm font-medium"><%= @user.idade %> anos</span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Main Content Grid %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <%# Informações Pessoais %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Informações Pessoais</h2>
            <p class="text-gray-600">Dados cadastrais</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-white p-2 rounded-lg border border-green-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Nome Completo</p>
              <p class="text-gray-800 font-medium"><%= @user.nome.present? ? @user.nome : 'Não definido' %></p>
            </div>
          </div>

          <% if @user.data_nascimento.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Data de Nascimento</p>
                <p class="text-gray-800 font-medium"><%= @user.data_nascimento.strftime('%d/%m/%Y') %></p>
              </div>
            </div>
          <% end %>

          <% if @user.cpf.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">CPF</p>
                <p class="text-gray-800 font-medium"><%= @user.cpf %></p>
              </div>
            </div>
          <% end %>

          <% if @user.rg.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">RG</p>
                <p class="text-gray-800 font-medium"><%= @user.rg %></p>
              </div>
            </div>
          <% end %>

          <% if @user.email.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">E-mail</p>
                <p class="text-gray-800 font-medium"><%= @user.email %></p>
              </div>
            </div>
          <% end %>

          <% if @user.telefone.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Telefone</p>
                <p class="text-gray-800 font-medium"><%= @user.telefone %></p>
              </div>
            </div>
          <% end %>

          <% if @user.sexo.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Sexo</p>
                <p class="text-gray-800 font-medium"><%= @user.sexo %></p>
              </div>
            </div>
          <% end %>

          <% if @user.tipo_sanguinio.present? %>
            <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
              <div class="bg-white p-2 rounded-lg border border-green-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Tipo Sanguíneo</p>
                <p class="text-gray-800 font-medium"><%= @user.tipo_sanguinio %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Informações dos Responsáveis %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Responsáveis</h2>
            <p class="text-gray-600">Contatos de emergência</p>
          </div>
        </div>

        <div class="space-y-4">
          <% if @user.responsavel_1.present? %>
            <div class="p-5 bg-green-50 rounded-2xl border border-green-200 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <div class="bg-white p-2 rounded-lg border border-green-200">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold text-green-600 uppercase">Responsável 1</p>
                  <p class="text-lg font-bold text-gray-800"><%= @user.responsavel_1 %></p>
                </div>
              </div>
              <% if @user.telefone_responsavel_1.present? %>
                <div class="flex items-center gap-2 text-gray-700 bg-white rounded-lg px-3 py-2 border border-green-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-sm font-medium"><%= @user.telefone_responsavel_1 %></span>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if @user.responsavel_2.present? %>
            <div class="p-5 bg-green-50 rounded-2xl border border-green-200 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <div class="bg-white p-2 rounded-lg border border-green-200">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold text-green-600 uppercase">Responsável 2</p>
                  <p class="text-lg font-bold text-gray-800"><%= @user.responsavel_2 %></p>
                </div>
              </div>
              <% if @user.telefone_responsavel_2.present? %>
                <div class="flex items-center gap-2 text-gray-700 bg-white rounded-lg px-3 py-2 border border-green-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span class="text-sm font-medium"><%= @user.telefone_responsavel_2 %></span>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if @user.responsavel_1.blank? && @user.responsavel_2.blank? %>
            <div class="text-center py-8">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <p class="text-gray-500 font-medium">Nenhum responsável cadastrado</p>
            </div>
          <% end %>
        </div>
      </div>

    </div>

    <%# Informações Acadêmicas %>
    <div class="bg-white rounded-3xl p-6 md:p-8 border border-green-100 shadow-md mt-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="bg-gradient-to-br from-green-400 to-emerald-500 p-4 rounded-2xl shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-800">Informações Acadêmicas</h2>
          <p class="text-gray-600">Dados da escola e turma</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% if @escola.present? %>
          <div class="flex items-start gap-4 p-4 bg-green-50 rounded-xl border border-green-100">
            <div class="bg-white p-2 rounded-lg border border-green-200">
