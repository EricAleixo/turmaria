<% content_for :title, "Painel do Administrador" %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50">
  <div class="container mx-auto px-4 py-6 max-w-7xl">

    <%# Header Card - Admin %>
    <div class="bg-white shadow-lg rounded-3xl overflow-hidden mb-6 relative border border-blue-100">
      
      <%# Padrão decorativo sutil %>
      <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="admin-grid" width="50" height="50" patternUnits="userSpaceOnUse">
              <circle cx="25" cy="25" r="2" fill="#6366f1"/>
              <circle cx="0" cy="0" r="1" fill="#6366f1"/>
              <circle cx="50" cy="50" r="1" fill="#6366f1"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#admin-grid)"/>
        </svg>
      </div>

      <%# Botão de Editar %>
      <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
        <%= link_to edit_profile_path, class: "btn btn-circle btn-sm md:btn-md bg-blue-50 hover:bg-blue-100 border border-blue-200 shadow-sm transition-all hover:scale-110" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-blue-600 w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
          </svg>
        <% end %>
      </div>

      <div class="relative px-6 md:px-10 py-8 md:py-12">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          
          <%# Avatar com badge Admin %>
          <div class="relative flex-shrink-0">
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-3xl shadow-md bg-gradient-to-br from-blue-400 to-indigo-500 relative ring-4 ring-blue-100">
              <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                <%= image_tag @user.foto.variant(resize_to_fill: [144, 144]), class: "object-cover h-full w-full rounded-3xl" %>
              <% else %>
                <span class="text-5xl md:text-6xl font-bold text-white absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                  <%= @user.nome.present? ? @user.nome.first.upcase : 'A' %>
                </span>
              <% end %>
            </div>
            
            <%# Badge Admin %>
            <div class="absolute -bottom-2 -right-2 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-2xl px-3 py-1 shadow-md">
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-xs font-bold text-white">ADMIN</span>
              </div>
            </div>
          </div>

          <%# Informações %>
          <div class="flex-grow">
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-3xl md:text-5xl font-black text-gray-800">
                <%= @user.nome.present? ? @user.nome : 'Administrador' %>
              </h1>
              <div class="badge badge-lg bg-blue-50 text-blue-700 border border-blue-200 font-bold gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Administrador
              </div>
            </div>
            
            <% if @escola.present? %>
              <p class="text-gray-600 text-lg mb-4">Gerenciando <%= @escola.nome %></p>
            <% else %>
              <p class="text-gray-600 text-lg mb-4">Sem escola vinculada</p>
            <% end %>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-700">
              <div class="flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-xl px-4 py-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-sm font-medium"><%= @user.email %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Dashboard Stats da Escola %>
    <% if @escola.present? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        
        <%# Total de Turmas %>
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-blue-500 group">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-blue-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @escola.turmas_count %></h3>
          <p class="text-gray-600 text-sm font-medium">Turmas</p>
        </div>

        <%# Total de Alunos %>
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-indigo-500 group">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-indigo-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @escola.alunos_count %></h3>
          <p class="text-gray-600 text-sm font-medium">Alunos Matriculados</p>
        </div>

        <%# Total de Professores %>
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-purple-500 group">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-purple-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @escola.professors.count %></h3>
          <p class="text-gray-600 text-sm font-medium">Professores</p>
        </div>

        <%# Tipo de Escola %>
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all border-l-4 border-pink-500 group">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-pink-100 p-3 rounded-xl shadow-lg group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-1"><%= @escola.tipo_humanizado %></h3>
          <p class="text-gray-600 text-sm font-medium">Tipo de Escola</p>
        </div>

      </div>
    <% end %>

    <%# Main Content Grid %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <%# Informações da Conta %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-blue-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-blue-400 to-indigo-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Informações da Conta</h2>
            <p class="text-gray-600">Dados do administrador</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
            <div class="bg-blue-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Nome</p>
              <p class="text-gray-800 font-medium"><%= @user.nome.present? ? @user.nome : 'Não definido' %></p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
            <div class="bg-blue-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">E-mail</p>
              <p class="text-gray-800 font-medium"><%= @user.email %></p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
            <div class="bg-blue-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Tipo de Conta</p>
              <p class="text-gray-800 font-medium">Administrador</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
            <div class="bg-blue-100 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex-grow">
              <p class="text-sm font-semibold text-gray-600 mb-1">Membro desde</p>
              <p class="text-gray-800 font-medium"><%= @user.created_at.strftime('%d/%m/%Y') %></p>
            </div>
          </div>
        </div>
      </div>

      <%# Informações da Escola %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-blue-100 shadow-md">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-blue-400 to-indigo-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Informações da Escola</h2>
            <p class="text-gray-600">Dados da instituição</p>
          </div>
        </div>

        <% if @escola.present? %>
          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
              <div class="bg-blue-100 p-2 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div class="flex-grow">
                <p class="text-sm font-semibold text-gray-600 mb-1">Nome da Escola</p>
                <p class="text-gray-800 font-medium"><%= @escola.nome %></p>
              </div>
            </div>

            <% if @escola.cnpj.present? %>
              <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <div class="bg-blue-100 p-2 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="flex-grow">
                  <p class="text-sm font-semibold text-gray-600 mb-1">CNPJ</p>
                  <p class="text-gray-800 font-medium"><%= @escola.cnpj %></p>
                </div>
              </div>
            <% end %>

            <% if @escola.telefone.present? %>
              <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <div class="bg-blue-100 p-2 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div class="flex-grow">
                  <p class="text-sm font-semibold text-gray-600 mb-1">Telefone</p>
                  <p class="text-gray-800 font-medium"><%= @escola.telefone %></p>
                </div>
              </div>
            <% end %>

            <% if @escola.email.present? %>
              <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <div class="bg-blue-100 p-2 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-grow">
                  <p class="text-sm font-semibold text-gray-600 mb-1">E-mail da Escola</p>
                  <p class="text-gray-800 font-medium"><%= @escola.email %></p>
                </div>
              </div>
            <% end %>

            <% if @escola.endereco.present? %>
              <div class="flex items-start gap-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <div class="bg-blue-100 p-2 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="flex-grow">
                  <p class="text-sm font-semibold text-gray-600 mb-1">Endereço</p>
                  <p class="text-gray-800 font-medium"><%= @escola.endereco_completo %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <p class="text-gray-500 font-medium">Nenhuma escola vinculada</p>
            <p class="text-gray-400 text-sm mt-2">Entre em contato com o super administrador para vincular uma escola</p>
          </div>
        <% end %>
      </div>

    </div>

    <% if @escola.present? %>
      <div class="bg-white rounded-3xl p-6 md:p-8 border border-blue-100 shadow-md mt-6">
        <div class="flex items-center gap-4 mb-6">
          <div class="bg-gradient-to-br from-blue-400 to-indigo-500 p-4 rounded-2xl shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Ações Rápidas</h2>
            <p class="text-gray-600">Acessos diretos às principais funções</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <%= link_to "#", class: "group bg-blue-50 hover:bg-blue-100 border border-blue-100 rounded-2xl p-5 transition-all hover:scale-105" do %>
            <div class="flex items-center gap-3 mb-3">
              <div class="bg-blue-100 p-3 rounded-xl group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
              </div>
              <h3 class="font-bold text-gray-800">Gerenciar Turmas</h3>
            </div>
            <p class="text-sm text-gray-600">Visualizar e administrar turmas</p>
          <% end %>

