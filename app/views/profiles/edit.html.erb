<% content_for :title, "Editar Perfil de #{@user.nome}" %>

<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
  <div class="container mx-auto px-4 py-6 max-w-4xl">
    
    <%= form_with(model: @user, 
                  scope: @user.model_name.singular.to_sym,
                  url: profile_path, 
                  method: :patch, 
                  html: { class: "w-full", multipart: true, id: "profile-form" }, 
                  data: { turbo: false }, 
                  novalidate: true) do |f| %>
      
      <%# Header Card com Banner %>
      <div class="bg-white shadow-2xl rounded-3xl overflow-hidden mb-6">
        
        <%# Banner com gradiente %>
        <div class="h-40 md:h-48 relative" style="background: linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%);">
          
          <%# Botão Cancelar %>
          <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
            <%= link_to profile_path, class: "btn btn-circle btn-sm md:btn-md bg-white hover:bg-gray-50 border-0 shadow-xl transition-all hover:scale-110" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>

          <%# Padrão decorativo %>
          <div class="absolute inset-0 opacity-10">
            <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                  <circle cx="20" cy="20" r="2" fill="white"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)"/>
            </svg>
          </div>
        </div>
        
        <%# Conteúdo do Perfil %>
        <div class="px-4 md:px-10 py-6 md:py-8">
          
          <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
            <%# Avatar Editável %>
            <div class="avatar flex-shrink-0 relative">
              <div class="w-24 h-24 md:w-32 md:h-32 rounded-3xl shadow-2xl bg-gradient-to-br from-green-400 to-emerald-600 relative group cursor-pointer">
                
                <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                  <%= image_tag @user.foto.variant(resize_to_fill: [128, 128]), class: "object-cover h-full w-full rounded-3xl transition-opacity duration-300 group-hover:opacity-75" %>
                <% else %>
                  <div class="h-full w-full rounded-3xl transition-opacity duration-300 group-hover:opacity-75 flex items-center justify-center">
                    <span class="text-4xl md:text-5xl font-bold text-white">
                      <%= @user.nome.present? ? @user.nome.first.upcase : 'P' %>
                    </span>
                  </div>
                <% end %>
                
                <%# Overlay para trocar foto %>
                <label for="<%= f.object_name %>_foto" class="absolute inset-0 flex flex-col items-center justify-center bg-gray-900 bg-opacity-60 rounded-3xl cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity duration-300" title="Clique para trocar a foto">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.742 4h2.516a2 2 0 011.664.89l.812 1.22a2 2 0 001.664.89H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span class="text-xs text-white font-medium">Trocar Foto</span>
                </label>
                
                <%= f.file_field :foto, class: "hidden", accept: 'image/png,image/gif,image/jpeg' %>
              </div>
              
              <%# Checkbox para remover foto %>
              <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                <div class="absolute -bottom-2 -right-2 bg-white rounded-full shadow-lg p-2 flex items-center gap-2">
                  <%= f.check_box :remove_foto, class: "checkbox checkbox-error checkbox-sm", id: "remove_foto_checkbox" %>
                  <label for="remove_foto_checkbox" class="text-xs text-gray-700 cursor-pointer">Remover</label>
                </div>
              <% end %>
            </div>

            <%# Informações do Header %>
            <div class="flex-grow">
              <h1 class="text-2xl md:text-4xl font-bold text-gray-800 mb-2">Editar Perfil</h1>
              <p class="text-sm md:text-base text-gray-600">Atualize suas informações pessoais e credenciais</p>
            </div>
          </div>
          
        </div>
      </div>

      <%# Mensagens de Erro %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border-l-4 border-red-500 rounded-xl p-4 mb-6 shadow-lg">
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="flex-grow">
              <h3 class="font-bold text-red-800 mb-2">Por favor, corrija os seguintes <%= @user.errors.count %> <%= @user.errors.count == 1 ? 'erro' : 'erros' %>:</h3>
              <ul class="list-disc list-inside space-y-1 text-sm text-red-700">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>
      
      <%# Formulário Principal %>
      <div class="space-y-6">
        
        <%# Card: Informações Pessoais %>
        <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
          <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
            <div class="bg-gradient-to-br from-blue-400 to-blue-600 p-3 rounded-2xl shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-gray-800">Informações Pessoais</h2>
              <p class="text-sm text-gray-600">Dados básicos do seu perfil</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <%# Nome %>
            <div class="form-control">
              <%= f.label :nome, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Nome Completo</span>
              <% end %>
              <%= f.text_field :nome, class: "input input-bordered w-full focus:input-success", placeholder: "Seu nome completo" %>
            </div>
            
            <%# Email (readonly) %>
            <div class="form-control">
              <%= f.label :email, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">E-mail</span>
              <% end %>
              <%= f.email_field :email, class: "input input-bordered w-full bg-gray-100 cursor-not-allowed", readonly: true %>
              <label class="label">
                <span class="label-text-alt text-gray-500">O email não pode ser alterado</span>
              </label>
            </div>
            
            <%# Telefone %>
            <% if @user.is_a?(Aluno) || @user.is_a?(Professor) %>
              <div class="form-control">
                <%= f.label :telefone, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Telefone</span>
                <% end %>
                <%= f.text_field :telefone, class: "input input-bordered w-full focus:input-success", id: "#{f.object_name}_telefone", placeholder: "(00) 00000-0000" %>
              </div>
            <% end %>
            
            <%# Data de Nascimento (Aluno) %>
            <% if @user.is_a?(Aluno) %>
              <div class="form-control">
                <%= f.label :data_nascimento, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Data de Nascimento</span>
                <% end %>
                <%= f.date_field :data_nascimento, class: "input input-bordered w-full focus:input-success" %>
              </div>
            <% end %>

            <%# Formação (Professor) %>
            <% if @user.is_a?(Professor) %>
              <div class="form-control w-full">
                <%= f.label :formacao, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Formação</span>
                <% end %>
                
                <% formacao_opcoes = Professor.formacaos.keys.map { |key| [key.humanize.capitalize, key] } %>
                <% valor_atual = @user.formacao.present? ? @user.formacao.humanize.capitalize : "Selecione sua Formação" %>
                
                <div class="dropdown w-full">
                  <div tabindex="0" role="button" class="btn btn-outline w-full justify-between normal-case font-normal">
                    <span id="formacao-display"><%= valor_atual %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                  <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-full mt-2 max-h-60 overflow-y-auto">
                    <% formacao_opcoes.each do |label, value| %>
                      <li>
                        <a onclick="selecionarFormacao('<%= value %>', '<%= label %>')"><%= label %></a>
                      </li>
                    <% end %>
                  </ul>
                </div>
                
                <%= f.hidden_field :formacao, id: "formacao-hidden-field" %>
              </div>
              
              <script>
                function selecionarFormacao(valor, label) {
                  document.getElementById('formacao-display').textContent = label;
                  document.getElementById('formacao-hidden-field').value = valor;
                  // Fecha o dropdown
                  document.activeElement.blur();
                }
              </script>
            <% end %>

          </div>
        </div>

        <%# Card: Segurança e Senha %>
        <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
          <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
            <div class="bg-gradient-to-br from-purple-400 to-purple-600 p-3 rounded-2xl shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-gray-800">Segurança e Senha</h2>
              <p class="text-sm text-gray-600">Altere sua senha de acesso</p>
            </div>
          </div>
          
          <div class="alert bg-blue-50 border-l-4 border-blue-500 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm text-blue-800">Deixe os campos em branco se não quiser alterar a senha</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <%# Nova Senha %>
            <div class="form-control">
              <%= f.label :password, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Nova Senha</span>
              <% end %>
              <%= f.password_field :password, class: "input input-bordered w-full focus:input-success", autocomplete: "new-password", placeholder: "••••••••" %>
              <label class="label">
                <span class="label-text-alt text-gray-500">Mínimo de 6 caracteres</span>
              </label>
            </div>
            
            <%# Confirmação de Senha %>
            <div class="form-control">
              <%= f.label :password_confirmation, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Confirmar Nova Senha</span>
              <% end %>
              <%= f.password_field :password_confirmation, class: "input input-bordered w-full focus:input-success", autocomplete: "new-password", placeholder: "••••••••" %>
              <label class="label">
                <span class="label-text-alt text-gray-500">Digite a senha novamente</span>
              </label>
            </div>

          </div>
        </div>
        
        <%# Botões de Ação %>
        <div class="flex flex-col-reverse md:flex-row justify-end gap-4 pb-8">
          <%= link_to profile_path, class: "btn btn-lg btn-ghost hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Cancelar
          <% end %>
          
          <button type="button" 
                  onclick="document.getElementById('profile-form').submit();"
                  class="btn btn-lg bg-green-600 hover:bg-green-700 text-white border-0 shadow-xl hover:shadow-2xl transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Salvar Alterações
          </button>
        </div>
        
      </div>

    <% end %>

  </div>
</div>

<%= javascript_include_tag "imask", "data-turbo-track": "reload" %>
<%= javascript_include_tag "mascaras", "data-turbo-track": "reload" %>