<% content_for :title, "Editar Perfil de #{@user.nome}" %>

<!-- Cropper.js CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">

<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50">
  <div class="container mx-auto px-4 py-6 max-w-4xl">
    
    <%= form_with(model: @user, 
                  scope: @user.model_name.singular.to_sym,
                  url: profile_path, 
                  method: :patch, 
                  html: { class: "w-full", id: "profile-form" }, 
                  data: { turbo: false }) do |f| %>
      
      <%# Header Card com Banner %>
      <div class="bg-white shadow-2xl rounded-3xl overflow-hidden mb-6">
        
        <%# Banner com gradiente %>
        <div class="h-40 md:h-48 relative" style="background: linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%);">
          
          <%# Botão Cancelar %>
          <div class="absolute top-4 right-4 md:top-6 md:right-6 z-20">
            <%= link_to profile_path, class: "btn btn-circle btn-sm md:btn-md bg-white hover:bg-gray-50 border-0 shadow-xl transition-all hover:scale-110" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>

          <%# Padrão decorativo %>
          <div class="absolute inset-0 opacity-10">
            <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                  <circle cx="20" cy="20" r="2" fill="white"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)"/>
            </svg>
          </div>
        </div>
        
        <%# Conteúdo do Perfil %>
        <div class="px-4 md:px-10 py-6 md:py-8">
          
          <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
            <%# Avatar Editável CIRCULAR %>
            <div class="avatar flex-shrink-0 relative">
              <div id="avatar-container" class="w-32 h-32 md:w-40 md:h-40 rounded-full shadow-2xl bg-gradient-to-br from-green-400 to-emerald-600 relative group cursor-pointer ring-4 ring-white">
                
                <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                  <%= image_tag @user.foto.variant(resize_to_fill: [160, 160]), 
                      class: "object-cover h-full w-full rounded-full transition-opacity duration-300 group-hover:opacity-75",
                      id: "current-avatar-img" %>
                <% else %>
                  <div id="avatar-placeholder" class="h-full w-full rounded-full transition-opacity duration-300 group-hover:opacity-75 flex items-center justify-center">
                    <span class="text-5xl md:text-6xl font-bold text-white">
                      <%= @user.nome.present? ? @user.nome.first.upcase : 'P' %>
                    </span>
                  </div>
                <% end %>
                
                <%# Overlay para trocar foto %>
                <label for="foto-file-input" class="absolute inset-0 flex flex-col items-center justify-center bg-gray-900 bg-opacity-60 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity duration-300" title="Clique para trocar a foto">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.742 4h2.516a2 2 0 011.664.89l.812 1.22a2 2 0 001.664.89H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span class="text-xs text-white font-medium">Trocar Foto</span>
                </label>
                
                <input type="file" id="foto-file-input" class="hidden" accept="image/jpeg,image/jpg,image/png,image/gif">
              </div>
              
              <%# Botão para remover foto %>
              <% if @user.respond_to?(:foto) && @user.foto.attached? %>
                <div class="absolute bottom-0 right-0" id="remove-photo-btn">
                  <label for="remove_foto_checkbox" class="btn btn-circle btn-sm bg-red-500 hover:bg-red-600 border-0 shadow-lg cursor-pointer" title="Remover foto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </label>
                  <%= f.check_box :remove_foto, class: "hidden", id: "remove_foto_checkbox" %>
                </div>
              <% end %>
            </div>

            <%# Informações do Header %>
            <div class="flex-grow">
              <h1 class="text-2xl md:text-4xl font-bold text-gray-800 mb-2">Editar Perfil</h1>
              <p class="text-sm md:text-base text-gray-600">Atualize suas informações pessoais e credenciais</p>
            </div>
          </div>
          
        </div>
      </div>

      <%# Mensagens de Erro %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border-l-4 border-red-500 rounded-xl p-4 mb-6 shadow-lg">
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="flex-grow">
              <h3 class="font-bold text-red-800 mb-2">Por favor, corrija os seguintes <%= @user.errors.count %> <%= @user.errors.count == 1 ? 'erro' : 'erros' %>:</h3>
              <ul class="list-disc list-inside space-y-1 text-sm text-red-700">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      <% end %>
      
      <%# Hidden field para a imagem cropada %>
      <%= f.hidden_field :foto, id: "cropped-photo-data" %>
      
      <%# Formulário Principal %>
      <div class="space-y-6">
        
        <%# Card: Informações Pessoais %>
        <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
          <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
            <div class="bg-gradient-to-br from-blue-400 to-blue-600 p-3 rounded-2xl shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-gray-800">Informações Pessoais</h2>
              <p class="text-sm text-gray-600">Dados básicos do seu perfil</p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <%# Nome %>
            <div class="form-control">
              <%= f.label :nome, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Nome Completo</span>
              <% end %>
              <%= f.text_field :nome, class: "input input-bordered w-full focus:input-success", placeholder: "Seu nome completo" %>
            </div>
            
            <%# Email (readonly) %>
            <div class="form-control">
              <%= f.label :email, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">E-mail</span>
              <% end %>
              <%= f.email_field :email, class: "input input-bordered w-full bg-gray-100 cursor-not-allowed", readonly: true %>
              <label class="label">
                <span class="label-text-alt text-gray-500">O email não pode ser alterado</span>
              </label>
            </div>
            
            <%# Telefone %>
            <% if @user.is_a?(Aluno) || @user.is_a?(Professor) %>
              <div class="form-control">
                <%= f.label :telefone, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Telefone</span>
                <% end %>
                <%= f.text_field :telefone, class: "input input-bordered w-full focus:input-success", id: "#{f.object_name}_telefone", placeholder: "(00) 00000-0000" %>
              </div>
            <% end %>
            
            <%# Data de Nascimento (Aluno) %>
            <% if @user.is_a?(Aluno) %>
              <div class="form-control">
                <%= f.label :data_nascimento, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Data de Nascimento</span>
                <% end %>
                <%= f.date_field :data_nascimento, class: "input input-bordered w-full focus:input-success" %>
              </div>
            <% end %>

            <%# Formação (Professor) %>
            <% if @user.is_a?(Professor) %>
              <div class="form-control w-full">
                <%= f.label :formacao, class: "label" do %>
                  <span class="label-text font-semibold text-gray-700">Formação</span>
                <% end %>
                
                <% formacao_opcoes = Professor.formacaos.keys.map { |key| [key.humanize.capitalize, key] } %>
                <% valor_atual = @user.formacao.present? ? @user.formacao.humanize.capitalize : "Selecione sua Formação" %>
                
                <div class="dropdown w-full">
                  <div tabindex="0" role="button" class="btn btn-outline w-full justify-between normal-case font-normal">
                    <span id="formacao-display"><%= valor_atual %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                  <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-full mt-2 max-h-60 overflow-y-auto">
                    <% formacao_opcoes.each do |label, value| %>
                      <li>
                        <a onclick="selecionarFormacao('<%= value %>', '<%= label %>')"><%= label %></a>
                      </li>
                    <% end %>
                  </ul>
                </div>
                
                <%= f.hidden_field :formacao, id: "formacao-hidden-field" %>
              </div>
            <% end %>

          </div>
        </div>

        <%# Card: Segurança e Senha %>
        <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8">
          <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
            <div class="bg-gradient-to-br from-purple-400 to-purple-600 p-3 rounded-2xl shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl md:text-2xl font-bold text-gray-800">Segurança e Senha</h2>
              <p class="text-sm text-gray-600">Altere sua senha de acesso</p>
            </div>
          </div>
          
          <div class="alert bg-blue-50 border-l-4 border-blue-500 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm text-blue-800">Deixe os campos em branco se não quiser alterar a senha</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <%# Nova Senha %>
            <div class="form-control">
              <%= f.label :password, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Nova Senha</span>
              <% end %>
              <%= f.password_field :password, class: "input input-bordered w-full focus:input-success", autocomplete: "new-password", placeholder: "••••••••" %>
              <label class="label">
                <span class="label-text-alt text-gray-500">Mínimo de 6 caracteres</span>
              </label>
            </div>
            
            <%# Confirmação de Senha %>
            <div class="form-control">
              <%= f.label :password_confirmation, class: "label" do %>
                <span class="label-text font-semibold text-gray-700">Confirmar Nova Senha</span>
              <% end %>
              <%= f.password_field :password_confirmation, class: "input input-bordered w-full focus:input-success", autocomplete: "new-password", placeholder: "••••••••" %>
              <label class="label">
                <span class="label-text-alt text-gray-500">Digite a senha novamente</span>
              </label>
            </div>

          </div>
        </div>
        
        <%# Botões de Ação %>
        <div class="flex flex-col-reverse md:flex-row justify-end gap-4 pb-8">
          <%= link_to profile_path, class: "btn btn-lg btn-ghost hover:bg-gray-100" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Cancelar
          <% end %>
          
          <button type="submit" 
                  class="btn btn-lg bg-green-600 hover:bg-green-700 text-white border-0 shadow-xl hover:shadow-2xl transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Salvar Alterações
          </button>
        </div>
        
      </div>

    <% end %>

  </div>
</div>

<%# Modal de Crop CIRCULAR %>
<div id="crop-modal" class="modal">
  <div class="modal-box max-w-2xl bg-white p-0 overflow-hidden">
    <div class="bg-gradient-to-r from-green-500 to-emerald-600 px-6 py-4">
      <h3 class="font-bold text-xl text-white">Ajustar Foto de Perfil</h3>
      <p class="text-green-50 text-sm mt-1">Posicione sua foto no círculo</p>
    </div>
    
    <div class="p-6">
      <div id="crop-container" class="max-h-96 overflow-hidden bg-gray-900 rounded-xl flex items-center justify-center">
        <img id="crop-image" src="" alt="Imagem para crop" style="max-width: 100%; display: block;">
      </div>

      <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
        <div class="text-sm text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Mova e ajuste a área circular
        </div>
        <div class="flex gap-3">
          <button type="button" id="crop-cancel" class="btn btn-outline btn-md">
            Cancelar
          </button>
          <button type="button" id="crop-confirm" class="btn bg-green-500 hover:bg-green-600 text-white border-none btn-md shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Aplicar
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="modal-backdrop"></div>
</div>

<!-- Cropper.js Script -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<script>
<% if @user.is_a?(Professor) %>
  function selecionarFormacao(valor, label) {
    document.getElementById('formacao-display').textContent = label;
    document.getElementById('formacao-hidden-field').value = valor;
    document.activeElement.blur();
  }
<% end %>

document.addEventListener('DOMContentLoaded', function() {
  const fileInput = document.getElementById('foto-file-input');
  const cropModal = document.getElementById('crop-modal');
  const cropImage = document.getElementById('crop-image');
  const cropConfirm = document.getElementById('crop-confirm');
  const cropCancel = document.getElementById('crop-cancel');
  const croppedPhotoData = document.getElementById('cropped-photo-data');
  const avatarContainer = document.getElementById('avatar-container');
  const removePhotoBtn = document.getElementById('remove-photo-btn');
  const removeCheckbox = document.getElementById('remove_foto_checkbox');
  let cropper = null;

  // Quando selecionar arquivo
  fileInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    // Validar tipo de arquivo
    if (!file.type.match('image.*')) {
      alert('Por favor, selecione uma imagem válida (JPG, PNG ou GIF).');
      fileInput.value = '';
      return;
    }

    // Validar tamanho (5MB)
    if (file.size > 5 * 1024 * 1024) {
      alert('A imagem deve ter no máximo 5MB.');
      fileInput.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = function(event) {
      cropImage.src = event.target.result;
      cropModal.classList.add('modal-open');

      // Destruir cropper anterior se existir
      if (cropper) {
        cropper.destroy();
      }

      // Aguardar a imagem carregar
      cropImage.onload = function() {
        // Inicializar Cropper.js com CROP CIRCULAR
        cropper = new Cropper(cropImage, {
          aspectRatio: 1,
          viewMode: 1,
          dragMode: 'move',
          autoCropArea: 1,
          restore: false,
          guides: false,
          center: true,
          highlight: false,
          cropBoxMovable: true,
          cropBoxResizable: true,
          toggleDragModeOnDblclick: false,
          minCropBoxWidth: 200,
          minCropBoxHeight: 200,
          ready: function() {
            // Adiciona estilo circular ao crop box
            const cropBox = document.querySelector('.cropper-crop-box');
            if (cropBox) {
              cropBox.style.borderRadius = '50%';
            }
            const face = document.querySelector('.cropper-face');
            if (face) {
              face.style.borderRadius = '50%';
            }
          }
        });
      };
    };
    reader.readAsDataURL(file);
  });

  // Confirmar crop
  cropConfirm.addEventListener('click', function() {
    if (!cropper) return;

    // Obter imagem cropada como canvas CIRCULAR
    const canvas = cropper.getCroppedCanvas({
      width: 400,
      height: 400,
      imageSmoothingEnabled: true,
      imageSmoothingQuality: 'high',
    });

    // Criar canvas circular
    const roundedCanvas = document.createElement('canvas');
    const roundedCtx = roundedCanvas.getContext('2d');
    roundedCanvas.width = 400;
    roundedCanvas.height = 400;

    // Desenhar círculo
    roundedCtx.beginPath();
    roundedCtx.arc(200, 200, 200, 0, Math.PI * 2);
    roundedCtx.closePath();
    roundedCtx.clip();

    // Desenhar imagem dentro do círculo
    roundedCtx.drawImage(canvas, 0, 0, 400, 400);

    // Converter para blob e depois para base64
    roundedCanvas.toBlob(function(blob) {
      const reader = new FileReader();
      reader.onloadend = function() {
        const base64data = reader.result;
        
        // Atualizar preview do avatar
        const currentImg = document.getElementById('current-avatar-img');
        const placeholder = document.getElementById('avatar-placeholder');
        
        if (currentImg) {
          currentImg.src = base64data;
        } else if (placeholder) {
          avatarContainer.innerHTML = `
            <img src="${base64data}" 
                 class="object-cover h-full w-full rounded-full transition-opacity duration-300 group-hover:opacity-75" 
                 id="current-avatar-img">
            <label for="foto-file-input" class="absolute inset-0 flex flex-col items-center justify-center bg-gray-900 bg-opacity-60 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.742 4h2.516a2 2 0 011.664.89l.812 1.22a2 2 0 001.664.89H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-xs text-white font-medium">Trocar Foto</span>
            </label>
          `;
          
          // Adicionar botão de remover se não existir
          if (!removePhotoBtn) {
            const parentDiv = avatarContainer.parentElement;
            const btnHtml = `
              <div class="absolute bottom-0 right-0" id="remove-photo-btn">
                <label for="remove_foto_checkbox" class="btn btn-circle btn-sm bg-red-500 hover:bg-red-600 border-0 shadow-lg cursor-pointer">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </label>
              </div>
            `;
            parentDiv.insertAdjacentHTML('beforeend', btnHtml);
          }
        }

        // Salvar base64 no hidden field
        croppedPhotoData.value = base64data;
        
        console.log('Foto cropada salva no campo hidden');
        
        // Desmarcar checkbox de remover se estiver marcado
        if (removeCheckbox) {
          removeCheckbox.checked = false;
        }

        // Fechar modal
        cropModal.classList.remove('modal-open');
        if (cropper) {
          cropper.destroy();
        }
        fileInput.value = '';
      };
      reader.readAsDataURL(blob);
    }, 'image/png', 0.95);
  });

  // Cancelar crop
  cropCancel.addEventListener('click', function() {
    cropModal.classList.remove('modal-open');
    if (cropper) {
      cropper.destroy();
    }
    fileInput.value = '';
  });

  // Fechar modal ao clicar fora
  cropModal.addEventListener('click', function(e) {
    if (e.target === cropModal) {
      cropModal.classList.remove('modal-open');
      if (cropper) {
        cropper.destroy();
      }
      fileInput.value = '';
    }
  });
});
</script>

