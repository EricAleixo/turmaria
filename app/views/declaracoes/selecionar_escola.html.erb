<div class="min-h-screen bg-gray-100 py-8 px-4">
  <div class="max-w-9xl mx-auto">
    <!-- Cabeçalho -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">Configuração de Declarações por Escola</h1>
      <p class="text-gray-600">Selecione uma escola para parametrizar o layout, cabeçalho, textos e assinaturas dos PDFs das declarações de alunos.</p>
    </div>
    
    <!-- Grid de Cards de Escolas -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @escolas.each do |escola| %>
        <% cabecalho_custom = escola.declaracao_cabecalho.present? %>
        <% corpo_custom = escola.declaracao_corpo.present? %>
        <% assinatura_custom = escola.declaracao_assinatura_cargo.present? || escola.declaracao_assinatura_nome.present? %>
        
        <div class="bg-white rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-300 flex flex-col justify-between">
          <!-- Header do Card -->
          <div class="p-6 border-b border-gray-200">
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1">
                <h3 class="font-semibold text-gray-800 text-lg mb-1"><%= escola.nome %></h3>
                <span class="inline-block px-3 py-1 text-xs rounded-full <%= escola.tipo == 'publica' ? 'bg-blue-100 text-blue-800' : 'bg-purple-100 text-purple-800' %>">
                  <%= escola.tipo_humanizado %>
                </span>
              </div>
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 ml-3">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-600">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>
            </div>
            
            <!-- Estatísticas/Status da Escola -->
            <div class="mt-4 space-y-2">
              <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Status da Declaração:</h4>
              
              <!-- Cabeçalho -->
              <div class="flex items-center justify-between text-sm py-1 border-b border-gray-100">
                <span class="text-gray-600">Cabeçalho</span>
                <% if cabecalho_custom %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-0.5 rounded-full border border-green-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Personalizado
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded-full border border-gray-200">
                    Padrão do Sistema
                  </span>
                <% end %>
              </div>
              
              <!-- Corpo/Texto -->
              <div class="flex items-center justify-between text-sm py-1 border-b border-gray-100">
                <span class="text-gray-600">Corpo do Texto</span>
                <% if corpo_custom %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-0.5 rounded-full border border-green-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Personalizado
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded-full border border-gray-200">
                    Padrão do Sistema
                  </span>
                <% end %>
              </div>
              
              <!-- Assinatura -->
              <div class="flex items-center justify-between text-sm py-1">
                <span class="text-gray-600">Assinatura</span>
                <% if assinatura_custom %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-green-700 bg-green-50 px-2 py-0.5 rounded-full border border-green-200">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Personalizada
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded-full border border-gray-200">
                    Diretor(a) Escolar
                  </span>
                <% end %>
              </div>
            </div>
          </div>
          
          <!-- Footer do Card -->
          <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg flex items-center justify-center">
            <%= link_to configuracoes_escola_declaracao_path(escola), class: "w-full text-center py-2 px-4 bg-green-600 hover:bg-green-700 text-white font-medium text-sm rounded-lg transition-colors flex items-center justify-center gap-2" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.297 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.43l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.645-.869L9.594 3.94Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
              <span>Configurar Declaração</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Mensagem quando não há escolas -->
    <% if @escolas.empty? %>
      <div class="bg-white rounded-lg shadow-sm p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-gray-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-800 mb-2">Nenhuma escola cadastrada</h3>
        <p class="text-gray-600 mb-6">Cadastre escolas no sistema antes de configurar suas declarações.</p>
        <%= link_to new_escola_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span>Criar Primeira Escola</span>
        <% end %>
      </div>
    <% end %>
    
    <!-- Botão de Voltar -->
    <div class="mt-8 text-center">
      <%= link_to dashboard_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-gray-50 text-gray-700 font-medium rounded-lg shadow-sm transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        <span>Voltar ao Dashboard</span>
      <% end %>
    </div>
  </div>
</div>
