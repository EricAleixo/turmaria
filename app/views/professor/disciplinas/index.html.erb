<%# app/views/professor/disciplinas/index.html.erb %>

<div class="p-6 bg-gray-100 min-h-screen">
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">
            Disciplinas de Lançamento em: <%= @turma.nome %>
        </h1>
        <p class="text-gray-600">Selecione a disciplina para realizar o lançamento de notas ou frequência.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% if @disciplinas.any? %>
            <% @disciplinas.each do |disciplina| %>
                <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200">
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-gray-900 mb-2"><%= disciplina.nome %></h3>
                        
                        <%# Exibe o professor (Útil para confirmar a associação) %>
                        <p class="text-sm text-gray-600 mb-4">Professor(a): <%= disciplina.professor&.nome || 'Não atribuído' %></p>

                        <div class="flex space-x-3">
                            
                            <%# 1. LINK PARA NOTAS (RESULTADOS) - USANDO professor_turma_disciplina_resultados_path %>
                            <%# Rota: professor/turmas/:turma_id/disciplinas/:disciplina_id/resultados (Controller: professor/notas/resultados) %>
                            <%= link_to 'Lançar Notas', 
                                professor_turma_disciplina_resultado_path(@turma, disciplina),
                                class: "flex-1 bg-blue-500 hover:bg-blue-600 text-white text-center py-2 px-4 rounded-lg text-sm font-medium transition-colors" %>
                            
                            <%# 2. LINK PARA FREQUÊNCIA - USANDO new_professor_turma_disciplina_frequencia_path %>
                            <%# Rota: new_professor/turmas/:turma_id/disciplinas/:disciplina_id/frequencias (Controller: professor/frequencias) %>
                            <%= link_to 'Lançar Frequência', 
                                new_professor_turma_disciplina_frequencia_path(@turma, disciplina),
                                class: "flex-1 bg-gray-500 hover:bg-gray-600 text-white text-center py-2 px-4 rounded-lg text-sm font-medium transition-colors" %>
                        </div>
                    </div>
                </div>
            <% end %>
        <% else %>
             <div class="col-span-full text-center py-12 border-2 border-dashed border-gray-300 rounded-lg mt-6">
                <h3 class="mt-2 text-lg font-medium text-gray-900">Nenhuma disciplina sua nesta turma</h3>
                <p class="mt-1 text-sm text-gray-500">Você não está lecionando em nenhuma disciplina nesta turma no momento. Verifique suas atribuições.</p>
                <%= link_to 'Voltar para Turmas', minhas_turmas_path, class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none" %>
            </div>
        <% end %>
    </div>
</div>