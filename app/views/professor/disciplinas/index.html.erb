<div class="p-6 sm:p-8 lg:p-10 bg-gray-100 min-h-screen">
  <div class="max-w-7xl mx-auto">
    
    <header class="mb-8 p-6 bg-white shadow-lg rounded-xl border-b-4 border-indigo-600">
      <% if @contexto_turma %>
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Disciplinas da Turma: <%= @turma.nome %></h1>
        <p class="text-lg text-gray-600">Selecione a disciplina para gerenciar notas e frequência.</p>
      <% else %>
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Minhas Disciplinas (Geral)</h1>
        <p class="text-lg text-gray-600">Todas as disciplinas que você leciona. Clique em uma para ver detalhes.</p>
      <% end %>

      <%= link_to professor_turmas_path, 
            class: 'mt-4 inline-flex items-center text-sm font-semibold text-green-600 hover:text-green-800 transition duration-150 ease-in-out py-1 px-3 bg-green-100 rounded-lg' do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 w-4 h-4 mr-1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Voltar para Minhas Turmas
      <% end %>
    </header>

    <% if @disciplinas.any? %>
      <% disciplinas_por_area = @disciplinas.group_by(&:area_disciplina) %>
      
      <% disciplinas_por_area.each do |area, disciplinas| %>
        <div class="mb-8">
          <% if area %>
            <div class="mb-4 flex items-center">
              <div class="w-1 h-8 rounded-full mr-3" style="background-color: <%= area.cor %>;"></div>
              <h2 class="text-2xl font-bold text-gray-800"><%= area.nome&.humanize || 'Área Não Definida' %></h2>
              <span class="ml-3 px-3 py-1 text-sm font-medium text-gray-600 bg-gray-200 rounded-full">
                <%= disciplinas.count %> <%= disciplinas.count == 1 ? 'disciplina' : 'disciplinas' %>
              </span>
            </div>
          <% else %>
            <div class="mb-4 flex items-center">
              <div class="w-1 h-8 bg-gray-400 rounded-full mr-3"></div>
              <h2 class="text-2xl font-bold text-gray-800">Sem Área Definida</h2>
              <span class="ml-3 px-3 py-1 text-sm font-medium text-gray-600 bg-gray-200 rounded-full">
                <%= disciplinas.count %> <%= disciplinas.count == 1 ? 'disciplina' : 'disciplinas' %>
              </span>
            </div>
          <% end %>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% disciplinas.each do |disciplina| %>
              <% cor_disciplina = disciplina.cor_nome || area&.cor || '#3B82F6' %>
              <% 
                # Busca as turmas onde o professor ensina esta disciplina
                turmas_desta_disciplina = current_professor.turmas.joins(:disciplinas).where(disciplinas: { id: disciplina.id }).distinct
              %>
              
              <div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 flex flex-col h-full overflow-hidden" style="border-top: 4px solid <%= cor_disciplina %>;">
                
                <div class="p-6 flex-1">
                  <div class="flex items-center mb-4">
                    <div class="w-3 h-3 rounded-full mr-3 flex-shrink-0" style="background-color: <%= cor_disciplina %>;"></div>
                    <h3 class="text-2xl font-bold text-gray-800 leading-tight"><%= disciplina.nome %></h3>
                  </div>
                  
                  <div class="space-y-3">
                    <% if @contexto_turma %>
                      <div class="flex items-center text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2 flex-shrink-0" style="color: <%= cor_disciplina %>;">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
                        </svg>
                        <span class="text-sm"><span class="font-medium">Avaliações Ativas:</span> <%= disciplina.avaliacoes_configuracoes.where(turma: @turma).count %></span>
                      </div>
                    <% else %>
                      <%# Badges das turmas aparecem apenas quando NÃO há contexto de turma %>
                      <% if turmas_desta_disciplina.any? %>
                        <div class="pt-2">
                          <div class="flex items-center mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1.5 text-gray-500">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                            </svg>
                            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Ensina em:</span>
                          </div>
                          <div class="flex flex-wrap gap-1.5">
                            <% turmas_desta_disciplina.limit(4).each do |turma| %>
                              <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full transition-all duration-200 hover:scale-105" 
                                    style="background-color: <%= cor_disciplina %>15; color: <%= cor_disciplina %>; border: 1px solid <%= cor_disciplina %>40;">
                                <%= turma.nome %>
                              </span>
                            <% end %>
                            <% if turmas_desta_disciplina.count > 4 %>
                              <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-gray-600 bg-gray-100 rounded-full border border-gray-300">
                                +<%= turmas_desta_disciplina.count - 4 %>
                              </span>
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <div class="mt-auto bg-gray-50 p-6">
                  <% if @contexto_turma %>
                    <div class="flex flex-col space-y-2">
                      <%= link_to professor_turma_disciplina_notas_avaliacoes_path(@turma, disciplina), 
                            class: "w-full flex items-center justify-center text-white text-center py-2.5 px-4 rounded-lg text-sm font-semibold transition-all shadow-md hover:shadow-lg hover:opacity-90",
                            style: "background-color: #{cor_disciplina};" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                        Lançar/Gerenciar Notas
                      <% end %>
                      
                      <div class="grid grid-cols-2 gap-2 pt-1">
                        <%= link_to professor_turma_disciplina_resultados_path(@turma, disciplina), 
                              class: "w-full flex items-center justify-center bg-indigo-100 hover:bg-indigo-200 text-indigo-700 text-center py-2 px-3 rounded-lg text-sm font-medium transition-colors" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75c0 .621-.504 1.125-1.125 1.125h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25A1.125 1.125 0 0 1 9.75 19.875V8.625Zm6.375-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V5.25Z" />
                          </svg>
                          Resultados
                        <% end %>
                        
                        <%= link_to historico_professor_turma_path(@turma), 
                              class: "w-full flex items-center justify-center bg-gray-200 hover:bg-gray-300 text-gray-700 text-center py-2 px-3 rounded-lg text-sm font-medium transition-colors" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A1.875 1.875 0 0 1 18 22.5h-12a1.875 1.875 0 0 1-1.499-2.382Z" />
                          </svg>
                          Frequência
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
              
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12 border border-dashed rounded-lg bg-white">
        <p class="text-lg font-medium text-gray-700">
          <% if @contexto_turma %>
            Nenhuma disciplina encontrada para você nesta turma.
          <% else %>
            Você não está associado a nenhuma disciplina.
          <% end %>
        </p>
        <p class="mt-1 text-sm text-gray-500">Verifique sua associação de professor-disciplina-turma com a administração da escola.</p>
      </div>
    <% end %>
  </div>
</div>