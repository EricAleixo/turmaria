<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">Registrar Frequência</h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %>
          </p>
        </div>
        <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" do %>
          Voltar para Turmas
        <% end %>
      </div>
    </div>

    <!-- Formulário -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <%= form_with model: @frequencia, url: frequencias_path, local: true, class: "p-4 sm:p-6" do |form| %>
        <%= hidden_field_tag :turma_id, @turma.id %>
        
        <!-- Data e Turma -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-4 sm:mb-6">
          <div>
            <%= form.label :data_aula, "Data da Aula", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.date_field :data_aula, value: Date.current, max: Date.current, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Turma</label>
            <div class="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-gray-600 text-sm sm:text-base">
              <%= @turma.nome %> - <%= @turma.serie %>º ano (<%= @turma.turno.humanize %>)
            </div>
          </div>
        </div>

        <!-- Conteúdo Trabalhado -->
        <div class="mb-4 sm:mb-6">
          <%= form.label :conteudo_trabalhado, "Conteúdo Trabalhado", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :conteudo_trabalhado, placeholder: "Ex: Análise combinatória, permutação...", rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base" %>
        </div>

        <!-- Lista de Presença -->
        <div class="mb-4 sm:mb-6">
          <!-- Header com Contadores e Ações -->
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
            <div>
              <h3 class="text-base sm:text-lg font-medium text-gray-900">Lista de Presença</h3>
              <p class="text-xs sm:text-sm text-gray-500 mt-1 flex flex-wrap gap-x-3 gap-y-1">
                <span><span id="contador-presente" class="text-green-600 font-medium">0</span> presentes</span>
                <span>•</span>
                <span><span id="contador-ausente" class="text-red-600 font-medium">0</span> ausentes</span>
                <span>•</span>
                <span><span id="contador-justificado" class="text-yellow-600 font-medium">0</span> justificados</span>
              </p>
            </div>
            
            <!-- Botão Ações Rápidas -->
            <div class="relative">
              <button type="button" id="btn-acoes-rapidas" class="w-full sm:w-auto flex items-center justify-center space-x-2 px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg font-medium transition-all duration-200 shadow-md hover:shadow-lg text-sm sm:text-base">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span>Ações Rápidas</span>
                <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              
              <!-- Menu Dropdown -->
              <div id="menu-acoes" class="hidden absolute right-0 left-0 sm:left-auto mt-2 w-full sm:w-64 bg-white rounded-lg shadow-xl border border-gray-200 z-10">
                <div class="py-2">
                  <button type="button" data-acao="presente" class="w-full text-left px-4 py-3 hover:bg-green-50 transition-colors flex items-center space-x-3 group">
                    <div class="w-8 h-8 bg-green-100 group-hover:bg-green-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                      <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-medium text-gray-900 text-sm">Marcar Todos Presentes</div>
                      <div class="text-xs text-gray-500">Registro de aula normal</div>
                    </div>
                  </button>
                  
                  <button type="button" data-acao="falta" class="w-full text-left px-4 py-3 hover:bg-red-50 transition-colors flex items-center space-x-3 group">
                    <div class="w-8 h-8 bg-red-100 group-hover:bg-red-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                      <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-medium text-gray-900 text-sm">Marcar Todos Ausentes</div>
                      <div class="text-xs text-gray-500">Aula cancelada ou sem alunos</div>
                    </div>
                  </button>
                  
                  <button type="button" data-acao="justificada" class="w-full text-left px-4 py-3 hover:bg-yellow-50 transition-colors flex items-center space-x-3 group">
                    <div class="w-8 h-8 bg-yellow-100 group-hover:bg-yellow-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                      <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-medium text-gray-900 text-sm">Marcar Todos Justificados</div>
                      <div class="text-xs text-gray-500">Atividade especial ou evento</div>
                    </div>
                  </button>
                  
                  <div class="border-t border-gray-100 my-2"></div>
                  
                  <button type="button" data-acao="inverter" class="w-full text-left px-4 py-3 hover:bg-gray-50 transition-colors flex items-center space-x-3 group">
                    <div class="w-8 h-8 bg-gray-100 group-hover:bg-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-medium text-gray-900 text-sm">Inverter Seleção</div>
                      <div class="text-xs text-gray-500">Presentes viram ausentes</div>
                    </div>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Lista de Alunos -->
          <%= render 'tabela_alunos', turma: @turma %>
        </div>

        <!-- Observações Gerais -->
        <div class="mb-4 sm:mb-6">
          <%= form.label :observacoes, "Observações Gerais da Aula", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :observacoes, placeholder: "Observações gerais sobre a aula...", rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <!-- Botão Submit -->
        <div class="flex justify-end">
          <%= form.submit "Registrar Frequência", class: "w-full sm:w-auto px-6 py-3 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors text-sm sm:text-base shadow-md hover:shadow-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>

input[type="radio"].radio-presente {
  appearance: none;
  -webkit-appearance: none;
  width: 1rem;
  height: 1rem;
  border: 2px solid #16a34a;
  border-radius: 50%;
  outline: none;
  cursor: pointer;
  position: relative;
  background-color: white;
}

input[type="radio"].radio-presente:checked {
  background-color: #16a34a;
  border-color: #16a34a;
}

input[type="radio"].radio-presente:checked::before {
  content: '';
  display: block;
  width: 0.375rem;
  height: 0.375rem;
  background-color: white;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

input[type="radio"].radio-falta {
  appearance: none;
  -webkit-appearance: none;
  width: 1rem;
  height: 1rem;
  border: 2px solid #dc2626;
  border-radius: 50%;
  outline: none;
  cursor: pointer;
  position: relative;
  background-color: white;
}

input[type="radio"].radio-falta:checked {
  background-color: #dc2626;
  border-color: #dc2626;
}

input[type="radio"].radio-falta:checked::before {
  content: '';
  display: block;
  width: 0.375rem;
  height: 0.375rem;
  background-color: white;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

input[type="radio"].radio-justificada {
  appearance: none;
  -webkit-appearance: none;
  width: 1rem;
  height: 1rem;
  border: 2px solid #ca8a04;
  border-radius: 50%;
  outline: none;
  cursor: pointer;
  position: relative;
  background-color: white;
}

input[type="radio"].radio-justificada:checked {
  background-color: #ca8a04;
  border-color: #ca8a04;
}

input[type="radio"].radio-justificada:checked::before {
  content: '';
  display: block;
  width: 0.375rem;
  height: 0.375rem;
  background-color: white;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* Efeito hover */
input[type="radio"].radio-presente:hover {
  box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.1);
}

input[type="radio"].radio-falta:hover {
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
}

input[type="radio"].radio-justificada:hover {
  box-shadow: 0 0 0 3px rgba(202, 138, 4, 0.1);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Inicializa todos como presentes
  document.querySelectorAll('.aluno-card').forEach(card => {
    updateCardColor(card.dataset.alunoId, 'presente');
  });
  
  atualizarContadores();

  // Toggle do menu dropdown
  const btnAcoes = document.getElementById('btn-acoes-rapidas');
  const menuAcoes = document.getElementById('menu-acoes');
  
  btnAcoes.addEventListener('click', function(e) {
    e.stopPropagation();
    menuAcoes.classList.toggle('hidden');
  });

  // Fecha o menu ao clicar fora
  document.addEventListener('click', function(e) {
    if (!menuAcoes.contains(e.target) && !btnAcoes.contains(e.target)) {
      menuAcoes.classList.add('hidden');
    }
  });

  // Ações do menu
  document.querySelectorAll('[data-acao]').forEach(btn => {
    btn.addEventListener('click', function() {
      const acao = this.dataset.acao;
      
      switch(acao) {
        case 'presente':
          marcarTodos('presente');
          break;
        case 'falta':
          marcarTodos('falta');
          break;
        case 'justificada':
          marcarTodos('justificada');
          break;
        case 'inverter':
          inverterSelecao();
          break;
      }
      
      menuAcoes.classList.add('hidden');
      atualizarContadores();
    });
  });

  // Atualiza contadores quando houver mudança
  document.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', atualizarContadores);
  });
});

function marcarTodos(status) {
  document.querySelectorAll(`input[value="${status}"]`).forEach(radio => {
    radio.checked = true;
    const alunoId = radio.name.match(/\[(\d+)\]/)[1];
    updateCardColor(alunoId, status);
  });
}

function inverterSelecao() {
  document.querySelectorAll('.aluno-card').forEach(card => {
    const alunoId = card.dataset.alunoId;
    const radioPresente = document.querySelector(`input[name="alunos[${alunoId}][status]"][value="presente"]`);
    const radioFalta = document.querySelector(`input[name="alunos[${alunoId}][status]"][value="falta"]`);
    
    if (radioPresente.checked) {
      radioFalta.checked = true;
      updateCardColor(alunoId, 'falta');
    } else if (radioFalta.checked) {
      radioPresente.checked = true;
      updateCardColor(alunoId, 'presente');
    }
  });
}

function atualizarContadores() {
  const presente = document.querySelectorAll('input[value="presente"]:checked').length;
  const ausente = document.querySelectorAll('input[value="falta"]:checked').length;
  const justificado = document.querySelectorAll('input[value="justificada"]:checked').length;
  
  document.getElementById('contador-presente').textContent = presente;
  document.getElementById('contador-ausente').textContent = ausente;
  document.getElementById('contador-justificado').textContent = justificado;
}

function updateCardColor(alunoId, status) {
  const card = document.querySelector(`[data-aluno-id="${alunoId}"]`);
  if (!card) return;

  card.classList.remove('border-green-500', 'bg-green-50', 'border-red-500', 'bg-red-50', 'border-yellow-500', 'bg-yellow-50', 'border-gray-200', 'bg-white');
  
  switch(status) {
    case 'presente':
      card.classList.add('border-green-500', 'bg-green-50');
      break;
    case 'falta':
      card.classList.add('border-red-500', 'bg-red-50');
      break;
    case 'justificada':
      card.classList.add('border-yellow-500', 'bg-yellow-50');
      break;
  }
}
</script>