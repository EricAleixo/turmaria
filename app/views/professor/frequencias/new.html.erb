<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">Registrar Frequência</h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %>
          </p>
        </div>
        <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" do %>
          Voltar para Turmas
        <% end %>
      </div>
    </div>

    <!-- Formulário -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <%= form_with model: @frequencia,
              class: "py-4 sm:p-6",
              url: professor_turma_frequencias_path(@turma),
              method: :post,
              local: true do |form| %>
        
        <!-- Data e Turma -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 mb-4 sm:mb-6">
          <div>
            <%= form.label :data_aula, "Data da Aula", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.date_field :data_aula, value: Date.current, max: Date.current, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Turma</label>
            <div class="w-full px-3 py-2 bg-gray-50 border border-gray-300 rounded-lg text-gray-600 text-sm sm:text-base">
              <%= @turma.nome %> - <%= @turma.serie %>º ano (<%= @turma.turno_humanizado %>)
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 sm:gap-6 mb-4 sm:mb-6">
          <div>
            <%= dropdown(
                form: form,
                method: :disciplina_id,
                collection: @disciplinas.all.map { |d| 
                  disabled = !@turma.disciplinas.include?(d)
                  [d.nome, d.id, { disabled: disabled }] 
                },
                placeholder: "Selecione a disciplina",
                label: "Disciplina *"
              ) %>
          </div>
        </div>

        <!-- Conteúdo Trabalhado -->
        <div class="mb-4 sm:mb-6">
          <%= form.label :conteudo_trabalhado, "Conteúdo Trabalhado", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :conteudo_trabalhado, placeholder: "Ex: Análise combinatória, permutação...", rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base" %>
        </div>

        <!-- Lista de Presença -->
        <div class="mb-4 sm:mb-6">
          <% if !@turma.alunos.any? %>
            <!-- Sem Alunos -->
            <div class="text-center py-12 px-4">
              <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 bg-gray-100 rounded-full mb-4">
                <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <h3 class="text-lg sm:text-xl font-medium text-gray-900 mb-2">Nenhum aluno cadastrado</h3>
              <p class="text-sm sm:text-base text-gray-500 mb-6 max-w-md mx-auto">
                Esta turma ainda não possui alunos. Adicione alunos à turma para poder registrar a frequência.
              </p>
            </div>
          <% else %>
            <!-- Header com Contadores e Ações -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
              <div>
                <h3 class="text-base sm:text-lg font-medium text-gray-900">Lista de Presença</h3>
                <p class="text-xs sm:text-sm text-gray-500 mt-1 flex flex-wrap gap-x-3 gap-y-1">
                  <span><span id="contador-presente" class="text-green-600 font-medium">0</span> presentes</span>
                  <span>•</span>
                  <span><span id="contador-ausente" class="text-red-600 font-medium">0</span> ausentes</span>
                  <span>•</span>
                  <span><span id="contador-justificado" class="text-yellow-600 font-medium">0</span> justificados</span>
                </p>
              </div>
              
              <!-- Botão Ações Rápidas -->
              <div class="relative">
                <button type="button" id="btn-acoes-rapidas" class="w-full sm:w-auto flex items-center justify-center space-x-2 px-4 py-2 bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg font-medium cursor-pointer transition-all duration-200 shadow-md hover:shadow-lg text-sm sm:text-base">
                  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <span>Ações Rápidas</span>
                  <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                
                <!-- Menu Dropdown -->
                <div id="menu-acoes" class="hidden absolute right-0 left-0 sm:left-auto mt-2 w-full sm:w-64 bg-white rounded-lg shadow-xl border border-gray-200 z-10">
                  <div class="py-2">
                    <button type="button" data-acao="presente" class="w-full text-left px-4 py-3 hover:bg-green-50 transition-colors flex items-center space-x-3 group">
                      <div class="w-8 h-8 bg-green-100 group-hover:bg-green-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 text-sm">Marcar Todos Presentes</div>
                        <div class="text-xs text-gray-500">Registro de aula normal</div>
                      </div>
                    </button>
                    
                    <button type="button" data-acao="falta" class="w-full text-left px-4 py-3 hover:bg-red-50 transition-colors flex items-center space-x-3 group">
                      <div class="w-8 h-8 bg-red-100 group-hover:bg-red-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 text-sm">Marcar Todos Ausentes</div>
                        <div class="text-xs text-gray-500">Aula cancelada ou sem alunos</div>
                      </div>
                    </button>
                    
                    <button type="button" data-acao="justificada" class="w-full text-left px-4 py-3 hover:bg-yellow-50 transition-colors flex items-center space-x-3 group">
                      <div class="w-8 h-8 bg-yellow-100 group-hover:bg-yellow-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                        <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 text-sm">Marcar Todos Justificados</div>
                        <div class="text-xs text-gray-500">Atividade especial ou evento</div>
                      </div>
                    </button>
                    
                    <div class="border-t border-gray-100 my-2"></div>
                    
                    <button type="button" data-acao="inverter" class="w-full text-left px-4 py-3 hover:bg-gray-50 transition-colors flex items-center space-x-3 group">
                      <div class="w-8 h-8 bg-gray-100 group-hover:bg-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors">
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 text-sm">Inverter Seleção</div>
                        <div class="text-xs text-gray-500">Presentes viram ausentes</div>
                      </div>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Lista de Alunos -->
            <%= render 'tabela_alunos', turma: @turma %>
            
            <!-- Observações Gerais -->
            <div class="mt-4 sm:mt-6">
              <%= form.label :observacoes, "Observações Gerais da Aula", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= form.text_area :observacoes, placeholder: "Observações gerais sobre a aula...", rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>

            <!-- Botão Submit -->
            <div class="flex justify-end mt-4 sm:mt-6">
              <%= form.submit "Registrar Frequência", class: "w-full sm:w-auto px-6 py-3 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors cursor-pointer text-sm sm:text-base shadow-md hover:shadow-lg" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
.status-btn {
  background-color: #f9fafb;
  border-color: #d1d5db;
  color: #6b7280;
}

.status-btn:hover {
  background-color: #f3f4f6;
}

.presente-btn.active {
  background-color: #dcfce7;
  border-color: #16a34a;
  color: #15803d;
}

.falta-btn.active {
  background-color: #fef2f2;
  border-color: #dc2626;
  color: #dc2626;
}

.justificada-btn.active {
  background-color: #fefce8;
  border-color: #ca8a04;
  color: #a16207;
}

.aluno-row {
  transition: all 0.2s ease;
}

.aluno-row.bg-green-50 {
  background-color: #f0fdf4;
}

.aluno-row.bg-red-50 {
  background-color: #fef2f2;
}

.aluno-row.bg-yellow-50 {
  background-color: #fefce8;
}
</style>

<script>
// Funções globais para serem acessadas de qualquer lugar
window.FrequenciaManager = {
  setStatus: function(alunoId, status) {
    // Remover classe active de todos os botões do aluno
    const buttons = document.querySelectorAll(`[data-aluno-id="${alunoId}"].status-btn`);
    buttons.forEach(btn => btn.classList.remove('active'));
    
    // Adicionar classe active ao botão clicado
    const activeButton = document.querySelector(`[data-aluno-id="${alunoId}"][data-status="${status}"]`);
    if (activeButton) {
      activeButton.classList.add('active');
    }
    
    // Atualizar o campo hidden
    const hiddenField = document.getElementById(`status_${alunoId}`);
    if (hiddenField) {
      hiddenField.value = status;
    }
    
    // Atualizar cor da linha
    this.updateRowColor(alunoId, status);
    
    // Atualizar contadores
    this.atualizarContadores();
  },

  updateRowColor: function(alunoId, status) {
    const row = document.querySelector(`div.aluno-row[data-aluno-id="${alunoId}"]`);
    if (!row) return;

    row.classList.remove('bg-green-50', 'bg-red-50', 'bg-yellow-50');
    
    switch(status) {
      case 'presente':
        row.classList.add('bg-green-50');
        break;
      case 'falta':
        row.classList.add('bg-red-50');
        break;
      case 'justificada':
        row.classList.add('bg-yellow-50');
        break;
    }
  },

  marcarTodos: function(status) {
    const alunos = document.querySelectorAll('.aluno-row[data-aluno-id]');
    const alunoIds = [...new Set(Array.from(alunos).map(el => el.getAttribute('data-aluno-id')))];
    
    alunoIds.forEach(alunoId => {
      this.setStatus(parseInt(alunoId), status);
    });
  },

  inverterSelecao: function() {
    const alunos = document.querySelectorAll('.aluno-row[data-aluno-id]');
    const alunoIds = [...new Set(Array.from(alunos).map(el => el.getAttribute('data-aluno-id')))];
    
    alunoIds.forEach(alunoId => {
      const hiddenField = document.getElementById(`status_${alunoId}`);
      if (hiddenField) {
        const currentStatus = hiddenField.value;
        let newStatus;
        
        if (currentStatus === 'presente') {
          newStatus = 'falta';
        } else if (currentStatus === 'falta') {
          newStatus = 'presente';
        } else {
          // Se for justificada, não inverte
          return;
        }
        
        this.setStatus(parseInt(alunoId), newStatus);
      }
    });
  },

  atualizarContadores: function() {
    const presente = document.querySelectorAll('input[id^="status_"][value="presente"]').length;
    const ausente = document.querySelectorAll('input[id^="status_"][value="falta"]').length;
    const justificado = document.querySelectorAll('input[id^="status_"][value="justificada"]').length;
    
    const contadorPresente = document.getElementById('contador-presente');
    const contadorAusente = document.getElementById('contador-ausente');
    const contadorJustificado = document.getElementById('contador-justificado');
    
    if (contadorPresente) contadorPresente.textContent = presente;
    if (contadorAusente) contadorAusente.textContent = ausente;
    if (contadorJustificado) contadorJustificado.textContent = justificado;
  },

  init: function() {
    // Inicializa todos como presentes
    const alunos = document.querySelectorAll('.aluno-row[data-aluno-id]');
    
    alunos.forEach(row => {
      const alunoId = row.getAttribute('data-aluno-id');
      this.setStatus(parseInt(alunoId), 'presente');
    });

    // Toggle do menu dropdown
    const btnAcoes = document.getElementById('btn-acoes-rapidas');
    const menuAcoes = document.getElementById('menu-acoes');
    
    if (btnAcoes && menuAcoes) {
      // Remove listeners antigos se existirem
      const newBtnAcoes = btnAcoes.cloneNode(true);
      btnAcoes.parentNode.replaceChild(newBtnAcoes, btnAcoes);
      
      newBtnAcoes.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        menuAcoes.classList.toggle('hidden');
      });

      // Fecha o menu ao clicar fora
      document.addEventListener('click', function(e) {
        if (!menuAcoes.contains(e.target) && !newBtnAcoes.contains(e.target)) {
          menuAcoes.classList.add('hidden');
        }
      });
    }

    // Ações do menu
    const botoesAcao = document.querySelectorAll('[data-acao]');
    
    botoesAcao.forEach(btn => {
      // Remove listeners antigos
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const acao = newBtn.dataset.acao;
        
        switch(acao) {
          case 'presente':
            this.marcarTodos('presente');
            break;
          case 'falta':
            this.marcarTodos('falta');
            break;
          case 'justificada':
            this.marcarTodos('justificada');
            break;
          case 'inverter':
            this.inverterSelecao();
            break;
        }
        
        if (menuAcoes) {
          menuAcoes.classList.add('hidden');
        }
      });
    });
  }
};

// Função global para compatibilidade com onclick
function setStatus(alunoId, status) {
  window.FrequenciaManager.setStatus(alunoId, status);
}

// Inicializar quando o DOM carregar
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', function() {
    window.FrequenciaManager.init();
  });
} else {
  // DOM já está carregado
  window.FrequenciaManager.init();
}

// Reinicializar em caso de Turbolinks/Turbo
document.addEventListener('turbolinks:load', function() {
  window.FrequenciaManager.init();
});

document.addEventListener('turbo:load', function() {
  window.FrequenciaManager.init();
});
</script>