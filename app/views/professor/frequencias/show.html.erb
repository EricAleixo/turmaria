<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Frequência - <%= @frequencia.data_aula.strftime("%d/%m/%Y") %>
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @frequencia.turma.nome %></span> - <%= @frequencia.turma.escola.nome %>
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base" do %>
            Voltar para Turmas
          <% end %>
          <%= link_to edit_frequencia_path(@frequencia), class: "w-full sm:w-auto text-center bg-indigo-500 hover:bg-indigo-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base" do %>
            Editar Frequência
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-8">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-blue-100 text-blue-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @frequencia.total_alunos %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-green-100 text-green-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Presentes</p>
            <p class="text-xl sm:text-2xl font-bold text-green-600"><%= @frequencia.total_presentes %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-red-100 text-red-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Faltas</p>
            <p class="text-xl sm:text-2xl font-bold text-red-600"><%= @frequencia.total_faltas %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-yellow-100 text-yellow-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Justificadas</p>
            <p class="text-xl sm:text-2xl font-bold text-yellow-600"><%= @frequencia.total_justificadas %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Conteúdo Trabalhado e Observações -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
      <!-- Conteúdo Trabalhado -->
      <div class="bg-white rounded-lg shadow-md">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4">Conteúdo Trabalhado</h2>
          <% if @frequencia.conteudo_trabalhado.present? %>
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.conteudo_trabalhado %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhum conteúdo foi registrado para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Observações Gerais -->
      <div class="bg-white rounded-lg shadow-md">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4">Observações Gerais da Aula</h2>
          <% if @frequencia.observacoes.present? %>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.observacoes %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhuma observação foi registrada para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lista de Alunos -->
    <div class="bg-white rounded-lg shadow-md">
      <div class="p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900">Lista de Presença</h2>
          <div class="text-xs sm:text-sm text-gray-600 bg-green-50 border border-green-200 rounded-lg px-3 py-2">
            Percentual de Presença: <span class="font-bold text-green-600"><%= @frequencia.percentual_presenca %>%</span>
          </div>
        </div>

        <!-- Quick Edit Form -->
        <%= form_with url: update_presencas_frequencia_path(@frequencia), method: :patch, local: true, id: "presencas-form" do |form| %>
          
          <!-- Usando o Partial -->
          <%= render 'tabela_alunos_show', frequencia: @frequencia, frequencia_alunos: @frequencia_alunos %>

          <!-- Save Button -->
          <% if @frequencia_alunos.any? %>
            <div class="mt-6 pt-6 border-t border-gray-200">
              <div class="flex flex-col sm:flex-row justify-end gap-3">
                <%= link_to "Cancelar", minhas_turmas_path, 
                      class: "w-full sm:w-auto text-center px-6 py-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg font-medium transition-colors text-sm sm:text-base" %>
                <%= form.submit "Salvar Alterações", 
                      class: "w-full sm:w-auto px-6 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors shadow-md hover:shadow-lg text-sm sm:text-base" %>
              </div>
            </div>
          <% end %>
        <% end %>

        <!-- Empty State -->
        <% if @frequencia_alunos.empty? %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhum aluno encontrado</h3>
            <p class="mt-1 text-sm text-gray-500">Esta frequência não possui registros de alunos.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>