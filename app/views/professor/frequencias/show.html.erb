<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Frequência - <%= @frequencia.data_aula.strftime("%d/%m/%Y") %>
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @frequencia.turma.nome %></span> - <%= @frequencia.turma.escola.nome %>
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base" do %>
            Voltar para Turmas
          <% end %>
          <%= link_to edit_frequencia_path(@frequencia), class: "w-full sm:w-auto text-center bg-indigo-500 hover:bg-indigo-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base" do %>
            Editar Frequência
          <% end %>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-8">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-blue-100 text-blue-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @frequencia.total_alunos %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-green-100 text-green-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Presentes</p>
            <p class="text-xl sm:text-2xl font-bold text-green-600"><%= @frequencia.total_presentes %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-red-100 text-red-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Faltas</p>
            <p class="text-xl sm:text-2xl font-bold text-red-600"><%= @frequencia.total_faltas %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-yellow-100 text-yellow-600 mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4">
            <p class="text-xs sm:text-sm font-medium text-gray-600">Justificadas</p>
            <p class="text-xl sm:text-2xl font-bold text-yellow-600"><%= @frequencia.total_justificadas %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Conteúdo Trabalhado e Observações -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
      <!-- Conteúdo Trabalhado -->
      <div class="bg-white rounded-lg shadow-md">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4">Conteúdo Trabalhado</h2>
          <% if @frequencia.conteudo_trabalhado.present? %>
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.conteudo_trabalhado %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhum conteúdo foi registrado para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Observações Gerais -->
      <div class="bg-white rounded-lg shadow-md">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4">Observações Gerais da Aula</h2>
          <% if @frequencia.observacoes.present? %>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.observacoes %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhuma observação foi registrada para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lista de Alunos -->
    <div class="bg-white rounded-lg shadow-md">
      <div class="p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900">Lista de Presença</h2>
          <div class="text-xs sm:text-sm text-gray-600 bg-green-50 border border-green-200 rounded-lg px-3 py-2">
            Percentual de Presença: <span class="font-bold text-green-600"><%= @frequencia.percentual_presenca %>%</span>
          </div>
        </div>

        <!-- Quick Edit Form -->
        <%= form_with url: update_presencas_frequencia_path(@frequencia), method: :patch, local: true, id: "presencas-form" do |form| %>
          <div class="space-y-3 sm:space-y-4">
            <% @frequencia_alunos.each do |freq_aluno| %>
              <div class="border-2 border-gray-200 rounded-lg p-3 sm:p-4 hover:border-gray-300 transition-colors
                          <%= case freq_aluno.status
                              when 'presente' then 'bg-green-50 border-green-300'
                              when 'falta' then 'bg-red-50 border-red-300'
                              when 'justificada' then 'bg-yellow-50 border-yellow-300'
                              else 'bg-white'
                              end %>">
                
                <!-- Aluno Info -->
                <div class="flex items-center mb-3">
                  <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white font-medium mr-3 flex-shrink-0">
                    <span class="text-sm"><%= freq_aluno.aluno.nome.first.upcase %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-medium text-gray-900 text-sm sm:text-base truncate"><%= freq_aluno.aluno.nome %></p>
                    <p class="text-xs sm:text-sm text-gray-500">Mat: <%= freq_aluno.aluno.matricula || 'N/A' %></p>
                  </div>
                </div>

                <!-- Status Controls -->
                <div class="space-y-3">
                  <!-- Status Buttons -->
                  <div class="flex flex-col sm:flex-row gap-2">
                    <label class="flex-1">
                      <%= radio_button_tag "frequencia_alunos[#{freq_aluno.id}][status]", 'presente', 
                            freq_aluno.status == 'presente',
                            class: "hidden radio-presente-show",
                            onchange: "updateStatusDisplayShow(this)" %>
                      <span class="flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all
                            <%= freq_aluno.status == 'presente' ? 'bg-green-500 text-white shadow-md' : 'bg-green-50 text-green-700 hover:bg-green-100 border border-green-200' %>">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        Presente
                      </span>
                    </label>

                    <label class="flex-1">
                      <%= radio_button_tag "frequencia_alunos[#{freq_aluno.id}][status]", 'falta', 
                            freq_aluno.status == 'falta',
                            class: "hidden radio-falta-show",
                            onchange: "updateStatusDisplayShow(this)" %>
                      <span class="flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all
                            <%= freq_aluno.status == 'falta' ? 'bg-red-500 text-white shadow-md' : 'bg-red-50 text-red-700 hover:bg-red-100 border border-red-200' %>">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Ausente
                      </span>
                    </label>

                    <label class="flex-1">
                      <%= radio_button_tag "frequencia_alunos[#{freq_aluno.id}][status]", 'justificada', 
                            freq_aluno.status == 'justificada',
                            class: "hidden radio-justificada-show",
                            onchange: "updateStatusDisplayShow(this)" %>
                      <span class="flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all
                            <%= freq_aluno.status == 'justificada' ? 'bg-yellow-500 text-white shadow-md' : 'bg-yellow-50 text-yellow-700 hover:bg-yellow-100 border border-yellow-200' %>">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Justificado
                      </span>
                    </label>
                  </div>

                  <!-- Observações -->
                  <div class="w-full">
                    <%= text_area_tag "frequencia_alunos[#{freq_aluno.id}][observacoes]", 
                          freq_aluno.observacoes,
                          placeholder: "Observações sobre #{freq_aluno.aluno.nome.split.first}...",
                          rows: 2,
                          class: "w-full px-3 py-2 text-xs sm:text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Save Button -->
          <% if @frequencia_alunos.any? %>
            <div class="mt-6 pt-6 border-t border-gray-200">
              <div class="flex flex-col sm:flex-row justify-end gap-3">
                <%= link_to "Cancelar", minhas_turmas_path, 
                      class: "w-full sm:w-auto text-center px-6 py-2.5 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg font-medium transition-colors text-sm sm:text-base" %>
                <%= form.submit "Salvar Alterações", 
                      class: "w-full sm:w-auto px-6 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors shadow-md hover:shadow-lg text-sm sm:text-base" %>
              </div>
            </div>
          <% end %>
        <% end %>

        <!-- Empty State -->
        <% if @frequencia_alunos.empty? %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhum aluno encontrado</h3>
            <p class="mt-1 text-sm text-gray-500">Esta frequência não possui registros de alunos.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
function updateStatusDisplayShow(radio) {
  const card = radio.closest('.border-2');
  const container = radio.closest('.flex');
  const labels = container.querySelectorAll('label span');
  const status = radio.value;
  
  // Remove todas as classes de status do card
  card.classList.remove('bg-green-50', 'border-green-300', 'bg-red-50', 'border-red-300', 'bg-yellow-50', 'border-yellow-300', 'bg-white');
  
  // Remove active classes de todos os labels
  labels.forEach(label => {
    // Remove classes ativas
    label.classList.remove('bg-green-500', 'bg-red-500', 'bg-yellow-500', 'text-white', 'shadow-md');
    // Adiciona classes inativas baseado no tipo
    if (label.textContent.includes('Presente')) {
      label.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-green-50 text-green-700 hover:bg-green-100 border border-green-200';
    } else if (label.textContent.includes('Ausente')) {
      label.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-red-50 text-red-700 hover:bg-red-100 border border-red-200';
    } else if (label.textContent.includes('Justificado')) {
      label.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-yellow-50 text-yellow-700 hover:bg-yellow-100 border border-yellow-200';
    }
  });
  
  // Adiciona classes ativas ao label selecionado
  const selectedLabel = radio.nextElementSibling;
  
  if (status === 'presente') {
    selectedLabel.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-green-500 text-white shadow-md';
    card.classList.add('bg-green-50', 'border-green-300');
  } else if (status === 'falta') {
    selectedLabel.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-red-500 text-white shadow-md';
    card.classList.add('bg-red-50', 'border-red-300');
  } else if (status === 'justificada') {
    selectedLabel.className = 'flex items-center justify-center px-3 py-2 rounded-lg text-xs sm:text-sm font-medium cursor-pointer transition-all bg-yellow-500 text-white shadow-md';
    card.classList.add('bg-yellow-50', 'border-yellow-300');
  }
}
</script>