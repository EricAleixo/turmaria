<div class="bg-white rounded-lg overflow-hidden">
  <!-- Versão Desktop - Tabela -->
  <div class="hidden md:block p-4">
    <div class="space-y-4">
      <% @turma.alunos.order(:nome).each do |aluno| %>
        <div class="bg-gray-50 rounded-lg aluno-row" data-aluno-id="<%= aluno.id %>">
          <div class="flex items-center justify-between p-4">
            <!-- Info do Aluno -->
            <div class="flex items-center flex-1">
              <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center mr-4">
                <span class="text-sm font-bold text-white">
                  <%= aluno.nome.split.map(&:first).join.upcase %>
                </span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900"><%= aluno.nome %></h3>
                <p class="text-sm text-gray-500">Matrícula: <%= aluno.matricula %></p>
              </div>
            </div>

            <!-- Botões de Status -->
            <div class="flex items-center gap-3">
              <!-- Presente -->
              <button type="button" 
                      class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-full border transition-colors status-btn presente-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="presente"
                      onclick="setStatus('<%= aluno.id %>', 'presente')">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Presente
              </button>

              <!-- Falta -->
              <button type="button" 
                      class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-full border transition-colors status-btn falta-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="falta"
                      onclick="setStatus('<%= aluno.id %>', 'falta')">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Falta
              </button>

              <!-- Justificada -->
              <button type="button" 
                      class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium rounded-full border transition-colors status-btn justificada-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="justificada"
                      onclick="setStatus('<%= aluno.id %>', 'justificada')">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Justificada
              </button>
            </div>

            <%= hidden_field_tag "alunos[#{aluno.id}][status]", "presente", id: "status_#{aluno.id}" %>
          </div>

          <!-- Campo de Observações -->
          <div class="px-4 pb-4">
            <input type="text" 
                   name="alunos[<%= aluno.id %>][observacoes]" 
                   placeholder="Observações..." 
                   class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Versão Mobile - Cards -->
  <div class="block md:hidden p-3">
    <div class="space-y-3">
      <% @turma.alunos.order(:nome).each do |aluno| %>
        <div class="bg-gray-50 rounded-lg shadow-sm aluno-row" data-aluno-id="<%= aluno.id %>">
          <!-- Header do Card -->
          <div class="flex items-center p-3 border-b border-gray-200">
            <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
              <span class="text-xs font-bold text-white">
                <%= aluno.nome.split.map(&:first).join.upcase %>
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 text-sm truncate"><%= aluno.nome %></h3>
              <p class="text-xs text-gray-500">Mat: <%= aluno.matricula %></p>
            </div>
          </div>

          <!-- Botões de Status em Grid -->
          <div class="p-3">
            <div class="grid grid-cols-3 gap-2 mb-3">
              <!-- Presente -->
              <button type="button" 
                      class="flex flex-col items-center justify-center gap-1 px-2 py-3 text-xs font-medium rounded-lg border transition-colors status-btn presente-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="presente"
                      onclick="setStatus('<%= aluno.id %>', 'presente')">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Presente</span>
              </button>

              <!-- Falta -->
              <button type="button" 
                      class="flex flex-col items-center justify-center gap-1 px-2 py-3 text-xs font-medium rounded-lg border transition-colors status-btn falta-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="falta"
                      onclick="setStatus('<%= aluno.id %>', 'falta')">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Falta</span>
              </button>

              <!-- Justificada -->
              <button type="button" 
                      class="flex flex-col items-center justify-center gap-1 px-2 py-3 text-xs font-medium rounded-lg border transition-colors status-btn justificada-btn" 
                      data-aluno-id="<%= aluno.id %>" 
                      data-status="justificada"
                      onclick="setStatus('<%= aluno.id %>', 'justificada')">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <span>Justificada</span>
              </button>
            </div>

            <%= hidden_field_tag "alunos[#{aluno.id}][status]", "presente", id: "status_#{aluno.id}" %>

            <!-- Campo de Observações -->
            <input type="text" 
                   name="alunos[<%= aluno.id %>][observacoes]" 
                   placeholder="Observações..." 
                   class="w-full px-3 py-2 text-xs border border-gray-300 rounded-lg bg-white focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
.status-btn {
  background-color: #f9fafb;
  border-color: #d1d5db;
  color: #6b7280;
}

.status-btn:hover {
  background-color: #f3f4f6;
}

.presente-btn.active {
  background-color: #dcfce7;
  border-color: #16a34a;
  color: #15803d;
}

.falta-btn.active {
  background-color: #fef2f2;
  border-color: #dc2626;
  color: #dc2626;
}

.justificada-btn.active {
  background-color: #fefce8;
  border-color: #ca8a04;
  color: #a16207;
}

.aluno-row {
  transition: all 0.2s ease;
  border: 2px solid transparent;
}

.aluno-row.bg-green-50 {
  background-color: #f0fdf4;
  border-color: #16a34a;
}

.aluno-row.bg-red-50 {
  background-color: #fef2f2;
  border-color: #dc2626;
}

.aluno-row.bg-yellow-50 {
  background-color: #fefce8;
  border-color: #ca8a04;
}
</style>

<script>
console.log('=== SCRIPT DE FREQUÊNCIA CARREGADO ===');

function setStatus(alunoId, status) {
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log('🎯 setStatus CHAMADO');
  console.log('   Aluno ID:', alunoId);
  console.log('   Status:', status);
  
  // Remover classe active de todos os botões do aluno
  const buttons = document.querySelectorAll(`[data-aluno-id="${alunoId}"].status-btn`);
  console.log('   Botões encontrados:', buttons.length);
  
  buttons.forEach((btn, index) => {
    console.log(`   Botão ${index + 1}:`, btn.dataset.status, '- removendo active');
    btn.classList.remove('active');
  });
  
  // Adicionar classe active ao botão clicado
  const activeButton = document.querySelector(`[data-aluno-id="${alunoId}"][data-status="${status}"]`);
  console.log('   Botão a ativar encontrado:', activeButton ? 'SIM' : 'NÃO');
  
  if (activeButton) {
    activeButton.classList.add('active');
    console.log('   ✅ Classe "active" adicionada ao botão:', status);
  } else {
    console.error('   ❌ ERRO: Botão não encontrado!');
  }
  
  // Atualizar o campo hidden
  const hiddenField = document.getElementById(`status_${alunoId}`);
  console.log('   Campo hidden encontrado:', hiddenField ? 'SIM' : 'NÃO');
  
  if (hiddenField) {
    const valorAnterior = hiddenField.value;
    hiddenField.value = status;
    console.log('   Campo hidden atualizado:', valorAnterior, '→', status);
  } else {
    console.error('   ❌ ERRO: Campo hidden não encontrado!');
  }
  
  // Atualizar cor da linha
  console.log('   Chamando updateRowColor...');
  updateRowColor(alunoId, status);
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');
}

function updateRowColor(alunoId, status) {
  console.log('🎨 updateRowColor CHAMADO');
  console.log('   Aluno ID:', alunoId);
  console.log('   Status:', status);
  
  const row = document.querySelector(`div.aluno-row[data-aluno-id="${alunoId}"]`);
  console.log('   Linha encontrada:', row ? 'SIM' : 'NÃO');
  
  if (!row) {
    console.error('   ❌ ERRO: Linha não encontrada!');
    return;
  }

  console.log('   Classes antes:', row.className);
  row.classList.remove('bg-green-50', 'bg-red-50', 'bg-yellow-50');
  
  switch(status) {
    case 'presente':
      row.classList.add('bg-green-50');
      console.log('   ✅ Adicionada classe: bg-green-50');
      break;
    case 'falta':
      row.classList.add('bg-red-50');
      console.log('   ✅ Adicionada classe: bg-red-50');
      break;
    case 'justificada':
      row.classList.add('bg-yellow-50');
      console.log('   ✅ Adicionada classe: bg-yellow-50');
      break;
    default:
      console.warn('   ⚠️  Status desconhecido:', status);
  }
  
  console.log('   Classes depois:', row.className);
}

function marcarTodos(status) {
  console.log('📝 marcarTodos CHAMADO - Status:', status);
  const alunos = document.querySelectorAll('[data-aluno-id]');
  const alunoIds = [...new Set(Array.from(alunos).map(el => el.getAttribute('data-aluno-id')))];
  console.log('   Total de alunos únicos:', alunoIds.length);
  
  alunoIds.forEach((alunoId, index) => {
    console.log(`   Marcando aluno ${index + 1}/${alunoIds.length} (ID: ${alunoId})`);
    setStatus(parseInt(alunoId), status);
  });
  
  console.log('✅ marcarTodos CONCLUÍDO\n');
}

// Inicializa as cores quando a página carregar
document.addEventListener('DOMContentLoaded', function() {
  console.log('\n🚀 DOM CONTENT LOADED - INICIALIZANDO...');
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  
  const rows = document.querySelectorAll('.aluno-row[data-aluno-id]');
  console.log('📊 Total de linhas de alunos encontradas:', rows.length);
  
  rows.forEach((row, index) => {
    const alunoId = row.getAttribute('data-aluno-id');
    const hiddenField = document.getElementById(`status_${alunoId}`);
    
    console.log(`\n   Aluno ${index + 1}/${rows.length}:`);
    console.log('   - ID:', alunoId);
    console.log('   - Hidden field encontrado:', hiddenField ? 'SIM' : 'NÃO');
    
    if (hiddenField) {
      const status = hiddenField.value;
      console.log('   - Status inicial:', status);
      updateRowColor(parseInt(alunoId), status);
    } else {
      console.error('   ❌ ERRO: Campo hidden não encontrado para aluno ID:', alunoId);
    }
  });
  
  console.log('\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log('✅ INICIALIZAÇÃO CONCLUÍDA');
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');
  
  // Adicionar event listeners aos botões
  console.log('🔧 CONFIGURANDO EVENT LISTENERS...');
  const allButtons = document.querySelectorAll('.status-btn');
  console.log('   Total de botões encontrados:', allButtons.length);
  
  allButtons.forEach((button, index) => {
    const alunoId = button.getAttribute('data-aluno-id');
    const status = button.getAttribute('data-status');
    
    console.log(`   Botão ${index + 1}: Aluno ID ${alunoId}, Status: ${status}`);
    
    button.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('\n🖱️  BOTÃO CLICADO!');
      console.log('   Target:', e.target);
      console.log('   Current Target:', e.currentTarget);
      setStatus(parseInt(alunoId), status);
    });
  });
  
  console.log('✅ EVENT LISTENERS CONFIGURADOS\n');
});

console.log('=== FIM DO SCRIPT ===\n');
</script>