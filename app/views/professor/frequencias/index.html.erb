<%# app/views/professor/frequencias/index.html.erb (CÓDIGO FINAL COM CORREÇÃO DE ÍCONES) %>

<%= content_for :page_title, "Dashboard de Frequências" %>

<%# Helper para calcular a variação (Mantido) %>
<% 
  def calcular_variacao(atual, passado)
    return "<span class='text-xs font-medium text-gray-500'>Novo Período</span>".html_safe if passado.zero? && atual > 0
    return "<span class='text-xs font-medium text-gray-500'>Estável</span>".html_safe if passado.zero? && atual.zero?
    
    variacao = (atual.to_f - passado) / (passado.zero? ? 1 : passado.to_f) * 100
    
    cor_classe = variacao >= 0 ? 'text-green-600' : 'text-red-600'
    simbolo = variacao >= 0 ? '+' : ''
    
    "<span class='text-xs font-medium #{cor_classe}'>#{simbolo}#{'%.0f' % variacao}% vs Mês Passado</span>".html_safe
  end
%>

<%# 1. Fundo da Página CLARO %>
<div class="bg-gradient-to-br from-slate-50 via-gray-100 to-gray-200 min-h-screen p-4 sm:p-8">
  <div class="w-full max-w-7xl mx-auto">
    
    <%# Container principal claro e destacado %>
    <div class="bg-white p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-gray-100">
      
      <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">
          Dashboard de Frequências
        </h1>
        <hr class="border-gray-200 mt-4"/>
      </div>

      
      
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061A1.125 1.125 0 0 1 3 16.811V8.69ZM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061a1.125 1.125 0 0 1-1.683-.977V8.69Z" />
        </svg>
        Resumo Rápido
      </h2>

      <% estatisticas = defined?(@estatisticas_gerais) ? @estatisticas_gerais : {} %>
      
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-10">
        
        <%# Card 1: Aulas no Mês - Ícone e layout restaurados %>
        <div class="bg-white rounded-xl shadow-lg p-4 sm:p-5 border-l-4 border-green-500 flex justify-between items-center transition-all hover:shadow-xl">
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Aulas no Mês</p>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900"><%= estatisticas[:aulas_mes] || 0 %></p>
            <%= calcular_variacao(estatisticas[:aulas_mes] || 0, estatisticas[:aulas_mes_passado] || 0) %>
          </div>
          <%# Ícone restaurado: Sem w-12 h-12, sem flex items-center justify-center %>
          <div class="p-3 rounded-full bg-green-100 text-green-600 flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
        </div>

        <%# Card 2: Faltas Registradas - Ícone e layout restaurados %>
        <div class="bg-white rounded-xl shadow-lg p-4 sm:p-5 border-l-4 border-red-500 flex justify-between items-center transition-all hover:shadow-xl">
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Total de Faltas</p>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900"><%= estatisticas[:faltas_registradas] || 0 %></p>
            <span class="text-xs font-medium text-gray-500">Em <%= estatisticas[:total_registros] || 0 %> registros</span>
          </div>
          <%# Ícone restaurado %>
          <div class="p-3 rounded-full bg-red-100 text-red-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
          </div>
        </div>

        <%# Card 3: Média de Presença - Ícone e layout restaurados %>
        <div class="bg-white rounded-xl shadow-lg p-4 sm:p-5 border-l-4 border-blue-500 flex justify-between items-center transition-all hover:shadow-xl">
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Média de Presença</p>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900"><%= estatisticas[:media_presenca] || '0.0%' %></p>
            <span class="text-xs font-medium text-gray-500">Todas as suas turmas</span>
          </div>
          <%# Ícone restaurado: Sem w-12 h-12, sem flex items-center justify-center %>
          <div class="p-3 rounded-full bg-blue-100 text-blue-600 flex-shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" /></svg>
          </div>
        </div>

        <%# Card 4: Turmas Ativas - Ícone e layout restaurados %>
        <div class="bg-white rounded-xl shadow-lg p-4 sm:p-5 border-l-4 border-purple-500 flex justify-between items-center transition-all hover:shadow-xl">
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Turmas Ativas</p>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900"><%= estatisticas[:turmas_ativas] || 0 %></p>
            <span class="text-xs font-medium text-purple-600">Total associado</span>
          </div>
          <%# Ícone restaurado %>
          <div class="p-3 rounded-full bg-purple-100 text-purple-600 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
        </div>
      </div>
      
      
      <hr class="border-gray-200 mb-8"/>
      
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4 border-b pb-2">
        Registro Detalhado
      </h2>
      
      <div class="overflow-x-auto">
        <% if @frequencias.present? %>
          <table class="table w-full shadow-xl rounded-xl overflow-hidden">
            <thead>
              <tr class="bg-green-600 text-white">
                <th class="rounded-tl-xl">Matéria</th>
                <th>Data</th>
                <th>Hora</th>
                <th>Turma</th>
                <th class="rounded-tr-xl">Ações</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              <% @frequencias.each do |frequencia| %>
                <tr class="hover:bg-green-50 transition-all duration-300 border-b border-gray-200 group">
                  <td class="py-4 font-semibold text-slate-700">
                    <%= frequencia.disciplina.nome %>
                  </td>
                  <td class="text-slate-600">
                    <%= frequencia.data_aula.strftime('%d/%m/%Y') %>
                  </td>
                  <td class="text-slate-600">
                    <%= frequencia.created_at.strftime('%H:%M') %>
                  </td>
                  <td class="text-slate-600">
                    <span class="badge badge-lg bg-green-200 text-green-800 border-0 font-medium">
                      <%= frequencia.turma.nome %>
                    </span>
                  </td>
                  
                  <td>
                    <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                      <%= link_to professor_turma_frequencia_path(frequencia.turma, frequencia), class: "btn btn-sm btn-circle bg-green-600 text-white border-0 hover:bg-green-700 hover:scale-110 transition-all duration-300 shadow-lg", title: "Ver detalhes" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      <% end %>
                    </div>
                  </td>
                  
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="text-center py-16 bg-gray-50 rounded-xl border-2 border-dashed border-slate-200">
            <div class="max-w-md mx-auto">
              <div class="text-6xl mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-20 h-20 mx-auto text-gray-800">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                </svg>

              </div>
              <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhuma frequência registrada.</h3>
              <p class="text-slate-500 mb-6">Comece lançando a frequência para as suas turmas.</p>
              
              <%= link_to professor_turmas_path, class: "btn btn-lg bg-gradient-to-r from-green-600 to-green-700 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 rounded-full" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Lançar Frequência
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    </div> </div>
</div>