<div class="bg-white rounded-lg overflow-hidden">
  <div class="space-y-4">
    <% frequencia_alunos.each do |freq_aluno| %>
      <div class="bg-gray-50 rounded-lg aluno-row" data-aluno-id="<%= freq_aluno.aluno.id %>" data-freq-aluno-id="<%= freq_aluno.id %>">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-4 gap-4">
          <!-- Info do Aluno -->
          <div class="flex items-center flex-1">
            <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
              <span class="text-sm font-bold text-white">
                <%= freq_aluno.aluno.nome.split.map(&:first).join.upcase %>
              </span>
            </div>
            <div class="min-w-0">
              <h3 class="font-semibold text-gray-900 truncate"><%= freq_aluno.aluno.nome %></h3>
              <p class="text-sm text-gray-500">Matrícula: <%= freq_aluno.aluno.matricula || 'N/A' %></p>
            </div>
          </div>

          <!-- Botões de Status -->
          <div class="flex items-center gap-2 sm:gap-3 flex-wrap sm:flex-nowrap">
            <!-- Presente -->
            <button type="button" 
                    class="flex items-center gap-1 sm:gap-2 px-2 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-full border transition-colors status-btn presente-btn <%= 'active' if freq_aluno.status == 'presente' %>" 
                    data-freq-aluno-id="<%= freq_aluno.id %>" 
                    data-status="presente"
                    onclick="setStatusShow(<%= freq_aluno.id %>, 'presente')">
              <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="hidden sm:inline">Presente</span>
              <span class="sm:hidden">P</span>
            </button>

            <!-- Falta -->
            <button type="button" 
                    class="flex items-center gap-1 sm:gap-2 px-2 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-full border transition-colors status-btn falta-btn <%= 'active' if freq_aluno.status == 'falta' %>" 
                    data-freq-aluno-id="<%= freq_aluno.id %>" 
                    data-status="falta"
                    onclick="setStatusShow(<%= freq_aluno.id %>, 'falta')">
              <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              <span class="hidden sm:inline">Falta</span>
              <span class="sm:hidden">F</span>
            </button>

            <!-- Justificada -->
            <button type="button" 
                    class="flex items-center gap-1 sm:gap-2 px-2 sm:px-3 py-1.5 text-xs sm:text-sm font-medium rounded-full border transition-colors status-btn justificada-btn <%= 'active' if freq_aluno.status == 'justificada' %>" 
                    data-freq-aluno-id="<%= freq_aluno.id %>" 
                    data-status="justificada"
                    onclick="setStatusShow(<%= freq_aluno.id %>, 'justificada')">
              <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
              <span class="hidden sm:inline">Justificada</span>
              <span class="sm:hidden">J</span>
            </button>
          </div>

          <%= hidden_field_tag "frequencia_alunos[#{freq_aluno.id}][status]", freq_aluno.status, id: "status_#{freq_aluno.id}" %>
        </div>

        <!-- Campo de Observações -->
        <div class="px-4 pb-4">
          <%= text_area_tag "frequencia_alunos[#{freq_aluno.id}][observacoes]", 
                freq_aluno.observacoes,
                placeholder: "Observações sobre #{freq_aluno.aluno.nome.split.first}...",
                rows: 2,
                class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
.status-btn {
  background-color: #f9fafb;
  border-color: #d1d5db;
  color: #6b7280;
}

.status-btn:hover {
  background-color: #f3f4f6;
}

.presente-btn.active {
  background-color: #dcfce7;
  border-color: #16a34a;
  color: #15803d;
}

.falta-btn.active {
  background-color: #fef2f2;
  border-color: #dc2626;
  color: #dc2626;
}

.justificada-btn.active {
  background-color: #fefce8;
  border-color: #ca8a04;
  color: #a16207;
}

.aluno-row {
  transition: all 0.2s ease;
  border: 2px solid transparent;
}

.aluno-row.bg-green-50 {
  background-color: #f0fdf4;
  border-color: #16a34a;
}

.aluno-row.bg-red-50 {
  background-color: #fef2f2;
  border-color: #dc2626;
}

.aluno-row.bg-yellow-50 {
  background-color: #fefce8;
  border-color: #ca8a04;
}
</style>

<script>
function setStatusShow(frequenciaAlunoId, status) {
  // Remover classe active de todos os botões deste freq_aluno
  const buttons = document.querySelectorAll(`[data-freq-aluno-id="${frequenciaAlunoId}"].status-btn`);
  buttons.forEach(btn => btn.classList.remove('active'));
  
  // Adicionar classe active ao botão clicado
  const activeButton = document.querySelector(`[data-freq-aluno-id="${frequenciaAlunoId}"][data-status="${status}"]`);
  if (activeButton) {
    activeButton.classList.add('active');
  }
  
  // Atualizar o campo hidden
  const hiddenField = document.getElementById(`status_${frequenciaAlunoId}`);
  if (hiddenField) {
    hiddenField.value = status;
  }
  
  // Atualizar cor da linha
  updateRowColorShow(frequenciaAlunoId, status);
}

function updateRowColorShow(frequenciaAlunoId, status) {
  const row = document.querySelector(`div.aluno-row[data-freq-aluno-id="${frequenciaAlunoId}"]`);
  if (!row) return;

  row.classList.remove('bg-green-50', 'bg-red-50', 'bg-yellow-50');
  
  switch(status) {
    case 'presente':
      row.classList.add('bg-green-50');
      break;
    case 'falta':
      row.classList.add('bg-red-50');
      break;
    case 'justificada':
      row.classList.add('bg-yellow-50');
      break;
  }
}

// Inicializa as cores quando a página carregar
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.aluno-row[data-freq-aluno-id]').forEach(row => {
    const freqAlunoId = row.getAttribute('data-freq-aluno-id');
    const hiddenField = document.getElementById(`status_${freqAlunoId}`);
    if (hiddenField) {
      const status = hiddenField.value;
      updateRowColorShow(freqAlunoId, status);
    }
  });
});
</script>