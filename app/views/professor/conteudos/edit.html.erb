<% content_for :title, "Editing conteudo" %>
<div class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Lado esquerdo -->
    <div class="flex items-center gap-4">
      <%= link_to "Voltar",
          professor_turma_conteudos_path(@turma),
          class: "text-sm font-medium text-gray-600 hover:text-green-600 transition-colors" %>

      <div class="h-6 w-px bg-gray-300"></div>

      <div>
        <h1 class="text-lg font-semibold text-gray-800">
          Atualize o conteúdo
        </h1>
        <p class="text-xs text-gray-500">
          Lugar para o cadastro de conteúdos e atividades escolares
        </p>
      </div>
    </div>

    <!-- Lado direito (ações) -->
    <div class="flex items-center gap-3">

      <!-- Botão principal -->
      <button type="submit"
              form="conteudo_form"
              class="px-5 py-2.5 text-sm font-semibold rounded-lg bg-green-600 text-white hover:bg-green-700 shadow-sm hover:shadow transition-all">
        Atualizar conteúdo
      </button>

    </div>
  </div>
</div>

<%= render "form", conteudo: @conteudo %>


