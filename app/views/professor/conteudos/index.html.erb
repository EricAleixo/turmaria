<%= content_for :page_title, "Conteúdos" %>

<div class="drawer lg:drawer-open bg-gradient-to-br from-slate-50 via-emerald-50 to-teal-50 min-h-screen">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    <div class="w-full p-4">
      <!-- Mobile Header -->
      <div class="flex items-center mb-6 lg:hidden bg-gradient-to-r from-emerald-600 to-teal-600 text-white rounded-2xl p-4 shadow-lg">
        <label for="my-drawer" class="btn btn-square btn-ghost text-white hover:bg-white/20">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>

        <h1 class="text-xl font-bold ml-2">
            Meus Conteúdos
        </h1>
      </div>

      <main class="w-full max-w-9xl mx-auto">
        <!-- Card Container -->
        <div class="bg-white/80 backdrop-blur-sm p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-white/20">
          <div class="bg-green-500 text-white rounded-2xl p-6 mb-8 shadow-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div class="flex flex-col items-start space-y-2 flex-grow">
              <h1 class="text-2xl lg:text-4xl font-bold">Meus Conteúdos</h1>
              <div class="badge badge-lg bg-white/20 text-white border-white/30">
                <%= @conteudos&.count || 0 %> <%= (@conteudos&.count || 0) == 1 ? 'conteúdo' : 'conteúdos' %>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto flex-shrink-0">
              <%= link_to new_professor_turma_conteudo_path(@turma), class: "btn btn-md bg-white text-blue-600 hover:bg-blue-50 border-0 shadow-lg hover:scale-105 transition-all duration-300" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Novo Conteúdo
              <% end %>
            </div>
          </div>

          <!-- Search -->
          <div class="mb-6">
            <%= form_with url: professor_conteudos_path(current_professor),
                method: :get,
                data: { turbo_frame: "conteudos" },
                class: 'w-full' do |form| %>

              <!-- Layout responsivo -->
              <div class="flex flex-col md:flex-row gap-3">
                <!-- Campo de busca -->
                <div class="w-full md:flex-1">
                  <%= form.text_field :busca, 
                      placeholder: "Buscar por título do conteúdo...", 
                      value: params[:busca],
                      class: "input input-bordered w-full bg-gray-50 border-gray-300 focus:border-emerald-500 focus:ring-emerald-500" %>
                </div>

                <!-- Botões de filtro e limpar -->
                <div class="flex gap-3 md:flex-shrink-0">
                  <label for="filtro-modal" class="btn bg-gray-50 border-gray-300 text-gray-700 hover:bg-emerald-500 hover:text-white flex-1 md:w-44 justify-between">
                    Filtros
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </label>

                  <%= link_to "Limpar",
                      professor_conteudos_path(current_professor),
                      class: "btn btn-outline border-gray-300 text-gray-700 hover:bg-gray-50 flex-1 md:flex-none md:px-6" %>
                </div>
              </div>
            <% end %>
          </div>

          <% if @conteudos.blank? %>
            <div class="text-center py-16 bg-gradient-to-br from-slate-50 to-blue-50 rounded-3xl border-2 border-dashed border-slate-200">
              <div class="max-w-md mx-auto">
                <div class="flex justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                  </svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum conteúdo encontrado</h3>
                <p class="text-slate-500 mb-6">Não existem conteúdos cadastrados para esta turma ou filtros.</p>
                <%= link_to new_professor_turma_conteudo_path(@turma), class: "btn btn-lg bg-gradient-to-r from-emerald-500 to-teal-500 text-white rounded-full" do %>
                  Adicionar Conteúdo
                <% end %>
              </div>
            </div>
          <% else %>
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
              <table class="table w-full shadow-xl rounded-xl overflow-hidden">
                <thead>
                  <tr class="bg-green-500 text-white">
                    <th class="rounded-tl-xl">Título</th>
                    <th>Bimestre</th>
                    <th>Descrição</th>
                    <th>Disciplina</th>
                    <th class="rounded-tr-xl">Ações</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  <% @conteudos.each do |conteudo| %>
                    <tr class="hover:bg-blue-50 transition-all duration-300 border-b border-gray-200 group">
                      <td class="py-4 font-bold text-slate-700"><%= conteudo.titulo %></td>
                      <td><%= conteudo.bimestre || "-" %></td>
                      <td><%= conteudo.descricao || "-" %></td>
                      <td><%= conteudo.disciplina&.nome&.capitalize || "Sem disciplina" %></td>
                      <td>
                        <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                          <!-- Ver -->
                          <%= link_to professor_painel_conteudo_path(conteudo),
                              class: "btn btn-sm btn-circle bg-gradient-to-r from-blue-500 to-green-300 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg",
                              title: "Ver conteúdo",
                              data: { turbo: false } do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                          <% end %>

                          <!-- Editar -->
                          <%= link_to edit_professor_turma_conteudo_path(@turma, conteudo),
                              class: "btn btn-sm btn-circle bg-gradient-to-r from-amber-500 to-orange-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg",
                              title: "Editar conteúdo",
                              data: { turbo: false } do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                            </svg>
                          <% end %>

                          <!-- Deletar -->
                          <%= delete_button_with_modal(
                            path: professor_painel_conteudo_path(conteudo),
                            modal_id: "modal-delete-conteudo-#{conteudo.id}",
                            title: "Excluir Conteúdo?",
                            message: "Tem certeza que deseja excluir",
                            item_name: conteudo.titulo,
                            btn_class: "btn btn-sm btn-circle bg-gradient-to-r from-red-500 to-pink-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg"
                          ) %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <!-- Mobile Cards -->
            <div class="grid grid-cols-1 gap-4 md:hidden">
              <% @conteudos.each do |conteudo| %>
                <div class="bg-white/80 shadow-xl hover:shadow-2xl transition-all duration-300 rounded-lg p-4">
                  <div class="flex justify-between items-start">
                    <div>
                      <h2 class="text-lg font-bold"><%= conteudo.titulo %></h2>
                      <p class="text-sm text-slate-500 mt-1"><%= truncate(conteudo.descricao, length: 80) %></p>
                      <div class="divider w-full my-2"></div>

                      <div class="flex flex-wrap gap-2 mt-2">
                        <span class="badge badge-sm bg-gradient-to-r from-yellow-500 to-orange-400 text-white border-0 font-bold">
                          Bimestre: <%= conteudo.bimestre || "N/A" %>
                        </span>
                      </div>
                    </div>

                    <!-- Dropdown Ações -->
                    <div class="dropdown dropdown-end z-50">
                      <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">⋮</label>
                      <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
                        <!-- Ver -->
                        <li>
                          <%= link_to professor_painel_conteudo_path(conteudo),
                              data: { turbo: false } do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 inline-block mr-2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Ver conteúdo
                          <% end %>
                        </li>

                        <!-- Editar -->
                        <li>
                          <%= link_to edit_professor_turma_conteudo_path(@turma, conteudo),
                              data: { turbo: false } do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 inline-block mr-2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                            </svg>
                            Editar conteúdo
                          <% end %>
                        </li>

                        <!-- Excluir - Trigger do Modal -->
                        <li>
                          <%= delete_modal_trigger(
                            modal_id: "delete-mobile-#{conteudo.id}",
                            text: "Excluir conteúdo"
                          ) %>
                        </li>
                      </ul>
                    </div>
                  </div>
                </div>

                <!-- Modal de confirmação (fora do card) -->
                <%= delete_modal(
                  path: professor_painel_conteudo_path(conteudo),
                  modal_id: "delete-mobile-#{conteudo.id}",
                  title: "Excluir Conteúdo?",
                  message: "Tem certeza que deseja excluir",
                  item_name: conteudo.titulo
                ) %>
              <% end %>
            </div>
          <% end %>
        </div>
      </main>
    </div>
  </div>
</div>