<%# app/views/professor/notas/registros/new.html.erb %>

<div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
  <div class="border-b-2 border-green-500 pb-4 mb-6">
    <h1 class="text-3xl font-extrabold text-gray-800 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 mr-3 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Lançamento de Notas
    </h1>
    <p class="text-gray-500 mt-1">
      <%= @avaliacao_configuracao.nome %> - <%= @bimestre %>º Bimestre
    </p>
  </div>

  <%= form_with model: @registros_form, 
                url: professor_turma_disciplina_notas_avaliaco_registros_path(@turma, @disciplina, @avaliacao_configuracao),
                method: :post,
                class: "space-y-4" do |form| %>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr>
            <th>Aluno</th>
            <th class="text-center">Nota (0 a 10)</th>
          </tr>
        </thead>
        <tbody>
          <% @registros.each do |registro| %>
            <tr>
              <td class="font-medium"><%= registro.aluno.nome %></td>
              <td class="text-center">
                <%= text_field_tag "open_struct[registros][#{registro.aluno.id}][valor]",
                                   registro.valor&.to_s&.gsub('.', ','),
                                   class: 'input input-bordered input-sm w-24 text-center input-nota',
                                   placeholder: '0,0',
                                   pattern: '[0-9]{1,2}[,.]?[0-9]{0,2}',
                                   inputmode: 'decimal' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-between pt-6 border-t border-gray-200">
      <%= link_to '← Voltar', 
                  professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina),
                  class: 'btn btn-ghost text-gray-600' %>
      
      <%= form.submit 'Salvar Notas', 
                      class: 'btn bg-green-500 hover:bg-green-700 text-white font-bold' %>
    </div>
  <% end %>
</div>

<script>
  // 🎯 SOLUÇÃO: Aceita tanto PONTO quanto VÍRGULA
  document.addEventListener('DOMContentLoaded', function() {
    const notaInputs = document.querySelectorAll('.input-nota');
    
    notaInputs.forEach(input => {
      // Converte automaticamente ao digitar
      input.addEventListener('input', function(e) {
        // Permite apenas números, vírgula e ponto
        let valor = this.value.replace(/[^0-9.,]/g, '');
        
        // Remove múltiplos separadores decimais
        const parts = valor.split(/[.,]/);
        if (parts.length > 2) {
          valor = parts[0] + ',' + parts.slice(1).join('');
        }
        
        // Converte ponto para vírgula
        valor = valor.replace('.', ',');
        
        this.value = valor;
      });
      
      // Valida e formata ao sair do campo
      input.addEventListener('blur', function() {
        let valor = this.value.trim();
        
        if (!valor) return;
        
        // Converte vírgula para ponto temporariamente para validar
        const valorNumerico = parseFloat(valor.replace(',', '.'));
        
        // Valida range
        if (isNaN(valorNumerico)) {
          alert('Digite um número válido');
          this.value = '';
          return;
        }
        
        if (valorNumerico < 0 || valorNumerico > 10) {
          alert('A nota deve estar entre 0 e 10');
          this.value = '';
          return;
        }
        
        // Formata com 1 casa decimal (opcional)
        // this.value = valorNumerico.toFixed(1).replace('.', ',');
      });
      
      // Permite navegar com Enter
      input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          const inputs = Array.from(notaInputs);
          const index = inputs.indexOf(this);
          if (index < inputs.length - 1) {
            inputs[index + 1].focus();
          }
        }
      });
    });
  });
</script>

<style>
  .input-nota:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }
</style>