<div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
  <div class="border-b-2 border-green-500 pb-4 mb-6">
    <h1 class="text-3xl font-extrabold text-gray-800 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 mr-3 text-green-500"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <%= @avaliacao_configuracao.persisted? ? 'Editar Avaliação' : 'Nova Avaliação' %>
    </h1>
    <p class="text-gray-500 mt-1">
      <%= @disciplina.nome %> - <%= @turma.nome %>
    </p>
  </div>

  <%= form_with model: @avaliacao_configuracao,
        url: @avaliacao_configuracao.persisted? ?
              professor_turma_disciplina_notas_avaliaco_path(@turma, @disciplina, @avaliacao_configuracao) :
              professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina),
        method: @avaliacao_configuracao.persisted? ? :patch : :post,
        class: "space-y-4",
        data: {
          filter_url: filter_by_bimestre_professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina),
          avaliacao_original_id: @avaliacao_configuracao.avaliacao_original_id
        } do |form| %>

    <!-- NOME -->
    <div>
      <label class="label font-semibold">Nome da Avaliação</label>
      <%= form.text_field :nome,
            class: 'input input-bordered w-full',
            required: true %>
    </div>

    <!-- BIMESTRE -->
    <div>
      <label class="label font-semibold">Bimestre</label>
      <%= form.select :bimestre,
            options_for_select(
              @turma.bimestres_disponiveis.map { |b| ["#{b}º Bimestre", b] },
              @avaliacao_configuracao.bimestre
            ),
            { prompt: 'Selecione o bimestre' },
            class: 'select select-bordered w-full',
            id: 'bimestre-select' %>
    </div>

    <!-- RECUPERAÇÃO -->
    <div class="flex items-center gap-3">
      <%= form.check_box :is_recuperacao,
            class: 'checkbox checkbox-success',
            id: 'is-recuperacao' %>
      <span class="font-medium">Avaliação de recuperação</span>
    </div>

    <!-- SUBSTITUI -->
    <div id="avaliacao-original-wrapper"
         class="<%= @avaliacao_configuracao.is_recuperacao? ? '' : 'hidden' %>">
      <label class="label font-semibold">Avaliação que será substituída</label>
      <%= form.select :avaliacao_original_id,
            [],
            { prompt: 'Selecione a avaliação' },
            class: 'select select-bordered w-full',
            id: 'avaliacao-original-select' %>
    </div>

    <div class="flex justify-between pt-6 border-t border-gray-200">
      <%= link_to '← Voltar',
            professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina),
            class: 'btn btn-ghost' %>

      <%= form.submit class: 'btn bg-green-500 hover:bg-green-700 text-white font-bold' %>
    </div>

  <% end %>
</div>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const isRecuperacao = document.getElementById('is-recuperacao')
  const wrapper = document.getElementById('avaliacao-original-wrapper')
  const selectOriginal = document.getElementById('avaliacao-original-select')
  const bimestreSelect = document.getElementById('bimestre-select')
  const form = document.querySelector('form')

  const filterUrl = form.dataset.filterUrl
  const preselectedId = form.dataset.avaliacaoOriginalId

  function carregarAvaliacoes() {
    const bimestre = bimestreSelect.value
    if (!bimestre || !isRecuperacao.checked) return

    fetch(`${filterUrl}?bimestre=${bimestre}`)
      .then(r => r.json())
      .then(data => {
        selectOriginal.innerHTML = '<option value="">Selecione a avaliação</option>'

        data.forEach(av => {
          const opt = document.createElement('option')
          opt.value = av.id
          opt.textContent = av.nome

          if (preselectedId && String(av.id) === String(preselectedId)) {
            opt.selected = true
          }

          selectOriginal.appendChild(opt)
        })
      })
  }

  isRecuperacao.addEventListener('change', () => {
    wrapper.classList.toggle('hidden', !isRecuperacao.checked)
    carregarAvaliacoes()
  })

  bimestreSelect.addEventListener('change', carregarAvaliacoes)

  // 🔥 CARREGA AUTOMATICAMENTE NO EDIT
  if (isRecuperacao.checked && bimestreSelect.value) {
    carregarAvaliacoes()
  }
})
</script>
