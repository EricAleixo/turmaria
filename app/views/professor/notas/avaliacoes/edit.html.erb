<% content_for :title, "Editar Avaliação" %>

<%# O layout principal (com o drawer) deve ser utilizado, então focamos apenas no conteúdo. %>

<div class="w-full p-4 sm:p-6 lg:p-8 bg-gray-50 min-h-screen">
  <%# Botão de menu móvel: mantém-se %>
  <div class="flex items-center mb-6 lg:hidden">
    <label for="my-drawer" class="btn btn-square btn-ghost">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </label>
    <h1 class="text-xl font-bold ml-2">Editar Avaliação</h1>
  </div>

  <main class="w-full max-w-4xl mx-auto">
    <%# 🍞 Breadcrumbs (Caminho de Navegação) %>
    <div class="text-sm breadcrumbs mb-6">
      <ul>
        <li><%= link_to "Turmas", professor_turmas_path, class: "text-green-500 hover:text-green-700 transition-colors" %></li>
        <li><%= link_to @turma.nome, professor_turma_disciplinas_path(@turma), class: "text-green-500 hover:text-green-700 transition-colors" %></li>
        <li><%= link_to @disciplina.nome, professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina), class: "text-green-500 hover:text-green-700 transition-colors" %></li>
        <li class="font-semibold text-gray-700">Editar Avaliação</li>
      </ul>
    </div>

    <%# 📝 Título da Seção %>
    <div class="mb-6 border-b pb-4">
      <h2 class="text-3xl font-extrabold text-gray-800">
        Editando Coluna: <span class="text-green-500"><%= @avaliacao_configuracao.nome %></span>
      </h2>
      <p class="text-gray-600 mt-1">Disciplina: <span class="font-semibold text-green-500"><%= @disciplina.nome %></span> | Turma: <%= @turma.nome %></p>
    </div>

    <%# Renderização do formulário %>
    <%= render 'form' %>
  </main>
</div>

<div class="modal-container">
  <turbo-frame id="modal"></turbo-frame>
</div>