<div class="p-6 bg-gray-100 min-h-screen">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-1">Editar Lançamento de Notas</h1>
    <p class="text-gray-600">
      <span class="font-bold">Turma:</span> <%= @turma.nome %> | 
      <span class="font-bold">Disciplina:</span> <%= @disciplina.nome %> | 
      <span class="font-bold">Avaliação:</span> <%= @avaliacao_configuracao.nome %> (Bimestre: <%= @avaliacao_configuracao.bimestre %>)
    </p>
  </div>
  
  <%= link_to '← Voltar para Avaliações', 
              professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina), 
              class: 'text-blue-600 hover:text-blue-800 mb-4 inline-block' %>

  <div class="bg-white p-8 shadow-md rounded-lg mt-4">
    <% # Chama a partial do formulário de lançamento de notas. 
       # O link de update é o mesmo do create, pois usamos PUT/PATCH no Rails para o mesmo recurso aninhado %>
    <%= render 'form', url: professor_turma_disciplina_notas_avaliacao_registros_path(@turma, @disciplina, @avaliacao_configuracao), method: :patch %>
  </div>
</div>