<% # app/views/professor/notas/registros/_form.html.erb %>

<% # A partial recebe as variáveis 'url' e 'method' (para create ou update) %>
<%= form_with(scope: :open_struct, # <--- CORRIGIDO: Define o nome do parâmetro raiz no hash params
              url: url, 
              # Se 'method' não for passado, Rails usa POST (para new/create)
              method: local_assigns[:method] || :post, 
              data: { turbo: true }) do |form| %>

  <div class="mb-4">
    <p class="text-sm text-gray-700">Preencha os campos com as notas (use ponto ou vírgula). Deixe em branco para ignorar ou remover uma nota existente.</p>
  </div>

  <table class="table-auto w-full divide-y divide-gray-200 bg-white shadow-sm rounded-lg">
    <tbody class="divide-y divide-gray-200">
      
      <% # Itera sobre a coleção de registros (AGORA, usando o objeto diretamente, sem depender do form.object) %>
      <%= form.fields_for :registros, @registros do |registro_fields| %>
        
        <% registro = registro_fields.object %>
        <% aluno = registro.aluno %>
        
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= aluno.id %> <%# OU USE aluno.matricula %>
            </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
            <%= aluno.nome %>
            <% if registro_fields.object.errors[:valor].any? %>
              <div class="text-danger small text-red-600 font-bold"><%= registro_fields.object.errors[:valor].join(', ') %></div>
            <% end %>
          </td>
          
          <td class="px-6 py-4 whitespace-nowrap text-center">
            <%= registro_fields.fields_for aluno.id.to_s, registro do |nota_field| %>
              <%= nota_field.text_field :valor, 
                                       step: '0.01', 
                                       class: 'form-control text-center w-24 mx-auto border border-gray-300 rounded-md shadow-sm p-2', 
                                       placeholder: 'Nota',
                                       value: nota_field.object.valor.to_s.gsub('.', ',') 
                                       %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-8">
    <%= form.submit 'Salvar e Recalcular Médias', class: 'btn bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-lg text-lg cursor-pointer transition-colors shadow-md' %>
    
    <%= link_to 'Cancelar', 
                professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina), 
                class: 'btn bg-gray-400 hover:bg-gray-500 text-white font-bold py-2 px-4 rounded-lg ml-4 transition-colors' %>
  </div>
<% end %>