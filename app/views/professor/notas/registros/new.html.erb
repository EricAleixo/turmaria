<div class="p-4 sm:p-6 lg:p-8 bg-gray-50 min-h-screen">
  <div class="max-w-6xl mx-auto"> 
    
    <div class="bg-white shadow-lg rounded-xl p-6 mb-8 border-t-4 border-indigo-500">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Lançamento de Notas</h1>
          <div class="text-sm text-gray-600 space-y-1">
            <p><span class="font-semibold text-gray-800">Turma:</span> <%= @turma.nome %></p>
            <p><span class="font-semibold text-gray-800">Disciplina:</span> <%= @disciplina.nome %></p>
            <p class="mt-1">
              <span class="font-semibold text-indigo-600">Avaliação:</span> 
              <%= @avaliacao_configuracao.nome %> (Bimestre: <%= @avaliacao_configuracao.bimestre %>)
            </p>
          </div>
        </div>
        
        <%= link_to '← Voltar para Avaliações', 
              professor_turma_disciplina_notas_avaliacoes_path(@turma, @disciplina), 
              class: 'text-sm font-medium text-green-600 hover:text-green-800 transition duration-150 ease-in-out py-2 px-3 bg-green-100 rounded-lg' %>
      </div>
    </div>

    <div class="bg-white p-6 sm:p-8 shadow-xl rounded-xl">
      <% # CORREÇÃO CRÍTICA: O helper gerado é 'avaliaco_registros_path' %>
      <%= render 'form', 
          url: professor_turma_disciplina_notas_avaliaco_registros_path(@turma, @disciplina, @avaliacao_configuracao) %>
    </div>
  </div>
</div>