<div class="p-6 bg-gray-100 min-h-screen">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Minhas Turmas</h1>
    <p class="text-gray-600">Gerencie as turmas onde você leciona e registre frequências</p>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-blue-100 text-blue-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Total de Turmas</p>
          <p class="text-2xl font-bold text-gray-900"><%= @estatisticas[:total_turmas] %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-green-100 text-green-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Total de Alunos</p>
          <p class="text-2xl font-bold text-gray-900"><%= @estatisticas[:total_alunos] %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-purple-100 text-purple-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Frequências Registradas</p>
          <p class="text-2xl font-bold text-gray-900"><%= @estatisticas[:frequencias_registradas] %></p>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600">Frequências Hoje</p>
          <p class="text-2xl font-bold text-gray-900"><%= @estatisticas[:turmas_com_frequencia_hoje] %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Turmas Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @turmas.each do |turma| %>
      <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200">
        <div class="p-6">
          <!-- Turma Header -->
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-900"><%= turma.nome %></h3>
            <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm font-medium rounded-full">
              <%= turma.turno.humanize %>
            </span>
          </div>

          <!-- Turma Info -->
          <div class="space-y-2 mb-4">
            <p class="text-sm text-gray-600">
              <span class="font-medium">Escola:</span> <%= turma.escola.nome %>
            </p>
            <p class="text-sm text-gray-600">
              <span class="font-medium">Série:</span> <%= turma.serie %>º ano
            </p>
            <p class="text-sm text-gray-600">
              <span class="font-medium">Alunos:</span> <%= turma.alunos.count %>
            </p>
            <p class="text-sm text-gray-600">
              <span class="font-medium">Frequências:</span> <%= turma.frequencias.count %>
            </p>
          </div>

          <!-- Status da Frequência Hoje -->
          <% frequencia_hoje = turma.frequencias.where(data_aula: Date.current).first %>
          <div class="mb-4">
            <% if frequencia_hoje %>
              <div class="flex items-center text-green-600">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm font-medium">Frequência registrada hoje</span>
              </div>
            <% else %>
              <div class="flex items-center text-orange-600">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-sm font-medium">Frequência não registrada hoje</span>
              </div>
            <% end %>
          </div>

          <!-- Actions -->
          <div class="flex space-x-2">
            <% if frequencia_hoje %>
              <%= link_to frequencia_path(frequencia_hoje), class: "flex-1 bg-green-500 hover:bg-green-600 text-white text-center py-2 px-4 rounded-lg text-sm font-medium transition-colors" do %>
                Ver Frequência
              <% end %>
            <% else %>
              <%= link_to nova_frequencia_turma_path(turma), class: "flex-1 bg-green-500 hover:bg-green-600 text-white text-center py-2 px-4 rounded-lg text-sm font-medium transition-colors" do %>
                Registrar Frequência
              <% end %>
            <% end %>
            
            <%= link_to historico_turma_path(turma), class: "flex-1 bg-gray-500 hover:bg-gray-600 text-white text-center py-2 px-4 rounded-lg text-sm font-medium transition-colors" do %>
              Histórico
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Empty State -->
  <% if @turmas.empty? %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhuma turma encontrada</h3>
      <p class="mt-1 text-sm text-gray-500">Você ainda não foi associado a nenhuma turma.</p>
    </div>
  <% end %>
</div>
