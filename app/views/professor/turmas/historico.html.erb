<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Histórico de Frequências
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %>
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Voltar para Turmas
          <% end %>
          
          <!-- Dropdown de Disciplinas -->
          <div class="relative w-full sm:w-auto">
            <button id="dropdownButton" type="button" 
                    class="w-full sm:w-auto text-center bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Nova Frequência
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            
            <div id="dropdownMenu" class="hidden absolute right-0 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
              <div class="py-2">
                <div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase">
                  Selecione a Disciplina
                </div>
                <% if current_professor.disciplinas.any? %>
                  <% current_professor.disciplinas.each do |disciplina| %>
                    <%= link_to new_professor_turma_disciplina_frequencia_path(@turma, disciplina), 
                          class: "block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-green-600 transition-colors" do %>
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                        <span><%= disciplina.nome %></span>
                      </div>
                    <% end %>
                  <% end %>
                <% else %>
                  <div class="px-4 py-3 text-sm text-gray-500 text-center">
                    Nenhuma disciplina disponível
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Estatísticas do Mês -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-6 mb-6">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-purple-100 text-purple-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Aulas Registradas</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @estatisticas_mes[:total_aulas] %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-blue-100 text-blue-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @estatisticas_mes[:total_alunos] %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-green-100 text-green-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Média de Presença</p>
            <p class="text-xl sm:text-2xl font-bold text-green-600"><%= @estatisticas_mes[:media_presenca] %>%</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Layout Grid: Calendário + Painel de Detalhes -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Calendário (Coluna Esquerda - 2/3 em desktop) -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-md">
          <div class="p-4 sm:p-6">
            <!-- Header do Calendário -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h2 class="text-lg sm:text-xl font-bold text-gray-900">
                  <%= Date::MONTHNAMES[@mes] %> de <%= @ano %>
                </h2>
              </div>
              
              <!-- Navegação do Mês -->
              <div class="flex items-center gap-2">
                <% mes_anterior = @mes == 1 ? 12 : @mes - 1 %>
                <% ano_anterior = @mes == 1 ? @ano - 1 : @ano %>
                <%= link_to historico_turma_path(@turma, mes: mes_anterior, ano: ano_anterior), 
                      class: "p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                  </svg>
                <% end %>
                
                <span class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg">
                  <%= "#{@mes.to_s.rjust(2, '0')}/#{@ano}" %>
                </span>
                
                <% mes_proximo = @mes == 12 ? 1 : @mes + 1 %>
                <% ano_proximo = @mes == 12 ? @ano + 1 : @ano %>
                <% unless Date.new(ano_proximo, mes_proximo, 1) > Date.current %>
                  <%= link_to historico_turma_path(@turma, mes: mes_proximo, ano: ano_proximo), 
                        class: "p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  <% end %>
                <% end %>
              </div>
            </div>

            <!-- Legenda -->
            <div class="flex flex-wrap gap-3 mb-6 text-xs">
              <div class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-gray-600">Registrada</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
                <span class="text-gray-600">Sem Registro</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                </svg>
                <span class="text-gray-600">Hoje</span>
              </div>
            </div>

            <!-- Grid do Calendário -->
            <div class="grid grid-cols-7 gap-1">
              <!-- Cabeçalho dos dias da semana -->
              <% %w[Dom Seg Ter Qua Qui Sex Sáb].each do |dia| %>
                <div class="p-2 text-center text-xs font-medium text-gray-500 bg-gray-50 rounded">
                  <%= dia %>
                </div>
              <% end %>

              <!-- Dias vazios no início do mês -->
              <% @data_inicio.wday.times do %>
                <div class="p-2 aspect-square"></div>
              <% end %>

              <!-- Dias do mês -->
              <% (@data_inicio..@data_fim).each do |data| %>
                <% 
                  tem_frequencia = @datas_com_frequencia.include?(data)
                  eh_hoje = data == Date.current
                  eh_passado = data < Date.current
                  frequencia = @frequencias.find { |f| f.data_aula == data }
                %>
                
                <div class="relative aspect-square">
                  <% if tem_frequencia %>
                    <button type="button"
                            onclick="mostrarDetalhes(<%= frequencia.id %>)"
                            data-frequencia-id="<%= frequencia.id %>"
                            data-data="<%= data.strftime('%d/%m/%Y') %>"
                            data-presentes="<%= frequencia.total_presentes %>"
                            data-faltas="<%= frequencia.total_faltas %>"
                            data-justificadas="<%= frequencia.total_justificadas %>"
                            data-total="<%= frequencia.total_alunos %>"
                            data-conteudo="<%= frequencia.conteudo_trabalhado %>"
                            data-observacoes="<%= frequencia.observacoes %>"
                            class="w-full h-full flex flex-col items-center justify-center p-1 rounded-lg transition-all hover:shadow-md dia-com-frequencia <%= eh_hoje ? 'bg-blue-500 text-white' : 'bg-green-500 text-white hover:bg-green-600' %>">
                      <span class="text-xs font-bold"><%= data.day %></span>
                      <svg class="w-3 h-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </button>
                  <% elsif eh_passado %>
                    <button type="button"
                            onclick="abrirDropdownData(event)"
                            class="w-full h-full flex items-center justify-center p-1 rounded-lg transition-all hover:bg-gray-300 <%= eh_hoje ? 'bg-blue-200 text-blue-800' : 'bg-gray-200 text-gray-600 hover:text-gray-800' %>">
                      <span class="text-xs font-medium"><%= data.day %></span>
                    </button>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center p-1 rounded-lg <%= eh_hoje ? 'bg-blue-100 text-blue-600' : 'text-gray-400' %>">
                      <span class="text-xs"><%= data.day %></span>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Painel de Detalhes (Coluna Direita - 1/3 em desktop) -->
      <div class="lg:col-span-1">
        <div id="painel-detalhes" class="bg-white rounded-lg shadow-md sticky top-6 hidden lg:block">
          <div id="painel-vazio" class="p-6 text-center">
            <svg class="mx-auto h-16 w-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Clique em uma data com frequência para ver os detalhes</p>
          </div>

          <div id="painel-conteudo" class="hidden">
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900" id="detail-data"></h3>
                <button onclick="fecharDetalhes()" class="lg:hidden text-gray-400 hover:text-gray-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>

              <!-- Estatísticas -->
              <div class="space-y-3 mb-6">
                <div class="bg-blue-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Total de Alunos</span>
                    <span class="text-lg font-bold text-gray-900" id="detail-total">0</span>
                  </div>
                </div>

                <div class="bg-green-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Presentes</span>
                    <span class="text-lg font-bold text-green-600" id="detail-presentes">0</span>
                  </div>
                </div>

                <div class="bg-red-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Faltas</span>
                    <span class="text-lg font-bold text-red-600" id="detail-faltas">0</span>
                  </div>
                </div>

                <div class="bg-yellow-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Justificadas</span>
                    <span class="text-lg font-bold text-yellow-600" id="detail-justificadas">0</span>
                  </div>
                </div>
              </div>

              <!-- Conteúdo Trabalhado -->
              <div class="mb-4" id="detail-conteudo-container">
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Conteúdo Trabalhado</h4>
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                  <p class="text-sm text-gray-700" id="detail-conteudo"></p>
                </div>
              </div>

              <!-- Observações -->
              <div class="mb-6" id="detail-observacoes-container">
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Observações</h4>
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
                  <p class="text-sm text-gray-700" id="detail-observacoes"></p>
                </div>
              </div>

              <!-- Botão Ver Detalhes Completos -->
              <a id="detail-link" href="#" class="block w-full text-center px-4 py-2.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors text-sm">
                Ver Detalhes Completos
              </a>
            </div>
          </div>
        </div>

        <!-- Painel Mobile (aparece abaixo do calendário) -->
        <div id="painel-mobile" class="lg:hidden mt-6 bg-white rounded-lg shadow-md hidden">
          <div class="p-4">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-bold text-gray-900" id="mobile-detail-data"></h3>
              <button onclick="fecharDetalhesMobile()" class="text-gray-400 hover:text-gray-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <!-- Estatísticas Grid 2x2 -->
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="bg-blue-50 rounded-lg p-3">
                <p class="text-xs font-medium text-gray-600 mb-1">Total</p>
                <p class="text-xl font-bold text-gray-900" id="mobile-detail-total">0</p>
              </div>

              <div class="bg-green-50 rounded-lg p-3">
                <p class="text-xs font-medium text-gray-600 mb-1">Presentes</p>
                <p class="text-xl font-bold text-green-600" id="mobile-detail-presentes">0</p>
              </div>

              <div class="bg-red-50 rounded-lg p-3">
                <p class="text-xs font-medium text-gray-600 mb-1">Faltas</p>
                <p class="text-xl font-bold text-red-600" id="mobile-detail-faltas">0</p>
              </div>

              <div class="bg-yellow-50 rounded-lg p-3">
                <p class="text-xs font-medium text-gray-600 mb-1">Justificadas</p>
                <p class="text-xl font-bold text-yellow-600" id="mobile-detail-justificadas">0</p>
              </div>
            </div>

            <!-- Conteúdo Trabalhado -->
            <div class="mb-4" id="mobile-conteudo-container">
              <h4 class="text-sm font-semibold text-gray-700 mb-2">Conteúdo Trabalhado</h4>
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                <p class="text-sm text-gray-700" id="mobile-detail-conteudo"></p>
              </div>
            </div>

            <!-- Observações -->
            <div class="mb-4" id="mobile-observacoes-container">
              <h4 class="text-sm font-semibold text-gray-700 mb-2">Observações</h4>
              <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
                <p class="text-sm text-gray-700" id="mobile-detail-observacoes"></p>
              </div>
            </div>

            <!-- Botão Ver Detalhes -->
            <a id="mobile-detail-link" href="#" class="block w-full text-center px-4 py-2.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors text-sm">
              Ver Detalhes Completos
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.dia-com-frequencia {
  position: relative;
}

.dia-com-frequencia.active {
  ring: 2px;
  ring-color: #3b82f6;
  transform: scale(1.05);
}
</style>

<script>
let frequenciaAtualId = null;

// Toggle do dropdown principal
document.getElementById('dropdownButton').addEventListener('click', function(e) {
  e.stopPropagation();
  const menu = document.getElementById('dropdownMenu');
  menu.classList.toggle('hidden');
});

// Fechar dropdown ao clicar fora
document.addEventListener('click', function(e) {
  const dropdown = document.getElementById('dropdownMenu');
  const button = document.getElementById('dropdownButton');
  
  if (!dropdown.contains(e.target) && !button.contains(e.target)) {
    dropdown.classList.add('hidden');
  }
});

function mostrarDetalhes(frequenciaId) {
  const btn = document.querySelector(`[data-frequencia-id="${frequenciaId}"]`);
  if (!btn) return;

  // Remove active de todos os dias
  document.querySelectorAll('.dia-com-frequencia').forEach(d => d.classList.remove('active'));
  btn.classList.add('active');

  const data = btn.dataset.data;
  const presentes = btn.dataset.presentes;
  const faltas = btn.dataset.faltas;
  const justificadas = btn.dataset.justificadas;
  const total = btn.dataset.total;
  const conteudo = btn.dataset.conteudo;
  const observacoes = btn.dataset.observacoes;

  frequenciaAtualId = frequenciaId;

  // Atualiza painel desktop
  document.getElementById('painel-vazio').classList.add('hidden');
  document.getElementById('painel-conteudo').classList.remove('hidden');
  
  document.getElementById('detail-data').textContent = data;
  document.getElementById('detail-total').textContent = total;
  document.getElementById('detail-presentes').textContent = presentes;
  document.getElementById('detail-faltas').textContent = faltas;
  document.getElementById('detail-justificadas').textContent = justificadas;
  
  if (conteudo && conteudo !== '') {
    document.getElementById('detail-conteudo').textContent = conteudo;
    document.getElementById('detail-conteudo-container').classList.remove('hidden');
  } else {
    document.getElementById('detail-conteudo-container').classList.add('hidden');
  }
  
  if (observacoes && observacoes !== '') {
    document.getElementById('detail-observacoes').textContent = observacoes;
    document.getElementById('detail-observacoes-container').classList.remove('hidden');
  } else {
    document.getElementById('detail-observacoes-container').classList.add('hidden');
  }
  
  document.getElementById('detail-link').href = `/frequencias/${frequenciaId}`;

  // Atualiza painel mobile
  document.getElementById('painel-mobile').classList.remove('hidden');
  document.getElementById('mobile-detail-data').textContent = data;
  document.getElementById('mobile-detail-total').textContent = total;
  document.getElementById('mobile-detail-presentes').textContent = presentes;
  document.getElementById('mobile-detail-faltas').textContent = faltas;
  document.getElementById('mobile-detail-justificadas').textContent = justificadas;
  
  if (conteudo && conteudo !== '') {
    document.getElementById('mobile-detail-conteudo').textContent = conteudo;
    document.getElementById('mobile-conteudo-container').classList.remove('hidden');
  } else {
    document.getElementById('mobile-conteudo-container').classList.add('hidden');
  }
  
  if (observacoes && observacoes !== '') {
    document.getElementById('mobile-detail-observacoes').textContent = observacoes;
    document.getElementById('mobile-observacoes-container').classList.remove('hidden');
  } else {
    document.getElementById('mobile-observacoes-container').classList.add('hidden');
  }
  
  document.getElementById('mobile-detail-link').href = `/frequencias/${frequenciaId}`;

  // Scroll suave para o painel no mobile
  if (window.innerWidth < 1024) {
    setTimeout(() => {
      document.getElementById('painel-mobile').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }
}

function fecharDetalhes() {
  document.getElementById('painel-vazio').classList.remove('hidden');
  document.getElementById('painel-conteudo').classList.add('hidden');
  document.querySelectorAll('.dia-com-frequencia').forEach(d => d.classList.remove('active'));
  frequenciaAtualId = null;
}

function fecharDetalhesMobile() {
  document.getElementById('painel-mobile').classList.add('hidden');
  document.querySelectorAll('.dia-com-frequencia').forEach(d => d.classList.remove('active'));
  frequenciaAtualId = null;
}
</script>