<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Histórico de Frequências
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %>
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <%= link_to minhas_turmas_path, class: "w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Voltar para Turmas
          <% end %>
          <%= link_to nova_frequencia_turma_path(@turma), class: "w-full sm:w-auto text-center bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nova Frequência
          <% end %>
        </div>
      </div>
    </div>

    <!-- Estatísticas do Mês -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-6 mb-6">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-purple-100 text-purple-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Aulas Registradas</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @estatisticas_mes[:total_aulas] %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-blue-100 text-blue-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900"><%= @estatisticas_mes[:total_alunos] %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-green-100 text-green-600 mr-3 flex-shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Média de Presença</p>
            <p class="text-xl sm:text-2xl font-bold text-green-600"><%= @estatisticas_mes[:media_presenca] %>%</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calendário -->
    <div class="bg-white rounded-lg shadow-md">
      <div class="p-4 sm:p-6">
        <!-- Header do Calendário -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h2 class="text-lg sm:text-xl font-bold text-gray-900">
              <%= Date::MONTHNAMES[@mes] %> de <%= @ano %>
            </h2>
          </div>
          
          <!-- Navegação do Mês -->
          <div class="flex items-center gap-2">
            <% mes_anterior = @mes == 1 ? 12 : @mes - 1 %>
            <% ano_anterior = @mes == 1 ? @ano - 1 : @ano %>
            <%= link_to historico_turma_path(@turma, mes: mes_anterior, ano: ano_anterior), 
                  class: "p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            <% end %>
            
            <span class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg">
              <%= "#{@mes.to_s.rjust(2, '0')}/#{@ano}" %>
            </span>
            
            <% mes_proximo = @mes == 12 ? 1 : @mes + 1 %>
            <% ano_proximo = @mes == 12 ? @ano + 1 : @ano %>
            <% unless Date.new(ano_proximo, mes_proximo, 1) > Date.current %>
              <%= link_to historico_turma_path(@turma, mes: mes_proximo, ano: ano_proximo), 
                    class: "p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- Legenda -->
        <div class="flex flex-wrap gap-4 mb-6 text-xs sm:text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-600">Frequência Registrada</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-600">Sem Frequência</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-600">Hoje</span>
          </div>
        </div>

        <!-- Grid do Calendário -->
        <div class="grid grid-cols-7 gap-1 sm:gap-2">
          <!-- Cabeçalho dos dias da semana -->
          <% %w[Dom Seg Ter Qua Qui Sex Sáb].each do |dia| %>
            <div class="p-2 sm:p-3 text-center text-xs sm:text-sm font-medium text-gray-500 bg-gray-50 rounded-lg">
              <%= dia %>
            </div>
          <% end %>

          <!-- Dias vazios no início do mês -->
          <% @data_inicio.wday.times do %>
            <div class="p-2 sm:p-3 aspect-square"></div>
          <% end %>

          <!-- Dias do mês -->
          <% (@data_inicio..@data_fim).each do |data| %>
            <% 
              tem_frequencia = @datas_com_frequencia.include?(data)
              eh_hoje = data == Date.current
              eh_passado = data < Date.current
              frequencia = @frequencias.find { |f| f.data_aula == data }
            %>
            
            <div class="relative aspect-square">
              <% if tem_frequencia %>
                <%= link_to frequencia_path(frequencia), 
                      class: "w-full h-full flex flex-col items-center justify-center p-1 sm:p-2 rounded-lg transition-all hover:shadow-md #{eh_hoje ? 'bg-blue-500 text-white' : 'bg-green-500 text-white hover:bg-green-600'}" do %>
                  <span class="text-xs sm:text-sm font-bold"><%= data.day %></span>
                  <svg class="w-3 h-3 sm:w-4 sm:h-4 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              <% elsif eh_passado %>
                <%= link_to nova_frequencia_turma_path(@turma, data_aula: data), 
                      class: "w-full h-full flex items-center justify-center p-1 sm:p-2 rounded-lg transition-all hover:bg-gray-300 #{eh_hoje ? 'bg-blue-200 text-blue-800' : 'bg-gray-200 text-gray-600 hover:text-gray-800'}" do %>
                  <span class="text-xs sm:text-sm font-medium"><%= data.day %></span>
                <% end %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center p-1 sm:p-2 rounded-lg #{eh_hoje ? 'bg-blue-100 text-blue-600' : 'text-gray-400'}">
                  <span class="text-xs sm:text-sm"><%= data.day %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lista de Frequências do Mês -->
    <% if @frequencias.any? %>
      <div class="mt-6 bg-white rounded-lg shadow-md">
        <div class="p-4 sm:p-6">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Frequências Registradas em <%= Date::MONTHNAMES[@mes] %></h3>
          </div>
          
          <div class="space-y-3">
            <% @frequencias.order(data_aula: :desc).each do |frequencia| %>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                <div class="mb-2 sm:mb-0 flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <h4 class="font-medium text-gray-900">
                      <%= frequencia.data_aula.strftime("%d/%m/%Y") %> 
                      <span class="text-sm text-gray-500">(<%= frequencia.data_aula.strftime("%A").capitalize %>)</span>
                    </h4>
                  </div>
                  <% if frequencia.conteudo_trabalhado.present? %>
                    <p class="text-sm text-gray-600 mt-1 ml-7"><%= truncate(frequencia.conteudo_trabalhado, length: 100) %></p>
                  <% end %>
                </div>
                
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
                  <div class="flex gap-4 text-xs sm:text-sm">
                    <span class="flex items-center gap-1 text-green-600 font-medium">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      <%= frequencia.total_presentes %>
                    </span>
                    <span class="flex items-center gap-1 text-red-600 font-medium">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                      </svg>
                      <%= frequencia.total_faltas %>
                    </span>
                    <span class="flex items-center gap-1 text-yellow-600 font-medium">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                      </svg>
                      <%= frequencia.total_justificadas %>
                    </span>
                  </div>
                  
                  <%= link_to frequencia_path(frequencia), 
                        class: "w-full sm:w-auto text-center px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors text-sm flex items-center justify-center gap-2" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    Ver Detalhes
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="mt-6 bg-white rounded-lg shadow-md">
        <div class="p-8 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">Nenhuma frequência registrada</h3>
          <p class="text-gray-500 mb-4">Não há frequências registradas para <%= Date::MONTHNAMES[@mes] %> de <%= @ano %>.</p>
          <%= link_to nova_frequencia_turma_path(@turma), 
                class: "inline-flex items-center px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Registrar Nova Frequência
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>