<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Histórico de Frequências
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %> 
            Turma: <span class="font-medium">Turma A</span> - Escola Municipal
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <button class="w-full sm:w-auto text-center bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Voltar para Turmas
          </button>
          
          <!-- Dropdown de Disciplinas -->
          <div class="relative w-full sm:w-auto">
            <button id="dropdownButton" type="button" 
                    class="w-full sm:w-auto text-center bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors text-sm sm:text-base flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Nova Frequência
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            
            <div id="dropdownMenu" class="hidden absolute right-0 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
              <div class="py-2">
                <div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase">
                  Selecione a Disciplina
                </div>
                <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-green-50 hover:text-green-600 transition-colors">
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    <span>Matemática</span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Estatísticas -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-6 mb-6">
      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-purple-100 text-purple-600 mr-3">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Aulas Registradas</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900">15</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-blue-100 text-blue-600 mr-3">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-900">30</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-4 sm:p-6">
        <div class="flex items-center">
          <div class="p-2 sm:p-3 rounded-full bg-green-100 text-green-600 mr-3">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs sm:text-sm font-medium text-gray-600">Média de Presença</p>
            <p class="text-xl sm:text-2xl font-bold text-green-600">92.5%</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Layout Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Calendário -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-md p-4 sm:p-6">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
              <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <h2 class="text-lg sm:text-xl font-bold text-gray-900" id="mes-ano-titulo">Outubro 2024</h2>
            </div>
            
            <!-- Navegação -->
            <div class="flex items-center gap-2">
              <button id="btn-mes-anterior" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
              
              <button id="btn-mes-atual" class="px-4 py-2 text-sm font-medium text-white bg-blue-500 hover:bg-blue-600 rounded-lg transition-colors">
                Hoje
              </button>
              
              <button id="btn-mes-proximo" class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Legenda -->
          <div class="flex flex-wrap gap-3 mb-6 text-xs">
            <div class="flex items-center gap-1.5">
              <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-600">Registrada</span>
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3 h-3 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-600">Sem Registro</span>
            </div>
          </div>

          <!-- Grid do Calendário -->
          <div id="calendario-grid" class="grid grid-cols-7 gap-1">
            <!-- Será preenchido dinamicamente -->
          </div>
        </div>
      </div>

      <!-- Painel Desktop -->
      <div class="lg:col-span-1 hidden lg:block">
        <div id="painel-detalhes" class="bg-white rounded-lg shadow-md sticky top-6">
          <div id="painel-vazio" class="p-6 text-center">
            <svg class="mx-auto h-16 w-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500">Clique em uma data com frequência para ver os detalhes</p>
          </div>

          <div id="painel-conteudo" class="hidden">
            <div class="p-6">
              <div class="mb-4">
                <h3 class="text-lg font-bold text-gray-900" id="detail-data"></h3>
                <p class="text-sm text-gray-600 mt-1 flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                  <span id="detail-disciplina"></span>
                </p>
              </div>

              <!-- Estatísticas -->
              <div class="space-y-3 mb-6">
                <div class="bg-blue-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Total de Alunos</span>
                    <span class="text-lg font-bold text-gray-900" id="detail-total">0</span>
                  </div>
                </div>

                <div class="bg-green-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Presentes</span>
                    <span class="text-lg font-bold text-green-600" id="detail-presentes">0</span>
                  </div>
                </div>

                <div class="bg-red-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Faltas</span>
                    <span class="text-lg font-bold text-red-600" id="detail-faltas">0</span>
                  </div>
                </div>

                <div class="bg-yellow-50 rounded-lg p-3">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-gray-600">Justificadas</span>
                    <span class="text-lg font-bold text-yellow-600" id="detail-justificadas">0</span>
                  </div>
                </div>
              </div>

              <!-- Conteúdo -->
              <div class="mb-4" id="detail-conteudo-container">
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Conteúdo Trabalhado</h4>
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                  <p class="text-sm text-gray-700" id="detail-conteudo"></p>
                </div>
              </div>

              <!-- Observações -->
              <div class="mb-6" id="detail-observacoes-container">
                <h4 class="text-sm font-semibold text-gray-700 mb-2">Observações</h4>
                <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
                  <p class="text-sm text-gray-700" id="detail-observacoes"></p>
                </div>
              </div>

              <button class="block w-full text-center px-4 py-2.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors text-sm">
                Ver Detalhes Completos
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Painel Mobile -->
      <div id="painel-mobile" class="lg:hidden mt-6 bg-white rounded-lg shadow-md hidden">
        <div class="p-4">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="text-lg font-bold text-gray-900" id="mobile-detail-data"></h3>
              <p class="text-sm text-gray-600 mt-1" id="mobile-detail-disciplina"></p>
            </div>
            <button id="btn-fechar-mobile" class="text-gray-400 hover:text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div class="grid grid-cols-2 gap-3 mb-4">
            <div class="bg-blue-50 rounded-lg p-3">
              <p class="text-xs font-medium text-gray-600 mb-1">Total</p>
              <p class="text-xl font-bold text-gray-900" id="mobile-detail-total">0</p>
            </div>
            <div class="bg-green-50 rounded-lg p-3">
              <p class="text-xs font-medium text-gray-600 mb-1">Presentes</p>
              <p class="text-xl font-bold text-green-600" id="mobile-detail-presentes">0</p>
            </div>
            <div class="bg-red-50 rounded-lg p-3">
              <p class="text-xs font-medium text-gray-600 mb-1">Faltas</p>
              <p class="text-xl font-bold text-red-600" id="mobile-detail-faltas">0</p>
            </div>
            <div class="bg-yellow-50 rounded-lg p-3">
              <p class="text-xs font-medium text-gray-600 mb-1">Justificadas</p>
              <p class="text-xl font-bold text-yellow-600" id="mobile-detail-justificadas">0</p>
            </div>
          </div>

          <div class="mb-4" id="mobile-conteudo-container">
            <h4 class="text-sm font-semibold text-gray-700 mb-2">Conteúdo Trabalhado</h4>
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
              <p class="text-sm text-gray-700" id="mobile-detail-conteudo"></p>
            </div>
          </div>

          <div class="mb-4" id="mobile-observacoes-container">
            <h4 class="text-sm font-semibold text-gray-700 mb-2">Observações</h4>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-3">
              <p class="text-sm text-gray-700" id="mobile-detail-observacoes"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.dia-com-frequencia.active {
  box-shadow: 0 0 0 2px #3b82f6;
  transform: scale(1.05);
}
</style>

<script>
(function() {
  'use strict';
  
  // Estado do calendário
  let mesAtual = 9; // Outubro (0-11)
  let anoAtual = 2024;
  const dataHoje = new Date();
  
  // Dados de exemplo - simula frequências registradas
  const frequenciasExemplo = {
    '2024-10-01': {
      id: 1,
      data: '01/10/2024',
      disciplina: 'Matemática',
      presentes: 28,
      faltas: 2,
      justificadas: 0,
      total: 30,
      conteudo: 'Equações do segundo grau - Resolução por fórmula de Bhaskara',
      observacoes: 'Turma participativa, alguns alunos com dúvidas'
    },
    '2024-10-02': {
      id: 2,
      data: '02/10/2024',
      disciplina: 'Português',
      presentes: 29,
      faltas: 1,
      justificadas: 0,
      total: 30,
      conteudo: 'Análise sintática - Sujeito e predicado',
      observacoes: ''
    },
    '2024-10-08': {
      id: 3,
      data: '08/10/2024',
      disciplina: 'História',
      presentes: 27,
      faltas: 3,
      justificadas: 0,
      total: 30,
      conteudo: 'Revolução Francesa - Causas e consequências',
      observacoes: 'Boa participação dos alunos'
    },
    '2024-10-15': {
      id: 4,
      data: '15/10/2024',
      disciplina: 'Geografia',
      presentes: 30,
      faltas: 0,
      justificadas: 0,
      total: 30,
      conteudo: 'Clima e vegetação do Brasil',
      observacoes: ''
    },
    '2024-09-20': {
      id: 5,
      data: '20/09/2024',
      disciplina: 'Ciências',
      presentes: 26,
      faltas: 4,
      justificadas: 0,
      total: 30,
      conteudo: 'Sistema solar e planetas',
      observacoes: 'Alunos fizeram maquete'
    }
  };
  
  const mesesNomes = [
    'Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho',
    'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'
  ];
  
  // Gerar calendário
  function gerarCalendario() {
    const grid = document.getElementById('calendario-grid');
    const titulo = document.getElementById('mes-ano-titulo');
    
    if (!grid || !titulo) return;
    
    // Atualiza título
    titulo.textContent = `${mesesNomes[mesAtual]} ${anoAtual}`;
    
    // Limpa grid
    grid.innerHTML = '';
    
    // Cabeçalho dos dias
    ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'].forEach(dia => {
      const div = document.createElement('div');
      div.className = 'p-2 text-center text-xs font-medium text-gray-500 bg-gray-50 rounded';
      div.textContent = dia;
      grid.appendChild(div);
    });
    
    // Primeiro dia do mês
    const primeiroDia = new Date(anoAtual, mesAtual, 1);
    const ultimoDia = new Date(anoAtual, mesAtual + 1, 0);
    const diasNoMes = ultimoDia.getDate();
    const diaSemanaInicio = primeiroDia.getDay();
    
    // Dias vazios antes do primeiro dia
    for (let i = 0; i < diaSemanaInicio; i++) {
      const div = document.createElement('div');
      div.className = 'aspect-square';
      grid.appendChild(div);
    }
    
    // Dias do mês
    for (let dia = 1; dia <= diasNoMes; dia++) {
      const dataAtual = new Date(anoAtual, mesAtual, dia);
      const dataKey = `${anoAtual}-${String(mesAtual + 1).padStart(2, '0')}-${String(dia).padStart(2, '0')}`;
      const frequencia = frequenciasExemplo[dataKey];
      const ehHoje = dataAtual.toDateString() === dataHoje.toDateString();
      const ehPassado = dataAtual < dataHoje;
      
      const container = document.createElement('div');
      container.className = 'relative aspect-square';
      
      if (frequencia) {
        // Dia com frequência
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = `w-full h-full flex flex-col items-center justify-center p-1 rounded-lg transition-all hover:shadow-md dia-com-frequencia ${
          ehHoje ? 'bg-blue-500 text-white' : 'bg-green-500 text-white hover:bg-green-600'
        }`;
        
        // Adiciona data-attributes
        btn.setAttribute('data-frequencia-id', frequencia.id);
        btn.setAttribute('data-data', frequencia.data);
        btn.setAttribute('data-disciplina', frequencia.disciplina);
        btn.setAttribute('data-presentes', frequencia.presentes);
        btn.setAttribute('data-faltas', frequencia.faltas);
        btn.setAttribute('data-justificadas', frequencia.justificadas);
        btn.setAttribute('data-total', frequencia.total);
        btn.setAttribute('data-conteudo', frequencia.conteudo);
        btn.setAttribute('data-observacoes', frequencia.observacoes);
        
        btn.innerHTML = `
          <span class="text-xs font-bold">${dia}</span>
          <svg class="w-3 h-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        `;
        container.appendChild(btn);
      } else if (ehPassado) {
        // Dia passado sem frequência
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = `dia-sem-frequencia w-full h-full flex items-center justify-center p-1 rounded-lg transition-all hover:bg-gray-300 ${
          ehHoje ? 'bg-blue-200 text-blue-800' : 'bg-gray-200 text-gray-600 hover:text-gray-800'
        }`;
        btn.innerHTML = `<span class="text-xs font-medium">${dia}</span>`;
        container.appendChild(btn);
      } else {
        // Dia futuro
        const div = document.createElement('div');
        div.className = `w-full h-full flex items-center justify-center p-1 rounded-lg ${
          ehHoje ? 'bg-blue-100 text-blue-600' : 'text-gray-400'
        }`;
        div.innerHTML = `<span class="text-xs">${dia}</span>`;
        container.appendChild(div);
      }
      
      grid.appendChild(container);
    }
    
    console.log(`Calendário gerado: ${mesesNomes[mesAtual]} ${anoAtual}`);
  }
  
  // Navegar para mês anterior
  function mesAnterior() {
    mesAtual--;
    if (mesAtual < 0) {
      mesAtual = 11;
      anoAtual--;
    }
    gerarCalendario();
  }
  
  // Navegar para próximo mês
  function mesProximo() {
    mesAtual++;
    if (mesAtual > 11) {
      mesAtual = 0;
      anoAtual++;
    }
    gerarCalendario();
  }
  
  // Voltar para mês atual
  function voltarHoje() {
    mesAtual = dataHoje.getMonth();
    anoAtual = dataHoje.getFullYear();
    gerarCalendario();
  }
  
  // Toggle dropdown
  function initDropdown() {
    const btn = document.getElementById('dropdownButton');
    const menu = document.getElementById('dropdownMenu');
    if (btn && menu) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        menu.classList.toggle('hidden');
      });
      document.addEventListener('click', () => menu.classList.add('hidden'));
    }
  }

  // Mostrar detalhes
  function mostrarDetalhes(id) {
    console.log('=== MOSTRANDO DETALHES ===', id);
    
    const btn = document.querySelector(`[data-frequencia-id="${id}"]`);
    if (!btn) return;

    // Dados
    const data = {
      data: btn.dataset.data,
      disciplina: btn.dataset.disciplina,
      presentes: btn.dataset.presentes,
      faltas: btn.dataset.faltas,
      justificadas: btn.dataset.justificadas,
      total: btn.dataset.total,
      conteudo: btn.dataset.conteudo,
      observacoes: btn.dataset.observacoes
    };

    console.log('Dados:', data);

    // Remove active de todos
    document.querySelectorAll('.dia-com-frequencia').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Desktop
    const painelVazio = document.getElementById('painel-vazio');
    const painelConteudo = document.getElementById('painel-conteudo');
    
    if (painelVazio) painelVazio.classList.add('hidden');
    if (painelConteudo) painelConteudo.classList.remove('hidden');

    document.getElementById('detail-data').textContent = data.data;
    document.getElementById('detail-disciplina').textContent = data.disciplina;
    document.getElementById('detail-total').textContent = data.total;
    document.getElementById('detail-presentes').textContent = data.presentes;
    document.getElementById('detail-faltas').textContent = data.faltas;
    document.getElementById('detail-justificadas').textContent = data.justificadas;
    
    const detailConteudoContainer = document.getElementById('detail-conteudo-container');
    if (data.conteudo && data.conteudo.trim()) {
      document.getElementById('detail-conteudo').textContent = data.conteudo;
      detailConteudoContainer.classList.remove('hidden');
    } else {
      detailConteudoContainer.classList.add('hidden');
    }

    const detailObservacoesContainer = document.getElementById('detail-observacoes-container');
    if (data.observacoes && data.observacoes.trim()) {
      document.getElementById('detail-observacoes').textContent = data.observacoes;
      detailObservacoesContainer.classList.remove('hidden');
    } else {
      detailObservacoesContainer.classList.add('hidden');
    }

    // Mobile
    const painelMobile = document.getElementById('painel-mobile');
    if (painelMobile) painelMobile.classList.remove('hidden');

    document.getElementById('mobile-detail-data').textContent = data.data;
    document.getElementById('mobile-detail-disciplina').textContent = data.disciplina;
    document.getElementById('mobile-detail-total').textContent = data.total;
    document.getElementById('mobile-detail-presentes').textContent = data.presentes;
    document.getElementById('mobile-detail-faltas').textContent = data.faltas;
    document.getElementById('mobile-detail-justificadas').textContent = data.justificadas;

    const mobileConteudoContainer = document.getElementById('mobile-conteudo-container');
    if (data.conteudo && data.conteudo.trim()) {
      document.getElementById('mobile-detail-conteudo').textContent = data.conteudo;
      mobileConteudoContainer.classList.remove('hidden');
    } else {
      mobileConteudoContainer.classList.add('hidden');
    }

    const mobileObservacoesContainer = document.getElementById('mobile-observacoes-container');
    if (data.observacoes && data.observacoes.trim()) {
      document.getElementById('mobile-detail-observacoes').textContent = data.observacoes;
      mobileObservacoesContainer.classList.remove('hidden');
    } else {
      mobileObservacoesContainer.classList.add('hidden');
    }

    if (window.innerWidth < 1024) {
      setTimeout(() => painelMobile.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
    }
  }

  // Fechar mobile
  function fecharMobile() {
    const painelMobile = document.getElementById('painel-mobile');
    if (painelMobile) painelMobile.classList.add('hidden');
    document.querySelectorAll('.dia-com-frequencia').forEach(b => b.classList.remove('active'));
  }

  // Init
  function init() {
    console.log('Iniciando calendário...');
    
    // Gera calendário inicial
    gerarCalendario();
    
    initDropdown();

    // Navegação do calendário
    const btnAnterior = document.getElementById('btn-mes-anterior');
    const btnProximo = document.getElementById('btn-mes-proximo');
    const btnAtual = document.getElementById('btn-mes-atual');
    
    if (btnAnterior) btnAnterior.addEventListener('click', mesAnterior);
    if (btnProximo) btnProximo.addEventListener('click', mesProximo);
    if (btnAtual) btnAtual.addEventListener('click', voltarHoje);

    // Event delegation para os dias
    document.addEventListener('click', (e) => {
      const btnFreq = e.target.closest('.dia-com-frequencia');
      if (btnFreq) {
        e.preventDefault();
        const id = btnFreq.getAttribute('data-frequencia-id');
        if (id) mostrarDetalhes(id);
        return;
      }
    });

    const btnFechar = document.getElementById('btn-fechar-mobile');
    if (btnFechar) {
      btnFechar.addEventListener('click', (e) => {
        e.preventDefault();
        fecharMobile();
      });
    }

    console.log('Calendário pronto!');
  }

  // Executar quando DOM estiver pronto
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>