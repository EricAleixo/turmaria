<div class="min-h-screen bg-gradient-to-br from-green-50 to-emerald-50">
  <div class="container mx-auto px-4 py-8">
    
    <!-- Header da Escola com Design Melhorado -->
    <div class="card bg-gradient-to-r from-green-600 to-emerald-600 text-white shadow-2xl mb-8">
      <div class="card-body">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <div class="avatar placeholder">
                <div class="bg-white text-green-600 rounded-full w-16 h-16 shadow-lg relative">
                    <% if @escola.admin&.foto&.attached? %>
                        <%= image_tag @escola.admin.foto, class: "h-full w-full" %>
                    <% else %>
                    <span class="absolute top-1/2 left-1/2 -translate-1/2 text-2xl font-bold">
                        <%= @escola.nome.first.upcase %>
                    </span>
                    <% end %>
                </div>
              </div>
              <div>
                <h1 class="text-4xl font-bold mb-1"><%= @escola.nome %></h1>
                <div class="badge badge-lg bg-white text-green-600 border-0">
                  <%= @escola.tipo || 'Instituição de Ensino' %>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2 mt-4 text-green-50">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span><strong>CNPJ:</strong> <%= @escola.cnpj %></span>
              </div>
              
              <% if @escola.telefone.present? %>
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span><%= @escola.telefone %></span>
                </div>
              <% end %>
              
              <% if @escola.email.present? %>
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span><%= @escola.email %></span>
                </div>
              <% end %>
              
              <% if @escola.site.present? %>
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  <a href="<%= @escola.site %>" target="_blank" class="link link-hover font-semibold"><%= @escola.site %></a>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Cards de Estatísticas com Gradiente Verde -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Minhas Turmas -->
      <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-green-500">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Minhas Turmas</p>
              <h3 class="text-4xl font-bold text-green-600 mt-2"><%= @minhas_turmas_count %></h3>
              <p class="text-sm text-gray-600 mt-1">Turmas que você leciona</p>
            </div>
            <div class="bg-green-100 p-4 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Meus Alunos -->
      <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-emerald-500">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Meus Alunos</p>
              <h3 class="text-4xl font-bold text-emerald-600 mt-2"><%= @meus_alunos_count %></h3>
              <p class="text-sm text-gray-600 mt-1">Alunos nas suas turmas</p>
            </div>
            <div class="bg-emerald-100 p-4 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Minhas Disciplinas -->
      <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-teal-500">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Disciplinas</p>
              <h3 class="text-4xl font-bold text-teal-600 mt-2"><%= @minhas_disciplinas.map { |d| d[:disciplina_nome] }.uniq.count %></h3>
              <p class="text-sm text-gray-600 mt-1">Que você ministra</p>
            </div>
            <div class="bg-teal-100 p-4 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Minhas Disciplinas por Turma -->
    <div class="card bg-white shadow-xl mb-8 border-l-4 border-green-500">
      <div class="card-body">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-green-100 p-3 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-800">Minhas Disciplinas</h2>
        </div>
        
        <% if @minhas_disciplinas.any? %>
          <div class="overflow-x-auto">
            <table class="table w-full">
              <thead>
                <tr class="border-b-2 border-green-200">
                  <th class="bg-green-50 text-green-700 font-semibold">Disciplina</th>
                  <th class="bg-green-50 text-green-700 font-semibold">Turma</th>
                  <th class="bg-green-50 text-green-700 font-semibold text-center">Alunos</th>
                  <th class="bg-green-50 text-green-700 font-semibold text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% @minhas_disciplinas.group_by { |d| d[:disciplina_nome] }.each do |disciplina_nome, turmas| %>
                  <% turmas.each_with_index do |turma, index| %>
                    <tr class="hover:bg-green-50 transition-colors">
                      <td class="font-medium">
                        <% if index == 0 %>
                          <div class="flex items-center gap-2">
                            <div class="badge badge-lg bg-green-600 text-white border-0"><%= disciplina_nome %></div>
                            <% if turmas.size > 1 %>
                              <span class="text-xs text-gray-500">(<%= turmas.size %> turmas)</span>
                            <% end %>
                          </div>
                        <% end %>
                      </td>
                      <td>
                        <div class="badge badge-outline badge-success"><%= turma[:turma_nome] %></div>
                      </td>
                      <td class="text-center">
                        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-emerald-100 text-emerald-700 font-bold">
                          <%= turma[:total_alunos] %>
                        </span>
                      </td>
                      <td class="text-right">
                        <%= link_to professor_turmas_path, class: "btn btn-sm bg-green-600 hover:bg-green-700 text-white border-0" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                          Ver Turma
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="alert bg-green-50 border-l-4 border-green-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-green-600 shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-green-800">Você ainda não possui disciplinas atribuídas.</span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Meus Alunos -->
    <div class="card bg-white shadow-xl border-l-4 border-emerald-500">
      <div class="card-body">
        <div class="flex justify-between items-center mb-6 flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <div class="bg-emerald-100 p-3 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-800">Meus Alunos</h2>
          </div>
          <div class="badge badge-lg bg-emerald-600 text-white border-0 px-4 py-3">
            <%= @meus_alunos_count %> alunos
          </div>
        </div>
        
        <% alunos = current_professor.turmas.includes(:alunos).flat_map(&:alunos).uniq %>
        
        <% if alunos.any? %>
          <div class="overflow-x-auto">
            <table class="table w-full">
              <thead>
                <tr class="border-b-2 border-emerald-200">
                  <th class="bg-emerald-50 text-emerald-700 font-semibold">Aluno</th>
                  <th class="bg-emerald-50 text-emerald-700 font-semibold">Turma</th>
                  <th class="bg-emerald-50 text-emerald-700 font-semibold">Email</th>
                  <th class="bg-emerald-50 text-emerald-700 font-semibold text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% alunos.sort_by(&:nome).first(20).each do |aluno| %>
                  <tr class="hover:bg-emerald-50 transition-colors">
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar">
                          <div class="relative w-12 h-12 rounded-full bg-gradient-to-br from-emerald-400 to-green-600 ring-2 ring-emerald-200">
                            <% if aluno.foto.present? %>
                              <%= image_tag aluno.foto, alt: aluno.nome, class: "w-full h-full rounded-full object-cover" %>
                            <% else %>
                              <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-lg font-bold">
                                <%= aluno.nome.first.upcase %>
                              </span>
                            <% end %>
                          </div>
                        </div>
                        <div>
                          <div class="font-bold text-gray-800"><%= aluno.nome %></div>
                          <% if aluno.respond_to?(:matricula) && aluno.matricula.present? %>
                            <div class="text-xs text-gray-500">Mat: <%= aluno.matricula %></div>
                          <% end %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if aluno.turma.present? %>
                        <span class="badge badge-outline badge-success"><%= aluno.turma.nome %></span>
                      <% else %>
                        <span class="text-xs text-gray-400 italic">Sem turma</span>
                      <% end %>
                    </td>
                    <td class="text-gray-600"><%= aluno.email %></td>
                    <td class="text-right">
                      <% if aluno.turma.present? %>
                        <%= link_to professor_turma_aluno_path(aluno.turma, aluno), class: "btn btn-sm bg-emerald-600 hover:bg-emerald-700 text-white border-0" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                          </svg>
                          Ver Perfil
                        <% end %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          
          <% if alunos.count > 20 %>
            <div class="text-center mt-6">
              <%= link_to professor_alunos_path, class: "btn bg-emerald-600 hover:bg-emerald-700 text-white border-0" do %>
                Ver todos os alunos (<%= alunos.count %>)
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="alert bg-amber-50 border-l-4 border-amber-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-amber-600 shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="text-amber-800">Você ainda não possui alunos nas suas turmas.</span>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>