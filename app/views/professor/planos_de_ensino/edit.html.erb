<div class="px-8 py-10">

  <!-- Breadcrumb / Cabeçalho -->
  <div class="mb-6">
    <%= link_to professor_plano_de_ensino_path(@plano_de_ensino), class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-green-700 mb-3 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Voltar para o plano
    <% end %>
    <h1 class="text-2xl font-bold text-gray-800">Editar Plano de Ensino</h1>
    <p class="text-sm text-gray-500">
      <%= @plano_de_ensino.disciplina_nome %> · <%= @plano_de_ensino.turma_nome %>
    </p>
  </div>

  <%= render "form" %>

</div>