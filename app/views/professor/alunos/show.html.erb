<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header com Breadcrumb e Ações -->
    <div class="mb-8">
      <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <%= link_to professor_turmas_path, class: "inline-flex items-center text-sm font-medium text-gray-700 hover:text-emerald-600 transition-colors text-green-600" do %>
              Turmas
            <% end %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <%= link_to @turma.nome, "#", class: "ml-1 text-sm font-medium text-gray-700 hover:text-emerald-600 transition-colors md:ml-2 text-green-600" %>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2"><%= @aluno.nome %></span>
            </div>
          </li>
        </ol>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Perfil do Aluno</h1>
          <p class="mt-1 text-sm text-gray-500">Informações detalhadas e desempenho acadêmico</p>
        </div>
        
        <%= link_to professor_turmas_path, class: "inline-flex items-center justify-center px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-all" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Voltar
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Card Principal do Aluno -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <!-- Header com Gradiente Verde -->
          <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 h-32"></div>
          
          <div class="px-6 pb-6">
            <!-- Foto do Aluno -->
            <div class="relative -mt-16 mb-4">
              <div class="w-32 h-32 mx-auto bg-white rounded-full border-4 border-white shadow-lg overflow-hidden">
                <% if @aluno.foto_url.present? %>
                  <%= image_tag @aluno.foto_url, alt: @aluno.nome, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-emerald-100 flex items-center justify-center">
                    <span class="text-4xl font-bold text-emerald-600">
                      <%= @aluno.nome.first.upcase %>
                    </span>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Nome e Matrícula -->
            <div class="text-center mb-6">
              <h2 class="text-2xl font-bold text-gray-900 mb-1"><%= @aluno.nome %></h2>
              <p class="text-sm text-gray-500 mb-3">Matrícula: <%= @aluno.matricula || "Não informada" %></p>
              
              <!-- Badge da Turma -->
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-emerald-100 text-emerald-800">
                <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path>
                </svg>
                <%= @turma.nome %>
              </span>
            </div>

            <!-- Informações Rápidas -->
            <div class="space-y-3">
              <div class="flex items-center text-sm">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span class="text-gray-700 font-medium">Idade:</span>
                <span class="ml-2 text-gray-600"><%= @aluno.idade || "Não informada" %> anos</span>
              </div>

              <% if @aluno.email.present? %>
              <div class="flex items-center text-sm">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <span class="text-gray-700 font-medium">Email:</span>
                <span class="ml-2 text-gray-600 truncate"><%= @aluno.email %></span>
              </div>
              <% end %>

              <% if @aluno.telefone.present? %>
              <div class="flex items-center text-sm">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <span class="text-gray-700 font-medium">Telefone:</span>
                <span class="ml-2 text-gray-600"><%= @aluno.telefone %></span>
              </div>
              <% end %>

              <div class="flex items-center text-sm">
                <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                <span class="text-gray-700 font-medium">Escola:</span>
                <span class="ml-2 text-gray-600"><%= @aluno.escola&.nome || "Não informada" %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Conteúdo Principal -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Disciplinas que o Professor Leciona -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-emerald-50 to-white">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
              <svg class="w-6 h-6 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              Minhas Disciplinas
            </h3>
            <p class="mt-1 text-sm text-gray-500">Disciplinas que você leciona nesta turma</p>
          </div>
          
          <div class="px-6 py-5">
            <% disciplinas_comuns = current_professor.disciplinas & @turma.disciplinas %>
            
            <% if disciplinas_comuns.any? %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <% disciplinas_comuns.each do |disciplina| %>
                  <div class="group relative bg-gradient-to-br from-gray-50 to-white border-2 border-gray-200 rounded-lg p-4 hover:border-emerald-400 hover:shadow-md transition-all duration-200">
                    <!-- Indicador de Cor da Disciplina -->
                    <div class="absolute top-0 left-0 w-1 h-full rounded-l-lg" style="background-color: <%= disciplina.cor_nome || '#10b981' %>"></div>
                    
                    <div class="ml-3">
                      <h4 class="text-base font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">
                        <%= disciplina.nome %>
                      </h4>
                      
                      <% if disciplina.area_disciplina %>
                        <p class="text-xs text-gray-500 mt-1">
                          <%= disciplina.area_disciplina.nome %>
                        </p>
                      <% end %>
                      
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhuma disciplina encontrada</h3>
                <p class="mt-1 text-sm text-gray-500">Você não leciona nenhuma disciplina para esta turma.</p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Informações Pessoais -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
              <svg class="w-6 h-6 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Informações Pessoais
            </h3>
          </div>
          
          <div class="px-6 py-5">
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
              <div>
                <dt class="text-sm font-medium text-gray-500">CPF</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @aluno.cpf || "Não informado" %></dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">RG</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @aluno.rg || "Não informado" %></dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">Data de Nascimento</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= @aluno.data_nascimento ? l(@aluno.data_nascimento, format: :long) : "Não informada" %>
                </dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">Sexo</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @aluno.sexo || "Não informado" %></dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">Cor/Raça</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @aluno.cor || "Não informado" %></dd>
              </div>
              
              <div>
                <dt class="text-sm font-medium text-gray-500">Tipo Sanguíneo</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @aluno.tipo_sanguinio || "Não informado" %></dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Responsáveis -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
              <svg class="w-6 h-6 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              Responsáveis
            </h3>
          </div>
          
          <div class="px-6 py-5">
            <div class="space-y-6">
              <% if @aluno.responsavel_1.present? %>
                <div class="flex items-start space-x-4 p-4 bg-emerald-50 rounded-lg">
                  <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-emerald-200 rounded-full flex items-center justify-center">
                      <span class="text-xl font-bold text-emerald-700">1</span>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900"><%= @aluno.responsavel_1 %></p>
                    <% if @aluno.telefone_responsavel_1.present? %>
                      <p class="text-sm text-gray-600 mt-1">
                        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                        <%= @aluno.telefone_responsavel_1 %>
                      </p>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% if @aluno.responsavel_2.present? %>
                <div class="flex items-start space-x-4 p-4 bg-emerald-50 rounded-lg">
                  <div class="flex-shrink-0">
                    <div class="w-12 h-12 bg-emerald-200 rounded-full flex items-center justify-center">
                      <span class="text-xl font-bold text-emerald-700">2</span>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900"><%= @aluno.responsavel_2 %></p>
                    <% if @aluno.telefone_responsavel_2.present? %>
                      <p class="text-sm text-gray-600 mt-1">
                        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                        <%= @aluno.telefone_responsavel_2 %>
                      </p>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% unless @aluno.responsavel_1.present? || @aluno.responsavel_2.present? %>
                <div class="text-center py-6 text-gray-500 text-sm">
                  Nenhum responsável cadastrado
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Necessidades Especiais (se houver) -->
        <% if @aluno.necessidades_especiais_tipo.present? || @aluno.observacoes_pcd.present? %>
          <div class="bg-amber-50 border-l-4 border-amber-400 rounded-lg overflow-hidden">
            <div class="px-6 py-5">
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <svg class="h-6 w-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div class="ml-3 flex-1">
                  <h3 class="text-sm font-medium text-amber-800">Necessidades Especiais</h3>
                  <div class="mt-2 text-sm text-amber-700">
                    <% if @aluno.necessidades_especiais_tipo.present? %>
                      <p class="font-medium mb-1"><%= @aluno.necessidades_especiais_tipo %></p>
                    <% end %>
                    <% if @aluno.observacoes_pcd.present? %>
                      <p><%= @aluno.observacoes_pcd %></p>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>