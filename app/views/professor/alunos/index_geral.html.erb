<%= content_for :page_title, "Meus Alunos" %>

<div class="drawer lg:drawer-open bg-gradient-to-br from-slate-50 via-emerald-50 to-teal-50 min-h-screen">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    
    <div class="w-full p-4">
      <div class="flex items-center mb-6 lg:hidden bg-gradient-to-r from-emerald-600 to-teal-600 text-white rounded-2xl p-4 shadow-lg">
        <label for="my-drawer" class="btn btn-square btn-ghost text-white hover:bg-white/20">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <% if @turma %>
          <h1 class="text-xl font-bold ml-2">Alunos - <%= @turma.nome %></h1>
        <% else %>
          <h1 class="text-xl font-bold ml-2">Meus Alunos</h1>
        <% end %>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <% if notice.present? %>
          <div class="alert bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 shadow-xl mb-6 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="font-medium"><%= notice %></span>
          </div>
        <% end %>

        <div class="bg-white/80 backdrop-blur-sm p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-white/20">
          <div class="bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-2xl p-6 mb-8 shadow-xl">
            
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              
              <div class="flex flex-col items-start space-y-2 flex-grow">
                <h1 class="text-2xl lg:text-4xl font-bold">
                  <% if @turma %>
                    Alunos da Turma <%= @turma.nome %>
                  <% else %>
                    Meus Alunos em todas as Turmas
                  <% end %>
                </h1>
                <div class="badge badge-lg bg-white/20 text-white border-white/30">
                  <%= @alunos.count %> <%= @alunos.count == 1 ? 'aluno' : 'alunos' %>
                </div>
              </div>

              <div class="flex flex-row gap-3 flex-shrink-0">
                <%# ATUALIZAÇÃO 1: Botão agora leva para a rota correta de Turmas %>
                <%= link_to minhas_turmas_path, class: "btn btn-md bg-white text-emerald-600 hover:bg-emerald-50 border-0 shadow-lg hover:scale-105 transition-all duration-300" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 mr-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                  </svg>
                  Minhas Turmas
                <% end %>
              </div> 
            </div>
          </div>
          
          <%# CORREÇÃO DA ROTA: Usando hash para evitar o erro ActionController::UrlGenerationError %>
          <%= form_with(url: { controller: 'professor/alunos', action: 'index' }, method: :get, local: true, class: "mb-8 p-4 bg-gray-50 border border-gray-200 rounded-xl shadow-inner") do %>
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
              
              <div class="col-span-1 md:col-span-6 lg:col-span-7">
                <label class="label">
                  <span class="label-text font-medium text-slate-600">Pesquisar por Nome:</span>
                </label>
                <%= text_field_tag :search, params[:search], 
                                  class: "input input-bordered w-full bg-white", 
                                  placeholder: "Digite o nome do aluno" %>
              </div>

              <div class="col-span-1 md:col-span-4 lg:col-span-3">
                <label class="label">
                  <span class="label-text font-medium text-slate-600">Filtrar por Turma:</span>
                </label>
                
                <%# ATUALIZAÇÃO 2: Formata a opção da turma como "Série (Ano) Turma Nome" %>
                <% turma_options = current_professor.turmas.map { |t| ["#{t.serie}º Ano - #{t.nome}", t.id] } %>
                
                <%= select_tag :turma,
                              options_for_select([['Todas as Turmas', 'todos']] + turma_options, params[:turma]),
                              class: "select select-bordered w-full bg-white" %>
              </div>

              <div class="col-span-1 md:col-span-2 lg:col-span-2">
                <%= submit_tag "Filtrar", name: nil, 
                              class: "btn btn-md bg-emerald-500 text-white hover:bg-emerald-600 border-0 shadow-lg w-full" %>
              </div>
            </div>
          <% end %>
          <% if @alunos.empty? %>
            <div class="text-center py-16 bg-gradient-to-br from-slate-50 to-emerald-50 rounded-3xl border-2 border-dashed border-slate-200">
              <div class="max-w-md mx-auto">
                <div class="text-6xl mb-4">📚</div>
                <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum aluno encontrado nas suas turmas</h3>
                <p class="text-slate-500 mb-6">Verifique se você está alocado a alguma turma. Se estiver, pode não haver alunos cadastrados nela.</p>
                <%# ATUALIZAÇÃO 1: Botão que leva para a rota correta de Turmas %>
                <%= link_to minhas_turmas_path, class: "btn btn-lg bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 rounded-full" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mr-2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.155L12 14.25l7.74-4.095L12 6.06l-7.74 4.095zM12 18.75l-7.74-4.095M12 18.75V14.25m0-4.095V6.06M2.25 15.75l9.75 5.25 9.75-5.25M12 4.5l-9.75 5.25 9.75 5.25 9.75-5.25z" />
                  </svg>
                  Ver Minhas Turmas
                <% end %>
              </div>
            </div>
          <% else %>
            <div class="hidden md:block overflow-x-auto">
              <table class="table w-full shadow-xl rounded-xl overflow-hidden">
                <thead>
                  <tr class="bg-gradient-to-r from-emerald-500 to-teal-600 text-white">
                    <th class="rounded-tl-xl">Nome</th>
                    <th>Escola</th>
                    <th>Nascimento</th>
                    <th>Matrícula</th>
                    <th>Turma</th>
                    <th class="rounded-tr-xl">Ações</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  <% @alunos.each do |aluno| %>
                    <tr class="hover:bg-emerald-50 transition-all duration-300 border-b border-gray-200 group">
                      <td class="py-4">
                        <div class="flex items-center gap-3">
                          <div class="avatar placeholder">
                            <div class="bg-gradient-to-br from-emerald-400 to-teal-500 text-white rounded-full w-10 h-10 relative font-bold">
                              <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"><%= aluno.nome.first.upcase %></span>
                            </div>
                          </div>
                          <span class="font-bold text-slate-700"><%= aluno.nome %></span>
                        </div>
                      </td>
                      <td>
                        <div class="badge badge-lg bg-gradient-to-r from-emerald-400 to-teal-500 text-white border-0 font-medium">
                          <%= aluno.turma&.escola&.nome || "N/D" %>
                        </div>
                      </td>
                      <td class="text-slate-600 font-medium"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></td>
                      <td>
                          <div class="badge badge-outline badge-lg border-emerald-300 text-emerald-600 font-mono 
                          max-w-xs overflow-hidden whitespace-nowrap text-ellipsis">
                          <%= aluno.matricula.present? ? aluno.matricula : "N/D" %>
                          </div>
                      </td>
                      <td class="text-slate-600 font-bold">
                        <% if aluno.turma.present? %>
                          <%= "#{aluno.turma.serie}º Ano - Turma #{aluno.turma.nome}" %>
                        <% else %>
                          Sem Turma
                        <% end %>
                      </td>
                      <td>
                        <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                          <%= link_to '#', class: "btn btn-sm btn-circle bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 hover:scale-110 transition-all duration-300 shadow-lg", title: "Ver detalhes" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <div class="grid grid-cols-1 gap-4 md:hidden">
              <% @alunos.each do |aluno| %>
                <div class="card bg-white shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden border border-emerald-100">
                  <div class="card-body p-4">
                    <div class="flex justify-between items-start">
                      <div class="flex items-center gap-3">
                        <div class="avatar placeholder">
                          <div class="bg-gradient-to-br from-emerald-400 to-teal-500 text-white rounded-full w-10 h-10 relative font-bold">
                            <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"><%= aluno.nome.first.upcase %></span>
                          </div>
                        </div>
                        <div>
                          <h2 class="card-title text-slate-700"><%= aluno.nome %></h2>
                          <div class="badge badge-lg bg-gradient-to-r from-emerald-500 to-teal-500 text-white border-0 shadow-lg font-bold mt-1">
                            <%= aluno.turma.present? ? "Alocado" : "Não Alocado" %>
                          </div>
                        </div>
                      </div>
                      <div class="dropdown dropdown-end">
                        <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </label>
                        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
                          <% if aluno.turma.present? %>
                            <li>
                              <%= link_to '#' do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Ver aluno
                              <% end %>
                            </li>
                          <% else %>
                            <li><div class="text-slate-400 px-2 py-1">Ações limitadas</div></li>
                          <% end %>
                        </ul>
                      </div>
                    </div>
                    
                    <div class="divider my-2"></div>
                    
                    <div class="grid grid-cols-2 gap-2 text-sm">
                      <div>
                        <span class="text-slate-500">Turma:</span>
                        <span class="font-medium text-slate-700">
                           <% if aluno.turma.present? %>
                            <%= "#{aluno.turma.serie}º Ano - Turma #{aluno.turma.nome}" %>
                          <% else %>
                            Sem Turma
                          <% end %>
                        </span>
                      </div>
                      <div>
                        <span class="text-slate-500">Escola:</span>
                        <div class="badge badge-sm bg-gradient-to-r from-emerald-400 to-teal-500 text-white border-0 font-medium">
                          <%= aluno.turma&.escola&.nome || "N/D" %>
                        </div>
                      </div>
                      <div>
                        <span class="text-slate-500">Nascimento:</span>
                        <span class="font-medium text-slate-700"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "N/D" %></span>
                      </div>
                      <div>
                        <span class="text-slate-500">Matrícula:</span>
                        <div class="badge badge-outline badge-sm border-emerald-300 text-emerald-600 font-mono">
                          <%= aluno.matricula.present? ? truncate(aluno.matricula, length: 12) : "N/D" %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </main>
    </div>
  </div>
</div>