<%= form_with(model: [@escola, turma], class: "bg-white p-8 rounded-lg shadow-md") do |form| %>

  <% if turma.errors.any? %>
    <div class="alert alert-error mb-6">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>
          <h3 class="font-bold">Erro ao salvar!</h3>
          <ul class="list-disc list-inside">
            <% turma.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </span>
      </div>
    </div>
  <% end %>

  <!-- CABEÇALHO -->
  <div class="flex justify-between items-center mb-8 border-b pb-4">
    <h1 class="text-2xl font-bold text-gray-700">
      <%= turma.persisted? ? "Editar Turma" : "Nova Turma" %>
    </h1>
    <%= link_to "Voltar para Turmas", escola_turmas_path(@escola), class: "btn btn-outline btn-sm" %>
  </div>

  <!-- NOME -->
  <div class="form-control w-full mb-6">
    <%= form.label :nome, "Nome da Turma *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.text_field :nome, class: "input input-bordered w-full", placeholder: "Ex: 1º ano A", required: true %>
  </div>

  <!-- SERIE -->
  <div class="form-control w-full mb-6">
    <%= form.label :serie, "Série *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :serie, class: "input input-bordered w-full", placeholder: "1, 2 ou 3", required: true %>
  </div>

  <!-- DROPDOWN TURNO (ESTILO BASE) -->
  <div class="dropdown relative w-full mb-6" data-dropdown="custom">
    <div tabindex="0"
      class="dropdown-trigger w-full flex items-center justify-between bg-white border border-gray-300
             rounded-md px-4 py-2 cursor-pointer hover:border-black focus:border-black focus:outline-none shadow-none">

      <span id="turno-label"><%= turma.turno.present? ? turma.turno.capitalize : "Selecione o turno" %></span>

      <svg class="ml-2 h-5 w-5 text-gray-600" xmlns="http://www.w3.org/2000/svg"
        fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 9l-7 7-7-7" />
      </svg>
    </div>

    <ul class="dropdown-list menu p-2 bg-white border border-gray-300 rounded-md w-full mt-1 absolute hidden
               !z-[9999] max-h-60 overflow-auto shadow-none">
      <% [["Manhã","manha"], ["Tarde","tarde"], ["Noite","noite"], ["Integral","integral"]].each do |nome, valor| %>
        <li>
          <a href="#"
             class="dropdown-option hover:bg-green-100 px-3 py-2 rounded cursor-pointer"
             data-value="<%= valor %>">
            <%= nome %>
          </a>
        </li>
      <% end %>
    </ul>

    <%= form.hidden_field :turno, id: "turma_turno", value: turma.turno %>
  </div>

  <!-- DROPDOWN ANO LETIVO (ESTILO BASE) -->
  <div class="form-control w-full mb-6">
    <%= form.label :ano_letivo_id, "Ano Letivo *", class: "label label-text text-gray-600 font-semibold" %>

    <div class="dropdown relative w-full" data-dropdown="custom">
      <div tabindex="0"
        class="dropdown-trigger w-full flex items-center justify-between bg-white border border-gray-300
               rounded-md px-4 py-2 cursor-pointer hover:border-black focus:border-black focus:outline-none shadow-none">

        <span id="ano-letivo-label"><%= turma.ano_letivo.present? ? turma.ano_letivo.ano : "Selecione o Ano Letivo" %></span>

        <svg class="ml-2 h-5 w-5 text-gray-600" xmlns="http://www.w3.org/2000/svg"
          fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 9l-7 7-7-7" />
        </svg>
      </div>

      <ul class="dropdown-list menu p-2 bg-white border border-gray-300 rounded-md w-full mt-1 absolute hidden
                 !z-[9999] max-h-60 overflow-auto shadow-none">

        <% @anos_letivos.each do |ano| %>
          <li>
            <a href="#"
               class="dropdown-option hover:bg-green-100 px-3 py-2 rounded cursor-pointer"
               data-value="<%= ano.id %>">
               <%= ano.ano %>
            </a>
          </li>
        <% end %>
      </ul>

      <%= form.hidden_field :ano_letivo_id, id: "turma_ano_letivo", value: turma.ano_letivo_id %>
    </div>
  </div>

  <!-- AÇÕES -->
  <div class="flex justify-between mt-10">
    <%= link_to "Adicionar Ano Letivo", new_escola_ano_letivo_path(@escola),
                data: { turbo_frame: "modal" }, class: "btn btn-primary" %>

    <%= form.submit turma.persisted? ? "Atualizar" : "Criar Turma",
      class: "btn bg-green-500 hover:bg-green-600 text-white w-32" %>
  </div>

<% end %>

<!-- JS IGUAL AO BASE -->
<script>
document.addEventListener("turbo:load", () => {
  console.log("[DEBUG] turbo:load fired");

  document.querySelectorAll('[data-dropdown="custom"]').forEach((dropdown) => {
    const trigger = dropdown.querySelector(".dropdown-trigger");
    const list = dropdown.querySelector(".dropdown-list");
    const hidden = dropdown.querySelector('input[type="hidden"]');
    const label = trigger.querySelector("span");

    if (!trigger || !list || !hidden || !label) return;

    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      list.classList.toggle("hidden");
    });

    list.querySelectorAll(".dropdown-option").forEach((option) => {
      option.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        hidden.value = option.dataset.value;
        label.textContent = option.textContent.trim();

        list.classList.add("hidden");
      });
    });
  });

  document.addEventListener("click", (e) => {
    document.querySelectorAll('[data-dropdown="custom"]').forEach((dropdown) => {
      if (!dropdown.contains(e.target)) {
        dropdown.querySelector(".dropdown-list")?.classList.add("hidden");
      }
    });
  });
});
</script>
