<div class="min-h-screen bg-gray-100">

  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <!-- Título e breadcrumbs -->
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            Disciplina - <%= @disciplina.nome %>
          </h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li>
                <%= link_to "Disciplinas", disciplinas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %>
              </li>
              <li class="text-gray-600"><%= @disciplina.nome %></li>
            </ul>
          </div>
        </div>

        <!-- Botões -->
        <div class="flex gap-3">
          <%= link_to new_disciplina_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova Disciplina
          <% end %>

          <%= link_to edit_disciplina_path(@disciplina), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Editar Disciplina
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Conteúdo da disciplina -->
  <div class="px-6">
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">

      <!-- Header do card -->
      <div class="bg-gradient-to-r from-blue-500 to-green-300 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
          </svg>
          Informações da disciplina
        </h2>
      </div>

      <!-- Conteúdo -->
      <div class="p-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

          <!-- Badge da área -->
          <div class="lg:col-span-2 space-y-6">
            <%= badge_area(@disciplina.area) %>
          </div>

          <!-- Estatísticas da escola -->
          <div class="lg:col-span-1 bg-white rounded-lg shadow-lg p-6">
            <div class="grid grid-cols-2 gap-4 text-center">
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-wide">Professores da disciplina</p>
                <p class="text-lg font-bold text-indigo-600"><%= @disciplina.professores.pluck(:nome).join("<br>").html_safe%> </p>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-wide">Professores</p>
                <p class="text-lg font-bold text-indigo-600"><%= @disciplina.professores.count %></p>
              </div>
            </div>
          </div>

          <!-- Professores -->
          <div class="lg:col-span-1 bg-white rounded-lg shadow-lg p-6">
            <div id="professor_carousel" class="relative w-full max-w-sm mx-auto touch-pan-x select-none">
            
              <% if @disciplina.professores.any? %>
                <% @disciplina.professores.each_with_index do |professor, index| %>
                  <div 
                    class="professor-slide transition-opacity duration-300 <%= index == 0 ? '' : 'hidden opacity-0' %>"
                    data-index="<%= index %>"
                  >
                    <div class="text-center mb-6">
                      <!-- Avatar -->
                      <div class="mx-auto mb-4 w-20 h-20 bg-gradient-to-br from-blue-500 to-green-300 rounded-full flex items-center justify-center shadow-lg">
                        <span class="text-2xl font-bold text-white"><%= professor.nome.first.upcase %></span>
                      </div>

                      <!-- Nome e email -->
                      <h4 class="text-lg font-bold text-gray-900"><%= professor.nome %></h4>
                      <% if professor.email.present? %>
                        <p class="text-sm text-gray-600 flex items-center justify-center">
                          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                          </svg>
                          <%= professor.email %>
                        </p>
                      <% end %>

                      <!-- Status -->
                      <div class="mt-3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          <div class="w-2 h-2 bg-green-400 rounded-full mr-1"></div>
                          Ativo
                        </span>
                      </div>
                    </div>
                  </div>
                <% end %>

                <!-- Contador -->
                <p class="text-center text-xs text-gray-400 mt-2">
                  <span id="prof-index">1</span> / <%= @disciplina.professores.count %>
                </p>

                <!-- Botões de navegação -->
                <button 
                  id="prev-prof" 
                  class="absolute left-0 top-1/2 -translate-y-1/2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-full p-2 shadow"
                >
                  ←
                </button>
                <button 
                  id="next-prof" 
                  class="absolute right-0 top-1/2 -translate-y-1/2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-full p-2 shadow"
                >
                  →
                </button>

              <% else %>
                <div class="text-center py-8">
                  <div class="mx-auto mb-4 w-20 h-20 bg-gray-300 rounded-full flex items-center justify-center">
                    <svg class="w-10 h-10 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <p class="text-sm text-gray-500 mb-3">Nenhum professor atribuído</p>
                  <button class="text-xs bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full hover:bg-indigo-200 transition-colors">
                    Atribuir Professor
                  </button>
                </div>
              <% end %>
            </div>
          </div>


        </div>
      </div>

    </div>
  </div>

</div>

<script>
  document.addEventListener("turbo:load", () => {
    const slides = document.querySelectorAll(".professor-slide");
    const prevBtn = document.getElementById("prev-prof");
    const nextBtn = document.getElementById("next-prof");
    let current = 0;

    function showSlide(index) {
      slides.forEach((slide, i) => {
        slide.classList.add("hidden", "opacity-0");
        if (i === index) {
          slide.classList.remove("hidden", "opacity-0");
        }
      });
    }

    prevBtn.addEventListener("click", () => {
      current = (current - 1 + slides.length) % slides.length;
      showSlide(current);
    });

    nextBtn.addEventListener("click", () => {
      current = (current + 1) % slides.length;
      showSlide(current);
    });
  });
</script>