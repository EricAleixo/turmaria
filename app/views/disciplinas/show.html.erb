<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">

  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <!-- Título e breadcrumbs -->
        <div>
          <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color: <%= @disciplina.cor_nome || '#6B7280' %>20;">
              <span class="text-xl font-bold" style="color: <%= @disciplina.cor_nome || '#6B7280' %>;">
                <%= @disciplina.nome.first.upcase %>
              </span>
            </div>
            <%= @disciplina.nome %>
          </h1>
          <div class="text-sm breadcrumbs mt-2">
            <ul>
              <li>
                <%= link_to disciplinas_path, class: "text-green-600 hover:text-green-700 transition-colors duration-200 flex items-center gap-1" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                  Disciplinas
                <% end %>
              </li>
              <li class="text-gray-600"><%= @disciplina.nome %></li>
            </ul>
          </div>
        </div>

        <!-- Botões -->
        <div class="flex gap-3">
          <%= link_to new_disciplina_path, class: "bg-green-500 hover:bg-green-600 text-white px-5 py-2.5 rounded-xl font-medium transition-all hover:shadow-lg hover:scale-105 flex items-center gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova Disciplina
          <% end %>

          <%= link_to edit_disciplina_path(@disciplina), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-5 py-2.5 rounded-xl font-medium transition-all hover:shadow-lg hover:scale-105 flex items-center gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Editar
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Conteúdo da disciplina -->
  <div class="px-6 py-8">
    
    <!-- Badge da Área - Destacado -->
    <% if @disciplina.area_disciplina.present? %>
      <div class="mb-8 transform hover:scale-[1.02] transition-transform duration-200">
        <div class="bg-white rounded-2xl shadow-xl p-6 border-l-[6px]" style="border-color: <%= @disciplina.area_disciplina.cor %>;">
          <div class="flex items-center justify-between">
            <!-- Parte esquerda: ícone + textos -->
            <div class="flex items-center gap-4">
              <!-- Ícone -->
              <div class="w-14 h-14 rounded-xl flex items-center justify-center shadow-md" style="background-color: <%= @disciplina.area_disciplina.cor %>20;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7" style="color: <%= @disciplina.area_disciplina.cor %>;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                </svg>
              </div>

              <!-- Textos -->
              <div>
                <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">Área da Disciplina</p>
                <p class="text-2xl font-bold mt-1" style="color: <%= @disciplina.area_disciplina.cor %>;">
                  <%= @disciplina.area_disciplina.nome %>
                </p>
              </div>
            </div>

            <!-- Badge direita -->
            <span class="px-4 py-2 text-sm font-semibold rounded-xl shadow-sm" style="background-color: <%= @disciplina.area_disciplina.cor %>20; color: <%= @disciplina.area_disciplina.cor %>;">
              <%= @disciplina.area_disciplina.nome.upcase %>
            </span>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Grid de Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Card de Estatísticas -->
      <div class="bg-white rounded-2xl shadow-lg p-8 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-indigo-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900">Estatísticas</h3>
        </div>

        <div class="space-y-4">
          <!-- Professores count -->
          <div class="bg-gradient-to-r from-indigo-50 to-purple-50 rounded-xl p-4 border border-indigo-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-gray-600 font-medium">Total de Professores</p>
                <p class="text-3xl font-bold text-indigo-600 mt-1"><%= @disciplina.professores.count %></p>
              </div>
              <div class="w-12 h-12 bg-indigo-200 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7 text-indigo-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Turmas count (se existir) -->
          <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-xl p-4 border border-green-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-gray-600 font-medium">Turmas Vinculadas</p>
                <p class="text-3xl font-bold text-green-600 mt-1"><%= @disciplina.turmas.count %></p>
              </div>
              <div class="w-12 h-12 bg-green-200 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7 text-green-700">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Card de Professores - Carrossel -->
      <div class="bg-white rounded-2xl shadow-lg p-8 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900">Professores</h3>
        </div>

        <div id="professor_carousel" class="relative">
          <% if @disciplina.professores.any? %>
            <% @disciplina.professores.each_with_index do |professor, index| %>
              <div 
                class="professor-slide transition-all duration-500 <%= index == 0 ? 'opacity-100' : 'hidden opacity-0' %>"
                data-index="<%= index %>"
              >
                <div class="text-center">
                  <!-- Avatar com gradiente -->
                  <div class="mx-auto mb-5 w-24 h-24 rounded-2xl flex items-center justify-center shadow-lg transform hover:scale-110 transition-transform duration-300 bg-green-500">
                    <span class="text-3xl font-bold text-white"><%= professor.nome.first.upcase %></span>
                  </div>

                  <!-- Nome -->
                  <h4 class="text-xl font-bold text-gray-900 mb-2"><%= professor.nome %></h4>
                  
                  <!-- Email -->
                  <% if professor.email.present? %>
                    <div class="flex items-center justify-center gap-2 text-gray-600 mb-4">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      <span class="text-sm"><%= professor.email %></span>
                    </div>
                  <% end %>

                  <!-- Status Badge -->
                  <div class="flex justify-center">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold bg-green-100 text-green-700 shadow-sm">
                      <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                      Ativo
                    </span>
                  </div>
                </div>
              </div>
            <% end %>

            <!-- Navegação -->
            <div class="flex items-center justify-between mt-6">
              <button 
                id="prev-prof" 
                class="w-10 h-10 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl flex items-center justify-center shadow-sm transition-all hover:scale-110"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
              </button>

              <!-- Contador -->
              <div class="flex items-center gap-2">
                <span id="prof-index" class="text-lg font-bold text-gray-900">1</span>
                <span class="text-gray-400">/</span>
                <span class="text-lg font-medium text-gray-600"><%= @disciplina.professores.count %></span>
              </div>

              <button 
                id="next-prof" 
                class="w-10 h-10 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl flex items-center justify-center shadow-sm transition-all hover:scale-110"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            </div>

          <% else %>
            <!-- Estado vazio -->
            <div class="text-center py-12">
              <div class="mx-auto mb-4 w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center">
                <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <p class="text-gray-500 mb-4">Nenhum professor atribuído</p>
              <button class="bg-indigo-500 hover:bg-indigo-600 text-white px-5 py-2.5 rounded-xl font-medium cursor-pointer transition-all hover:shadow-lg">
                Atribuir Professor
              </button>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>

</div>

<script>
  document.addEventListener("turbo:load", () => {
    const slides = document.querySelectorAll(".professor-slide");
    const prevBtn = document.getElementById("prev-prof");
    const nextBtn = document.getElementById("next-prof");
    const indexDisplay = document.getElementById("prof-index");
    let current = 0;

    if (!slides.length || !prevBtn || !nextBtn) return;

    function showSlide(index) {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.classList.remove("hidden", "opacity-0");
          slide.classList.add("opacity-100");
        } else {
          slide.classList.add("hidden", "opacity-0");
          slide.classList.remove("opacity-100");
        }
      });
      
      if (indexDisplay) {
        indexDisplay.textContent = index + 1;
      }
    }

    prevBtn.addEventListener("click", () => {
      current = (current - 1 + slides.length) % slides.length;
      showSlide(current);
    });

    nextBtn.addEventListener("click", () => {
      current = (current + 1) % slides.length;
      showSlide(current);
    });
  });
</script>