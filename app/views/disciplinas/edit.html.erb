<div class="min-h-screen bg-gray-100">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Editar disciplina</h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li><%= link_to "disciplinas", disciplinas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li><%= link_to @disciplina.nome, disciplina_path(@disciplina), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
              <li class="text-gray-600">Editar</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-3">
          <%= link_to "Ver disciplina", disciplina_path(@disciplina), class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
          <%= button_to "Excluir", disciplina_path(@disciplina), method: :delete, 
              confirm: "Tem certeza que deseja excluir este disciplina?",
              class: "bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Container -->
  <div class="px-6">
    <div class="max-w-4xl mx-auto">
      <%= render 'form', disciplina: @disciplina %>
    </div>
  </div>
</div>