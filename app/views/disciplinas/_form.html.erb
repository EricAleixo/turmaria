<%=form_with(model: @disciplina, class: "bg-white rounded-lg shadow-sm border border-gray-200") do |form| %>
  <% if @disciplina&.errors&.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800">Erro ao salvar!</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @disciplina.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Header -->
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">
      <%= @disciplina&.persisted? ? "Editar disciplina" : "Nova disciplina" %>
    </h2>
    <p class="mt-1 text-sm text-gray-600">
      <%= @disciplina&.persisted? ? "Atualize as informações abaixo." : "Preencha os dados da disciplina abaixo." %>
    </p>
  </div>

  <!-- Form Body -->
  <div class="px-6 py-6">
    <h3 class="text-base font-medium text-gray-900 mb-4">Informações Básicas</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Nome -->
      <div class="mb-4">
        <label class="block mb-1">Nome</label>
        <button 
          type="button" 
          id="abrir-modal-nome" 
          class="w-full bg-white text-black border border-gray-300 hover:bg-green-400 hover:text-white px-4 py-2 rounded-lg font-medium transition text-left"
        >
            <%= @disciplina.nome.presence || "Criar nome" %>
          
        </button>
      </div>

      <!-- Área -->
      <div>
        <%= form.label :area, "Área da Disciplina", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :area, 
          (@disciplinas_areas || []).map { |a| [a[:nome], a[:nome]] } + [["Criar nova área", "nova_area"]], 
          { prompt: "Selecione a área" },
          { id:"area-select", class: "w-full bg-white text-black border border-gray-300 hover:bg-green-400 hover:text-white px-4 py-2 rounded-lg font-medium transition text-left"  } %>

        <!-- Campo hidden para a cor -->
        <%= form.hidden_field :cor, id: "disciplina-cor", value: @disciplina.cor || "#ffffff" %>
      </div>
    </div>

    <!-- Filtros Escola / Professor -->
    <% if current_user.is_a?(SuperAdmin) %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Escola *</label>
          <button 
            type="button" 
            id="abrir-modal-escola-btn"
            class="w-full bg-white text-black border border-gray-300 hover:bg-green-400 hover:text-white px-4 py-2 rounded-lg font-medium transition text-left"
          >
            Selecione a Escola
          </button>

          <p id="escola-selecionada" class="text-sm text-gray-600 mt-1"><%= @disciplina.escola&.nome %></p>
          <%= form.hidden_field :escola_id, id: "escola_id" %>

          <!-- Modal Escola -->
          <dialog id="modal-escola" class="modal">
            <div class="modal-box max-w-2xl bg-white rounded-2xl shadow-xl border border-gray-200 p-6">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Selecionar Escola</h3>
                <button type="button" id="fechar-modal-escola" class="text-gray-400 hover:text-gray-600">&times;</button>
              </div>

              <!-- Filtros -->
              <div class="flex flex-col md:flex-row md:items-center md:space-x-4 mb-4">
                <input type="text" id="filtro-nome-escola" placeholder="Buscar por nome..." class="flex-1 border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500 mb-2 md:mb-0">
                <select id="filtro-tipo-escola" class="border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500">
                  <option value="">Todas</option>
                  <option value="publica">Pública</option>
                  <option value="privada">Privada</option>
                </select>
              </div>

              <div id="lista-escolas" class="max-h-64 overflow-y-auto rounded-lg divide-y divide-green-500 p-2 bg-gray-50"></div>
            </div>
          </dialog>

          <!-- Modal de Área -->
          <dialog id="modal-area" class="modal">
            <div class="modal-box bg-white rounded-lg p-6 w-full max-w-md">
              <h3 class="text-lg font-bold mb-4">Criar Nova Área</h3>

              <div class="mb-4">
                <label class="block mb-1">Nome da Área</label>
                <input type="text" id="nova-area-nome" class="w-full border px-3 py-2 rounded-lg" placeholder="Digite o nome da área">
              </div>

              <div class="mb-4">
                <label class="block mb-1">Escolha a Cor</label>
                <div id="cores-fixas" class="flex gap-2 flex-wrap">
                  <div class="grid grid-cols-5 gap-4 mt-4">
                    <% cores = {
                      "Vermelho" => "#EF4444", 
                      "Azul" => "#3B82F6",
                      "Verde" => "#22C55E",
                      "Amarelo" => "#EAB308",
                      "Roxo" => "#A855F7",
                      "Rosa" => "#EC4899",
                      "Laranja" => "#F97316",
                      "Indigo" => "#6366F1",
                      "Esmeralda" => "#10B981",
                      "Teal" => "#14B8A6",
                      "Violeta" => "#8B5CF6",
                      "Ciano" => "#06B6D4",
                      "Ambar" => "#F59E0B",
                      "Rose" => "#F9A8D4",
                      "Cinza" => "#6B7280"
                    } %>

                    <% cores.each do |nome, hex| %>
                      <label class="flex flex-col items-center cursor-pointer group">
                        <span class="w-8 h-8 rounded-full border-2 border-gray-300 block transition" 
                              data-cor="<%= hex %>" 
                              style="background-color: <%= hex %>"></span>
                        <p class="text-xs text-gray-700 mt-1 group-hover:text-black"><%= nome %></p>
                      </label>
                    <% end %>

                    <label class="flex flex-col items-center cursor-pointer relative">
                      <!-- input escondido apenas para color picker -->
                      <input type="color" id="color-picker" class="absolute w-10 h-10 opacity-0 cursor-pointer">

                      <!-- bolinha custom -->
                      <span id="custom-color" 
                            class="w-10 h-10 rounded-full border border-gray-300 shadow-sm transition flex items-center justify-center"
                            style="background-color: <%= @disciplina.cor || '#ffffff' %>;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                      </span>

                      <!-- preview HEX -->
                      <span id="color-hex-preview" class="text-gray-600 text-sm font-mono mt-1">
                        <%= @disciplina.cor || "#ffffff" %>
                      </span>
                    </label>
                  </div>
                </div>
              </div>

              <div class="flex justify-end gap-2">
                <button type="button" id="cancelar-btn-area" class="px-4 py-2 bg-gray-300 rounded-lg">Cancelar</button>
                <button type="button" id="salvar-btn-area" class="px-4 py-2 bg-green-500 text-white rounded-lg">Salvar</button>
              </div>
            </div>
          </dialog>


          <%= form.hidden_field :cor_nome, id: "disciplina-cor-nome" %>

          <%= form.hidden_field :nome, id: "disciplina-nome" %>

          <dialog id="modal-nome" class="modal">
            <div class="modal-box bg-white rounded-lg p-6 w-full max-w-md">
              <h3 class="text-lg font-bold mb-4">Definir Nome</h3>

              <div class="mb-4">
                <label class="block mb-1">Nome</label>
                <input 
                  type="text" 
                  id="input-nome" 
                  class="w-full border px-3 py-2 rounded-lg" 
                  placeholder="Digite o nome"
                  value="<%= @disciplina.nome %>"
                >
              </div>

              <div class="mb-4">
                <label class="block mb-1">Escolha a Cor</label>
                <div id="cores-nome" class="flex gap-2 flex-wrap">
                  <div class="grid grid-cols-5 gap-4 mt-4">
                    <% cores = {
                      "Vermelho" => "#EF4444", 
                      "Azul" => "#3B82F6",
                      "Verde" => "#22C55E",
                      "Amarelo" => "#EAB308",
                      "Roxo" => "#A855F7",
                      "Rosa" => "#EC4899",
                      "Laranja" => "#F97316",
                      "Indigo" => "#6366F1",
                      "Esmeralda" => "#10B981",
                      "Teal" => "#14B8A6",
                      "Violeta" => "#8B5CF6",
                      "Ciano" => "#06B6D4",
                      "Ambar" => "#F59E0B",
                      "Rose" => "#F9A8D4",
                      "Cinza" => "#6B7280"
                    } %>

                    <% cores.each do |nome, hex| %>
                      <label class="flex flex-col items-center cursor-pointer group">
                        <span class="w-8 h-8 rounded-full border-2 border-gray-300 block transition" 
                              data-cor="<%= hex %>" 
                              style="background-color: <%= hex %>"></span>
                        <p class="text-xs text-gray-700 mt-1 group-hover:text-black"><%= nome %></p>
                      </label>
                    <% end %>

                    <label class="flex flex-col items-center cursor-pointer relative">
                      <input type="color" id="color-picker-nome" class="absolute w-10 h-10 opacity-0 cursor-pointer">
                      <span id="custom-color-nome" 
                            class="w-10 h-10 rounded-full border border-gray-300 shadow-sm transition flex items-center justify-center"
                            style="background-color: #ffffff;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                      </span>
                      <span id="color-hex-preview-nome" class="text-gray-600 text-sm font-mono mt-1">#ffffff</span>
                    </label>
                  </div>
                </div>
              </div>

              <div class="flex justify-end gap-2">
                <button type="button" id="cancelar-btn-nome" class="px-4 py-2 bg-gray-300 rounded-lg">Cancelar</button>
                <button type="button" id="salvar-btn-nome" class="px-4 py-2 bg-green-500 text-white rounded-lg">Salvar</button>
              </div>
            </div>
          </dialog>

        </div>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
    <div class="flex justify-between">
      <%= link_to "Cancelar", disciplinas_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      <%= form.submit @disciplina&.persisted? ? "Atualizar disciplina" : "Criar disciplina", class: "bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  </div>
<% end %>


<script>
document.addEventListener("turbo:load", function() {
  console.log("DEBUG: JS iniciado");

  // ==============================
  // EVITAR MÚLTIPLA INICIALIZAÇÃO
  // ==============================
  if (window.modalAreaInit) return;
  window.modalAreaInit = true;

  // ==============================
  // ELEMENTOS MODAL ESCOLA
  // ==============================
  const btnAbrirEscola = document.getElementById("abrir-modal-escola-btn");
  const modalEscola = document.getElementById("modal-escola");
  const btnFecharEscola = document.getElementById("fechar-modal-escola");
  const filtroNome = document.getElementById("filtro-nome-escola");
  const filtroTipo = document.getElementById("filtro-tipo-escola");
  const listaEscolas = document.getElementById("lista-escolas");
  const escolaHidden = document.getElementById("escola_id");

  console.log("DEBUG: Elementos modal escola", {btnAbrirEscola, modalEscola, btnFecharEscola, filtroNome, filtroTipo, listaEscolas, escolaHidden});

  if (btnAbrirEscola && modalEscola) {
    btnAbrirEscola.addEventListener("click", () => {
      console.log("DEBUG: Abrindo modal escola");
      modalEscola.showModal();
      buscarEscolas();
    });

    if (btnFecharEscola) btnFecharEscola.addEventListener("click", () => modalEscola.close());

    modalEscola.addEventListener("click", (event) => {
      const rect = modalEscola.querySelector(".modal-box").getBoundingClientRect();
      if (!(event.clientX >= rect.left && event.clientX <= rect.right &&
            event.clientY >= rect.top && event.clientY <= rect.bottom)) {
        modalEscola.close();
      }
    });
  }

  let timeoutBusca = null;
  function buscarEscolas() {
    const nome = filtroNome ? filtroNome.value.trim().toLowerCase() : "";
    const tipo = filtroTipo ? filtroTipo.value.toLowerCase() : "";
    clearTimeout(timeoutBusca);
    timeoutBusca = setTimeout(() => {
      fetch(`/disciplinas/buscar_escolas.json?escola_busca=${nome}&tipo=${tipo}`, { headers: { "Accept": "application/json" } })
        .then(res => res.json())
        .then(data => {
          if (!listaEscolas) return;
          listaEscolas.innerHTML = "";
          const escolas = data.escolas || [];
          if (escolas.length === 0) {
            listaEscolas.innerHTML = "<p class='px-3 py-2 text-gray-500 text-center'>Nenhuma escola encontrada</p>";
            return;
          }
          escolas.forEach(e => {
            const card = document.createElement("div");
            card.className = "p-3 mb-2 rounded-lg shadow hover:shadow-lg cursor-pointer flex justify-between items-center transition bg-white border border-gray-200 hover:bg-green-50";
            card.innerHTML = `
              <div>
                <p class="font-semibold text-gray-800 border-b-2 border-green-500 pb-1 mb-1">${e.nome}</p>
                <p class="text-sm text-gray-500">${e.tipo ? e.tipo.charAt(0).toUpperCase() + e.tipo.slice(1) : ''}</p>
              </div>
            `;
            card.addEventListener("click", () => {
              if (escolaHidden) escolaHidden.value = e.id;
              if (btnAbrirEscola) btnAbrirEscola.textContent = e.nome;
              if (modalEscola) modalEscola.close();
              console.log("DEBUG: Escola selecionada", {id: e.id, nome: e.nome, escolaHidden: escolaHidden ? escolaHidden.value : null});
            });
            listaEscolas.appendChild(card);
          });
        })
        .catch(() => {
          if (listaEscolas) listaEscolas.innerHTML = "<p class='px-3 py-2 text-red-500 text-center'>Erro ao buscar escolas</p>";
        });
    }, 300);
  }
  if (filtroNome) filtroNome.addEventListener("input", buscarEscolas);
  if (filtroTipo) filtroTipo.addEventListener("change", buscarEscolas);

  // ==============================
  // MODAL ÁREA / COR
  // ==============================
  const select = document.getElementById("area-select");
  const modalArea = document.getElementById("modal-area");
  const cancelarBtnArea = document.getElementById("cancelar-btn-area");
  const salvarBtnArea = document.getElementById("salvar-btn-area");

  if (!select || !modalArea || !cancelarBtnArea || !salvarBtnArea) return;

  const corHidden = document.getElementById("disciplina-cor");
  const coresFixas = document.querySelectorAll("#cores-fixas span[data-cor]");
  const inputCorCustom = document.getElementById("color-picker");
  const bolinhaCustom = document.getElementById("custom-color");
  const previewHex = document.getElementById("color-hex-preview");

  console.log("DEBUG: Elementos modal área", {select, modalArea, cancelarBtnArea, salvarBtnArea});
  console.log("DEBUG: Elementos cores", {corHidden, coresFixas, inputCorCustom, bolinhaCustom, previewHex});

  let corSelecionada = null;
  console.log("DEBUG: corSelecionada inicial", corSelecionada);

  // ==============================
  // Abrir modal "nova_area"
  // ==============================
  select.addEventListener("change", (e) => {
    if (!e.target) return;

    console.log("DEBUG: select mudou", e.target.value);

    if (e.target.value === "nova_area") {
      console.log("DEBUG: Abrindo modal nova área");
      modalArea.showModal();
    } else {
      const option = e.target.options[e.target.selectedIndex];
      if (option && option.dataset && option.dataset.cor) {
        corSelecionada = option.dataset.cor;
        if (corHidden) corHidden.value = corSelecionada;
        corHidden.dispatchEvent(new Event('input', { bubbles: true }));
        console.log("DEBUG: Área existente selecionada", corSelecionada, "hidden.value:", corHidden.value);
      }
    }
  });

  // ==============================
  // Cores fixas
  // ==============================
  coresFixas.forEach(c => {
    c.addEventListener("click", () => {
      corSelecionada = c.dataset.cor;
      if (corHidden) corHidden.value = corSelecionada;
      corHidden.dispatchEvent(new Event('input', { bubbles: true }));

      const radio = c.previousElementSibling;
      if (radio) radio.checked = true;

      resetBordas();
      c.style.borderColor = "#000000";

      console.log("DEBUG: Cor fixa clicada", corSelecionada, "hidden.value:", corHidden.value);
    });
  });

  // ==============================
  // Cor custom
  // ==============================
  if (inputCorCustom && bolinhaCustom && previewHex) {
    bolinhaCustom.addEventListener("click", () => inputCorCustom.click());
    inputCorCustom.addEventListener("input", () => {
      corSelecionada = inputCorCustom.value;
      if (corHidden) corHidden.value = corSelecionada;
      corHidden.dispatchEvent(new Event('input', { bubbles: true }));
      bolinhaCustom.style.backgroundColor = corSelecionada;
      previewHex.textContent = corSelecionada;
      resetBordas();

      console.log("DEBUG: Cor custom selecionada", corSelecionada, "hidden.value:", corHidden.value);
    });
  }

  // ==============================
  // Cancelar modal
  // ==============================
  cancelarBtnArea.addEventListener("click", () => {
    modalArea.close();
    select.value = "";
    corSelecionada = null;
    resetBordas();
    console.log("DEBUG: Modal área cancelado");
  });

  // ==============================
  // Salvar nova área
  // ==============================
  salvarBtnArea.addEventListener("click", () => {
    const nomeEl = document.getElementById("nova-area-nome");
    const nome = nomeEl ? nomeEl.value.trim() : "";
    if (!nome) { alert("Digite o nome da nova área"); return; }

    const novaCor = corSelecionada || "#FFFFFF";

    if (select) {
      const option = document.createElement("option");
      option.value = nome;
      option.textContent = nome;
      option.selected = true;
      option.dataset.cor = novaCor; // garante que a cor seja preservada
      select.appendChild(option);
    }

    if (corHidden) corHidden.value = novaCor;
    corHidden.dispatchEvent(new Event('input', { bubbles: true }));

    modalArea.close();
    if (nomeEl) nomeEl.value = "";
    corSelecionada = null;
    resetBordas();

    console.log("DEBUG: Salvando nova área", { nome, finalCor: novaCor, corHiddenValue: corHidden ? corHidden.value : null });
  });

  // ==============================
  // Fechar modal clicando fora
  // ==============================
  modalArea.addEventListener("click", (event) => {
    const box = modalArea.querySelector(".modal-box");
    if (!box) return;
    const rect = box.getBoundingClientRect();
    if (!(event.clientX >= rect.left && event.clientX <= rect.right &&
          event.clientY >= rect.top && event.clientY <= rect.bottom)) {
      modalArea.close();
      select.value = "";
      corSelecionada = null;
      resetBordas();
      console.log("DEBUG: Modal área fechado clicando fora");
    }
  });

  function resetBordas() {
    coresFixas.forEach(c => c.style.borderColor = "#D1D5DB");
    if (bolinhaCustom) bolinhaCustom.style.borderColor = "#D1D5DB";
  }

  // ==============================
  // MODAL NOME
  // ==============================
  const abrirModalNomeBtn = document.getElementById("abrir-modal-nome");
  const modalNome = document.getElementById("modal-nome");
  const cancelarBtnNome = document.getElementById("cancelar-btn-nome");
  const salvarBtnNome = document.getElementById("salvar-btn-nome");
  const inputNome = document.getElementById("input-nome");
  const nomeSelecionado = document.getElementById("nome-selecionado");

  if (abrirModalNomeBtn && modalNome) {
    // Abrir modal
    abrirModalNomeBtn.addEventListener("click", () => {
      modalNome.showModal();
    });

    // Cancelar
    if (cancelarBtnNome) {
      cancelarBtnNome.addEventListener("click", () => {
        modalNome.close();
      });
    }

    // Salvar
    if (salvarBtnNome && inputNome && nomeSelecionado) {
      salvarBtnNome.addEventListener("click", () => {
        const novoNome = inputNome.value.trim();
        if (novoNome !== "") {
          nomeSelecionado.textContent = novoNome;

          // Atualiza hidden_field se existir (para enviar no submit)
          const hiddenNome = document.getElementById("disciplina-nome");
          if (hiddenNome) {
            hiddenNome.value = novoNome;
            hiddenNome.dispatchEvent(new Event("input", { bubbles: true }));
          }
        }
        modalNome.close();
      });
    }

    // Fechar clicando fora do modal
    modalNome.addEventListener("click", (event) => {
      const box = modalNome.querySelector(".modal-box");
      if (!box) return;
      const rect = box.getBoundingClientRect();
      if (!(event.clientX >= rect.left && event.clientX <= rect.right &&
            event.clientY >= rect.top && event.clientY <= rect.bottom)) {
        modalNome.close();
      }
    });
  }

    // ==============================
  // SELEÇÃO DE CORES DO MODAL NOME
  // ==============================
  const coresFixasNome = document.querySelectorAll("#cores-nome span[data-cor]");
  const inputCorCustomNome = document.getElementById("color-picker-nome");
  const bolinhaCustomNome = document.getElementById("custom-color-nome");
  const previewHexNome = document.getElementById("color-hex-preview-nome");
  let corSelecionadaNome = null;

  if (coresFixasNome.length > 0) {
    coresFixasNome.forEach(c => {
      c.addEventListener("click", () => {
        corSelecionadaNome = c.dataset.cor;
        resetBordasNome();
        c.style.borderColor = "#000";
        previewHexNome.textContent = corSelecionadaNome;
        if (bolinhaCustomNome) bolinhaCustomNome.style.borderColor = "#D1D5DB";
      });
    });
  }

  if (inputCorCustomNome && bolinhaCustomNome && previewHexNome) {
    bolinhaCustomNome.addEventListener("click", () => inputCorCustomNome.click());
    inputCorCustomNome.addEventListener("input", () => {
      corSelecionadaNome = inputCorCustomNome.value;
      bolinhaCustomNome.style.backgroundColor = corSelecionadaNome;
      previewHexNome.textContent = corSelecionadaNome;
      resetBordasNome();
    });
  }

  function resetBordasNome() {
    coresFixasNome.forEach(c => c.style.borderColor = "#D1D5DB");
    if (bolinhaCustomNome) bolinhaCustomNome.style.borderColor = "#D1D5DB";
  }

  // Integrar cor ao salvar
  if (salvarBtnNome) {
    salvarBtnNome.addEventListener("click", () => {
      const hiddenCorNome = document.getElementById("disciplina-cor-nome");
      if (hiddenCorNome && corSelecionadaNome) {
        hiddenCorNome.value = corSelecionadaNome;
        hiddenCorNome.dispatchEvent(new Event("input", { bubbles: true }));
      }
    });
  }

  document.querySelectorAll("dialog").forEach(modal => {
  modal.addEventListener("keydown", (event) => {
    if (event.key === "Enter") {
      event.preventDefault(); // bloqueia submit automático
      event.stopPropagation();

      // encontra o botão "Salvar" dentro do modal
      const salvarBtn = modal.querySelector("button[id^='salvar-btn']");
      if (salvarBtn) {
        salvarBtn.click(); // simula o clique
        console.log("DEBUG: Enter acionou botão Salvar do modal", modal.id);
      }
    }
  });
});

document.getElementById("salvar-btn-nome").addEventListener("click", () => {
  const valor = document.getElementById("input-nome").value;
  document.getElementById("disciplina-nome").value = valor;
});

});


</script>


