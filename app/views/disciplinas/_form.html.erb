<%= form_with(model: @disciplina, class: "bg-white rounded-lg shadow-sm border border-gray-200") do |form| %>
  <% if @disciplina&.errors&.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800">Erro ao salvar!</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @disciplina.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Header -->
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">
      <%= @disciplina&.persisted? ? "Editar disciplina" : "Nova disciplina" %>
    </h2>
    <p class="mt-1 text-sm text-gray-600">
      <%= @disciplina&.persisted? ? "Atualize as informações abaixo." : "Preencha os dados da disciplina abaixo." %>
    </p>
  </div>

  <!-- Form Body -->
  <div class="px-6 py-6">
    <h3 class="text-base font-medium text-gray-900 mb-4">Informações Básicas</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Nome -->
      <div>
        <%= form.label :nome, "Nome *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :nome, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", placeholder: "Ex: Matemática", required: true %>
      </div>

      <!-- Área -->
      <div>
        <%= form.label :area, "Área da Disciplina", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :area, 
          Disciplina.areas.keys.map { |a| [a.titleize, a] }, 
          { prompt: "Selecione a área" }, 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" %>
      </div>
    </div>

    <!-- Filtros Escola / Professor -->
    <% if current_user.is_a?(SuperAdmin) %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <!-- Escola -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Escola *</label>
          <input 
            type="text" 
            id="escola_input" 
            placeholder="Buscar escola para inserir a disciplina"
            autocomplete="off"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
          <%= form.hidden_field :escola_id, id: "escola_id" %>
          <div id="escolas_results" class="absolute rounded bg-white max-h-60 overflow-auto mt-1"></div>
        </div>

        <!-- Professores -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Professores *</label>
          <input 
            type="text" 
            id="professor_input" 
            placeholder="Buscar professor para atribuir a disciplina" 
            autocomplete="off"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
          <%= hidden_field_tag "disciplina[professor_ids][]", nil, id: "professor_id" %>
          <div id="professors_results" class="absolute rounded bg-white max-h-60 overflow-auto mt-1"></div>
        </div>
      </div>
    <% else %>
      <!-- Admin: apenas Professor -->
      <div class="grid grid-cols-1 gap-6 mt-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Professores *</label>
          <input 
            type="text" 
            id="professor_input" 
            placeholder="Buscar professor para atribuir a disciplina" 
            autocomplete="off"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
          <%= hidden_field_tag "disciplina[professor_ids][]", nil, id: "professor_id" %>
          <div id="professors_results" class="absolute rounded bg-white max-h-60 overflow-auto mt-1"></div>
        </div>
        <!-- Escola é fixo via hidden -->
        <%= form.hidden_field :escola_id, value: current_user.escolas.first.id, id: "escola_id" %>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
    <div class="flex justify-between">
      <%= link_to "Cancelar", disciplinas_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      <%= form.submit @disciplina&.persisted? ? "Atualizar disciplina" : "Criar disciplina", class: "bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  </div>
<% end %>


<script>
document.addEventListener("turbo:load", function() {
  // --- ESCOLAS (apenas SuperAdmin) ---
  const escolaInput = document.getElementById("escola_input");
  const escolaHidden = document.getElementById("escola_id");

  if (escolaInput) {
    const escolaResults = document.getElementById("escolas_results");
    let timeoutEscola = null;

    escolaInput.addEventListener("input", function() {
      const query = escolaInput.value.trim();
      if (!query) {
        escolaResults.innerHTML = "";
        escolaHidden.value = "";
        return;
      }

      clearTimeout(timeoutEscola);
      timeoutEscola = setTimeout(() => {
        fetch(`<%= new_disciplina_path %>?escola_busca=${encodeURIComponent(query)}`, { headers: { "Accept": "application/json" } })
          .then(res => res.json())
          .then(data => {
            escolaResults.innerHTML = "";
            const escolas = data.escolas || [];
            if (escolas.length === 0) {
              escolaResults.innerHTML = "<p class='px-3 py-2 text-gray-500'>Nenhuma escola encontrada</p>";
              return;
            }

            escolas.forEach(escola => {
              const div = document.createElement("div");
              div.textContent = escola.nome;
              div.classList.add("px-3", "py-2", "cursor-pointer", "hover:bg-green-200");

              div.addEventListener("click", () => {
                escolaInput.value = escola.nome;
                escolaHidden.value = escola.id;
                escolaResults.innerHTML = "";

                // Limpa professores ao mudar a escola
                const professorInput = document.getElementById("professor_input");
                const professorHidden = document.getElementById("professor_id");
                const professorResults = document.getElementById("professors_results");
                if (professorInput && professorHidden && professorResults) {
                  professorInput.value = "";
                  professorHidden.value = "";
                  professorResults.innerHTML = "";
                }
              });

              escolaResults.appendChild(div);
            });
          });
      }, 200);
    });
  }

  // --- PROFESSORES ---
  const professorInput = document.getElementById("professor_input");
  const professorHidden = document.getElementById("professor_id");
  const professorResults = document.getElementById("professors_results");

  if (professorInput && professorHidden && professorResults) {
    let timeoutProfessor = null;

    professorInput.addEventListener("input", function() {
      const query = professorInput.value.trim();
      const escolaHidden = document.getElementById("escola_id");
      const escolaId = escolaHidden ? escolaHidden.value : null;

      // Exclusivo: só busca se escolaId estiver definido
      if (!query || !escolaId) {
        professorResults.innerHTML = "<p class='px-3 py-2 text-gray-500'>Selecione uma escola primeiro</p>";
        professorHidden.value = "";
        return;
      }

      clearTimeout(timeoutProfessor);
      timeoutProfessor = setTimeout(() => {
        const url = `<%= new_disciplina_path %>?professor_busca=${encodeURIComponent(query)}&escola_id=${escolaId}`;
        fetch(url, { headers: { "Accept": "application/json" } })
          .then(res => res.json())
          .then(data => {
            professorResults.innerHTML = "";
            const professores = data.professores || [];
            if (professores.length === 0) {
              professorResults.innerHTML = "<p class='px-3 py-2 text-gray-500'>Nenhum professor encontrado</p>";
              return;
            }

            professores.forEach(professor => {
              const div = document.createElement("div");
              div.textContent = professor.nome;
              div.classList.add("px-3", "py-2", "cursor-pointer", "hover:bg-green-200");

              div.addEventListener("click", () => {
                professorInput.value = professor.nome;
                professorHidden.value = professor.id;
                professorResults.innerHTML = "";
              });

              professorResults.appendChild(div);
            });
          });
      }, 200);
    });
  }
});

</script>
