<div class="drawer lg:drawer-open bg-gray-100">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    
    <div class="w-full p-4">
      <div class="flex items-center mb-6 lg:hidden">
        <label for="my-drawer" class="btn btn-square btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </label>
        <h1 class="text-xl font-bold ml-2"><%= @ano_letivo.persisted? ? "Editar Ano Letivo" : "Novo Ano Letivo" %></h1>
      </div>

      <main class="w-full max-w-4xl mx-auto">
        <%# INSERÇÃO DO BREADCRUMB %>
        <div class="text-sm breadcrumbs mb-4">
          <ul>
            <li><%= link_to "Escolas", escolas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li><%= link_to @escola.nome, escola_path(@escola), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li><%= link_to @ano_letivo.ano, escola_ano_letivo_path(@escola, @ano_letivo), class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li class="text-gray-600">Editar</li>
          </ul>
        </div>

      </main>
    </div>

  </div>
</div> 
