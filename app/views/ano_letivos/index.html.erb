<% content_for :title, "Ano Letivos" %>

<div class="drawer lg:drawer-open bg-gradient-to-br from-slate-50 via-green-50 to-teal-50 min-h-screen">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    <div class="w-full p-4">
      <!-- Mobile Header with Gradient -->
      <div class="flex items-center mb-6 lg:hidden bg-gradient-to-r from-blue-500 to-green-500 text-white rounded-2xl p-4 shadow-lg">
        <label for="my-drawer" class="btn btn-square btn-ghost text-white hover:bg-white/20 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <h1 class="text-base sm:text-lg font-bold ml-2 truncate min-w-0">Ano Letivos</h1>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <!-- Breadcrumbs -->
        <div class="breadcrumbs text-sm mb-6">
          <ul class="bg-white/60 backdrop-blur-sm rounded-full px-6 py-3 shadow-lg border border-white/20">
            <li><%= link_to "Escolas", escolas_menager_paths, class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %></li>
            <% if @escola %>
              <li><%= link_to @escola.nome, escola_path(@escola), class: "text-blue-600 hover:text-blue-800 font-medium transition-colors" %></li>
            <% end %>
            <li class="text-slate-500 font-medium">Anos Letivos</li>
          </ul>
        </div>

        <!-- Success Alert -->
        <% if notice.present? %>
          <div class="alert bg-gradient-to-r from-green-600 to-green-700 text-white border-0 shadow-xl mb-6 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="font-medium"><%= notice %></span>
          </div>
        <% end %>

        <!-- Premium Card Container -->
        <div class="bg-white/80 backdrop-blur-sm p-4 sm:p-6 lg:p-8 rounded-3xl shadow-2xl border border-white/20">
          <div class="bg-gradient-to-r from-blue-500 to-green-500 text-white rounded-2xl p-6 mb-8 shadow-xl">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              <div class="flex flex-col items-start space-y-2 flex-grow min-w-0">
                <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold break-words">Anos Letivos</h1>
                <div class="badge badge-lg bg-blue-400 text-white border-white/30 font-semibold">
                  <%= @ano_letivos&.count || 0 %> <%= (@ano_letivos&.count || 0) == 1 ? 'ano letivo' : 'anos letivos' %>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto flex-shrink-0">
                <%= link_to new_escola_ano_letivo_path(@escola), class: "btn btn-sm sm:btn-md bg-white text-green-700 hover:bg-green-50 border-0 shadow-lg hover:scale-105 transition-all duration-300 whitespace-nowrap text-xs sm:text-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 sm:w-5 sm:h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  <span class="hidden sm:inline">Criar Ano Letivo</span>
                  <span class="sm:hidden">Criar</span>
                <% end %>
              </div>
            </div>
          </div>

          <% if @ano_letivos.blank? %>
            <!-- Empty State -->
            <div class="text-center py-16 bg-gradient-to-br from-slate-50 to-green-50 rounded-3xl border-2 border-dashed border-slate-200">
              <div class="max-w-md mx-auto">
                <div class="text-6xl mb-4">📅</div>
                <h3 class="text-2xl font-bold text-slate-700 mb-2">Nenhum ano letivo encontrado</h3>
                <p class="text-slate-500 mb-6">Não existem anos letivos cadastrados para esta escola.</p>
                <%= link_to new_escola_ano_letivo_path(@escola), class: "btn btn-lg bg-gradient-to-r from-green-600 to-green-700 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 rounded-full" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mr-2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  Criar Primeiro Ano Letivo
                <% end %>
              </div>
            </div>
          <% else %>
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
              <table class="table w-full shadow-xl rounded-xl overflow-hidden">
                <thead>
                  <tr class="bg-gradient-to-r from-blue-500 to-green-500 text-white">
                    <th class="py-3 font-bold text-sm rounded-tl-xl">ANO</th>
                    <th class="py-3 font-bold text-sm">INÍCIO</th>
                    <th class="py-3 font-bold text-sm">FIM</th>
                    <th class="py-3 font-bold text-sm rounded-tr-xl">AÇÕES</th>
                  </tr>
                </thead>
                <tbody class="bg-white">
                  <% @ano_letivos.each do |ano| %>
                    <tr class="hover:bg-gray-50/50 transition-all duration-300 border-b border-gray-200 group">
                      <td class="py-4">
                        <span class="font-semibold text-slate-700"><%= ano.ano %></span>
                      </td>
                      <td>
                        <span class="text-slate-600"><%= ano.data_inicio %></span>
                      </td>
                      <td>
                        <span class="text-slate-600"><%= ano.data_fim %></span>
                      </td>
                      <td>
                        <div class="flex gap-2 opacity-70 group-hover:opacity-100 transition-all duration-300">
                          <%= link_to escola_ano_letivo_path(@escola, ano), class: "btn btn-sm btn-circle text-green-500 border-0 hover:scale-108 transition-all duration-300 shadow-lg", title: "Ver ano letivo" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                          <% end %>

                          <%= link_to edit_escola_ano_letivo_path(@escola, ano), class: "btn btn-sm btn-circle text-amber-500 border-0 hover:scale-108 transition-all duration-300 shadow-lg", title: "Editar ano letivo" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                            </svg>
                          <% end %>

                          <%= button_to escola_ano_letivo_path(@escola, ano), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este ano letivo?" }, class: "btn btn-sm btn-circle text-red-500 border-0 hover:scale-108 transition-all duration-300 shadow-lg", title: "Deletar ano letivo" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <!-- Mobile Cards -->
            <div class="grid grid-cols-1 gap-4 md:hidden">
              <% @ano_letivos.each do |ano| %>
                <div class="bg-white shadow-xl hover:shadow-2xl transition-all duration-300 overflow-visible rounded-lg border border-gray-100">
                  <div class="card-body p-4">
                    <!-- Header -->
                    <div class="flex justify-between items-start gap-2">
                      <div class="min-w-0 flex-1">
                        <h2 class="font-bold text-slate-700 text-lg break-words"><%= ano.ano %></h2>
                        <div class="divider my-2"></div>
                        <div class="flex flex-col gap-1">
                          <p class="text-sm text-gray-600"><strong>Início:</strong> <%= ano.data_inicio %></p>
                          <p class="text-sm text-gray-600"><strong>Fim:</strong> <%= ano.data_fim %></p>
                        </div>
                      </div>

                      <!-- Dropdown ações -->
                      <div class="dropdown dropdown-end flex-shrink-0">
                        <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                          </svg>
                        </label>

                        <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-white rounded-xl w-52 z-50 border border-gray-200">
                          <li>
                            <%= link_to escola_ano_letivo_path(@escola, ano), data: { turbo: false } do %>
                              <span class="flex items-center gap-2 text-emerald-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                Ver ano letivo
                              </span>
                            <% end %>
                          </li>

                          <li>
                            <%= link_to edit_escola_ano_letivo_path(@escola, ano), data: { turbo: false } do %>
                              <span class="flex items-center gap-2 text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
                                </svg>
                                Editar ano letivo
                              </span>
                            <% end %>
                          </li>

                          <li>
                            <%= button_to escola_ano_letivo_path(@escola, ano), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir?" } do %>
                              <span class="flex items-center gap-2 text-red-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                </svg>
                                Excluir ano letivo
                              </span>
                            <% end %>
                          </li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

        </div> <!-- end premium container -->
      </main>
    </div>
  </div>
</div>

<script>
  function validateDeleteConfirmation(anoLetivoId) {
    const confirmAnoInput = document.querySelector(`.confirm-ano-input[data-ano-letivo-id="${anoLetivoId}"]`);
    const deleteButton = document.getElementById(`delete-btn-${anoLetivoId}`);
    const anoLetivoAno = confirmAnoInput.getAttribute('data-ano-letivo-ano');

    if (confirmAnoInput.value.trim() === anoLetivoAno.trim()) {
      deleteButton.style.pointerEvents = 'auto';
      deleteButton.style.opacity = '1';
    } else {
      deleteButton.style.pointerEvents = 'none';
      deleteButton.style.opacity = '0.5';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const confirmAnoInputs = document.querySelectorAll('.confirm-ano-input');

    confirmAnoInputs.forEach(input => {
      input.addEventListener('input', () => {
        const anoLetivoId = input.getAttribute('data-ano-letivo-id');
        validateDeleteConfirmation(anoLetivoId);
      });
    });
  });
</script>