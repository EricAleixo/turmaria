<% 
  turbo_data = turbo_frame_request? ? { turbo_frame: "_top" } : { turbo: false }
%>

<%= form_with(model: [@escola, @ano_letivo], class: "bg-white p-8 rounded-lg shadow-md", data: turbo_data) do |form| %>
  <% if @ano_letivo.errors.any? %>
    <div class="alert alert-error mb-6">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>
          <h3 class="font-bold">Erro ao salvar!</h3>
          <ul class="list-disc list-inside">
            <% @ano_letivo.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </span>
      </div>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8 border-b pb-4">
    <h1 class="text-2xl font-bold text-gray-700">
      <%= @ano_letivo.persisted? ? "Editar Ano Letivo" : "Novo Ano Letivo" %>
    </h1>
  </div>

  <div class="form-control w-full mb-6">
    <%= form.label :ano, "Ano *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :ano, class: "input input-bordered w-full", placeholder: "Ex: 2025", required: true %>
  </div>

  <div class="form-control w-full mb-6">
    <%= form.label :data_inicio, "Data de Início *", class: "label label-text text-gray-600 font-semibold" %>
    <div class="relative">
      <%= form.text_field :data_inicio, 
          class: "input input-bordered w-full pr-10 datepicker-field", 
          placeholder: "dd/mm/aaaa", 
          required: true, 
          autocomplete: "off" %>
      <svg class="absolute right-3 top-1/2 transform -translate-y-1/2 h-5 w-5 text-gray-600 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
  </div>

  <div class="form-control w-full mb-6">
    <%= form.label :data_fim, "Data de Fim *", class: "label label-text text-gray-600 font-semibold" %>
    <div class="relative">
      <%= form.text_field :data_fim, 
          class: "input input-bordered w-full pr-10 datepicker-field",
          placeholder: "dd/mm/aaaa",
          required: true, 
          autocomplete: "off" %>
      <svg class="absolute right-3 top-1/2 transform -translate-y-1/2 h-5 w-5 text-gray-600 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
  </div>

  <div class="form-control w-full mb-6">
    <%= form.label :numero_bimestre, "Quantidade de Bimestres *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :numero_bimestre, class: "input input-bordered w-full", required: true %>
  </div>

  <div class="flex justify-between mt-10">
    <%= link_to "Voltar", request.referer.present? ? request.referer : [@escola, @ano_letivo], class: "btn btn-ghost" %>
    <%= form.submit @ano_letivo.persisted? ? "Atualizar" : "Criar Ano Letivo", class: "btn bg-green-500 hover:bg-green-600 text-white" %>
  </div>
<% end %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>

<script>
(function() {
  'use strict';
  
  const DatePicker = {
    instances: new Map(),
    
    // Destrói todas as instâncias
    destroyAll() {
      this.instances.forEach(instance => instance.destroy());
      this.instances.clear();
      
      // Remove calendários órfãos do DOM
      document.querySelectorAll('.flatpickr-calendar').forEach(cal => cal.remove());
    },
    
    // Inicializa os calendários
    init() {
      if (typeof flatpickr === 'undefined') return;
      
      document.querySelectorAll('.datepicker-field').forEach(input => {
        // Evita re-inicialização
        if (this.instances.has(input)) return;
        
        const instance = flatpickr(input, {
          locale: 'pt',
          dateFormat: 'd/m/Y',
          allowInput: true,
          disableMobile: true,
          monthSelectorType: 'static',
          
          onReady: (selectedDates, dateStr, instance) => {
            this.setupYearInput(instance);
            this.setupSwipeGestures(instance);
          },
          
          onChange: (selectedDates, dateStr, instance) => {
            if (selectedDates.length > 0) {
              setTimeout(() => instance.close(), 200);
            }
          }
        });
        
        this.instances.set(input, instance);
      });
    },
    
    // Configura input de ano customizado
    setupYearInput(instance) {
      const calendar = instance.calendarContainer;
      const yearContainer = calendar.querySelector('.flatpickr-current-month');
      const yearSpan = yearContainer?.querySelector('.cur-year');
      
      if (!yearSpan || yearContainer.querySelector('.year-input')) return;
      
      const input = document.createElement('input');
      input.type = 'number';
      input.value = yearSpan.textContent;
      input.className = 'year-input';
      
      const updateYear = () => {
        const year = parseInt(input.value, 10);
        if (!isNaN(year) && year > 1900 && year < 2100) {
          instance.currentYear = year;
          instance.redraw();
        }
      };
      
      input.addEventListener('change', updateYear);
      input.addEventListener('blur', updateYear);
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
          updateYear();
          input.blur();
        }
      });
      
      yearSpan.textContent = '';
      yearSpan.appendChild(input);
    },
    
    // Configura gestos de swipe
    setupSwipeGestures(instance) {
      const calendar = instance.calendarContainer;
      const monthView = calendar.querySelector('.flatpickr-days');
      
      if (!monthView) return;
      
      let startX = 0;
      let currentX = 0;
      let isDragging = false;
      const THRESHOLD = 50;
      
      const changeMonth = (direction) => {
        const offset = direction === 'next' ? 1 : -1;
        monthView.style.transition = 'transform 0.25s ease';
        monthView.style.transform = `translateX(${offset * -100}%)`;
        
        setTimeout(() => {
          instance.currentMonth += offset;
          instance.redraw();
          monthView.style.transition = 'none';
          monthView.style.transform = `translateX(${offset * 100}%)`;
          requestAnimationFrame(() => {
            monthView.style.transition = 'transform 0.25s ease';
            monthView.style.transform = 'translateX(0)';
          });
        }, 250);
      };
      
      // Touch events
      const handleTouchStart = e => {
        startX = e.touches[0].clientX;
        isDragging = true;
        monthView.style.transition = 'none';
      };
      
      const handleTouchMove = e => {
        if (!isDragging) return;
        currentX = e.touches[0].clientX - startX;
        monthView.style.transform = `translateX(${currentX * 0.3}px)`;
      };
      
      const handleTouchEnd = () => {
        if (!isDragging) return;
        isDragging = false;
        monthView.style.transition = 'transform 0.25s ease';
        
        if (Math.abs(currentX) > THRESHOLD) {
          changeMonth(currentX > 0 ? 'prev' : 'next');
        } else {
          monthView.style.transform = 'translateX(0)';
        }
      };
      
      monthView.addEventListener('touchstart', handleTouchStart, { passive: true });
      monthView.addEventListener('touchmove', handleTouchMove, { passive: true });
      monthView.addEventListener('touchend', handleTouchEnd);
      
      // Sobrescreve os event listeners padrão das setas
      const prevBtn = calendar.querySelector('.flatpickr-prev-month');
      const nextBtn = calendar.querySelector('.flatpickr-next-month');
      
      if (prevBtn) {
        // Remove todos os event listeners anteriores clonando o elemento
        const newPrevBtn = prevBtn.cloneNode(true);
        prevBtn.parentNode.replaceChild(newPrevBtn, prevBtn);
        
        newPrevBtn.addEventListener('click', e => {
          e.preventDefault();
          e.stopPropagation();
          changeMonth('prev');
        });
      }
      
      if (nextBtn) {
        // Remove todos os event listeners anteriores clonando o elemento
        const newNextBtn = nextBtn.cloneNode(true);
        nextBtn.parentNode.replaceChild(newNextBtn, nextBtn);
        
        newNextBtn.addEventListener('click', e => {
          e.preventDefault();
          e.stopPropagation();
          changeMonth('next');
        });
      }
    }
  };
  
  // Event listeners do Turbo
  const events = {
    'turbo:before-frame-render': () => DatePicker.destroyAll(),
    'turbo:submit-start': () => DatePicker.destroyAll(),
    'turbo:before-visit': () => DatePicker.destroyAll(),
    'turbo:frame-load': () => setTimeout(() => DatePicker.init(), 50),
    'turbo:load': () => DatePicker.init()
  };
  
  Object.entries(events).forEach(([event, handler]) => {
    document.addEventListener(event, handler);
  });
  
  // Aguarda carregamento do Flatpickr
  const waitForFlatpickr = setInterval(() => {
    if (typeof flatpickr !== 'undefined') {
      DatePicker.init();
      clearInterval(waitForFlatpickr);
    }
  }, 100);
})();
</script>

<style>
/* === CALENDÁRIO BASE === */
.flatpickr-calendar {
  background: white;
  border-radius: 1rem;
  box-shadow: 0 20px 50px rgba(34, 197, 94, 0.18);
  max-width: 90vw;
  width: auto !important;
  z-index: 10000 !important;
}

/* === INPUT DE ANO === */
.year-input {
  border: 1px solid #22c55e;
  border-radius: 0.25rem;
  font-weight: 500;
  width: 4rem;
  text-align: center;
  padding: 0.25rem;
  transition: all 0.2s;
}

.year-input:hover,
.year-input:focus {
  border-color: #16a34a;
  box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2);
  outline: none;
}

/* Remove setas do input de ano */
.flatpickr-calendar .arrowUp,
.flatpickr-calendar .arrowDown {
  display: none !important;
}

/* === BOTÕES DE NAVEGAÇÃO === */
.flatpickr-prev-month,
.flatpickr-next-month {
  color: #22c55e !important;
  transition: all 0.2s;
}

.flatpickr-prev-month:hover,
.flatpickr-next-month:hover {
  color: #16a34a !important;
  transform: scale(1.1);
  background-color: rgba(34, 197, 94, 0.1);
}

.flatpickr-prev-month svg path,
.flatpickr-next-month svg path {
  stroke: currentColor !important;
  fill: none !important;
}

/* === DIAS === */
.flatpickr-day {
  border-radius: 50%;
  transition: all 0.2s;
}

.flatpickr-day:hover {
  background-color: rgba(34, 197, 94, 0.2);
  color: #14532d;
}

.flatpickr-day.selected,
.flatpickr-day.startRange,
.flatpickr-day.endRange {
  background-color: #22c55e !important;
  color: white !important;
  box-shadow: 0 2px 10px rgba(34, 197, 94, 0.4);
}

.flatpickr-day.today {
  border: 2px solid #22c55e;
  color: #16a34a;
  font-weight: 600;
}

.flatpickr-day.today.selected {
  background-color: #22c55e !important;
  color: white !important;
  border: none !important;
}

.flatpickr-day.disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* === SWIPE GESTURES === */
.flatpickr-days {
  transition: transform 0.25s ease;
  touch-action: pan-y;
  user-select: none;
}

/* === RESPONSIVO === */
@media (max-width: 768px) {
  .flatpickr-prev-month,
  .flatpickr-next-month {
    display: none !important;
  }
}
</style>