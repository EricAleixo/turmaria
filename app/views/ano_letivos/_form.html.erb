<% if turbo_frame_request? %>
  <%= form_with(model: [@escola, @ano_letivo], class: "bg-white p-8 rounded-lg shadow-md", data: { turbo_frame: "_top" }) do |form| %>
    <% if @ano_letivo.errors.any? %>
      <div class="alert alert-error mb-6">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>
            <h3 class="font-bold">Erro ao salvar!</h3>
            <ul class="list-disc list-inside">
              <% @ano_letivo.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </span>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between items-center mb-8 border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-700"><%= @ano_letivo.persisted? ? "Editar Ano Letivo" : "Novo Ano Letivo" %></h1>
    </div>

    <%= form.label :ano, "Ano *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :ano, class: "input input-bordered w-full", placeholder: "Ex: 2025", required: true %>

    <%= form.label :data_inicio, "Data de Início *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.text_field :data_inicio, class: "input input-bordered w-full datepicker", placeholder: "Selecione a data", required: true, autocomplete: "off" %>

    <%= form.label :data_fim, "Data de Fim *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.text_field :data_fim, class: "input input-bordered w-full datepicker", placeholder: "Selecione a data", required: true, autocomplete: "off" %>

    <%= form.label :numero_bimestre, "Quantidade de Bimestres *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :numero_bimestre, class: "input input-bordered w-full", required: true %>

    <div class="flex justify-between mt-10">
      <%= link_to "Voltar", request.referer.present? ? request.referer : [@escola, @ano_letivo], class: "btn btn-ghost" %>
      <%= form.submit @ano_letivo.persisted? ? "Atualizar" : "Criar Ano Letivo", class: "btn bg-green-500 hover:bg-green-600 text-white" %>
    </div>
  <% end %>
<% else %>
  <%= form_with(model: [@escola, @ano_letivo], class: "bg-white p-8 rounded-lg shadow-md", data: { turbo: false }) do |form| %>
    <% if @ano_letivo.errors.any? %>
      <div class="alert alert-error mb-6">
        <div>
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>
            <h3 class="font-bold">Erro ao salvar!</h3>
            <ul class="list-disc list-inside">
              <% @ano_letivo.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </span>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between items-center mb-8 border-b pb-4">
      <h1 class="text-2xl font-bold text-gray-700"><%= @ano_letivo.persisted? ? "Editar Ano Letivo" : "Novo Ano Letivo" %></h1>
    </div>

    <%= form.label :ano, "Ano *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :ano, class: "input input-bordered w-full", placeholder: "Ex: 2025", required: true %>

    <%= form.label :data_inicio, "Data de Início *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.text_field :data_inicio, class: "input input-bordered w-full datepicker", placeholder: "Selecione a data", required: true, autocomplete: "off" %>

    <%= form.label :data_fim, "Data de Fim *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.text_field :data_fim, class: "input input-bordered w-full datepicker", placeholder: "Selecione a data", required: true, autocomplete: "off" %>

    <%= form.label :numero_bimestre, "Quantidade de Bimestres *", class: "label label-text text-gray-600 font-semibold" %>
    <%= form.number_field :numero_bimestre, class: "input input-bordered w-full", required: true %>

    <div class="flex justify-between mt-10">
      <%= link_to "Voltar", request.referer.present? ? request.referer : [@escola, @ano_letivo], class: "btn btn-ghost" %>
      <%= form.submit @ano_letivo.persisted? ? "Atualizar" : "Criar Ano Letivo", class: "btn bg-green-500 hover:bg-green-600 text-white" %>
    </div>
  <% end %>
<% end %>




<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>


<script>
document.addEventListener("turbo:load", () => {
  // Remove qualquer calendário anterior
  document.querySelectorAll(".flatpickr-calendar").forEach(el => el.remove());

  flatpickr(".datepicker", {
    locale: "pt",
    dateFormat: "d/m/Y",
    allowInput: true,
    disableMobile: true,
    monthSelectorType: "static",

    onOpen(selectedDates, dateStr, instance) {
      if (selectedDates.length > 0) {
        instance.currentYear = selectedDates[0].getFullYear();
        instance.currentMonth = selectedDates[0].getMonth();
        instance.redraw();
      }
      const el = instance.calendarContainer;
      el.classList.add("fade-in", "swipe-hint");
      setTimeout(() => el.classList.remove("swipe-hint"), 1000);
      setTimeout(() => el.classList.remove("fade-in"), 300);
    },

    onChange(selectedDates, dateStr, instance) {
      if (selectedDates.length > 0) {
        setTimeout(() => instance.close(), 300);
      }
    },

    onReady(selectedDates, dateStr, instance) {
      const calendar = instance.calendarContainer;
      const monthView = calendar.querySelector(".flatpickr-days");

      // === Input de ano customizado ===
      const yearContainer = calendar.querySelector(".flatpickr-current-month");
      if (yearContainer && !yearContainer.querySelector("input")) {
        const yearSpan = yearContainer.querySelector(".cur-year");
        const input = document.createElement("input");
        input.type = "number";
        input.value = yearSpan.textContent;
        input.className = "flatpickr-year-input";
        input.style.width = "4rem";
        input.style.textAlign = "center";
        yearSpan.textContent = "";
        yearSpan.appendChild(input);

        const applyYearChange = () => {
          const newYear = parseInt(input.value, 10);
          if (!isNaN(newYear)) {
            instance.currentYear = newYear;
            instance.redraw();
          }
        };

        input.addEventListener("change", applyYearChange);
        input.addEventListener("blur", applyYearChange);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") { applyYearChange(); input.blur(); }
        });
      }

      // === Animação de mudança de mês ===
      let startX = 0, currentX = 0, isDragging = false, dragged = false;
      const threshold = 50, minDrag = 10;

      const animateMonth = (direction) => {
        const dir = direction === "right" ? 1 : -1; 
        monthView.style.transition = "transform 0.25s ease";
        monthView.style.transform = `translateX(${dir * 100}%)`;

        setTimeout(() => {
          instance.currentMonth += dir;
          instance.redraw();
          monthView.style.transition = "none";
          monthView.style.transform = `translateX(${-dir * 100}%)`;
          requestAnimationFrame(() => {
            monthView.style.transition = "transform 0.25s ease";
            monthView.style.transform = "translateX(0)";
          });
        }, 250);
      };

      // === Setas com animação (removendo comportamento interno do flatpickr) ===
      let prevBtn = calendar.querySelector(".flatpickr-prev-month");
      let nextBtn = calendar.querySelector(".flatpickr-next-month");

      if (prevBtn) prevBtn.replaceWith(prevBtn.cloneNode(true));
      if (nextBtn) nextBtn.replaceWith(nextBtn.cloneNode(true));

      prevBtn = calendar.querySelector(".flatpickr-prev-month");
      nextBtn = calendar.querySelector(".flatpickr-next-month");

      if (prevBtn) prevBtn.addEventListener("click", (e) => { e.preventDefault(); animateMonth("right"); });
      if (nextBtn) nextBtn.addEventListener("click", (e) => { e.preventDefault(); animateMonth("left"); });

      // === Swipe ===
      const startDrag = (x, target) => {
        if (target.closest(".flatpickr-prev-month") || target.closest(".flatpickr-next-month")) return;
        startX = x; currentX = 0; isDragging = true; dragged = false;
        monthView.style.transition = "none";
      };
      const moveDrag = (x) => {
        if (!isDragging) return;
        currentX = x - startX;
        if (Math.abs(currentX) > minDrag) { dragged = true; monthView.style.transform = `translateX(${currentX * 0.4}px)`; }
      };
      const endDrag = () => {
        if (!isDragging) return;
        isDragging = false;
        monthView.style.transition = "transform 0.25s ease";
        if (!dragged) { monthView.style.transform = "translateX(0)"; return; }
        if (Math.abs(currentX) > threshold) animateMonth(currentX > 0 ? "right" : "left");
        else monthView.style.transform = "translateX(0)";
      };
      ["touchstart", "mousedown"].forEach(evt => calendar.addEventListener(evt, (e) => startDrag(e.changedTouches ? e.changedTouches[0].screenX : e.clientX, e.target)));
      ["touchmove", "mousemove"].forEach(evt => calendar.addEventListener(evt, (e) => moveDrag(e.changedTouches ? e.changedTouches[0].screenX : e.clientX)));
      ["touchend", "mouseup", "mouseleave"].forEach(evt => calendar.addEventListener(evt, endDrag));

      // === Fechamento suave ===
      const calendarEl = instance.calendarContainer;
      const originalClose = instance.close;
      instance.close = function() {
        calendarEl.classList.add("closing");
        setTimeout(() => { originalClose.call(instance); calendarEl.classList.remove("closing"); }, 220);
      };
    },
  });
});
</script>


<style>
/* === ANIMAÇÕES GERAIS === */
@keyframes pulse { 0% { transform: scale(0.9); } 100% { transform: scale(1); } }
@keyframes hint-swipe { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 50% { transform: translateX(8px); } 75% { transform: translateX(-8px); } }

/* === CALENDÁRIO BASE === */
.flatpickr-calendar {
  background-color: #fff;
  border-radius: 1rem;
  box-shadow: 0 20px 50px rgba(34,197,94,0.18);
  transition: opacity 0.25s ease, transform 0.25s ease, background-color 0.2s ease;
  opacity: 0;
  transform: scale(0.96);
  max-width: 90vw;
  width: auto !important;
  will-change: opacity, transform;
}
.flatpickr-calendar.open, .flatpickr-calendar.fade-in[style] { opacity: 1 !important; transform: scale(1) !important; }
.flatpickr-calendar.closing { opacity: 0; transform: scale(0.95); }

/* === SWIPE === */
.flatpickr-days {
  transition: transform 0.25s ease;
  will-change: transform;
  touch-action: pan-y;
  user-select: none;
  cursor: grab;
}
.flatpickr-days:active { cursor: grabbing; }
.flatpickr-calendar.swipe-hint .flatpickr-days { animation: hint-swipe 0.8s ease; }

/* === BOTÕES DE NAVEGAÇÃO === */
.flatpickr-prev-month, .flatpickr-next-month {
  background: transparent !important;
  color: #22c55e !important;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  padding: 0.25rem;
  cursor: pointer;
  border-radius: 0.25rem;
  transition: color 0.2s ease, transform 0.15s ease, background-color 0.2s ease, box-shadow 0.2s ease;
}
.flatpickr-prev-month:hover, .flatpickr-next-month:hover {
  color: #16a34a !important;
  transform: scale(1.15);
  background-color: rgba(34,197,94,0.1);
  box-shadow: 0 4px 15px rgba(34,197,94,0.2);
}
.flatpickr-prev-month:active, .flatpickr-next-month:active { transform: scale(0.9); }
.flatpickr-prev-month svg path, .flatpickr-next-month svg path { stroke: currentColor !important; fill: none !important; }

/* === INPUT DE ANO === */
.flatpickr-year-input {
  border: 1px solid #22c55e;
  border-radius: 0.25rem;
  font-weight: 500;
  width: 4rem;
  text-align: center;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.flatpickr-year-input:hover, .flatpickr-year-input:focus {
  border-color: #16a34a;
  box-shadow: 0 0 0 2px rgba(34,197,94,0.2);
  outline: none;
}
.flatpickr-calendar .arrowUp, .flatpickr-calendar .arrowDown { display: none !important; }

/* === DIAS === */
.flatpickr-day {
  border-radius: 9999px;
  transition: all 0.2s ease;
}
.flatpickr-day:hover { background-color: rgba(34,197,94,0.2); color: #14532d; cursor: pointer; }
.flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange {
  background-color: #22c55e !important;
  color: #fff !important;
  box-shadow: 0 2px 10px rgba(34,197,94,0.4);
  animation: pulse 0.25s ease;
}
.flatpickr-day.today {
  border: 2px solid #22c55e;
  color: #16a34a;
  background-color: transparent;
  font-weight: 600;
}
.flatpickr-day.today:hover { background-color: rgba(34,197,94,0.2); color: #14532d; }
.flatpickr-day.today.selected { background-color: #22c55e !important; color: #fff !important; border: none !important; }

/* === DIAS DESABILITADOS === */
.flatpickr-day.disabled { opacity: 0.4; cursor: not-allowed; }

/* === RESPONSIVO === */
@media (max-width: 768px) {
  .flatpickr-prev-month, .flatpickr-next-month { display: none !important; }
}
</style>
