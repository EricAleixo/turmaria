                   } %>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium <%= status_classes[plano.status] %>">
                  <%= plano.status_humanizado %>
                </span>
              </td>
              <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                <div class="flex space-x-3">
                  <%= link_to escola_plano_de_ensino_path(escola, plano), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                    <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>
                  <%= link_to edit_escola_plano_de_ensino_path(escola, plano), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>
                  <%= delete_button_with_modal(
                      path: escola_plano_de_ensino_path(escola, plano),
                      modal_id: dom_id(plano, :delete),
                      title: "Excluir plano de ensino",
                      message: "Tem certeza que deseja excluir este plano de ensino",
                      item_name: "#{plano.disciplina.nome} - #{plano.turma.nome}",
                      btn_class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800"
                    ) %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if escola.planos_de_ensino.count > 10 %>
        <div class="border-t border-gray-200 px-6 py-4 text-center">
          <%= link_to "Ver todos os planos (#{escola.planos_de_ensino.count})", escola_planos_de_ensino_path(escola), class: "font-semibold text-emerald-600 hover:text-emerald-800" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum plano de ensino cadastrado</h3>
      <p class="mt-1 text-sm text-gray-500">Os professores ainda não criaram planos de ensino nesta escola.</p>
      <div class="mt-6">
        <%= link_to "Criar Primeiro Plano", new_escola_plano_de_ensino_path(escola), class: "rounded-lg bg-indigo-600 px-5 py-2.5 font-medium text-white shadow-md transition-colors hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>
</div>

<div class="hidden md:block mt-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
  <div class="flex items-center justify-between border-b border-gray-200 p-6">
    <h3 class="text-2xl font-bold text-gray-800">Conteúdos da Escola</h3>

    <!-- Ações desktop -->
    <div class="flex w-80 gap-3">
      <%= link_to "Ver Conteúdos", escola_conteudos_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
      <%= link_to "Novo Conteúdo", new_escola_conteudo_path(escola), class: "btn bg-green-500 text-white w-1/2" %>
    </div>
  </div>

  <% if conteudos.any? %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Título</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Descrição</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Professor</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Disciplina</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Data</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Ações</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-100 bg-white">
          <% conteudos.limit(10).each do |conteudo| %>
            <tr class="transition-colors hover:bg-emerald-50/50">
              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900"><%= conteudo.titulo %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= truncate(conteudo.descricao, length: 80) %></td>
              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900"><%= conteudo.professor&.nome || "Sem professor atribuido"%></td>
              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900"><%= conteudo.disciplina&.nome || "Sem disciplina atribuida"%></td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                <%= conteudo.created_at.present? ? conteudo.created_at.strftime("%d/%m/%Y") : "Sem data" %>
              </td>

              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium">
                <div class="flex space-x-3">
                  <%= link_to escola_conteudo_path(escola, conteudo), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                    <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>

                  <%= link_to edit_escola_conteudo_path(escola, conteudo), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>

                <%= delete_button_with_modal(
                  path: escola_conteudo_path(escola, conteudo),
                  modal_id: dom_id(conteudo, :delete),
                  title: "Excluir conteúdo",
                  message: "Tem certeza que deseja excluir o conteúdo",
                  item_name: conteudo.titulo,
                  btn_class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800"
                ) %>


                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if escola.conteudos.count > 10 %>
        <div class="border-t border-gray-200 px-6 py-4 text-center">
          <%= link_to "Ver todos os conteúdos (#{escola.conteudos.count})", escola_conteudos_path(escola), class: "font-semibold text-emerald-600 hover:text-emerald-800" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <svg class="mx-auto h-16 w-16 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
      <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum conteúdo cadastrado</h3>
      <p class="mt-1 text-sm text-gray-500">Comece adicionando o primeiro conteúdo desta escola.</p>
      <div class="mt-6">
        <%= link_to "Criar Primeiro Conteúdo", new_escola_conteudo_path(escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
<!-- ADICIONE AQUI A TABELA DE FREQUÊNCIAS -->
<div class="hidden md:block mt-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
  <div class="flex items-center justify-between border-b border-gray-200 p-6">
    <h3 class="text-2xl font-bold text-gray-800">Frequências da Escola</h3>

    <!-- Ações desktop -->
    <div class="flex justify-end w-80 gap-3">
      <%= link_to "Ver Frequências", escola_frequencias_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
    </div>
  </div>

  <% if frequencias.any? %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Data</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Turma</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Disciplina</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Professor</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Presentes</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Faltas</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Ações</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-100 bg-white">
          <% frequencias.limit(10).each do |frequencia| %>
            <tr class="transition-colors hover:bg-green-50/50">
              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                  </svg>
                  <span class="text-sm font-medium text-gray-900">
                    <%= frequencia.data_aula.strftime("%d/%m/%Y") %>
                  </span>
                </div>
              </td>

              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= frequencia.turma.nome %>
                </span>
              </td>

              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900">
                <%= frequencia.disciplina&.nome || "N/A" %>
              </td>

              <% if frequencia.professor %>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <div class="flex-shrink-0 h-8 w-8">
                      <% if frequencia.professor.foto.attached? %>
                        <%= image_tag frequencia.professor.foto, class: "h-8 w-8 rounded-full object-cover border-2 border-green-200" %>
                      <% else %>
                        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                          <span class="text-white text-xs font-bold">
                            <%= frequencia.professor.nome.first.upcase %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-gray-900 truncate">
                        <%= frequencia.professor.nome %>
                      </div>
                    </div>
                  </div>
                </td>
                <% else %>
                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900">
                  <p>Sem professor atribuido</p>
                </td>
              <% end %>

              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-sm font-semibold text-green-600">
                    <%= frequencia.total_presentes %>
                  </span>
                </div>
              </td>

              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-sm font-semibold text-red-600">
                    <%= frequencia.total_faltas %>
                  </span>
                </div>
              </td>

              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium">
                <div class="flex space-x-3">
                  <%= link_to escola_frequencia_path(escola, frequencia), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                    <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>

                  <%= link_to edit_escola_frequencia_path(escola, frequencia), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>

                  <%= delete_button_with_modal(
                      path: escola_frequencia_path(escola, frequencia),
                      modal_id: dom_id(frequencia, :delete),
                      title: "Excluir frequência",
                      message: "Tem certeza que deseja excluir esta frequência",
                      item_name: frequencia.data_aula.strftime("%d/%m/%Y"),
                      btn_class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800"
                    ) %>  
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <% if frequencias.count > 10 %>
        <div class="border-t border-gray-200 px-6 py-4 text-center">
          <%= link_to "Ver todas as frequências (#{escola.frequencias.count})", escola_frequencias_path(escola), class: "font-semibold text-green-600 hover:text-green-800" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <svg class="mx-auto h-16 w-16 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
      </svg>
      <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhuma frequência registrada</h3>
      <p class="mt-1 text-sm text-gray-500">Ainda não há registros de frequência para esta escola.</p>
      <div class="mt-6">
        <%= link_to "Ver Frequências", escola_frequencias_path(escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
      </div>
    </div>
  <% end %>

</div>

<%= render 'escolas/mobile_cards', disciplinas: @escola.disciplinas, professores: @escola.professors, anos_letivos: @escola.ano_letivos, turmas:@escola.turmas, alunos: @alunos, conteudos: @escola.conteudos, frequencias: @frequencias %>