<div class="hidden md:block">
  <div class="mt-8 mb-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg ">
    <div class="flex items-center justify-between border-b border-gray-200 p-6">
      <h3 class="text-2xl font-bold text-gray-800">Turmas da Escola</h3>
  
      <div class="hidden w-80 gap-3 sm:flex">
        <%= link_to "Ver Turmas", escola_turmas_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
        <%= link_to "Nova Turma", new_escola_turma_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
      </div>
  
      <div class="sm:hidden dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-blue-50 hover:bg-blue-100 text-blue-600 border border-blue-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
          <li>
            <%= link_to escola_turmas_path(escola), class: "flex items-center gap-2 hover:bg-blue-50 text-gray-700 hover:text-blue-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver Turmas
            <% end %>
          </li>
          <li>
            <%= link_to new_escola_turma_path(escola), class: "flex items-center gap-2 hover:bg-blue-50 text-gray-700 hover:text-blue-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Nova Turma
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  
    <% if escola.turmas.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Série</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Turno</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Alunos</th>
              <th class="hidden px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white sm:table-cell">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% escola.turmas.each do |turma| %>
              <tr class="transition-colors hover:bg-indigo-50/50">
                <td class="whitespace-nowrap px-6 py-4">
                  <div class="text-sm font-medium text-gray-900"><%= turma.nome %></div>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.serie %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.turno %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.alunos.count %> alunos</td>
                <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                  <div class="flex space-x-3">
                    <%= link_to escola_turma_path(escola, turma), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                      <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_turma_path(escola, turma), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= link_to escola_turma_path(escola, turma),
                                method: :delete,
                                data: { turbo_confirm: 'Tem certeza que deseja excluir esta turma?' },
                                class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhuma turma cadastrada</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando a primeira turma desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeira Turma", new_escola_turma_path(escola), class: "rounded-lg bg-indigo-600 px-5 py-2.5 font-medium text-white shadow-md transition-colors hover:bg-indigo-700" %>
        </div>
      </div>
    <% end %>
  </div>




<div class="mb-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
  <div class="flex items-center justify-between border-b border-gray-200 p-6">
    <h3 class="text-2xl font-bold text-gray-800">Professores da Escola</h3>

    <div class="hidden w-80 gap-3 sm:flex">
      <%# Usando rotas não aninhadas com parâmetro escola_id %>
      <%= link_to "Ver Professores", professors_path(escola_id: @escola.id), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
      <%= link_to "Novo Professor", new_professor_path(escola_id: @escola.id), class: "btn bg-green-500 text-white w-1/2" %>
    </div>

    <div class="sm:hidden dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-green-50 hover:bg-green-100 text-green-600 border border-green-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
        </svg>
      </div>
      <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
        <li>
          <%= link_to professors_path(escola_id: @escola.id), class: "flex items-center gap-2 hover:bg-green-50 text-gray-700 hover:text-green-700" do %>
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            Ver Professores
          <% end %>
        </li>
        <li>
          <%= link_to new_professor_path(escola_id: @escola.id), class: "flex items-center gap-2 hover:bg-green-50 text-gray-700 hover:text-green-700" do %>
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Novo Professor
          <% end %>
        </li>
      </ul>
    </div>
  </div>

  <%# Conteúdo da Tabela de Professores %>
  <% if @professores.any? %>
    <div class="overflow-x-auto hidden md:block"> <%# Esconde a tabela no mobile %>
      <table class="w-full">
        <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Nome</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Matérias</th> <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Formação</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Tipo</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Ações</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-100 bg-white">
          <% @professores.each do |professor| %>
            <tr class="transition-colors hover:bg-emerald-50/50">
              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center space-x-3">
                  <%# Inicial do Professor %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-500 text-white font-semibold shadow-sm border border-blue-400">
                    <%= professor.nome[0].upcase %>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= professor.nome %></div>
                  </div>
                </div>
              </td>

              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-1">
                  <%= disciplinas_badges(professor) || "-" %>
                </div>
              </td>

              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                <%= professor.formacao&.humanize&.titleize || "-" %>
              </td>

              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800">
                  <%= professor.tipo_professor&.titleize || "Não Informado" %>
                </span>
              </td>

              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium">
                <div class="flex space-x-3">
                  <%# Links de Ação - Usando rotas globais %>
                  <%= link_to escola_professor_path(escola, professor), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700", title: "Ver professor" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                  <% end %>

                  <%= link_to edit_professor_path(professor), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800", title: "Editar professor" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  <% end %>

                  <%= link_to professor_path(professor), method: :delete,
                    data: { turbo_confirm: 'Tem certeza que deseja excluir este professor?' },
                    class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800",
                    title: "Excluir professor" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Cards para Dispositivos Móveis (Mobile) %>
    <div class="md:hidden space-y-4 pt-4">
      <% @professores.each do |professor| %>
        <%# Lógica de cores baseada na sua formação (mantida do seu código original) %>
        <% card_classes = case professor.formacao.to_s
          when 'doutorado'
            "bg-gradient-to-br from-blue-50/40 via-blue-100/40 to-blue-200/60 border border-blue-300/50"
          when 'mestrado'
            "bg-gradient-to-br from-red-50/40 via-red-100/40 to-red-200/60 border border-red-300/50"
          when 'pos_graduado'
            "bg-gradient-to-br from-yellow-50/40 via-yellow-100/40 to-yellow-200/60 border border-yellow-300/50"
          when 'graduado'
            "bg-gradient-to-br from-green-50/40 via-green-100/40 to-green-200/60 border border-green-300/50"
          else
            "bg-white border border-gray-200"
          end %>

        <% bg_pattern = case professor.formacao
          when 'doutorado'
            "bg-gradient-to-br from-blue-50/20 via-transparent to-blue-100/30"
          when 'mestrado'
            "bg-gradient-to-br from-red-50/20 via-transparent to-red-100/30"
          when 'pos_graduado'
            "bg-gradient-to-br from-yellow-50/20 via-transparent to-yellow-100/30"
          when "graduado"
            "bg-gradient-to-br from-green-50/20 via-transparent to-green-100/30"
          else
            "bg-gradient-to-br from-gray-50/20 via-transparent to-gray-100/30"
          end %>

        <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
          <div class="absolute inset-0 <%= bg_pattern %> pointer-events-none"></div>

          <div class="relative z-10">
            <div class="flex justify-between items-start mb-4">
              <div class="flex-1">
                <div class="flex items-center space-x-3 mb-2">
                  <%# Inicial do Professor %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-500 text-white font-semibold shadow-sm border border-blue-400">
                    <%= professor.nome[0].upcase %>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900"><%= professor.nome %></h3>
                </div>
              </div>

              <%# Tipo do Professor %>
              <div class="ml-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-sm">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
                  <%= professor.tipo_professor&.titleize || "Tipo não informado"%>
                </span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="col-span-2 bg-white/70 backdrop-blur-sm border border-blue-200/50 rounded-xl p-4 shadow-sm">
                <p class="text-xs font-medium text-blue-700 uppercase tracking-wide mb-2">Matérias</p>
                <div class="flex flex-wrap gap-1">
                  <% if professor.disciplinas.any? %>
                    <%= disciplinas_badges(professor) %>
                  <% else %>
                    <span class="text-sm text-gray-500">Sem matérias atribuídas</span>
                  <% end %>
                </div>
              </div>
              <%# Formação (Movido para linha separada para manter a estrutura) %>
              <div class="col-span-2 bg-gradient-to-br from-blue-100 to-blue-200/80 border border-blue-300/50 rounded-xl p-4 text-center shadow-sm">
                 <p class="text-xs font-medium text-blue-800 uppercase tracking-wide">Formação</p>
                 <p class="text-sm font-semibold text-gray-900 mt-1"><%= professor.formacao&.humanize&.titleize || "Não informada" %></p>
              </div>
            </div>

            <div class="flex justify-center space-x-2 pt-4 border-t border-blue-200/50">
              <%# Links de Ação - Usando rotas globais %>
              <%= link_to professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105", data: { turbo: false } do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                Ver
              <% end %>
              <%= link_to edit_professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105", data: { turbo: false } do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                Editar
              <% end %>
              <%= button_to professor_path(professor), method: :delete,
                data: { confirm: "Tem certeza que deseja excluir esta professor?" },
                class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105",
                form: { data: { turbo_frame: "_top" } } do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                Excluir
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# Mensagem para quando não há professores, no estilo da tabela de alunos %>
    <div class="px-6 py-12 text-center text-gray-500">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhum professor encontrado</h3>
      <p class="mt-1 text-sm text-gray-500">
        Comece adicionando um novo professor para esta escola.
      </p>
      <div class="mt-6">
        <%= link_to "Adicionar Professor", new_professor_path(escola_id: @escola.id), class: "inline-flex items-center rounded-md border border-transparent bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2" %>
      </div>
    </div>
  <% end %>
