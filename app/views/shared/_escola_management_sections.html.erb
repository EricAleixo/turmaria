<div class="hidden md:block">
  <div class="mt-8 mb-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg ">
    <div class="flex items-center justify-between border-b border-gray-200 p-6">
      <h3 class="text-2xl font-bold text-gray-800">Turmas da Escola</h3>
  
      <div class="hidden w-80 gap-3 sm:flex">
        <%= link_to "Ver Turmas", escola_turmas_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
        <%= link_to "Nova Turma", new_escola_turma_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
      </div>
  
      <div class="sm:hidden dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-blue-50 hover:bg-blue-100 text-blue-600 border border-blue-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
          <li>
            <%= link_to escola_turmas_path(escola), class: "flex items-center gap-2 hover:bg-blue-50 text-gray-700 hover:text-blue-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver Turmas
            <% end %>
          </li>
          <li>
            <%= link_to new_escola_turma_path(escola), class: "flex items-center gap-2 hover:bg-blue-50 text-gray-700 hover:text-blue-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Nova Turma
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  
    <% if escola.turmas.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Série</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Turno</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Alunos</th>
              <th class="hidden px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white sm:table-cell">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% escola.turmas.each do |turma| %>
              <tr class="transition-colors hover:bg-indigo-50/50">
                <td class="whitespace-nowrap px-6 py-4">
                  <div class="text-sm font-medium text-gray-900"><%= turma.nome %></div>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.serie %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.turno %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700"><%= turma.alunos.count %> alunos</td>
                <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                  <div class="flex space-x-3">
                    <%= link_to escola_turma_path(escola, turma), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                      <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_turma_path(escola, turma), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= link_to escola_turma_path(escola, turma),
                                method: :delete,
                                data: { turbo_confirm: 'Tem certeza que deseja excluir esta turma?' },
                                class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhuma turma cadastrada</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando a primeira turma desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeira Turma", new_escola_turma_path(escola), class: "rounded-lg bg-indigo-600 px-5 py-2.5 font-medium text-white shadow-md transition-colors hover:bg-indigo-700" %>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="mb-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
    <div class="flex items-center justify-between border-b border-gray-200 p-6">
      <h3 class="text-2xl font-bold text-gray-800">Alunos da Escola</h3>
  
      <div class="hidden w-80 gap-3 sm:flex">
        <%= link_to "Ver Alunos", escola_alunos_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
        <%= link_to "Novo Aluno", new_escola_aluno_path(escola), class: "btn bg-green-500 text-white w-1/2" %>
      </div>
  
      <div class="sm:hidden dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-green-50 hover:bg-green-100 text-green-600 border border-green-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
          <li>
            <%= link_to escola_alunos_path(escola), class: "flex items-center gap-2 hover:bg-green-50 text-gray-700 hover:text-green-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver Alunos
            <% end %>
          </li>
          <li>
            <%= link_to new_escola_aluno_path(escola), class: "flex items-center gap-2 hover:bg-green-50 text-gray-700 hover:text-green-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Novo Aluno
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  
    <% if alunos.any? %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Aluno</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Data de Nascimento</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Turma</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Status</th>
            <th class="hidden px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white sm:table-cell">Ações</th>
          </tr>
        </thead>
  
        <tbody class="divide-y divide-gray-100 bg-white">
          <% alunos.limit(10).each do |aluno| %>
            <tr class="transition-colors hover:bg-emerald-50/50">
              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center space-x-3">
                  <% if aluno.foto.present? %>
                    <%= image_tag aluno.foto, class: "h-10 w-10 rounded-full object-cover shadow-sm border border-gray-200" %>
                  <% else %>
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500 text-white font-semibold shadow-sm border border-emerald-400">
                      <%= aluno.nome[0].upcase %>
                    </div>
                  <% end %>
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= aluno.nome %></div>
                  </div>
                </div>
              </td>
  
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                <%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informada" %>
              </td>
  
              <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                <%= aluno.turma.present? ? aluno.turma.nome : "Sem turma" %>
              </td>
  
              <td class="whitespace-nowrap px-6 py-4">
                <% if aluno.turma.present? %>
                  <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">Alocado</span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-800">Não alocado</span>
                <% end %>
              </td>
  
              <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                <div class="flex space-x-3">
                  <%= link_to escola_aluno_path(escola, aluno), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-blue-100/50 hover:text-blue-700" do %>
                    <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>
                  <%= link_to edit_escola_aluno_path(escola, aluno), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>
                  <%= link_to escola_aluno_path(escola, aluno),
                              method: :delete,
                              data: { turbo_confirm: 'Tem certeza que deseja excluir este aluno?' },
                              class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800" do %>
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
  
      <% if escola.alunos.count > 10 %>
        <div class="border-t border-gray-200 px-6 py-4 text-center">
          <%= link_to "Ver todos os alunos (#{escola.alunos.count})", escola_alunos_path(escola), class: "font-semibold text-emerald-600 hover:text-emerald-800" %>
        </div>
      <% end %>
    </div>
  <% else %>
  
      <div class="py-12 text-center">
        <svg class="mx-auto h-16 w-16 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum aluno cadastrado</h3>
        <p class="mt-1 text-sm text-gray-500">Comece adicionando o primeiro aluno desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeiro Aluno", new_escola_aluno_path(escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
    <div class="flex items-center justify-between border-b border-gray-200 p-6">
      <h3 class="text-2xl font-bold text-gray-800">Anos Letivos</h3>
  
      <div class="hidden w-80 gap-3 sm:flex">
        <%= link_to "Ver Anos", escola_ano_letivos_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
        <%= link_to "Novo Ano Letivo", new_escola_ano_letivo_path(escola), class: "btn w-1/2 whitespace-nowrap border-purple-700 bg-purple-700 text-white hover:border-purple-800 hover:bg-purple-800" %>
      </div>
  
      <div class="sm:hidden dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-purple-50 hover:bg-purple-100 text-purple-600 border border-purple-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
          <li>
            <%= link_to escola_ano_letivos_path(escola), class: "flex items-center gap-2 hover:bg-purple-50 text-gray-700 hover:text-purple-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver Anos
            <% end %>
          </li>
          <li>
            <%= link_to new_escola_ano_letivo_path(escola), class: "flex items-center gap-2 hover:bg-purple-50 text-gray-700 hover:text-purple-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Novo Ano Letivo
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  
    <% if escola.ano_letivos.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Ano</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Data de Início</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Data de Fim</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Status</th>
              <th class="hidden px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white sm:table-cell">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% escola.ano_letivos.each do |ano| %>
              <tr class="transition-colors hover:bg-violet-50/50">
                <td class="whitespace-nowrap px-6 py-4">
                  <div class="text-sm font-medium text-gray-900">Ano <%= ano.ano %></div>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                  <%= ano.data_inicio.present? ? ano.data_inicio.strftime("%d/%m/%Y") : "Não definido" %>
                </td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
                  <%= ano.data_fim.present? ? ano.data_fim.strftime("%d/%m/%Y") : "Não definido" %>
                </td>
                <td class="whitespace-nowrap px-6 py-4">
                  <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">Ativo</span>
                </td>
                <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                  <div class="flex space-x-3">
                    <%= link_to escola_ano_letivo_path(escola, ano), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-purple-100/50 hover:text-purple-800" do %>
                      <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_ano_letivo_path(escola, ano), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    <% end %>
                    <%= link_to escola_ano_letivo_path(escola, ano),
                                method: :delete,
                                data: { turbo_confirm: 'Tem certeza que deseja excluir este ano letivo?' },
                                class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="mx-auto h-16 w-16 text-purple-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum ano letivo cadastrado</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando o primeiro ano letivo desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeiro Ano Letivo", new_escola_ano_letivo_path(escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
  
   <div class="mt-8 overflow-hidden rounded-xl border border-gray-100 bg-white shadow-lg">
    <div class="flex items-center justify-between border-b border-gray-200 p-6">
      <h3 class="text-2xl font-bold text-gray-800">Disciplinas</h3>
  
      <div class="hidden w-80 gap-3 sm:flex">
        <%= link_to "Ver  Disiciplinas", escola_disciplinas_path(escola), class: "btn w-1/2 border-blue-500 bg-blue-500 text-white hover:border-blue-600 hover:bg-blue-600" %>
        <%= link_to "Nova Disciplinas", new_escola_disciplina_path(escola), class: "btn w-1/2 whitespace-nowrap border-purple-700 bg-purple-700 text-white hover:border-purple-800 hover:bg-purple-800" %>
      </div>
  
      <div class="sm:hidden dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle bg-purple-50 hover:bg-purple-100 text-purple-600 border border-purple-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-64 border border-gray-100 mt-2 animate-fadeIn">
          <li>
            <%= link_to escola_disciplina_path(escola), class: "flex items-center gap-2 hover:bg-purple-50 text-gray-700 hover:text-purple-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver Disciplinas
            <% end %>
          </li>
          <li>
            <%= link_to new_escola_disciplina_path(escola), class: "flex items-center gap-2 hover:bg-purple-50 text-gray-700 hover:text-purple-700" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Nova Disciplinas
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  
    <% if escola.disciplinas.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="border-b border-gray-200 bg-gradient-to-r from-blue-500 to-green-300">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Professores</th>
              <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white">Área</th>
              <th class="hidden px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-white sm:table-cell">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% escola.disciplinas.each do |d| %>
              <tr class="transition-colors hover:bg-violet-50/50">
                <td class="whitespace-nowrap px-6 py-4">
                  <div class="text-sm font-medium text-gray-900"><%=d.nome%></div>
                </td>
                <td class="whitespace-nowrap px-6 py-4">
                  <span class="text-sm font-medium text-gray-900"><%=d.professores.map(&:nome).join(", ").presence  || "Sem professores"%></span>
                </td>
                <td class="whitespace-nowrap px-6 py-4">
                  <span class="text-sm font-medium text-gray-900"><%=badge_direita(d.area) || "Sem professores"%></span>
                </td>
                <td class="hidden whitespace-nowrap px-6 py-4 text-sm font-medium sm:table-cell">
                  <div class="flex space-x-3">
                    <%= link_to escola_disciplina_path(escola, d), class: "rounded-full p-1 text-blue-500 transition-colors hover:bg-purple-100/50 hover:text-purple-800" do %>
                      <svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_disciplina_path(escola, d), class: "rounded-full p-1 text-yellow-600 transition-colors hover:bg-yellow-100/50 hover:text-yellow-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    <% end %>
                    <%= link_to escola_disciplina_path(escola, d),
                                method: :delete,
                                data: { turbo_confirm: 'Tem certeza que deseja excluir este ano letivo?' },
                                class: "rounded-full p-1 text-red-600 transition-colors hover:bg-red-100/50 hover:text-red-800" do %>
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="py-12 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="mx-auto h-16 w-16">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhuma disciplina cadastrada</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando a primeira disciplina desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeira Disciplina", new_escola_disciplina_path(escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
<%= render 'escolas/mobile_cards', disciplinas: @escola.disciplinas, professores: @escola.professors, anos_letivos: @escola.ano_letivos, turmas:@escola.turmas, alunos: @alunos  %>