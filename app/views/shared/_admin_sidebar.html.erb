<!-- Admin Sidebar -->
<div class="drawer-side z-111111111111">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside class="w-64 min-h-full bg-white shadow-lg">
     <!-- Header -->
    <div class="p-5 bg-blue-500" data-aos="fade-down" data-aos-duration="500">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 21h18M4 21V9l8-6 8 6v12M9 21v-6h6v6" />
          </svg>
        </div>

        <div>
          <h2 class="text-xl font-bold text-white tracking-tight">Turmaria</h2>
          <p class="text-xs text-blue-100 font-medium">Gestão Escolar</p>
        </div>
      </div>

      <!-- Card Portal -->
      <div class="bg-white/10 backdrop-blur-md rounded-xl p-3 border border-white/20 shadow-lg">
        <p class="text-[10px] text-blue-200 font-semibold uppercase tracking-wider mb-1">
          Área Administrativa
        </p>
        <h3 class="text-sm font-bold text-white">
          Portal do Administrador
        </h3>

        <% if @escola.present? %>
          <div class="mt-2">
            <span class="inline-flex items-center px-2.5 py-1 rounded-lg
              bg-white text-blue-700 text-xs font-semibold shadow-sm">
              <%= @escola.nome %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
    
    <nav class="p-4">
      <ul class="space-y-2">
        <!-- Dashboard - Goes to Admin's School -->
        
        <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
          <% if current_admin&.escolas&.first.present? %>
           <%= link_to dashboard_link_path, class: "flex items-center p-3 rounded-lg #{current_page?(dashboard_link_path) ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5M9 12.75h6m-6 3h6m-6-6h6" />
              </svg>
              Dashboard
            <% end %>
          <% else %>
            <%= link_to welcome_escola_path, class: "flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
              </svg>
              Cadastrar Escola
            <% end %>
          <% end %>
        </li>

        <!-- School Management (only if admin has school) -->
        <% if current_admin&.escolas&.first.present? %>
          <!-- Years and Classes -->
          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
             <%= link_to minhas_escolas_admin_path, class: "flex items-center p-3 rounded-lg #{escola_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
              Minhas Escolas
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_ano_letivo_path,
            class: "flex items-center p-3 rounded-lg 
            #{ano_letivos_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5M9 12.75h6m-6 3h6m-6-6h6" />
              </svg>
              Anos Letivos
            <% end %>
          </li>


          <!-- Students of the School -->
          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_alunos_path, class: "flex items-center p-3 rounded-lg #{alunos_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
              </svg>
              Alunos
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_disciplinas_path, class: "flex items-center p-3 rounded-lg #{disciplinas_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              Disciplinas
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_planos_de_ensino_path, class: "flex items-center p-3 rounded-lg #{planos_de_ensino_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              Planos de Curso
            <% end %>
          </li>

          <!-- Teachers of the School -->
          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_professores_path, class: "flex items-center p-3 rounded-lg #{professors_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
              Professores
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_conteudos_path, class: "flex items-center p-3 rounded-lg #{conteudos_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-5 h-5 mr-3">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>

              Conteúdos
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to admin_cidades_path, class: "flex items-center p-3 rounded-lg #{cidades_section_active? ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
              </svg>  
              Cidades
            <% end %>
          </li>

          <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            <%= link_to selecionar_escola_frequencias_path, class: "flex items-center p-3 rounded-lg #{ frequencias_section_path? ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
              </svg>
              Frequências
            <% end %>
          </li>

          <!-- Coordinators of the School -->
          <%
            # <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            #   <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            #     <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
            #       <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            #     </svg>

            #     Coordenadores
            #   </a>
            # </li>

            # <!-- Reports -->
            # <li data-aos="fade-right" data-aos-delay="50" data-aos-duration="400">
            #   <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            #     <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
            #       <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            #     </svg>
            #     Relatórios
            #   </a>
            # </li>
           %>

        <% end %>
      </ul>
    </nav>
  </aside>
</div>
