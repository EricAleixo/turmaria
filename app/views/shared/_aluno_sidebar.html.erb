<!-- Aluno Sidebar -->
<div class="drawer-side">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside class="w-64 min-h-full bg-white shadow-lg">
    <!-- Profile Section -->
    <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-yellow-50 to-orange-50">
      <div class="flex flex-col items-center text-center">
        <div class="avatar placeholder mb-3">
          <div class="bg-yellow-500 text-white rounded-full w-16 h-16 ring ring-yellow-200 ring-offset-2 flex items-center justify-center">
            <span class="text-xl font-bold">
              <% if current_any_user&.nome.present? %>
                <%= current_any_user.nome.first.upcase %>
              <% elsif current_any_user&.email.present? %>
                <%= current_any_user.email.first.upcase %>
              <% else %>
                A
              <% end %>
            </span>
          </div>
        </div>
        
        <div class="w-full">
          <h3 class="font-bold text-gray-800 text-sm truncate">
            <%= current_any_user&.nome.present? ? current_any_user.nome : 'Aluno' %>
          </h3>
          <p class="text-xs text-gray-600 truncate mb-2">
            <%= current_any_user&.email %>
          </p>
          
          <!-- User Type Badge -->
          <div class="badge badge-sm bg-yellow-100 text-yellow-700 border-yellow-200 mb-3">
            Aluno
          </div>
          
          <!-- Logout Button -->
          <%= link_to destroy_user_session_path, method: :delete, 
              class: "btn btn-xs btn-outline btn-error w-full",
              data: { confirm: "Tem certeza que deseja sair?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Sair
          <% end %>
        </div>
      </div>
    </div>

    <!-- System Title -->
    <div class="p-4 border-b border-gray-200">
      <h2 class="text-xl font-bold text-gray-800">Turmaria</h2>
      <p class="text-sm text-gray-600">Portal do Aluno</p>
    </div>
    
    <nav class="p-4">
      <ul class="space-y-2">
        <!-- Dashboard -->
        <li>
          <%= link_to dashboard_path, class: "flex items-center p-3 rounded-lg #{current_page?(dashboard_path) ? 'bg-yellow-100 text-yellow-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l-1-3m1 3l-1-3m-16.5-3h16.5" />
            </svg>
            Dashboard
          <% end %>
        </li>

        <!-- My Grades -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
            Minhas Notas
          </a>
        </li>

        <!-- My Schedule -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5M9 12.75h6m-6 3h6m-6-6h6" />
            </svg>
            Horários
          </a>
        </li>

        <!-- My Attendance -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Minha Frequência
          </a>
        </li>

        <!-- My Teachers -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            Meus Professores
          </a>
        </li>

        <!-- Activities -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            Atividades
          </a>
        </li>
      </ul>
    </nav>
  </aside>
</div>
