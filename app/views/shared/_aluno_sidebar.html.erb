<div class="drawer-side">
  <label for="my-drawer" class="drawer-overlay"></label>
  
  <aside class="w-64 min-h-full bg-white shadow-lg flex flex-col">
    
    <div class="p-4 border-b border-gray-200 bg-green-500">
      <h2 class="text-xl font-bold text-white">Turmaria</h2>
      <p class="text-sm text-white">Gestão Escolar</p>
      <div class="mt-2">
        <div class="badge badge-sm bg-green-100 text-green-700 border-green-200">
          Portal do Aluno
        </div>
      </div>
    </div>
    
    <nav class="p-4 flex-grow overflow-y-auto">
      <ul class="space-y-2">
        
        <li>
          <% dashboard_active = current_page?(dashboard_path) %> 
          <%= link_to dashboard_path, class: "flex items-center p-3 rounded-lg #{dashboard_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>

            Dashboard
          <% end %>
        </li>

        <li>
          <% notas_active = current_page?(aluno_minhas_notas_path) %> 
          <%= link_to aluno_minhas_notas_path, class: "flex items-center p-3 rounded-lg #{notas_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
            Minhas Notas
          <% end %>
        </li>

        

        <li>
          <% frequencia_active = current_page?(aluno_minha_frequencia_path) %> 
          <%= link_to aluno_minha_frequencia_path, class: "flex items-center p-3 rounded-lg #{frequencia_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Minha Frequência
          <% end %>
        </li>

        <li>
          <% professores_active = false %>
          <%= link_to aluno_meus_professores_path, class: "flex items-center p-3 rounded-lg #{professores_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            Meus Professores
          <% end %>
        </li>

        <li>
          <% boletim_active = current_page?(aluno_boletins_path) || params[:controller] == 'aluno/boletins' %> 
          <%= link_to aluno_boletins_path, class: "flex items-center p-3 rounded-lg #{boletim_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
            Boletim
          <% end %>
        </li>
        
        <li class="border-t border-gray-200 pt-2 mt-2">
            <span class="text-xs font-semibold uppercase text-gray-500 tracking-wider px-3 py-1 block">Conteúdos</span>
        </li>

        <li>
          <%# Minhas Atividades %>
          <% atividades_active = current_page?(aluno_minhas_atividades_e_path) %>
          <%= link_to aluno_minhas_atividades_e_path, class: "flex items-center p-3 rounded-lg #{atividades_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            Minhas Atividades
          <% end %>
        </li>

        <li>
          <%# Materiais de Estudo (Usando o ícone fornecido) %>
          <% materiais_active = current_page?(aluno_meus_materiais_path) %> 
          <%= link_to aluno_meus_materiais_path, class: "flex items-center p-3 rounded-lg #{materiais_active ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
            Materiais de Estudo
          <% end %>
        </li>
      </ul>
    </nav>
    
    <div class="p-4 border-t border-gray-200">
      <div class="flex items-center justify-between">
        
        <div class="flex items-center flex-grow truncate">
          <div class="avatar placeholder mr-3 flex-shrink-0">
            <div class="bg-green-500 text-white rounded-full w-10 h-10 flex items-center justify-center">
              <span class="flex items-center justify-center h-full w-full font-bold text-lg">
                <% if current_aluno&.nome.present? %>
                  <%= current_aluno.nome.first.upcase %>
                <% elsif current_aluno&.email.present? %>
                  <%= current_aluno.email.first.upcase %>
                <% else %>
                  A
                <% end %>
              </span>
            </div>
          </div>
          
          <div class="w-full truncate">
            <h3 class="font-bold text-gray-800 text-sm truncate">
              <%= current_aluno&.nome.present? ? current_aluno.nome : 'Aluno(a)' %>
            </h3>
            <p class="text-xs text-gray-600 truncate">
              <%= current_aluno&.email %>
            </p>
          </div>
        </div>
        
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja sair?" }, 
              class: "btn btn-ghost btn-circle btn-sm text-gray-500 hover:text-red-500" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        <% end %>
      </div>
    </div>
    
  </aside>
</div>
