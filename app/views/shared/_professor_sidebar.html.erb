<!-- Professor Sidebar -->
<div class="drawer-side">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside class="w-64 min-h-full bg-white shadow-lg">
    <!-- Profile Section -->
    <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-purple-50">
      <div class="flex flex-col items-center text-center">
        <div class="avatar placeholder mb-3">
          <div class="bg-blue-500 text-white rounded-full w-16 h-16 ring ring-blue-200 ring-offset-2 flex items-center justify-center">
            <span class="text-xl font-bold">
              <% if current_any_user&.nome.present? %>
                <%= current_any_user.nome.first.upcase %>
              <% elsif current_any_user&.email.present? %>
                <%= current_any_user.email.first.upcase %>
              <% else %>
                P
              <% end %>
            </span>
          </div>
        </div>
        
        <div class="w-full">
          <h3 class="font-bold text-gray-800 text-sm truncate">
            <%= current_any_user&.nome.present? ? current_any_user.nome : 'Professor' %>
          </h3>
          <p class="text-xs text-gray-600 truncate mb-2">
            <%= current_any_user&.email %>
          </p>
          
          <!-- User Type Badge -->
          <div class="badge badge-sm bg-blue-100 text-blue-700 border-blue-200 mb-3">
            Professor
          </div>
          
          <!-- Logout Button -->
          <%= link_to destroy_user_session_path, method: :delete, 
              class: "btn btn-xs btn-outline btn-error w-full",
              data: { confirm: "Tem certeza que deseja sair?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Sair
          <% end %>
        </div>
      </div>
    </div>

    <!-- System Title -->
    <div class="p-4 border-b border-gray-200">
      <h2 class="text-xl font-bold text-gray-800">Turmaria</h2>
      <p class="text-sm text-gray-600">Portal do Professor</p>
    </div>
    
    <nav class="p-4">
      <ul class="space-y-2">
        <!-- Dashboard -->
        <li>
          <%= link_to dashboard_path, class: "flex items-center p-3 rounded-lg #{current_page?(dashboard_path) ? 'bg-blue-100 text-blue-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l-1-3m1 3l-1-3m-16.5-3h16.5" />
            </svg>
            Dashboard
          <% end %>
        </li>

        <!-- My Classes -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0112 12.75a5.995 5.995 0 018.232 4.41c.896.248 1.783.52 2.658.814m0 0a3 3 0 11-4.681 2.72 8.986 8.986 0 003.74.477m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
            Minhas Turmas
          </a>
        </li>

        <!-- My Students -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
            Meus Alunos
          </a>
        </li>

        <!-- Grades -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
            Notas
          </a>
        </li>

        <!-- Attendance -->
        <li>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Frequência
          </a>
        </li>
      </ul>
    </nav>
  </aside>
</div>
