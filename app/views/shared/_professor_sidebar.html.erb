<div class="drawer-side">
  <label for="my-drawer" class="drawer-overlay"></label>
  
  <aside class="w-64 min-h-full bg-white shadow-lg flex flex-col">
    
    <div class="p-4 border-b border-gray-200 bg-green-500">
      <h2 class="text-xl font-bold text-white">Turmaria</h2>
      <p class="text-sm text-white">Gestão Escolar</p>
      <div class="mt-2">
        <div class="badge badge-sm bg-green-100 text-green-700 border-green-200">
          Portal do Professor
        </div>
      </div>
    </div>
    
    <nav class="p-4 flex-grow overflow-y-auto">
      <ul class="space-y-2">
        
        <li>
          <%= link_to dashboard_path, class: "flex items-center p-3 rounded-lg #{current_page?(dashboard_path) ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l-1-3m1 3l-1-3m-16.5-3h16.5" />
            </svg>
            Dashboard
          <% end %>
        </li>

        <li>
          <%= link_to minhas_turmas_path, class: "flex items-center p-3 rounded-lg #{current_page?(minhas_turmas_path) ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
            Minhas Turmas
          <% end %>
        </li>

        <li>
          <%= link_to "#", class: "flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
            </svg>
            Meus Alunos
          <% end %>
        </li>

        <li>
          <%= link_to "#", class: "flex items-center p-3 rounded-lg hover:bg-gray-100 text-gray-700" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75" />
            </svg>
            Notas
          <% end %>
        </li>

        <li>
          <%= link_to frequencias_path, class: "flex items-center p-3 rounded-lg #{current_page?(frequencias_path) ? 'bg-green-100 text-green-700 font-medium' : 'hover:bg-gray-100 text-gray-700'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Frequência
          <% end %>
        </li>
        
      </ul>
    </nav>
    
    <div class="p-4 border-t border-gray-200">
      <div class="flex items-center justify-between">
        
        <div class="flex items-center flex-grow truncate">
          <div class="avatar placeholder mr-3 flex-shrink-0">
            <div class="bg-green-500 text-white rounded-full w-10 h-10 flex items-center justify-center">
              <span class="flex items-center justify-center h-full w-full font-bold text-lg">
                <% if current_professor&.nome.present? %>
                  <%= current_professor.nome.first.upcase %>
                <% elsif current_professor&.email.present? %>
                  <%= current_professor.email.first.upcase %>
                <% else %>
                  P
                <% end %>
              </span>
            </div>
          </div>
          
          <div class="w-full truncate">
            <h3 class="font-bold text-gray-800 text-sm truncate">
              <%= current_professor&.nome.present? ? current_professor.nome : 'Professor(a)' %>
            </h3>
            <p class="text-xs text-gray-600 truncate">
              <%= current_professor&.email %>
            </p>
          </div>
        </div>
        
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete, confirm: "Tem certeza que deseja sair?" }, 
              class: "btn btn-ghost btn-circle btn-sm text-gray-500 hover:text-red-500" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        <% end %>
      </div>
    </div>
    
  </aside>
</div>