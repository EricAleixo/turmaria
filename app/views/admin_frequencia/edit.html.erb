<div class="min-h-screen bg-gray-100 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">Editar Frequência</h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium"><%= @turma.nome %></span> - <%= @turma.escola.nome %>
          </p>
          <p class="text-xs sm:text-sm text-gray-500 mt-1">
            Data da aula: <%= @frequencia.data_aula.strftime("%d/%m/%Y") %>
          </p>
        </div>
        <%= link_to escola_frequencias_path(@escola), class: "w-full sm:w-auto text-center bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" do %>
          Voltar
        <% end %>
      </div>
    </div>

    <!-- Formulário -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <%= form_with model: @frequencia,
              url: escola_frequencia_path(@escola, @frequencia),
              method: :patch,
              data: { turbo: false },
              local: true do |form| %>
        <div class="p-4 sm:p-6">
        
        <!-- Informações da Aula -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
          <h3 class="text-sm font-semibold text-blue-900 mb-3">Informações da Aula</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
            <div>
              <span class="text-blue-600 font-medium">Data:</span>
              <span class="text-gray-700 ml-2"><%= @frequencia.data_aula.strftime("%d/%m/%Y") %></span>
            </div>
            <div>
              <span class="text-blue-600 font-medium">Turma:</span>
              <span class="text-gray-700 ml-2"><%= @turma.nome %> - <%= @turma.serie %>º ano</span>
            </div>
            <div>
              <span class="text-blue-600 font-medium">Turno:</span>
              <span class="text-gray-700 ml-2"><%= @turma.turno_humanizado %></span>
            </div>
          </div>
        </div>

        <!-- Professor -->
        <div class="mb-6">
          <%= form.label :professor_id, "Professor *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :professor_id,
                options_from_collection_for_select(
                  Professor.all.order(:nome),
                  :id,
                  :nome,
                  @frequencia.professor_id
                ),
                { prompt: "Selecione o professor" },
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <!-- Disciplina -->
        <div class="mb-6">
          <%= form.label :disciplina_id, "Disciplina *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :disciplina_id,
                options_from_collection_for_select(
                  @turma.disciplinas.order(:nome),
                  :id,
                  :nome,
                  @frequencia.disciplina_id
                ),
                { prompt: "Selecione a disciplina" },
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <!-- Data da Aula -->
        <div class="mb-6">
          <%= form.label :data_aula, "Data da Aula *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.date_field :data_aula,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <!-- Conteúdo Trabalhado -->
        <div class="mb-6">
          <%= form.label :conteudo_trabalhado, "Conteúdo Trabalhado", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :conteudo_trabalhado, 
                placeholder: "Ex: Análise combinatória, permutação...", 
                rows: 4, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <p class="mt-1 text-xs text-gray-500">Descreva os tópicos e conceitos abordados durante a aula</p>
        </div>

        <!-- Observações Gerais -->
        <div class="mb-6">
          <%= form.label :observacoes, "Observações Gerais da Aula", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :observacoes, 
                placeholder: "Observações gerais sobre a aula, comportamento da turma, ocorrências...", 
                rows: 4, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:text-base focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <p class="mt-1 text-xs text-gray-500">Registre informações relevantes sobre a aula, dificuldades encontradas ou destaques</p>
        </div>

        <!-- Resumo de Presenças (Somente visualização) -->
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-3 flex items-center">
            <svg class="w-5 h-5 text-gray-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Resumo de Presenças
          </h3>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-white rounded-lg p-3 border border-green-200">
              <div class="text-2xl font-bold text-green-600">
                <%= @frequencia_alunos.where(status: 'presente').count %>
              </div>
              <div class="text-xs text-gray-600 mt-1">Presentes</div>
            </div>
            <div class="bg-white rounded-lg p-3 border border-red-200">
              <div class="text-2xl font-bold text-red-600">
                <%= @frequencia_alunos.where(status: 'falta').count %>
              </div>
              <div class="text-xs text-gray-600 mt-1">Ausentes</div>
            </div>
            <div class="bg-white rounded-lg p-3 border border-yellow-200">
              <div class="text-2xl font-bold text-yellow-600">
                <%= @frequencia_alunos.where(status: 'falta_justificada').count %>
              </div>
              <div class="text-xs text-gray-600 mt-1">Justificadas</div>
            </div>
          </div>
          <div class="mt-3 p-3 bg-blue-50 border border-blue-200 rounded-lg">
            <p class="text-xs text-blue-800 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Para editar as presenças individuais dos alunos, acesse a 
              <%= link_to "página de visualização", escola_frequencia_path(@escola, @frequencia), class: "font-medium underline hover:text-blue-900" %>
            </p>
          </div>
        </div>

        <!-- Botões de Ação -->
        <div class="flex flex-col sm:flex-row gap-3 sm:justify-between">
          <div class="flex flex-col sm:flex-row gap-3">
            <%= link_to "Cancelar", 
                  escola_frequencia_path(@escola, @frequencia), 
                  class: "w-full sm:w-auto text-center px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg font-medium transition-colors" %>
            
            <%= form.submit "Salvar Alterações", 
                  class: "w-full sm:w-auto px-6 py-3 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors cursor-pointer shadow-md hover:shadow-lg" %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Card de Ajuda -->
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-blue-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="flex-1">
          <h4 class="text-sm font-semibold text-blue-900 mb-1">Dica</h4>
          <p class="text-xs text-blue-800">
            Esta página permite editar as informações gerais da aula, incluindo professor, disciplina e data. 
            Para alterar as presenças individuais dos alunos, vá para a página de visualização da frequência.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>


<style>
/* Estilos para melhorar a aparência dos selects */
select:focus {
  outline: none;
}

/* Animação suave para os cards de resumo */
.bg-white.rounded-lg.p-3 {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.bg-white.rounded-lg.p-3:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}
</style>