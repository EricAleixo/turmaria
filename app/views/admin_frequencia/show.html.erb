<div class="min-h-screen bg-gray-50 p-3 sm:p-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-4 sm:mb-6">
      <div class="flex flex-col gap-3">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-1 sm:mb-2">
            Frequência - <%= @frequencia.data_aula.strftime("%d/%m/%Y") %>
          </h1>
          <p class="text-sm sm:text-base text-gray-600">
            Turma: <span class="font-medium text-green-600"><%= @frequencia.turma.nome %></span> - <%= @frequencia.turma.escola.nome %>
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <%= link_to escola_frequencias_path(@escola), class: "w-full sm:w-auto text-center bg-gray-500 hover:bg-gray-600 text-white px-4 py-2.5 rounded-lg font-medium transition-all hover:shadow-lg text-sm sm:text-base flex items-center justify-center gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Voltar para Frequências
          <% end %>
          <%= link_to edit_escola_frequencia_path(@escola, @frequencia), class: "w-full sm:w-auto text-center bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-4 py-2.5 rounded-lg font-medium transition-all hover:shadow-lg text-sm sm:text-base flex items-center justify-center gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
            Editar Frequência
          <% end %>
          <button type="button" onclick="modal_excluir_frequencia.showModal()" class="cursor-pointer w-full sm:w-auto text-center px-6 py-3 bg-red-500 hover:bg-red-600 text-white rounded-lg font-medium transition-colors shadow-md hover:shadow-lg flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
            Excluir
          </button>
        </div>
      </div>
    </div>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-6">
      <!-- Professor Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 sm:p-6">
        <div class="flex items-center gap-4">
          <div class="flex-shrink-0">
            <% if @frequencia.professor.foto.attached? %>
              <%= image_tag @frequencia.professor.foto, class: "h-16 w-16 rounded-full object-cover border-3 border-green-200" %>
            <% else %>
              <div class="h-16 w-16 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                <span class="text-white text-xl font-bold">
                  <%= @frequencia.professor.nome.first.upcase %>
                </span>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-gray-500">Professor</p>
            <p class="text-base sm:text-lg font-bold text-gray-900 truncate"><%= @frequencia.professor.nome %></p>
            <p class="text-xs sm:text-sm text-gray-600 truncate"><%= @frequencia.professor.email %></p>
          </div>
        </div>
      </div>

      <!-- Disciplina Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 sm:p-6">
        <div class="flex items-center gap-4">
          <div class="p-3 rounded-full bg-green-100 text-green-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-gray-500">Disciplina</p>
            <p class="text-base sm:text-lg font-bold text-gray-900 truncate"><%= @frequencia.disciplina&.nome || "N/A" %></p>
          </div>
        </div>
      </div>

      <!-- Data/Hora Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 sm:p-6">
        <div class="flex items-center gap-4">
          <div class="p-3 rounded-full bg-green-100 text-green-600">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs sm:text-sm font-medium text-gray-500">Cadastrado em</p>
            <p class="text-base sm:text-lg font-bold text-gray-900"><%= @frequencia.created_at.strftime("%d/%m/%Y") %></p>
            <p class="text-xs sm:text-sm text-gray-600"><%= @frequencia.created_at.strftime("%H:%M") %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-8">
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl shadow-lg p-4 sm:p-6 transform hover:scale-105 transition-transform">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-white/20 text-white mb-2 sm:mb-0 self-start sm:self-auto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <div class="sm:ml-4 text-white">
            <p class="text-xs sm:text-sm font-medium opacity-90">Total de Alunos</p>
            <p class="text-2xl sm:text-3xl font-bold"><%= @frequencia.total_alunos %></p>
          </div>
        </div>
      </div>

      <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl shadow-lg p-4 sm:p-6 transform hover:scale-105 transition-transform">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-white/20 text-white mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4 text-white">
            <p class="text-xs sm:text-sm font-medium opacity-90">Presentes</p>
            <p class="text-2xl sm:text-3xl font-bold"><%= @frequencia.total_presentes %></p>
          </div>
        </div>
      </div>

      <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-xl shadow-lg p-4 sm:p-6 transform hover:scale-105 transition-transform">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-white/20 text-white mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4 text-white">
            <p class="text-xs sm:text-sm font-medium opacity-90">Faltas</p>
            <p class="text-2xl sm:text-3xl font-bold"><%= @frequencia.total_faltas %></p>
          </div>
        </div>
      </div>

      <div class="bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-xl shadow-lg p-4 sm:p-6 transform hover:scale-105 transition-transform">
        <div class="flex flex-col sm:flex-row sm:items-center">
          <div class="p-2 sm:p-3 rounded-full bg-white/20 text-white mb-2 sm:mb-0 self-start sm:self-auto">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="sm:ml-4 text-white">
            <p class="text-xs sm:text-sm font-medium opacity-90">Justificadas</p>
            <p class="text-2xl sm:text-3xl font-bold"><%= @frequencia.total_justificadas %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Conteúdo Trabalhado e Observações -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
      <!-- Conteúdo Trabalhado -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
            Conteúdo Trabalhado
          </h2>
          <% if @frequencia.conteudo_trabalhado.present? %>
            <div class="bg-green-50 border border-green-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.conteudo_trabalhado %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhum conteúdo foi registrado para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Observações Gerais -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="p-4 sm:p-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
            </svg>
            Observações Gerais da Aula
          </h2>
          <% if @frequencia.observacoes.present? %>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-800"><%= @frequencia.observacoes %></p>
            </div>
          <% else %>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 sm:p-4">
              <p class="text-sm sm:text-base text-gray-500 italic">Nenhuma observação foi registrada para esta aula.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Lista de Alunos -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
      <div class="p-4 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h2 class="text-lg sm:text-xl font-bold text-gray-900 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-green-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
            </svg>
            Lista de Presença
          </h2>
          <div class="text-xs sm:text-sm text-gray-600 bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-lg px-4 py-2">
            Percentual de Presença: <span class="font-bold text-green-600"><%= @frequencia.percentual_presenca %>%</span>
          </div>
        </div>

        <% if @frequencia_alunos.any? %>
          <!-- Desktop Table -->
          <div class="hidden lg:block overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gradient-to-r from-green-50 to-emerald-50">
                <tr>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                    #
                  </th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                    Aluno
                  </th>
                  <th class="px-6 py-4 text-center text-xs font-semibold text-green-700 uppercase tracking-wider">
                    Status
                  </th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                    Observações
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                <% @frequencia_alunos.each_with_index do |fa, index| %>
                  <tr class="hover:bg-green-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      <%= index + 1 %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center gap-3">
                        <div class="flex-shrink-0 h-10 w-10">
                          <% if fa.aluno.foto.attached? %>
                            <%= image_tag fa.aluno.foto, class: "h-10 w-10 rounded-full object-cover border-2 border-green-200" %>
                          <% else %>
                            <div class="h-10 w-10 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                              <span class="text-white text-sm font-bold">
                                <%= fa.aluno.nome.first.upcase %>
                              </span>
                            </div>
                          <% end %>
                        </div>
                        <div>
                          <div class="text-sm font-medium text-gray-900">
                            <%= fa.aluno.nome %>
                          </div>
                          <div class="text-xs text-gray-500">
                            <%= fa.aluno.email %>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                      <% case fa.status %>
                      <% when 'presente' %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          Presente
                        </span>
                      <% when 'falta_justificada' %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          Justificada
                        </span>
                      <% when 'falta' %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-red-100 text-red-800">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          Falta
                        </span>
                      <% else %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          Indefinido
                        </span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4">
                      <% if fa.observacoes.present? %>
                        <p class="text-sm text-gray-700 max-w-md"><%= fa.observacoes %></p>
                      <% else %>
                        <p class="text-sm text-gray-400 italic">Sem observações</p>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Mobile Cards -->
          <div class="lg:hidden space-y-3">
            <% @frequencia_alunos.each_with_index do |fa, index| %>
              <div class="bg-gray-50 rounded-lg border border-gray-200 p-4">
                <div class="flex items-start gap-3 mb-3">
                  <div class="flex-shrink-0 h-12 w-12">
                    <% if fa.aluno.foto.attached? %>
                      <%= image_tag fa.aluno.foto, class: "h-12 w-12 rounded-full object-cover border-2 border-green-200" %>
                    <% else %>
                      <div class="h-12 w-12 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                        <span class="text-white font-bold">
                          <%= fa.aluno.nome.first.upcase %>
                        </span>
                      </div>
                    <% end %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-gray-900 truncate"><%= fa.aluno.nome %></p>
                        <p class="text-xs text-gray-500 truncate"><%= fa.aluno.email %></p>
                      </div>
                      <span class="text-xs font-medium text-gray-500">#<%= index + 1 %></span>
                    </div>
                  </div>
                </div>
                
                <div class="flex items-center justify-between pt-3 border-t border-gray-200">
                  <span class="text-xs font-medium text-gray-600">Status:</span>
                  <% case fa.status %>
                  <% when 'presente' %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Presente
                    </span>
                  <% when 'falta_justificada' %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Justificada
                    </span>
                  <% when 'falta' %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-800">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Falta
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-800">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      Indefinido
                    </span>
                  <% end %>
                </div>

                <% if fa.observacoes.present? %>
                  <div class="mt-3 pt-3 border-t border-gray-200">
                    <p class="text-xs font-medium text-gray-600 mb-1">Observações:</p>
                    <p class="text-sm text-gray-700"><%= fa.observacoes %></p>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <!-- Empty State -->
          <div class="text-center py-12">
            <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path>
            </svg>
            <h3 class="mt-4 text-base sm:text-lg font-semibold text-gray-900">Nenhum aluno encontrado</h3>
            <p class="mt-2 text-sm text-gray-500">Esta frequência não possui registros de alunos.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>


<!-- Modal de Confirmação de Exclusão -->
<dialog id="modal_excluir_frequencia" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box">
    <div class="flex items-center gap-4 mb-4">
      <div class="flex-shrink-0">
        <div class="bg-red-100 rounded-full p-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-red-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
          </svg>
        </div>
      </div>
      <div>
        <h3 class="font-bold text-xl text-gray-900">Excluir Frequência</h3>
        <p class="text-sm text-gray-500">Esta ação não pode ser desfeita</p>
      </div>
    </div>
    
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-gray-700 mb-3">
        <strong class="text-red-700">Atenção:</strong> Você está prestes a excluir permanentemente a frequência da data 
        <strong><%= @frequencia.data_aula.strftime("%d/%m/%Y") %></strong> da turma 
        <strong><%= @frequencia.turma.nome %></strong>.
      </p>
      <ul class="text-sm text-gray-600 space-y-1 list-disc list-inside">
        <li>Todos os registros de presença dos alunos serão apagados</li>
        <li>As informações de conteúdo e observações serão perdidas</li>
        <li>Esta ação é <strong class="text-red-600">irreversível</strong></li>
      </ul>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
      <h4 class="text-sm font-semibold text-gray-700 mb-2">Dados da Frequência:</h4>
      <div class="grid grid-cols-2 gap-3 text-xs">
        <div>
          <span class="text-gray-500">Turma:</span>
          <p class="font-medium text-gray-900"><%= @frequencia.turma.nome %></p>
        </div>
        <div>
          <span class="text-gray-500">Data:</span>
          <p class="font-medium text-gray-900"><%= @frequencia.data_aula.strftime("%d/%m/%Y") %></p>
        </div>
        <div>
          <span class="text-gray-500">Professor:</span>
          <p class="font-medium text-gray-900"><%= @frequencia.professor.nome %></p>
        </div>
        <div>
          <span class="text-gray-500">Disciplina:</span>
          <p class="font-medium text-gray-900"><%= @frequencia.disciplina&.nome || "N/A" %></p>
        </div>
        <div>
          <span class="text-gray-500">Total de Alunos:</span>
          <p class="font-medium text-gray-900"><%= @frequencia.total_alunos %></p>
        </div>
        <div>
          <span class="text-gray-500">Presenças:</span>
          <p class="font-medium text-green-600"><%= @frequencia.total_presentes %></p>
        </div>
      </div>
    </div>
    
    <div class="modal-action flex-col sm:flex-row gap-2">
      <form method="dialog" class="w-full sm:w-auto order-2 sm:order-1">
        <button class="btn btn-ghost w-full sm:w-auto">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
          Cancelar
        </button>
      </form>
      <%= button_to escola_frequencia_path(@escola, @frequencia), 
            method: :delete, 
            data: { turbo: false },
            class: "btn btn-error text-white w-full sm:w-auto order-1 sm:order-2",
            form: { onsubmit: "modal_excluir_frequencia.close()" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
        Sim, Excluir Permanentemente
      <% end %>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>fechar</button>
  </form>
</dialog>