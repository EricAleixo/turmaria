<div class="container mx-auto px-4 py-8">
  <!-- Header -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
          Frequências - <%= @escola.nome %>
        </h1>
        <p class="text-gray-600 mt-2 text-sm sm:text-base">
          Gerencie todas as frequências registradas na escola
        </p>
      </div>
      <div class="flex gap-3">
        <%= link_to @escola, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2.5 rounded-lg font-medium transition-all hover:shadow-lg flex items-center justify-center gap-2 text-sm sm:text-base" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <span class="hidden sm:inline">Voltar para Escola</span>
          <span class="sm:hidden">Voltar</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Filtros -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-500">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
      </svg>
      Filtros
    </h2>
    <%= form_with url: escola_frequencias_path(@escola), method: :get, local: true, class: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" do |f| %>
      <!-- Filtro por Turma -->
      <div>
        <%= f.label :turma_id, "Turma", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :turma_id, 
            options_from_collection_for_select(@escola.turmas.order(:nome), :id, :nome, params[:turma_id]),
            { include_blank: "Todas as turmas" },
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all" %>
      </div>

      <!-- Filtro por Disciplina -->
      <div>
        <%= f.label :disciplina_id, "Disciplina", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :disciplina_id,
            options_from_collection_for_select(@escola.disciplinas.order(:nome), :id, :nome, params[:disciplina_id]),
            { include_blank: "Todas as disciplinas" },
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all" %>
      </div>

      <!-- Filtro por Professor -->
      <div>
        <%= f.label :professor_id, "Professor", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.select :professor_id,
            options_from_collection_for_select(@escola.professors.order(:nome), :id, :nome, params[:professor_id]),
            { include_blank: "Todos os professores" },
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all" %>
      </div>

      <!-- Filtro por Data -->
      <div>
        <%= f.label :data, "Data", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.date_field :data,
            value: params[:data],
            class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all" %>
      </div>

      <!-- Botões -->
      <div class="sm:col-span-2 lg:col-span-4 flex flex-col sm:flex-row gap-2">
        <%= f.submit "Filtrar", class: "bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-6 py-2.5 rounded-lg font-medium transition-all hover:shadow-lg cursor-pointer" %>
        <%= link_to "Limpar Filtros", escola_frequencias_path(@escola), class: "bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-2.5 rounded-lg font-medium transition-all text-center" %>
      </div>
    <% end %>
  </div>

  <!-- Cards de Estatísticas -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-6">
    <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl shadow-lg p-6 text-white transform hover:scale-105 transition-transform">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-green-100 text-sm font-medium">Total de Registros</p>
          <p class="text-3xl font-bold mt-2"><%= @frequencias.count %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-green-200">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
        </svg>
      </div>
    </div>

    <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl shadow-lg p-6 text-white transform hover:scale-105 transition-transform">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-emerald-100 text-sm font-medium">Turmas Ativas</p>
          <p class="text-3xl font-bold mt-2"><%= @frequencias.distinct.count(:turma_id) %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-emerald-200">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
      </div>
    </div>

    <div class="bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl shadow-lg p-6 text-white transform hover:scale-105 transition-transform">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-teal-100 text-sm font-medium">Professores</p>
          <p class="text-3xl font-bold mt-2"><%= @frequencias.distinct.count(:professor_id) %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-teal-200">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
        </svg>
      </div>
    </div>

    <div class="bg-gradient-to-br from-lime-500 to-lime-600 rounded-xl shadow-lg p-6 text-white transform hover:scale-105 transition-transform">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-lime-100 text-sm font-medium">Este Mês</p>
          <p class="text-3xl font-bold mt-2"><%= @frequencias.where("data_aula >= ?", Date.today.beginning_of_month).count %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-lime-200">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Tabela Desktop / Cards Mobile -->
  <% if @frequencias.any? %>
    <!-- Desktop Table (hidden on mobile) -->
    <div class="hidden lg:block bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gradient-to-r from-green-50 to-emerald-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Data
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Turma
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Disciplina
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Professor
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Conteúdo Trabalhado
              </th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-green-700 uppercase tracking-wider">
                Cadastrado em
              </th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-green-700 uppercase tracking-wider">
                Ações
              </th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @frequencias.each do |frequencia| %>
              <tr class="hover:bg-green-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-500">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                    </svg>
                    <span class="text-sm font-medium text-gray-900">
                      <%= frequencia.data_aula.strftime("%d/%m/%Y") %>
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <%= frequencia.turma.nome %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm text-gray-900">
                    <%= frequencia.disciplina&.nome || "N/A" %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <div class="flex-shrink-0 h-8 w-8">
                      <% if frequencia.professor.foto.attached? %>
                        <%= image_tag frequencia.professor.foto, class: "h-8 w-8 rounded-full object-cover border-2 border-green-200" %>
                      <% else %>
                        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                          <span class="text-white text-xs font-bold">
                            <%= frequencia.professor.nome.first.upcase %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                    <div>
                      <div class="text-sm font-medium text-gray-900">
                        <%= frequencia.professor.nome %>
                      </div>
                      <div class="text-xs text-gray-500">
                        <%= frequencia.professor.email %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-900 max-w-xs">
                    <%= truncate(frequencia.conteudo_trabalhado, length: 60) %>
                  </div>
                  <% if frequencia.observacoes.present? %>
                    <div class="text-xs text-green-600 mt-1 flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                      </svg>
                      Com observações
                    </div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900">
                    <%= frequencia.created_at.strftime("%d/%m/%Y") %>
                  </div>
                  <div class="text-xs text-gray-500">
                    <%= frequencia.created_at.strftime("%H:%M") %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex justify-end gap-2">
                    <%= link_to escola_frequencia_path(@escola, frequencia), class: "text-green-600 hover:text-green-900 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_frequencia_path(@escola, frequencia), class: "text-blue-600 hover:text-blue-900 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>
                    <%= link_to escola_frequencia_path(@escola, frequencia), 
                        method: :delete, 
                        data: { confirm: "Tem certeza que deseja excluir esta frequência?" },
                        class: "text-red-600 hover:text-red-900 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile Cards (visible only on mobile) -->
    <div class="lg:hidden space-y-4">
      <% @frequencias.each do |frequencia| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
          <!-- Card Header -->
          <div class="bg-gradient-to-r from-green-500 to-green-600 px-4 py-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
                <span class="font-semibold"><%= frequencia.data_aula.strftime("%d/%m/%Y") %></span>
              </div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= frequencia.turma.nome %>
              </span>
            </div>
          </div>

          <!-- Card Body -->
          <div class="p-4 space-y-3">
            <!-- Professor -->
            <div class="flex items-center gap-3 pb-3 border-b border-gray-100">
              <div class="flex-shrink-0 h-10 w-10">
                <% if frequencia.professor.foto.attached? %>
                  <%= image_tag frequencia.professor.foto, class: "h-10 w-10 rounded-full object-cover border-2 border-green-200" %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
                    <span class="text-white text-sm font-bold">
                      <%= frequencia.professor.nome.first.upcase %>
                    </span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-gray-900 truncate">
                  <%= frequencia.professor.nome %>
                </div>
                <div class="text-xs text-gray-500 truncate">
                  <%= frequencia.professor.email %>
                </div>
              </div>
            </div>

            <!-- Disciplina -->
            <div class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-500 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
              <div class="flex-1">
                <div class="text-xs text-gray-500 uppercase font-medium">Disciplina</div>
                <div class="text-sm text-gray-900 font-medium">
                  <%= frequencia.disciplina&.nome || "N/A" %>
                </div>
              </div>
            </div>

            <!-- Conteúdo -->
            <div class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-green-500 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              <div class="flex-1">
                <div class="text-xs text-gray-500 uppercase font-medium">Conteúdo Trabalhado</div>
                <div class="text-sm text-gray-900 mt-1">
                  <%= frequencia.conteudo_trabalhado %>
                </div>
                <% if frequencia.observacoes.present? %>
                  <div class="text-xs text-green-600 mt-2 flex items-center gap-1 bg-green-50 px-2 py-1 rounded inline-flex">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                    </svg>
                    Com observações
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Cadastrado em -->
            <div class="flex items-center gap-2 text-xs text-gray-500 pt-2 border-t border-gray-100">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Cadastrado em <%= frequencia.created_at.strftime("%d/%m/%Y às %H:%M") %>
            </div>
          </div>

          <!-- Card Footer - Actions -->
          <div class="bg-gray-50 px-4 py-3 flex justify-end gap-2 border-t border-gray-100">
            <%= link_to escola_frequencia_path(@escola, frequencia), class: "inline-flex items-center gap-1.5 text-green-600 hover:text-green-900 font-medium text-sm transition-colors px-3 py-1.5 rounded-lg hover:bg-green-100" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
              Ver
            <% end %>
            <%= link_to edit_escola_frequencia_path(@escola, frequencia), class: "inline-flex items-center gap-1.5 text-blue-600 hover:text-blue-900 font-medium text-sm transition-colors px-3 py-1.5 rounded-lg hover:bg-blue-100" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
              Editar
            <% end %>
            <%= link_to escola_frequencia_path(@escola, frequencia), 
                method: :delete, 
                data: { confirm: "Tem certeza que deseja excluir esta frequência?" },
                class: "inline-flex items-center gap-1.5 text-red-600 hover:text-red-900 font-medium text-sm transition-colors px-3 py-1.5 rounded-lg hover:bg-red-100" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
              Excluir
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12">
      <div class="flex flex-col items-center justify-center text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-20 h-20 text-gray-300 mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Nenhuma frequência encontrada</h3>
        <p class="text-gray-500 mb-4 max-w-md">
          <%= params[:turma_id].present? || params[:disciplina_id].present? || params[:professor_id].present? || params[:data].present? ? 
              "Tente ajustar os filtros para ver mais resultados." : 
              "Ainda não há registros de frequência para esta escola." %>
        </p>
        <% if params[:turma_id].present? || params[:disciplina_id].present? || params[:professor_id].present? || params[:data].present? %>
          <%= link_to "Limpar Filtros", escola_frequencias_path(@escola), class: "bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-6 py-2.5 rounded-lg font-medium transition-all hover:shadow-lg inline-flex items-center gap-2" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Paginação -->
  <% if @frequencias.respond_to?(:total_pages) && @frequencias.total_pages > 1 %>
    <div class="mt-6 flex justify-center">
      <%= paginate @frequencias, theme: 'twitter-bootstrap-4' %>
    </div>
  <% end %>
</div>