<!-- Container principal com gradiente de fundo -->
<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <main class="flex-1 p-4 sm:p-8">
        
        <!-- Header com breadcrumb e info do estado -->
        <div class="mb-8">
            <!-- Breadcrumb -->
            <nav class="flex items-center gap-2 text-sm mb-4">
                <%= link_to estados_path, class: "text-gray-500 hover:text-green-600 transition-colors flex items-center gap-1" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    Estados
                <% end %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
                <span class="text-green-600 font-medium"><%= @estado.nome %></span>
            </nav>

            <!-- Header principal -->
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-800">
                        Cidades - <%= @estado.nome %>
                    </h1>
                    <p class="text-gray-500 text-sm sm:text-base mt-1">
                        Gerencie os municípios do estado <span class="font-semibold text-gray-700"><%= @estado.sigla.present? ? @estado.sigla : "sem sigla" %></span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Cards de Resumo -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-8">
            
            <!-- Total de Cidades -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-green-600 bg-green-50 px-3 py-1 rounded-full">Cidades</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Total de Municípios</h2>
                    <p class="text-4xl font-bold text-gray-800">
                        <%= @cidades.count %>
                    </p>
                </div>
            </div>

            <!-- Nome do Estado -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">Estado</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Nome do Estado</h2>
                    <p class="text-2xl font-bold text-gray-800 truncate">
                        <%= @estado.nome.present? ? @estado.nome : "Sem nome" %>
                    </p>
                </div>
            </div>

            <!-- Sigla/UF -->
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center shadow-md">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-purple-600 bg-purple-50 px-3 py-1 rounded-full">UF</span>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-500 mb-2">Sigla do Estado</h2>
                    <p class="text-4xl font-bold text-gray-800">
                        <%= @estado.sigla.present? ? @estado.sigla : "--" %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Barra de Ações -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
            <div class="text-sm text-gray-600">
                Mostrando <span class="font-semibold text-gray-800"><%= @cidades.count %></span> <%= @cidades.count == 1 ? 'cidade' : 'cidades' %>
            </div>
            <div class="flex gap-3 w-full sm:w-auto">
                <%= link_to estados_path, class: 'btn btn-outline border-gray-300 hover:border-green-600 hover:bg-green-50 hover:text-green-600 gap-2 flex-1 sm:flex-initial' do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    Voltar
                <% end %>
                <%= link_to new_estado_cidade_path(@estado), class: 'btn bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white border-0 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 gap-2 flex-1 sm:flex-initial' do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Adicionar Cidade
                <% end %>
            </div>
        </div>

        <!-- Tabela de Cidades -->
        <% if @cidades.any? %>
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="table w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center">
                                    <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">#</span>
                                </th>
                                <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-6 text-left">
                                    <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Nome da Cidade</span>
                                </th>
                                <th class="bg-gradient-to-br from-gray-50 to-gray-100 py-4 px-4 text-center">
                                    <span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Ações</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <% @cidades.each_with_index do |cidade, index| %>
                                <tr class="border-b border-gray-100 hover:bg-gradient-to-r hover:from-green-50/40 hover:to-transparent transition-all duration-200 group">
                                    
                                    <!-- Número -->
                                    <td class="py-4 px-4 text-center">
                                        <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-gray-100 to-gray-200 text-gray-700 font-bold text-sm group-hover:from-green-100 group-hover:to-green-200 group-hover:text-green-700 transition-all duration-200 mx-auto shadow-sm">
                                            <%= index + 1 %>
                                        </div>
                                    </td>
                                    
                                    <!-- Nome da Cidade -->
                                    <td class="py-4 px-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-200">
                                                <%= cidade.nome.present? ? cidade.nome[0].upcase : "?" %>
                                            </div>
                                            <span class="text-base font-bold text-gray-800">
                                                <%= cidade.nome.present? ? cidade.nome : "Sem nome" %>
                                            </span>
                                        </div>
                                    </td>
                                    
                                    <!-- Ações -->
                                    <td class="py-4 px-4">
                                        <div class="flex items-center justify-center gap-2">

                                            <%= link_to admin_cidade_path(cidade), 
                                                class: "btn btn-sm btn-circle bg-gradient-to-br from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                                title: "Editar cidade" do %>
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                                </svg>
                                            <% end %>

                                            <!-- Botão Editar -->
                                            <%= link_to edit_estado_cidade_path(@estado, cidade), 
                                                class: "btn btn-sm btn-circle bg-gradient-to-br from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                                title: "Editar cidade" do %>
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                                </svg>
                                            <% end %>

                                            <!-- Botão Excluir -->
                                            <%= link_to confirm_delete_estado_cidade_path(@estado, cidade), 
                                                class: "btn btn-sm btn-circle bg-gradient-to-br from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white border-0 shadow-md hover:shadow-lg hover:scale-110 transition-all duration-200", 
                                                title: "Deletar cidade" do %>
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                                </svg>
                                            <% end %>
                                        </div>
                                    </td>
                                </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% else %>
            <!-- Empty State -->
            <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-16">
                <div class="text-center">
                    <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-gray-400">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-700 mb-2">Nenhuma cidade cadastrada</h3>
                    <p class="text-gray-500 mb-6">Comece adicionando a primeira cidade de <%= @estado.nome %></p>
                    <%= link_to new_estado_cidade_path(@estado), class: 'btn bg-gradient-to-r from-green-600 to-green-700 text-white border-0 gap-2' do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                        Adicionar Primeira Cidade
                    <% end %>
                </div>
            </div>
        <% end %>
    </main>
</div>