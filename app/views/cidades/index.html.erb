<div class="min-h-screen flex bg-base-200">
  <main class="flex-1 px-8 py-10">
    <!-- Título principal -->
    <h1 class="text-4xl font-bold mb-2">Cidades de <%= @estado.nome %></h1>
    <p class="text-gray-600 mb-8">
      Gerencie as cidades do estado de <%= @estado.nome %>
    </p>

    <!-- Cards de resumo -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Total de cidades -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">Total de Cidades</h2>
          <p class="text-3xl font-bold text-success"><%= @cidades.count %></p>
        </div>
      </div>

      <!-- Nome do estado -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">Estado</h2>
          <p class="text-2xl font-bold text-primary"><%= @estado.nome %></p>
        </div>
      </div>

      <!-- Sigla do estado -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body items-center text-center">
          <h2 class="card-title text-gray-500">UF</h2>
          <p class="text-2xl font-bold text-info"><%= @estado.sigla %></p>
        </div>
      </div>
    </div>

    <!-- Botão para adicionar nova cidade -->
    <div class="flex justify-end mb-4">
      <%= link_to 'Adicionar Cidade', new_estado_cidade_path(@estado), class: 'btn btn-success' %>
    </div>

    <!-- Tabela com as cidades -->
    <div class="overflow-x-auto bg-base-100 shadow rounded-lg">
      <table class="table table-zebra w-full text-center">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome da Cidade</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @cidades.each_with_index do |cidade, index| %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= cidade.nome %></td>
              <td class="space-x-2">
                <!-- Botão editar -->
                <%= link_to edit_estado_cidade_path(@estado, cidade), class: 'btn btn-xs btn-outline btn-info', title: "Editar" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0L16.862 3.426l3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712L3.651 16.637a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.2Z" />
                  </svg>
                <% end %>

                
                <!-- Botão excluir -->
                <%= link_to confirm_delete_estado_cidade_path(@estado, cidade),
                    class: 'btn btn-xs btn-outline btn-error',
                    title: 'Excluir' do %>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                        <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd" />
                    </svg>
                <% end %>

              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </main>
</div>
