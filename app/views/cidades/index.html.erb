<style>
    /* Definindo a fonte Inter como padrão e cores base */
    :root { font-family: 'Inter', sans-serif; }
    /* Ajustes de cores e estilos mantidos na view para simular o tema */
    .bg-base-100 { background-color: #ffffff; }
    .text-primary { color: #3b82f6; } 
    .text-success { color: #10b981; }
    .bg-success { background-color: #10b981; }
    .text-info { color: #06b6d4; }
    .text-error { color: #ef4444; }
    .border-info { border-color: #06b6d4; }
    .border-error { border-color: #ef4444; }
    .rounded-lg { border-radius: 0.5rem; }
</style>

<!-- Container principal com a cor de fundo e layout flex. -->
<div class="min-h-screen flex bg-gray-50">
    <!-- Ajuste de Padding para Responsividade: p-4 em mobile, p-8 em telas maiores -->
    <main class="flex-1 p-4 sm:p-8">
        
        <!-- Título Responsivo -->
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-800 mb-2">
            Cidades de <%= @estado.nome %>
        </h1>
        <p class="text-gray-500 mb-6 sm:mb-8 text-sm sm:text-base">
            Gerencie as cidades do estado de <%= @estado.nome %>
        </p>

        <!-- Cards de resumo -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-8">
            
            <!-- Total de cidades -->
            <div class="bg-base-100 shadow-xl rounded-lg border border-gray-100">
                <div class="items-center text-center p-4">
                    <h2 class="text-sm font-semibold text-gray-400">Total de Cidades</h2>
                    <p class="text-2xl sm:text-3xl font-bold text-success mt-1"><%= @cidades.count %></p>
                </div>
            </div>

            <!-- Nome do estado -->
            <div class="bg-base-100 shadow-xl rounded-lg border border-gray-100">
                <div class="items-center text-center p-4">
                    <h2 class="text-sm font-semibold text-gray-400">Estado</h2>
                    <p class="text-xl sm:text-2xl font-bold text-primary mt-1"><%= @estado.nome %></p>
                </div>
            </div>

            <!-- Sigla do estado -->
            <div class="bg-base-100 shadow-xl rounded-lg border border-gray-100">
                <div class="items-center text-center p-4">
                    <h2 class="text-sm font-semibold text-gray-400">UF</h2>
                    <p class="text-xl sm:text-2xl font-bold text-info mt-1"><%= @estado.sigla %></p>
                </div>
            </div>
        </div>

        <!-- Botões de Ação -->
        <div class="flex justify-between items-center mb-4">
            <%# Botão Voltar %>
            <%= link_to 'Voltar aos Estados', estados_path, class: 'px-4 py-2 text-primary border border-primary rounded-lg shadow-sm hover:bg-gray-100 transition duration-150' %>
            
            <%# Botão para adicionar nova cidade %>
            <%= link_to 'Adicionar Cidade', new_estado_cidade_path(@estado), class: 'px-4 py-2 text-white font-semibold rounded-lg shadow-md hover:bg-green-600 transition duration-150 bg-success' %>
        </div>

        <!-- Tabela com as cidades -->
        <div class="overflow-x-auto bg-base-100 shadow-xl rounded-lg">
            <table class="w-full text-center min-w-[400px]">
                <thead>
                    <tr class="text-xs sm:text-sm text-gray-600 uppercase bg-gray-50 border-b">
                        <th class="py-3 px-2 sm:px-4">#</th>
                        <th class="py-3 px-2 sm:px-4 text-left">Nome da Cidade</th>
                        <th class="py-3 px-2 sm:px-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% @cidades.each_with_index do |cidade, index| %>
                        <tr class="hover:bg-gray-50 transition duration-100 text-sm">
                            <td class="py-3 px-2 sm:px-4 text-center"><%= index + 1 %></td>
                            <td class="py-3 px-2 sm:px-4 text-left font-medium text-gray-700"><%= cidade.nome %></td>
                            <td class="py-3 px-2 sm:px-4 flex justify-center items-center space-x-1 sm:space-x-2">
                                
                                <!-- Botão editar (ícone consistente) -->
                                <%= link_to edit_estado_cidade_path(@estado, cidade), 
                                    class: 'text-info border border-info p-1 rounded hover:bg-info hover:text-white transition duration-150', 
                                    title: "Editar" do %>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                                        <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.2Z" />
                                    </svg>
                                <% end %>

                                <!-- Botão excluir (ícone consistente) -->
                                <%= link_to confirm_delete_estado_cidade_path(@estado, cidade),
                                    class: 'text-error border border-error p-1 rounded hover:bg-red-600 hover:text-white transition duration-150',
                                    title: 'Excluir' do %>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                                        <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd" />
                                    </svg>
                                <% end %>

                            </td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </main>
</div>