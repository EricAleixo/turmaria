<div class="min-h-screen flex bg-base-200">
  <main class="flex-1 px-8 py-10 max-w-lg mx-auto">
    <h1 class="text-3xl font-bold mb-6">Cadastrar Nova Cidade para <%= @estado.nome %></h1>

    <%= form_with(model: [@estado, @cidade], local: true) do |form| %>
      <div class="mb-4">
        <%= form.label :nome, "Nome da Cidade", class: "block mb-1 font-semibold" %>
        <%= form.text_field :nome, class: "input input-bordered w-full" %>
      </div>

      <div class="flex justify-between">
        <%= link_to '← Voltar para Cidades', estado_cidades_path(@estado), class: "text-blue-600 hover:underline" %>
        <%= form.submit "Salvar Cidade", class: "btn btn-success" %>
      </div>
    <% end %>
  </main>
</div>
