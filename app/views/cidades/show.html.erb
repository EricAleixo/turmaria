<div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50 py-8 md:py-12 px-4">
  <div class="max-w-4xl mx-auto">
    
    <!-- Breadcrumb -->
    <div class="text-sm breadcrumbs mb-6">
      <ul>
        <li><%= link_to "Estados", root_path, class: "text-green-600 hover:text-green-700" %></li>
        <li><%= link_to @estado.nome, estado_cidades_path(@estado), class: "text-green-600 hover:text-green-700" %></li>
        <li class="text-gray-600"><%= @cidade.nome %></li>
      </ul>
    </div>

    <!-- Header Card -->
    <div class="card bg-white shadow-2xl border border-green-100 mb-6">
      <div class="card-body p-6 md:p-10">
        
        <!-- Title Section -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 md:w-20 md:h-20 bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl shadow-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 md:h-10 md:w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h1 class="text-3xl md:text-4xl font-bold text-gray-800"><%= @cidade.nome %></h1>
              <p class="text-gray-500 mt-1">Detalhes da cidade</p>
            </div>
          </div>

          <!-- Actions Dropdown -->
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-outline gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
              </svg>
              Ações
            </label>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-white rounded-xl w-52 border border-green-100 mt-2">
              <li>
                <%= link_to edit_estado_cidade_path(@estado, @cidade), class: "flex items-center gap-2" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                  </svg>
                  Editar
                <% end %>
              </li>
              <li>
                <%= link_to confirm_delete_estado_cidade_path(@estado, @cidade), class: "flex items-center gap-2 text-error" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                  Excluir
                <% end %>
              </li>
            </ul>
          </div>
        </div>

        <!-- Info Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <!-- Informações Básicas -->
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-700 flex items-center gap-2 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
              Informações Básicas
            </h3>

            <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-4 rounded-xl border border-green-100">
              <label class="text-sm font-medium text-gray-600 mb-1 block">Nome da Cidade</label>
              <p class="text-lg font-semibold text-gray-800"><%= @cidade.nome %></p>
            </div>

            <div class="bg-gradient-to-br from-blue-50 to-cyan-50 p-4 rounded-xl border border-blue-100">
              <label class="text-sm font-medium text-gray-600 mb-1 block">Estado</label>
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-100 to-cyan-100 flex items-center justify-center font-bold text-blue-700 text-sm">
                  <%= @estado.sigla %>
                </div>
                <div>
                  <p class="text-lg font-semibold text-gray-800"><%= @estado.nome %></p>
                  <p class="text-sm text-gray-500"><%= @estado.regiao %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Metadados -->
          <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-700 flex items-center gap-2 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
              </svg>
              Metadados
            </h3>

            <div class="bg-gradient-to-br from-purple-50 to-pink-50 p-4 rounded-xl border border-purple-100">
              <label class="text-sm font-medium text-gray-600 mb-1 block">ID do Registro</label>
              <p class="text-lg font-mono font-semibold text-gray-800">#<%= @cidade.id %></p>
            </div>

            <div class="bg-gradient-to-br from-amber-50 to-orange-50 p-4 rounded-xl border border-amber-100">
              <label class="text-sm font-medium text-gray-600 mb-1 block">Criado em</label>
              <p class="text-base font-medium text-gray-800">
                <%= @cidade.created_at.strftime("%d/%m/%Y às %H:%M") %>
              </p>
            </div>

            <div class="bg-gradient-to-br from-teal-50 to-green-50 p-4 rounded-xl border border-teal-100">
              <label class="text-sm font-medium text-gray-600 mb-1 block">Última atualização</label>
              <p class="text-base font-medium text-gray-800">
                <%= @cidade.updated_at.strftime("%d/%m/%Y às %H:%M") %>
              </p>
            </div>
          </div>

        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mt-8 pt-6 border-t border-gray-200">
          <%= link_to estado_cidades_path(@estado), class: "btn btn-outline btn-lg flex-1" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Voltar para Lista
          <% end %>
          
          <%= link_to edit_estado_cidade_path(@estado, @cidade), class: "btn btn-lg bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white border-none flex-1 shadow-lg" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
            Editar Cidade
          <% end %>
        </div>

      </div>
    </div>

    <!-- Stats Card (opcional - exemplo de expansão) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="card bg-white shadow-lg border border-green-100">
        <div class="card-body p-6 text-center">
          <div class="text-3xl font-bold text-green-600 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-2 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="text-sm text-gray-600">Status</p>
          <p class="font-semibold text-gray-800">Ativo</p>
        </div>
      </div>

      <div class="card bg-white shadow-lg border border-blue-100">
        <div class="card-body p-6 text-center">
          <div class="text-3xl font-bold text-blue-600 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-2 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="text-sm text-gray-600">Região</p>
          <p class="font-semibold text-gray-800"><%= @estado.regiao %></p>
        </div>
      </div>

      <div class="card bg-white shadow-lg border border-purple-100">
        <div class="card-body p-6 text-center">
          <div class="text-3xl font-bold text-purple-600 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-2 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
          </div>
          <p class="text-sm text-gray-600">ID Único</p>
          <p class="font-semibold text-gray-800 font-mono">#<%= @cidade.id %></p>
        </div>
      </div>
    </div>

  </div>
</div>