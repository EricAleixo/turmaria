<div class="drawer lg:drawer-open bg-gray-100">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <div class="drawer-content flex flex-col items-center">
    
    <div class="w-full p-4">
      <div class="flex items-center mb-6 lg:hidden">
        <label for="my-drawer" class="btn btn-square btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </label>
        <h1 class="text-xl font-bold ml-2">Dashboard - <%= @escola.nome %></h1>
      </div>

      <main class="w-full max-w-7xl mx-auto">
        <!-- Breadcrumb -->
        <div class="text-sm breadcrumbs mb-5">
          <ul>
            <li><%= link_to "Escolas", escolas_path, class: "text-green-600 hover:text-green-800 transition-colors duration-200" %></li>
            <li class="text-gray-600"><%= @escola.nome %></li>
          </ul>
        </div>
        
        <!-- Dashboard Header -->
        <div class="flex justify-between items-center mb-8">
          <div>
            <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
            <p class="text-gray-600 mt-1"><%= @escola.nome %></p>
          </div>
          <%= link_to new_escola_turma_path(@escola), class: "btn bg-green-500 hover:bg-green-600 text-white" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova Turma
          <% end %>
        </div>

        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <!-- Classes Card -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-center">
              <div class="text-3xl font-bold text-blue-600 mb-2"><%= @escola.turmas.count %></div>
              <div class="text-gray-600 font-medium">Turmas</div>
            </div>
          </div>
          
          <!-- Teachers Card -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-800 mb-2"><%= @escola.turmas.count %></div>
              <div class="text-gray-600 font-medium">Professores</div>
            </div>
          </div>
          
          <!-- Students Card -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-center">
              <div class="text-3xl font-bold text-green-600 mb-2"><%= @escola.alunos.count %></div>
              <div class="text-gray-600 font-medium">Alunos</div>
            </div>
          </div>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
          <!-- Recent Grades Chart -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Notas Recentes</h3>
            <div class="h-64">
              <canvas id="recentGradesChart"></canvas>
            </div>
          </div>
          
          <!-- Attendance Overview Chart -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Visão Geral de Presença</h3>
            <div class="h-64">
              <canvas id="attendanceChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Analysis Date Chart -->
        <div class="bg-white rounded-lg p-6 shadow-sm mb-8">
          <h3 class="text-lg font-semibold text-gray-800 mb-4">Análise de Dados</h3>
          <div class="h-64">
            <canvas id="analysisChart"></canvas>
          </div>
        </div>

        <!-- Quick Actions Section -->
        <div class="space-y-8">
          <!-- Turmas da Escola -->
          <div class="bg-white rounded-lg shadow-sm">
            <div class="flex justify-between items-center p-6 border-b border-gray-200">
              <h3 class="text-xl font-semibold text-gray-800">Turmas da Escola</h3>
              <%= link_to new_escola_turma_path(@escola), class: "btn btn-sm bg-blue-600 hover:bg-blue-700 text-white" do %>
                Nova Turma
              <% end %>
            </div>
            
            <% if @escola.turmas.any? %>
              <div class="p-6">
                <!-- Desktop Table View -->
                <div class="hidden md:block overflow-x-auto">
                  <table class="table w-full">
                    <thead>
                      <tr>
                        <th>Nome</th>
                        <th>Série</th>
                        <th>Turno</th>
                        <th>Alunos</th>
                        <th>Ações</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @escola.turmas.each do |turma| %>
                        <tr>
                          <td class="font-medium"><%= turma.nome %></td>
                          <td><%= turma.serie %></td>
                          <td><%= turma.turno %></td>
                          <td><%= turma.alunos.count %> alunos</td>
                          <td>
                            <div class="flex gap-2">
                              <%= link_to escola_turma_path(@escola, turma), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white", title: "Ver turma" do %>
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                              </svg>
                            <% end %>
                            <%= link_to edit_escola_turma_path(@escola, turma), class: "btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white", title: "Editar turma" do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                </svg>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
                
                <!-- Mobile Card View -->
                <div class="md:hidden space-y-3">
                  <% @escola.turmas.each do |turma| %>
                    <div class="bg-gradient-to-r from-white to-blue-50 p-5 rounded-xl shadow-md border border-blue-200 hover:shadow-lg transition-all duration-200">
                      <div class="flex items-start justify-between mb-4">
                        <div class="flex-1">
                          <div class="flex items-center mb-2">
                            <div class="w-10 h-10 bg-gradient-to-br from-green-500 to-green-600 rounded-full flex items-center justify-center mr-3">
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                              </svg>
                            </div>
                            <div>
                              <h4 class="font-bold text-lg text-gray-800"><%= turma.nome %></h4>
                              <div class="flex items-center mt-1">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 mr-2">
                                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 011.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path>
                                  </svg>
                                  <%= turma.serie %>
                                </span>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                                  </svg>
                                  <%= turma.turno %>
                                </span>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                      
                      <div class="bg-white p-3 rounded-lg border border-gray-100 mb-4">
                        <div class="flex items-center justify-between">
                          <div class="text-gray-500 text-xs font-medium">Total de Alunos</div>
                          <div class="flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-green-600 mr-1">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                            </svg>
                            <span class="font-bold text-xl text-green-600"><%= turma.alunos.count %></span>
                          </div>
                        </div>
                      </div>
                      
                      <div class="flex justify-end gap-2">
                        <%= link_to escola_turma_path(@escola, turma), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white", title: "Ver turma" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          </svg>
                        <% end %>
                        <%= link_to edit_escola_turma_path(@escola, turma), class: "btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white", title: "Editar turma" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                          </svg>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% else %>
              <div class="p-16 text-center">
                <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                </div>
                <h4 class="text-lg font-medium text-gray-600 mb-2">Nenhuma turma cadastrada</h4>
                <p class="text-gray-500 mb-6">Comece criando a primeira turma desta escola</p>
                <%= link_to new_escola_turma_path(@escola), class: "btn bg-blue-600 hover:bg-blue-700 text-white" do %>
                  Criar Primeira Turma
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Alunos da Escola -->
          <div class="bg-white rounded-lg shadow-sm">
            <div class="flex justify-between items-center p-6 border-b border-gray-200">
              <h3 class="text-xl font-semibold text-gray-800">Alunos da Escola</h3>
              <%= link_to new_escola_aluno_path(@escola), class: "btn btn-sm bg-green-500 hover:bg-green-600 text-white" do %>
                Novo Aluno
              <% end %>
            </div>
            
            <% if @alunos.any? %>
              <div class="p-6">
                <!-- Desktop Table View -->
                <div class="hidden md:block overflow-x-auto">
                  <table class="table w-full">
                    <thead>
                      <tr>
                        <th>Nome</th>
                        <th>Data de Nascimento</th>
                        <th>Turma</th>
                        <th>Status</th>
                        <th>Ações</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @alunos.limit(10).each do |aluno| %>
                        <tr>
                          <td class="font-medium"><%= aluno.nome %></td>
                          <td><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informada" %></td>
                          <td><%= aluno.turma.present? ? aluno.turma.nome : "Sem turma" %></td>
                          <td>
                            <% if aluno.turma.present? %>
                              <span class="badge badge-success text-white">Alocado</span>
                            <% else %>
                              <span class="badge badge-ghost">Não alocado</span>
                            <% end %>
                          </td>
                          <td>
                            <div class="flex gap-2">
                              <%= link_to escola_aluno_path(@escola, aluno), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white", title: "Ver aluno" do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                              <% end %>
                              <%= link_to edit_escola_aluno_path(@escola, aluno), class: "btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white", title: "Editar aluno" do %>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                </svg>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>

                <!-- Mobile Card View -->
                <div class="md:hidden space-y-3">
                  <% @escola.alunos.limit(10).each do |aluno| %>
                    <div class="bg-gradient-to-r from-white to-gray-50 p-5 rounded-xl shadow-md border border-gray-200 hover:shadow-lg transition-all duration-200">
                      <div class="flex items-start justify-between mb-4">
                        <div class="flex-1">
                          <div class="flex items-center mb-2">
                            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center mr-3">
                              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-white">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                              </svg>
                            </div>
                            <div>
                              <h4 class="font-bold text-lg text-gray-800"><%= aluno.nome %></h4>
                              <% if aluno.turma.present? %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                  </svg>
                                  Alocado
                                </span>
                              <% else %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                                  </svg>
                                  Não alocado
                                </span>
                              <% end %>
                            </div>
                          </div>
                        </div>
                      </div>
                      
                      <div class="grid grid-cols-2 gap-3 mb-4 text-sm">
                        <div class="bg-white p-3 rounded-lg border border-gray-100">
                          <div class="text-gray-500 text-xs font-medium mb-1">Data de Nascimento</div>
                          <div class="font-semibold text-gray-800"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informada" %></div>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-gray-100">
                          <div class="text-gray-500 text-xs font-medium mb-1">Turma</div>
                          <div class="font-semibold text-gray-800"><%= aluno.turma.present? ? aluno.turma.nome : "Sem turma" %></div>
                        </div>
                      </div>
                      
                      <div class="flex justify-end gap-2">
                        <%= link_to escola_aluno_path(@escola, aluno), class: "btn btn-sm bg-blue-500 hover:bg-blue-600 text-white", title: "Ver aluno" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          </svg>
                        <% end %>
                        <%= link_to edit_escola_aluno_path(@escola, aluno), class: "btn btn-sm bg-yellow-500 hover:bg-yellow-600 text-white", title: "Editar aluno" do %>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
