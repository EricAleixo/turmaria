<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- Chart Initialization Script -->
<script>
// Store chart instances globally for cleanup
let recentGradesChart, attendanceChart, analysisChart;

function initializeCharts() {
  // Clean up existing charts if they exist
  if (recentGradesChart) {
    recentGradesChart.destroy();
  }
  if (attendanceChart) {
    attendanceChart.destroy();
  }
  if (analysisChart) {
    analysisChart.destroy();
  }

  // Check if chart elements exist before initializing
  const recentGradesCtx = document.getElementById('recentGradesChart');
  const attendanceCtx = document.getElementById('attendanceChart');
  const analysisCtx = document.getElementById('analysisChart');

  if (!recentGradesCtx || !attendanceCtx || !analysisCtx) {
    console.log('Chart elements not found, skipping initialization');
    return;
  }

  // Recent Grades Chart
  recentGradesChart = new Chart(recentGradesCtx.getContext('2d'), {
    type: 'line',
    data: {
      labels: ['Jun', 'Fev', 'Set', 'Ago', 'Bra', 'Jul'],
      datasets: [{
        label: 'Grades',
        data: [2, 1, 3, 4, 2, 1],
        borderColor: '#10B981',
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        borderWidth: 2,
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          max: 5,
          grid: {
            color: '#f3f4f6'
          }
        },
        x: {
          grid: {
            color: '#f3f4f6'
          }
        }
      }
    }
  });

  // Attendance Overview Chart
  attendanceChart = new Chart(attendanceCtx.getContext('2d'), {
    type: 'line',
    data: {
      labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'],
      datasets: [{
        label: 'Attendance',
        data: [85, 92, 78, 96, 87, 94],
        borderColor: '#10B981',
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        borderWidth: 2,
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          max: 100,
          grid: {
            color: '#f3f4f6'
          }
        },
        x: {
          grid: {
            color: '#f3f4f6'
          }
        }
      }
    }
  });

  // Analysis Chart
  analysisChart = new Chart(analysisCtx.getContext('2d'), {
    type: 'line',
    data: {
      labels: ['Fev', 'Mar', 'Jun', 'May', 'Jun', 'Jul', 'Ago', 'Set'],
      datasets: [{
        label: 'Analysis',
        data: [20, 25, 30, 35, 32, 38, 35, 40],
        borderColor: '#10B981',
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        borderWidth: 2,
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: {
            color: '#f3f4f6'
          }
        },
        x: {
          grid: {
            color: '#f3f4f6'
          }
        }
      }
    }
  });
}

// Initialize on DOMContentLoaded
document.addEventListener('DOMContentLoaded', function() {
  initializeCharts();
});

// Initialize on Turbo navigation
document.addEventListener('turbo:load', function() {
  initializeCharts();
});

// Clean up on Turbo before cache
document.addEventListener('turbo:before-cache', function() {
  if (recentGradesChart) {
    recentGradesChart.destroy();
    recentGradesChart = null;
  }
  if (attendanceChart) {
    attendanceChart.destroy();
    attendanceChart = null;
  }
  if (analysisChart) {
    analysisChart.destroy();
    analysisChart = null;
  }
});
</script>
