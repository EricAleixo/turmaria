<div class="min-h-screen bg-gray-100">
  <!-- Dashboard Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Dashboard - <%= @escola.nome %></h1>
          <div class="text-sm breadcrumbs mt-1">
            <ul>
              <li>
                  <%= link_to "Escolas",
                      escolas_menager_paths,
                      class: "text-green-600 hover:text-green-800 transition-colors duration-200" %>
              </li>
              <li class="text-gray-600"><%= @escola.nome %></li>
            </ul>
          </div>
        </div>

        <!-- Botões para telas sm e maiores -->
        <div class="hidden sm:flex gap-3">
          <%= link_to new_escola_turma_path(@escola), class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova Turma
          <% end %>

          <%= link_to edit_escola_path(@escola), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Editar Escola
          <% end %>
        </div>

        <!-- Dropdown para telas menores que sm -->
        <div class="sm:hidden dropdown dropdown-end">
          <label tabindex="0" class="btn btn-ghost btn-circle">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
          <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52 mt-2 border border-gray-200">
            <li>
              <%= link_to "Nova Turma", new_escola_turma_path(@escola) %>
            </li>
            <li>
              <%= link_to "Editar Escola", edit_escola_path(@escola) %>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </div>



  <div class="px-6">
    <!-- School Info Header Personalizada -->
<div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden mb-8">
  <!-- Header com gradiente -->
  <div class="bg-gradient-to-r from-blue-500 to-green-300 px-6 py-4">
    <h2 class="text-xl font-bold text-white flex items-center">
      <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
      </svg>
      Perfil da Instituição
    </h2>
  </div>

  <div class="p-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Informações Básicas -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Tipo e Status -->
        <div class="bg-gray-50 rounded-lg p-4 border-l-4 <%= @escola.tipo == 'publica' ? 'border-blue-500' : 'border-purple-500' %>">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="p-2 <%= @escola.tipo == 'publica' ? 'bg-blue-100' : 'bg-purple-100' %> rounded-lg">
                <% if @escola.tipo == 'publica' %>
                  <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                  </svg>
                <% else %>
                  <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                  </svg>
                <% end %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600">Categoria</p>
                <p class="text-lg font-semibold <%= @escola.tipo == 'publica' ? 'text-blue-700' : 'text-purple-700' %>">
                  Escola <%= @escola.tipo == 'publica' ? 'Pública' : 'Privada' %>
                </p>
              </div>
            </div>
            <span class="px-3 py-1 text-xs font-medium rounded-full <%= @escola.tipo == 'publica' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
              <%= @escola.tipo == 'publica' ? 'PÚBLICA' : 'PRIVADA' %>
            </span>
          </div>
        </div>

        <!-- Informações de Contato -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% if @escola.cnpj.present? %>
            <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-lg p-4 border border-green-200">
              <div class="flex items-center space-x-3">
                <div class="p-2 bg-green-100 rounded-lg">
                  <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium text-green-700 uppercase tracking-wide">CNPJ</p>
                  <p class="text-sm font-semibold text-gray-900 font-mono"><%= @escola.cnpj %></p>
                </div>
              </div>
            </div>
          <% end %>

          <% if @escola.telefone.present? %>
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-lg p-4 border border-blue-200">
              <div class="flex items-center space-x-3">
                <div class="p-2 bg-blue-100 rounded-lg">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium text-blue-700 uppercase tracking-wide">Telefone</p>
                  <p class="text-sm font-semibold text-gray-900"><%= @escola.telefone %></p>
                </div>
              </div>
            </div>
          <% end %>

          <% if @escola.email.present? %>
            <div class="bg-gradient-to-br from-yellow-50 to-orange-50 rounded-lg p-4 border border-yellow-200">
              <div class="flex items-center space-x-3">
                <div class="p-2 bg-yellow-100 rounded-lg">
                  <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium text-yellow-700 uppercase tracking-wide">E-mail</p>
                  <p class="text-sm font-semibold text-gray-900 break-all">
                    <a href="mailto:<%= @escola.email %>" class="hover:text-yellow-600 transition-colors">
                      <%= @escola.email %>
                    </a>
                  </p>
                </div>
              </div>
            </div>
          <% end %>

          <% if @escola.site.present? %>
            <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-lg p-4 border border-purple-200">
              <div class="flex items-center space-x-3">
                <div class="p-2 bg-purple-100 rounded-lg">
                  <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-medium text-purple-700 uppercase tracking-wide">Website</p>
                  <p class="text-sm font-semibold text-gray-900">
                    <a href="<%= @escola.site %>" target="_blank" class="hover:text-purple-600 transition-colors flex items-center">
                      <%= @escola.site.gsub(/https?:\/\//, '') %>
                      <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                    </a>
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Endereço -->
        <div class="bg-gradient-to-r from-gray-50 to-slate-50 rounded-lg p-4 border border-gray-200">
          <div class="flex items-start space-x-3">
            <div class="p-2 bg-gray-100 rounded-lg mt-1">
              <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-xs font-medium text-gray-700 uppercase tracking-wide mb-1">Endereço</p>
              <p class="text-sm font-semibold text-gray-900 leading-relaxed">
                <%= @escola.endereco_completo %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Perfil do Administrador -->
      <div class="space-y-4">
        <div class="bg-gradient-to-br from-indigo-50 via-blue-50 to-cyan-50 rounded-xl p-6 border border-indigo-200 shadow-sm">
          <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Administrador
          </h3>
          
          <% if @escola.admin.present? %>
            <div class="text-center">
              <!-- Avatar com primeira letra -->
              <% if @escola&.admin&.foto.present? %>
                  <%= image_tag @escola.admin.foto, 
                        class: "mx-auto mb-4 w-20 h-20 rounded-full object-cover shadow-lg" %>
                <% else %>
                  <div class="mx-auto mb-4 w-20 h-20 bg-gradient-to-br from-blue-500 to-green-300 
                              rounded-full flex items-center justify-center shadow-lg">
                    <span class="text-2xl font-bold text-white">
                      <%= @escola&.admin&.nome&.first&.upcase %>
                    </span>
                  </div>
                <% end %>

              
              <!-- Nome e informações -->
              <div class="space-y-2">
                <h4 class="text-lg font-bold text-gray-900">
                  <%= @escola.admin.nome %>
                </h4>
                <% if @escola.admin.email.present? %>
                  <p class="text-sm text-gray-600 flex items-center justify-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <%= @escola.admin.email %>
                  </p>
                <% end %>
                
                <!-- Badge de status -->
                <div class="mt-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <div class="w-2 h-2 bg-green-400 rounded-full mr-1"></div>
                    Ativo
                  </span>
                </div>

                <!-- Estatísticas rápidas -->
                <div class="mt-4 pt-4 border-t border-indigo-200">
                  <div class="grid grid-cols-2 gap-4 text-center">
                    <div>
                      <p class="text-xs text-gray-500 uppercase tracking-wide">Turmas</p>
                      <p class="text-lg font-bold text-indigo-600"><%= @escola.turmas.count %></p>
                    </div>
                    <div>
                      <p class="text-xs text-gray-500 uppercase tracking-wide">Alunos</p>
                      <p class="text-lg font-bold text-indigo-600"><%= @escola.alunos.count %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% else %>
            <!-- Estado quando não há admin -->
            <div class="text-center py-8">
              <div class="mx-auto mb-4 w-20 h-20 bg-gray-300 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <p class="text-sm text-gray-500 mb-3">Nenhum administrador atribuído</p>
              <button class="text-xs bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full hover:bg-indigo-200 transition-colors">
                Atribuir Admin
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

      <!-- Turmas Card -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Turmas</p>
            <p class="text-3xl font-bold text-green-600"><%= @escola.turmas.count %></p>
          </div>
          <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-green-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Professores Card -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Professores</p>
            <p class="text-3xl font-bold text-purple-600"><%= @escola.turmas.count %></p>
          </div>
          <div class="h-12 w-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Alunos Card -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Alunos</p>
            <p class="text-3xl font-bold text-orange-600"><%= @escola.alunos.count %></p>
          </div>
          <div class="h-12 w-12 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Notas Recentes -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Notas Recentes</h3>
        <div class="h-64">
          <canvas id="recentGradesChart"></canvas>
        </div>
      </div>

      <!-- Visão Geral de Presença -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Visão Geral de Presença</h3>
        <div class="h-64">
          <canvas id="attendanceChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Análise de Dados -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Análise de Dados</h3>
      <div class="h-64">
        <canvas id="analysisChart"></canvas>
      </div>
    </div>

    <!-- Management Sections -->
    <%= render 'shared/escola_management_sections', escola: @escola, alunos: @alunos, disciplinas_por_area: @disciplinas_por_area, professores: @escola.professors, conteudos: @escola.conteudos %>
  </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<%= render 'shared/escola_charts_script' %>
