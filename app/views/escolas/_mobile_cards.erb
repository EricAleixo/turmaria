                <div class="flex items-center justify-center gap-1">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-lg font-bold text-green-600"><%= frequencia.total_presentes %></span>
                </div>
                <p class="text-xs text-gray-600 mt-1">Presentes</p>
              </div>

              <div class="bg-white/70 backdrop-blur-sm border border-red-200/50 rounded-lg p-2 text-center">
                <div class="flex items-center justify-center gap-1">
                  <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-lg font-bold text-red-600"><%= frequencia.total_faltas %></span>
                </div>
                <p class="text-xs text-gray-600 mt-1">Faltas</p>
              </div>
            </div>

            <!-- Conteúdo (se houver) -->
            <% if frequencia.conteudo_trabalhado.present? %>
              <div class="mt-3 bg-white/70 backdrop-blur-sm border border-green-200/50 rounded-lg p-3">
                <p class="text-xs font-medium text-green-700 uppercase tracking-wide mb-1">Conteúdo Trabalhado</p>
                <p class="text-sm text-gray-700">
                  <%= truncate(frequencia.conteudo_trabalhado, length: 80) %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="py-12 text-center">
        <svg class="mx-auto h-16 w-16 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhuma frequência registrada</h3>
        <p class="mt-1 text-sm text-gray-500">Ainda não há registros de frequência para esta escola.</p>
        <div class="mt-6">
          <%= link_to "Ver Frequências", escola_frequencias_path(@escola), class: "rounded-lg bg-green-600 px-5 py-2.5 font-medium text-white shadow-md transition-colors hover:bg-green-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>w
