                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                        </svg>
                        Excluir aluno
                      <% end %>
                    </li>
                  <% else %>
                    <li><div class="text-slate-400 px-2 py-1">Sem escola</div></li>
                  <% end %>
                </ul>
              </div>
            </div>

            <div class="divider my-2"></div>

            <!-- Informações do aluno -->
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div>
                <span class="text-slate-500">Escola:</span>
                <div class="badge badge-sm <%= alocado ? 'bg-gradient-to-r from-blue-400 to-green-300 text-white' : 'bg-gradient-to-r from-slate-400 to-gray-500 text-white' %> border-0 font-medium">
                  Escola
                </div>
              </div>
              <div>
                <span class="text-slate-500">Turma:</span>
                <span class="font-medium <%= alocado ? 'text-slate-700' : 'text-slate-400' %>">
                  <%= alocado ? aluno.turma.nome : 'Sem turma' %>
                </span>
              </div>
              <div>
                <span class="text-slate-500">Nascimento:</span>
                <span class="font-medium text-slate-700"><%= aluno.data_nascimento.present? ? aluno.data_nascimento.strftime("%d/%m/%Y") : "Não informado" %></span>
