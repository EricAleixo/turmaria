

<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
<div class="flex justify-between items-center">
  <!-- Título -->
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Professores</h3>

  <!-- Dropdown de ações -->
  <div class="dropdown dropdown-end z-50">
    <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
      </svg>
    </label>

    <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
      <li>
        <%= link_to escola_professors_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.036 12.322a1.012 1.012 0 010-.639C3.423
                                 7.51 7.36 4.5 12 4.5c4.638 0
                                 8.573 3.007 9.963 7.178.07.207.07.431
                                 0 .639C20.577 16.49 16.64 19.5
                                 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
            Ver professores
          </span>
        <% end %>
      </li>

      <li>
        <%= link_to new_escola_professor_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                 viewBox="0 0 24 24" stroke-width="1.5"
                 stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo professor
          </span>
        <% end %>
      </li>
    </ul>
  </div>
</div>

<div class="grid grid-cols-1 gap-4 md:hidden">
  <% if professores.any? %>
  <% professores&.each do |professor| %>
    <div class="<%= gradient_mobile(professor.formacao) %> shadow-xl hover:shadow-2xl transition-all duration-300 overflow-hidden rounded-lg">
      <div class="card-body p-4">
        <!-- Header -->
        <div class="flex justify-between items-start">
          <div class="flex items-center gap-3">
            <div class="avatar placeholder">
              <% if professor.foto&.attached? %>
                <div class="w-10 h-10 rounded-full overflow-hidden">
                  <%= image_tag professor.foto.variant(resize_to_fill: [40,40]), class: "rounded-full object-cover w-10 h-10" %>
                </div>
              <% else %>
                <div class="bg-gradient-to-br from-blue-400 to-green-300 text-white rounded-full w-10 h-10 relative font-bold">
                  <span class="absolute top-1/2 left-1/2 -translate-1/2"><%= professor.nome.first.upcase %></span>
                </div>
              <% end %>
            </div>
            <div>
              <h2 class="card-title text-slate-700"><%= professor.nome %></h2>
              <div class="flex flex-wrap gap-1 mt-1">
                <span class="badge badge-sm bg-gradient-to-r from-blue-500 to-green-400 text-white border-0 font-bold">
                  <%= professor.tipo_professor&.titleize || "Tipo não informado" %>
                </span>
                <span class="badge badge-sm bg-gradient-to-r from-yellow-500 to-orange-400 text-white border-0 font-bold">
                  <%= professor.formacao&.titleize || "Formação não informada" %>
                </span>
              </div>
            </div>
          </div>

          <!-- Dropdown ações -->
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
              </svg>
            </label>
            <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-52">
              <li>
                <%= link_to escola_professor_path(@escola,professor), data: { turbo: false } do %>
                    <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.036 12.322a1.012 1.012 0 010-.639C3.423
                                 7.51 7.36 4.5 12 4.5c4.638 0
                                 8.573 3.007 9.963 7.178.07.207.07.431
                                 0 .639C20.577 16.49 16.64 19.5
                                 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      Ver professor
                    </span>
                <% end %>
              </li>
              <li>
                <%= link_to edit_escola_professor_path(@escola,professor), data: { turbo: false } do %>
                    <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M16.862 4.487l1.687-1.688a1.875
                                 1.875 0 112.652 2.652L10.582
                                 16.07a4.5 4.5 0 01-1.897
                                 1.13L6 18l.8-2.685a4.5 4.5
                                 0 011.13-1.897l8.932-8.931zm0
                                 0L19.5 7.125M18 14v4.75A2.25
                                 2.25 0 0115.75 21H5.25A2.25
                                 2.25 0 013 18.75V8.25A2.25
                                 2.25 0 015.25 6H10" />
                      </svg>
                      Editar professor
                    </span>
                <% end %>
              </li>
              <li>
                <%= button_to escola_professor_path(@escola,professor), method: :delete, data: { confirm: "Deseja excluir este professor?" } do %>
                    <span class="flex items-center gap-2 text-red-600">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M14.74 9l-.346 9m-4.788
                                 0L9.26 9m9.968-3.21c.342.052.682.107
                                 1.022.166m-1.022-.165L18.16
                                 19.673a2.25 2.25 0
                                 01-2.244 2.077H8.084a2.25
                                 2.25 0 01-2.244-2.077L4.772
                                 5.79m14.456 0a48.108 48.108 0
                                 00-3.478-.397m-12 .562c.34-.059.68-.114
                                 1.022-.165m0 0a48.11 48.11 0
                                 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964
                                 51.964 0 00-3.32 0c-1.18.037-2.09
                                 1.022-2.09 2.201v.916m7.5
                                 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                      Excluir professor
                    </span>
                <% end %>
              </li>
            </ul>
          </div>
        </div>

        <div class="divider my-2"></div>

        <!-- Disciplinas -->
        <div class="flex flex-wrap gap-1">
          <% if professor.disciplinas.any? %>
            <%= disciplinas_badges(professor) %>
          <% else %>
            <span class="text-sm font-medium text-gray-500">Sem disciplinas</span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
    <% else %>
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" class = "mx-auto h-16 w-16 text-blue-400" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor" className="size-6">
          <path strokeLinecap="round" strokeLinejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
        </svg>

        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum professor cadastrado</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando o primeiro professor desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeiro professor", new_escola_professor_path(@escola), class: "rounded-lg bg-indigo-600 px-5 py-2.5 font-medium text-white shadow-md transition-colors hover:bg-indigo-700" %>
        </div>
      </div>
    <% end %>
</div>

</div>

<!--Anos Letivos -->
<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <div class="flex justify-between items-center">
  <!-- Título -->
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Anos Letivos</h3>

  <!-- Dropdown de ações -->
  <div class="dropdown dropdown-end z-50">
    <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
      </svg>
    </label>

    <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
      <li>
        <%= link_to escola_ano_letivos_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.036 12.322a1.012 1.012 0 010-.639C3.423
                                 7.51 7.36 4.5 12 4.5c4.638 0
                                 8.573 3.007 9.963 7.178.07.207.07.431
                                 0 .639C20.577 16.49 16.64 19.5
                                 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
            Ver anos letivos
          </span>
        <% end %>
      </li>

      <li>
        <%= link_to new_escola_ano_letivo_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                 viewBox="0 0 24 24" stroke-width="1.5"
                 stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Novo ano letivo
          </span>
        <% end %>
      </li>
    </ul>
  </div>
</div>


  <div class="grid grid-cols-1 gap-4 md:hidden">
    <% if anos_letivos.any? %>
      <% anos_letivos.each do |ano| %>
        <div class="shadow-xl hover:shadow-2xl transition-all duration-300 rounded-lg relative bg-gradient-to-br from-teal-50/40 via-teal-100/40 to-teal-200/60 p-6 mb-5 w-full">
          
          <!-- Cabeçalho com nome e badge de bimestres -->
          <div class="flex justify-between items-center mb-2">
            <div class="flex items-center gap-3">
              <h2 class="card-title text-gray-900 text-xl font-bold"><%= ano.ano %></h2>
              <span class="badge badge-sm bg-gradient-to-r from-teal-500 to-cyan-400 text-white border-0 font-bold">
                <%= "#{ano.numero_bimestre} bimestres" %>
              </span>
            </div>  

            <!-- Dropdown de ações -->
            <div class="dropdown dropdown-end z-10">
              <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
                </svg>
              </label>

              <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
                <li>
                  <%= link_to escola_ano_letivo_path(@escola, ano), data: { turbo: false } do %>
                    <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.036 12.322a1.012 1.012 0 010-.639C3.423
                                 7.51 7.36 4.5 12 4.5c4.638 0
                                 8.573 3.007 9.963 7.178.07.207.07.431
                                 0 .639C20.577 16.49 16.64 19.5
                                 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      Ver ano letivo
                    </span>
                  <% end %>
                </li>

                <li>
                  <%= link_to edit_escola_ano_letivo_path(@escola, ano), data: { turbo: false } do %>
                    <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M16.862 4.487l1.687-1.688a1.875
                                 1.875 0 112.652 2.652L10.582
                                 16.07a4.5 4.5 0 01-1.897
                                 1.13L6 18l.8-2.685a4.5 4.5
                                 0 011.13-1.897l8.932-8.931zm0
                                 0L19.5 7.125M18 14v4.75A2.25
                                 2.25 0 0115.75 21H5.25A2.25
                                 2.25 0 013 18.75V8.25A2.25
                                 2.25 0 015.25 6H10" />
                      </svg>
                      Editar ano letivo
                    </span>
                  <% end %>
                </li>

                <li>
                  <%= button_to escola_ano_letivo_path(@escola, ano), method: :delete,
                        data: { confirm: "Deseja excluir este ano letivo?" } do %>
                    <span class="flex items-center gap-2 text-red-600 w-full">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M14.74 9l-.346 9m-4.788
                                 0L9.26 9m9.968-3.21c.342.052.682.107
                                 1.022.166m-1.022-.165L18.16
                                 19.673a2.25 2.25 0
                                 01-2.244 2.077H8.084a2.25
                                 2.25 0 01-2.244-2.077L4.772
                                 5.79m14.456 0a48.108 48.108 0
                                 00-3.478-.397m-12 .562c.34-.059.68-.114
                                 1.022-.165m0 0a48.11 48.11 0
                                 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964
                                 51.964 0 00-3.32 0c-1.18.037-2.09
                                 1.022-2.09 2.201v.916m7.5
                                 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                      Excluir ano letivo
                    </span>
                  <% end %>
                </li>
              </ul>
            </div>
          </div>

          <div class="divider my-2"></div>

          <!-- Badges de início e fim -->
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="badge badge-md bg-gradient-to-r from-green-400 to-teal-400 text-white border-0 font-semibold">
              Início: <%= ano.data_inicio.strftime("%d/%m/%Y") %>
            </span>
            <span class="badge badge-md bg-gradient-to-r from-red-400 to-pink-400 text-white border-0 font-semibold">
              Fim: <%= ano.data_fim.strftime("%d/%m/%Y") %>
            </span>
          </div>

        </div>
      <% end %>
    <% else %>
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="mx-auto h-16 w-16 text-purple-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Nenhum ano letivo cadastrado</h3>
        <p class="mt-1 text-sm text-gray-500">Comece criando o primeiro ano letivo desta escola.</p>
        <div class="mt-6">
          <%= link_to "Criar Primeiro Ano Letivo", new_escola_ano_letivo_path(@escola), class: "btn btn-primary rounded-lg px-5 py-2.5 font-medium text-white shadow-md transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>



<!-- Turmas -->
<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <div class="flex justify-between items-center">
  <!-- Título -->
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Turmas</h3>

  <!-- Dropdown de ações -->
  <div class="dropdown dropdown-end z-50">
    <label tabindex="0" class="btn btn-sm btn-circle btn-ghost">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
      </svg>
    </label>

    <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-base-100 rounded-box w-52 z-50">
      <li>
        <%= link_to escola_turmas_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                           viewBox="0 0 24 24" stroke-width="1.5"
                           stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M2.036 12.322a1.012 1.012 0 010-.639C3.423
                                 7.51 7.36 4.5 12 4.5c4.638 0
                                 8.573 3.007 9.963 7.178.07.207.07.431
                                 0 .639C20.577 16.49 16.64 19.5
                                 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
            Ver turmas
          </span>
        <% end %>
      </li>

      <li>
        <%= link_to new_escola_turma_path(@escola), data: { turbo: false } do %>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none"
                 viewBox="0 0 24 24" stroke-width="1.5"
                 stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova turma
          </span>
        <% end %>
      </li>
    </ul>
  </div>
</div>


  <% if turmas.any? %>
    <% turmas.each do |turma| %>
      <% card_classes = case turma.turno.to_s.downcase
when "manha"
  "bg-gradient-to-br from-white via-yellow-50 to-yellow-100 border border-yellow-200/50"
when "tarde"
  "bg-gradient-to-br from-white via-orange-50 to-orange-100 border border-orange-200/50"
when "noite"
  "bg-gradient-to-br from-white via-blue-50 to-blue-100 border border-blue-200/50"
when "integral"
  "bg-gradient-to-br from-white via-green-50 to-green-100 border border-green-200/50"
else
  "bg-white border border-gray-200"
  end
       %>

      <div class="relative  <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300 mb-5 w-full">
        <div class="absolute inset-0 pointer-events-none"></div>

        <div class="relative z-10">
          <!-- Header -->
