<div class="px-4 py-6 rounded-2xl border mt-5 border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <!-- Título -->
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Disciplinas</h3>

  <% if disciplinas&.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% disciplinas.each do |disciplina| %>
        <% card_classes = card_classes(disciplina.area) %>
        <% bg_pattern_class = bg_pattern(disciplina.area) %>

        <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 mb-5 w-full">
          <div class="absolute inset-0 <%= bg_pattern_class %> pointer-events-none"></div>

          <div class="relative z-10">
            <!-- Header do Card -->
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 space-y-2 sm:space-y-0">
              <h3 class="text-xl font-bold text-gray-900"><%= disciplina.nome %></h3>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-sm">
                <%= svgs(disciplina.area) %>
                <%= disciplina.area&.titleize || "Área não informada" %>
              </span>
            </div>

            <!-- Informações -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div class="bg-white/70 backdrop-blur-sm border border-gray-200/50 rounded-xl p-4 text-center shadow-sm">
                <div class="flex items-center justify-center mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
                  </svg>
                </div>
                <p class="text-xs font-medium text-gray-700 uppercase tracking-wide">Escola</p>
                <p class="text-sm font-semibold text-gray-900 mt-1"><%= disciplina.escola&.nome || "Não informado" %></p>
              </div>

              <div class="bg-white/70 backdrop-blur-sm border border-gray-200/50 rounded-xl p-4 text-center shadow-sm">
                <div class="flex items-center justify-center mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0zM7 10a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                </div>
                <p class="text-xs font-medium text-gray-700 uppercase tracking-wide">Professores</p>
                <p class="text-sm font-semibold text-gray-900 mt-1">
                  <%= disciplina.professores.map { |p| p == current_professor ? "Você" : p.nome }.join(", ").presence || "Nenhum" %>
                </p>
              </div>
            </div>

            <!-- Ações -->
            <div class="flex flex-col sm:flex-row justify-center sm:space-x-2 space-y-2 sm:space-y-0 pt-4 border-t border-blue-200/50">
              <%= link_to escola_disciplina_path(@escola,disciplina), class: "flex items-center px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                Ver
              <% end %>

              <%= link_to edit_escola_disciplina_path(@escola, disciplina), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Editar
              <% end %>

              <%= link_to escola_disciplina_path(@escola, disciplina), method: :delete, data: { confirm: "Tem certeza que deseja excluir esta disciplina?" }, class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
                <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Excluir
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <!-- Nenhuma disciplina -->
    <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Nenhuma disciplina encontrada</h2>
      <p class="text-gray-500 mb-6">Não há disciplinas cadastradas no momento.</p>

      <% if current_user.is_a?(Admin) %>
        <%= link_to "Criar Nova Disciplina", new_escola_disciplina_path(current_user.escolas.first), class: "btn bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-xl shadow-md transition-all" %>
      <% elsif current_user.is_a?(SuperAdmin) %>
        <%= link_to "Criar Nova Disciplina", new_disciplina_path, class: "btn bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-xl shadow-md transition-all" %>
      <% end %>
    </div>
  <% end %>
</div>


<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Professores</h3>

  <% if professores.any? %>
    <% professores.each do |professor| %>
      <% card_classes = case professor.formacao.to_s
        when 'doutorado'      then "bg-gradient-to-br from-blue-50/40 via-blue-100/40 to-blue-200/60 border border-blue-300/50"
        when 'mestrado'       then "bg-gradient-to-br from-red-50/40 via-red-100/40 to-red-200/60 border border-red-300/50"
        when 'pos_graduado'   then "bg-gradient-to-br from-yellow-50/40 via-yellow-100/40 to-yellow-200/60 border border-yellow-300/50"
        when 'graduado'       then "bg-gradient-to-br from-green-50/40 via-green-100/40 to-green-200/60 border border-green-300/50"
        else                      "bg-white border border-gray-200"
      end %>

      <% bg_pattern = case professor.formacao
        when 'doutorado'      then "bg-gradient-to-br from-blue-50/20 via-transparent to-blue-100/30"
        when 'mestrado'       then "bg-gradient-to-br from-red-50/20 via-transparent to-red-100/30"
        when 'pos_graduado'   then "bg-gradient-to-br from-yellow-50/20 via-transparent to-yellow-100/30"
        when 'graduado'       then "bg-gradient-to-br from-green-50/20 via-transparent to-green-100/30"
        else                      "bg-gradient-to-br from-gray-50/20 via-transparent to-gray-100/30"
      end %>

      <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 mb-5 w-full">
        <div class="absolute inset-0 <%= bg_pattern %> pointer-events-none"></div>

        <div class="relative z-10">
          <!-- Header do Card -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 space-y-3 sm:space-y-0">
            <h3 class="text-xl font-bold text-gray-900"><%= professor.nome %></h3>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-sm">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
              </svg>
              <%= professor.tipo_professor&.titleize || "Tipo não informado" %>
            </span>
          </div>

          <!-- Informações do Professor -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div class="bg-white/70 backdrop-blur-sm border border-blue-200/50 rounded-xl p-4 text-center shadow-sm">
              <div class="flex items-center justify-center mb-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <p class="text-xs font-medium text-blue-700 uppercase tracking-wide">CPF</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= professor&.cpf || "Não informado" %></p>
            </div>

            <div class="bg-gradient-to-br from-blue-100 to-blue-200/80 border border-blue-300/50 rounded-xl p-4 text-center shadow-sm">
              <div class="flex items-center justify-center mb-2">
                <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
              </div>
              <p class="text-xs font-medium text-blue-800 uppercase tracking-wide">Matérias</p>
              <p class="text-sm font-semibold text-gray-900 mt-1">Sem matérias</p>
            </div>
          </div>

          <!-- Ações do Card -->
          <div class="flex flex-col sm:flex-row justify-center sm:space-x-2 space-y-2 sm:space-y-0 pt-4 border-t border-blue-200/50">
            <%= link_to professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              Ver
            <% end %>

            <%= link_to edit_professor_path(professor), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Editar
            <% end %>

            <%= link_to professor_path(@escola, professor), method: :delete,
                data: { confirm: "Tem certeza que deseja excluir este professor?" },
                class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
              Excluir
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

  <% else %>
    <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Nenhum professor encontrado</h2>
      <p class="text-gray-500 mb-6">Não há professores cadastrados no momento.</p>
    </div>
  <% end %>
</div>


<!-- Cards de Ano Letivo -->
<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Anos Letivos</h3>

  <% if anos_letivos.any? %>
    <% anos_letivos.each do |ano| %>
      <% card_classes = "bg-gradient-to-br from-teal-50/40 via-teal-100/40 to-teal-200/60 border border-teal-300/50" %>
      <% bg_pattern = "bg-gradient-to-br from-teal-50/20 via-transparent to-teal-100/30" %>

      <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 mb-5 w-full">
        <div class="absolute inset-0 <%= bg_pattern %> pointer-events-none"></div>

        <div class="relative z-10">
          <!-- Header do Card -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 space-y-3 sm:space-y-0">
            <h3 class="text-xl font-bold text-gray-900"><%= ano.ano %></h3>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-teal-500 text-white shadow-sm">
              <%= "#{ano.numero_bimestre} bimestres" %>
            </span>
          </div>

          <!-- Informações do Ano -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div class="bg-white/70 backdrop-blur-sm border border-teal-200/50 rounded-xl p-4 text-center shadow-sm">
              <p class="text-xs font-medium text-gray-700 uppercase tracking-wide">Início</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= ano.data_inicio.strftime("%d/%m/%Y") %></p>
            </div>
            <div class="bg-white/70 backdrop-blur-sm border border-teal-200/50 rounded-xl p-4 text-center shadow-sm">
              <p class="text-xs font-medium text-gray-700 uppercase tracking-wide">Fim</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= ano.data_fim.strftime("%d/%m/%Y") %></p>
            </div>
          </div>

          <!-- Ações do Card -->
          <div class="flex flex-col sm:flex-row justify-center sm:space-x-2 space-y-2 sm:space-y-0 pt-4 border-t border-teal-200/50">
            <%= link_to escola_ano_letivo_path(@escola, ano), class: "flex items-center px-4 py-2.5 text-sm font-medium text-teal-700 bg-teal-50 hover:bg-teal-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ver
            <% end %>

            <%= link_to edit_escola_ano_letivo_path(@escola, ano), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Editar
            <% end %>

            <%= link_to escola_ano_letivos_path(@escola, ano), method: :delete, data: { confirm: "Tem certeza que deseja excluir este ano letivo?" }, class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Excluir
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Nenhum ano letivo -->
    <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Nenhum ano letivo encontrado</h2>
      <p class="text-gray-500 mb-6">Não há anos letivos cadastrados no momento.</p>
      <%= link_to "Criar Novo Ano Letivo", new_escola_ano_letivo_path(@escola), class: "btn bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-xl shadow-md transition-all" %>
    </div>
  <% end %>
</div>



<!-- Cards de Turmas -->
<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Turmas</h3>

  <% if turmas.any? %>
    <% turmas.each do |turma| %>
      <% card_classes = case turma.turno.to_s.downcase
        when 'manha' then "bg-gradient-to-br from-yellow-50/40 via-yellow-100/40 to-yellow-200/60 border border-yellow-300/50"
        when 'tarde' then "bg-gradient-to-br from-blue-50/40 via-blue-100/40 to-blue-200/60 border border-blue-300/50"
        when 'integral' then "bg-gradient-to-br from-indigo-50/40 via-indigo-100/40 to-indigo-200/60 border border-indigo-300/50"
        else "bg-white border border-gray-200"
      end %>

      <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 mb-5 w-full">
        <div class="absolute inset-0 pointer-events-none"></div>

        <div class="relative z-10">
          <!-- Header do Card -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 space-y-3 sm:space-y-0">
            <h3 class="text-xl font-bold text-gray-900"><%= turma.nome %></h3>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-white/50 border border-gray-300 text-gray-700 shadow-sm">
              <%= turma.turno&.capitalize || "Turno não informado" %>
            </span>
          </div>

          <!-- Informações da Turma -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div class="bg-white/70 backdrop-blur-sm border border-gray-200/50 rounded-xl p-4 text-center shadow-sm">
              <p class="text-xs font-medium text-gray-600 uppercase tracking-wide">Série</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= turma.serie || "Não informado" %></p>
            </div>

            <div class="bg-gradient-to-br from-green-100 to-green-200/80 border border-green-300/50 rounded-xl p-4 text-center shadow-sm">
              <p class="text-xs font-medium text-green-800 uppercase tracking-wide">Alunos</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= turma.alunos.count %></p>
            </div>
          </div>

          <!-- Ações do Card -->
          <div class="flex flex-col sm:flex-row justify-center sm:space-x-2 space-y-2 sm:space-y-0 pt-4 border-t border-gray-200/50">
            <%= link_to escola_turma_path(@escola, turma), class: "flex items-center px-4 py-2.5 text-sm font-medium text-green-700 bg-green-50 hover:bg-green-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ver
            <% end %>

            <%= link_to edit_escola_turma_path(@escola, turma), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Editar
            <% end %>

            <%= link_to escola_turma_path(@escola, turma), method: :delete, data: { confirm: "Tem certeza que deseja excluir esta turma?" }, class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Excluir
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Nenhuma turma -->
    <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Nenhuma turma encontrada</h2>
      <p class="text-gray-500 mb-6">Não há turmas cadastradas no momento.</p>
      <%= link_to "Criar Nova Turma", new_escola_turma_path(@escola), class: "btn bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-xl shadow-md transition-all" %>
    </div>
  <% end %>
</div>




<!-- Cards de Alunos -->
<div class="mt-8 px-4 py-6 rounded-2xl border border-gray-100 bg-white/80 backdrop-blur-sm shadow-md hover:shadow-lg transition-shadow duration-300 md:hidden">
  <h3 class="text-2xl font-bold text-gray-800 mb-6">Alunos</h3>

  <% if alunos.any? %>
    <% alunos.each do |a| %>
      <% card_classes = "bg-gradient-to-br from-blue-50/40 via-blue-100/40 to-blue-200/60 border border-blue-300/50" %>
      <% bg_pattern = "bg-gradient-to-br from-blue-50/20 via-transparent to-blue-100/30" %>

      <div class="relative overflow-hidden <%= card_classes %> rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 mb-5 w-full">
        <div class="absolute inset-0 <%= bg_pattern %> pointer-events-none"></div>

        <div class="relative z-10">
          <!-- Header do Card -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 space-y-3 sm:space-y-0">
            <div class="flex items-center space-x-3">
              <% if a.foto.present? %>
                <%= image_tag a.foto, class: "h-10 w-10 rounded-full object-cover shadow-sm border border-gray-200" %>
              <% else %>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500 text-white font-semibold shadow-sm border border-emerald-400">
                  <%= a.nome[0].upcase %>
                </div>
              <% end %>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-1"><%= a.nome %></h3>
              </div>
            </div>

            <div class="ml-0 sm:ml-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-sm">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                  <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                </svg>
                <%= a.cpf || "Status não informado" %>
              </span>
            </div>
          </div>

          <!-- Informações dos Responsáveis -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div class="bg-white/70 backdrop-blur-sm border border-blue-200/50 rounded-xl p-4 text-center shadow-sm">
              <div class="flex items-center justify-center mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <p class="text-xs font-medium text-blue-700 uppercase tracking-wide">Telefone do Responsável 1</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= a.telefone_responsavel_1 || "Não informado" %></p>
            </div>

            <div class="bg-gradient-to-br from-blue-100 to-blue-200/80 border border-blue-300/50 rounded-xl p-4 text-center shadow-sm">
              <div class="flex items-center justify-center mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <p class="text-xs font-medium text-blue-800 uppercase tracking-wide">Telefone do Responsável 2</p>
              <p class="text-sm font-semibold text-gray-900 mt-1"><%= a.telefone_responsavel_2 || "Não informado" %></p>
            </div>
          </div>

          <!-- Ações do Card -->
          <div class="flex flex-col sm:flex-row justify-center sm:space-x-2 space-y-2 sm:space-y-0 pt-4 border-t border-blue-200/50">
            <%= link_to escola_aluno_path(@escola, a), class: "flex items-center px-4 py-2.5 text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ver
            <% end %>

            <%= link_to edit_escola_aluno_path(@escola, a), class: "flex items-center px-4 py-2.5 text-sm font-medium text-yellow-700 bg-yellow-50 hover:bg-yellow-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Editar
            <% end %>

            <%= link_to escola_aluno_path(@escola, a), method: :delete, data: { confirm: "Tem certeza que deseja excluir este aluno?" }, class: "flex items-center px-4 py-2.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105 justify-center" do %>
              <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Excluir
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <!-- Nenhum aluno -->
    <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Nenhum aluno encontrado</h2>
      <p class="text-gray-500 mb-6">Não há alunos cadastrados no momento.</p>
    </div>
  <% end %>
</div>
