<div class="min-h-screen bg-gradient-to-br from-green-50 via-blue-50 to-purple-50">
  <div class="container mx-auto px-4 py-8">
    <!-- Welcome Header -->
    <div class="text-center mb-16">
      <div class="mb-6">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-green-500 rounded-full mb-4 shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
          </svg>
        </div>
      </div>
      
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        Bem-vindo ao <span class="text-green-600">Turmaria</span>!
      </h1>
      
      <p class="text-xl text-gray-600 cleaw-3xl mx-auto leading-relaxed mb-6">
        Um lugar onde a gestão escolar se torna simples, intuitiva e eficiente. 
        Transforme a administração da sua escola com ferramentas modernas e poderosas.
      </p>
      
      <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-500 mb-8">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Gestão de Alunos
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Controle de Turmas
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Relatórios Inteligentes
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Dashboard Completo
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-9xl mx-auto">
      <!-- Steps Guide -->
      <div class="mb-12">
        <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100 max-w-9xl mx-auto">
          <h2 class="text-2xl font-bold text-gray-800 mb-8 text-center">
            Vamos começar sua jornada em 3 passos simples!
          </h2>
          
          <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-green-600 font-bold text-2xl">1</span>
              </div>
              <h3 class="font-semibold text-gray-800 mb-2">Cadastre sua escola</h3>
              <p class="text-gray-600 text-sm">Preencha as informações básicas da sua instituição de ensino.</p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-blue-600 font-bold text-2xl">2</span>
              </div>
              <h3 class="font-semibold text-gray-800 mb-2">Configure seu sistema</h3>
              <p class="text-gray-600 text-sm">Personalize as configurações de acordo com suas necessidades.</p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-purple-600 font-bold text-2xl">3</span>
              </div>
              <h3 class="font-semibold text-gray-800 mb-2">Comece a gerenciar</h3>
              <p class="text-gray-600 text-sm">Adicione turmas, alunos e professores para começar a usar o sistema.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Section - Now Full Width and Prominent -->
      <div class="max-w-9xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="bg-gradient-to-r from-green-500 to-blue-500 p-8 text-white text-center">
            <h2 class="text-3xl font-bold mb-3">Cadastre sua Escola</h2>
            <p class="text-green-100 text-lg">Preencha os dados abaixo para começar sua jornada no Turmaria</p>
          </div>
          
          <div class="p-10">
            <%= render "welcome_form", escola: @escola %>
          </div>
        </div>
      </div>

      <!-- Features Cards - Moved to Bottom -->
      <div class="mt-16 max-w-9xl mx-auto">
        <div class="grid md:grid-cols-4 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 text-sm mb-1">Analytics</h3>
            <p class="text-xs text-gray-600">Relatórios detalhados</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 text-sm mb-1">Segurança</h3>
            <p class="text-xs text-gray-600">Dados protegidos</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 text-sm mb-1">Performance</h3>
            <p class="text-xs text-gray-600">Sistema rápido</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 text-center">
            <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 100 19.5 9.75 9.75 0 000-19.5z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 text-sm mb-1">Suporte</h3>
            <p class="text-xs text-gray-600">Ajuda 24/7</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
