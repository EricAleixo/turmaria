<div class="min-h-screen bg-gray-100">
  <!-- Dashboard Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-900">Dashboard Geral</h1>
        <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Total de Escolas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Escolas</p>
            <p class="text-3xl font-bold text-blue-600"><%= @total_escolas %></p>
          </div>
          <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Total de Turmas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Turmas</p>
            <p class="text-3xl font-bold text-green-600"><%= @total_turmas %></p>
          </div>
          <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-green-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>

          </div>
        </div>
      </div>

      <!-- Total de Alunos -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-3xl font-bold text-purple-600"><%= @total_alunos %></p>
          </div>
          <div class="h-12 w-12 bg-purple-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Média Alunos/Escola -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Média Alunos/Escola</p>
            <p class="text-3xl font-bold text-orange-600"><%= @media_alunos_escola %></p>
          </div>
          <div class="h-12 w-12 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Distribuição de Turmas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Distribuição de Turmas</h3>
        <div class="h-64">
          <canvas id="turmasChart"></canvas>
        </div>
      </div>

      <!-- Alunos por Escola -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Alunos por Escola</h3>
        <div class="h-64">
          <canvas id="alunosChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Análise de Crescimento do Sistema -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Análise de Crescimento do Sistema</h3>
      <div class="h-64">
        <canvas id="crescimentoChart"></canvas>
      </div>
    </div>

    <!-- Gerenciar Escolas Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex justify-between items-center">
          <h2 class="text-xl font-semibold text-gray-900">Gerenciar Escolas</h2>
          <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
        </div>
      </div>

      <!-- Search and Filter Controls -->
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <%= form_with url: escolas_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |form| %>
          <div class="flex-1 min-w-64">
            <%= form.text_field :busca, 
                placeholder: "Buscar por nome da escola...", 
                value: params[:busca],
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" %>
          </div>
          <div class="min-w-48">
            <%= form.select :filtro_select, 
                options_for_select([
                  ["Todas as escolas", ""],
                  ["Mais alunos", "most_students"],
                  ["Menos alunos", "least_students"],
                  ["Mais turmas", "most_classes"],
                  ["Menos turmas", "least_classes"],
                  ["Com CNPJ", "with_cnpj"],
                  ["Sem CNPJ", "without_cnpj"]
                ], params[:filtro_select]),
                {},
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" } %>
          </div>
          <div class="flex gap-2">
            <%= form.submit "Filtrar", class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
            <%= link_to "Limpar", escolas_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
          </div>
        <% end %>
      </div>

      <!-- Schools Table -->
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">CNPJ</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Turmas</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alunos</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @escolas.each do |escola| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= escola.nome %></div>
                  <% if escola.endereco&.cidade.present? %>
                    <div class="text-sm text-gray-500"><%= escola.endereco.cidade %>, <%= escola.endereco.estado %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.cnpj.present? ? escola.cnpj : "-" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.turmas.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.alunos.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to escola_path(escola), class: "text-blue-600 hover:text-blue-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_path(escola), class: "text-yellow-600 hover:text-yellow-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= button_to escola_path(escola), method: :delete, 
                        confirm: "Tem certeza que deseja excluir esta escola?",
                        class: "text-red-600 hover:text-red-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <% if @escolas.empty? %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Nenhuma escola encontrada</h3>
            <p class="mt-1 text-sm text-gray-500">Comece criando uma nova escola.</p>
            <div class="mt-6">
              <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Chart configuration
  const chartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        grid: {
          color: '#f3f4f6'
        }
      },
      x: {
        grid: {
          color: '#f3f4f6'
        }
      }
    }
  };

  // Distribuição de Turmas Chart
  const turmasCtx = document.getElementById('turmasChart').getContext('2d');
  const turmasData = {
    labels: [<%= raw @escolas.map(&:nome).map { |nome| "'#{nome}'" }.join(', ') %>],
    datasets: [{
      data: [<%= @escolas.map { |escola| escola.turmas.count }.join(', ') %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(turmasCtx, {
    type: 'line',
    data: turmasData,
    options: chartOptions
  });

  // Alunos por Escola Chart
  const alunosCtx = document.getElementById('alunosChart').getContext('2d');
  const alunosData = {
    labels: [<%= raw @escolas.map(&:nome).map { |nome| "'#{nome}'" }.join(', ') %>],
    datasets: [{
      data: [<%= @escolas.map { |escola| escola.alunos.count }.join(', ') %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(alunosCtx, {
    type: 'line',
    data: alunosData,
    options: chartOptions
  });

  // Crescimento do Sistema Chart
  const crescimentoCtx = document.getElementById('crescimentoChart').getContext('2d');
  const crescimentoData = {
    labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
    datasets: [{
      label: 'Escolas',
      data: [0, 1, 1, 2, 2, 3, 3, 3, 3, 3, 3, <%= @total_escolas %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(crescimentoCtx, {
    type: 'line',
    data: crescimentoData,
    options: {
      ...chartOptions,
      plugins: {
        legend: {
          display: true
        }
      }
    }
  });
});

// Handle Turbo navigation
document.addEventListener('turbo:load', function() {
  // Re-initialize charts if needed
  if (typeof Chart !== 'undefined') {
    Chart.helpers.each(Chart.instances, function(instance) {
      instance.destroy();
    });
    // Trigger DOMContentLoaded to reinitialize charts
    document.dispatchEvent(new Event('DOMContentLoaded'));
  }
});
</script>