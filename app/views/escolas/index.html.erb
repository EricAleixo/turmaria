<!-- Chart.js CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>

<script>
  // Variáveis globais para os charts para evitar conflitos
  window.turmasChart = null;
  window.alunosChart = null;

  // Função para inicializar os gráficos
  function initializeCharts() {
    // Verificar se o Chart.js está carregado
    if (typeof Chart === 'undefined') {
      console.error('Chart.js não foi carregado');
      return;
    }

    // Destruir gráficos existentes se houverem
    if (window.turmasChart) {
      window.turmasChart.destroy();
      window.turmasChart = null;
    }
    if (window.alunosChart) {
      window.alunosChart.destroy();
      window.alunosChart = null;
    }

    // Configuração para os gráficos
    const chartOptions = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            boxWidth: 12,
            padding: 15,
            font: {
              size: 12
            }
          }
        },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleColor: 'white',
          bodyColor: 'white',
          borderColor: 'rgba(255, 255, 255, 0.2)',
          borderWidth: 1
        }
      }
    };

    // Dados reais do Rails
    const escolasData = <%= raw @escolas.present? ? @escolas.map(&:nome).to_json : '[]' %>;
    const turmasData = <%= raw @escolas.present? ? @escolas.map { |e| e.turmas.count }.to_json : '[]' %>;
    const alunosData = <%= raw @escolas.present? ? @escolas.map { |e| e.alunos.count }.to_json : '[]' %>;

    console.log('Dados das escolas:', escolasData);
    console.log('Dados das turmas:', turmasData);
    console.log('Dados dos alunos:', alunosData);

    // Cores verdes para os gráficos
    const greenBackgroundColors = [
      'rgba(34, 197, 94, 0.8)',   // green-500
      'rgba(22, 163, 74, 0.8)',   // green-600
      'rgba(21, 128, 61, 0.8)',   // green-700
      'rgba(22, 101, 52, 0.8)',   // green-800
      'rgba(20, 83, 45, 0.8)',    // green-900
      'rgba(134, 239, 172, 0.8)', // green-300
      'rgba(74, 222, 128, 0.8)',  // green-400
      'rgba(187, 247, 208, 0.8)', // green-200
      'rgba(220, 252, 231, 0.8)', // green-100
      'rgba(240, 253, 244, 0.8)'  // green-50
    ];

    const greenBorderColors = [
      'rgba(34, 197, 94, 1)',     // green-500
      'rgba(22, 163, 74, 1)',     // green-600
      'rgba(21, 128, 61, 1)',     // green-700
      'rgba(22, 101, 52, 1)',     // green-800
      'rgba(20, 83, 45, 1)',      // green-900
      'rgba(134, 239, 172, 1)',   // green-300
      'rgba(74, 222, 128, 1)',    // green-400
      'rgba(187, 247, 208, 1)',   // green-200
      'rgba(220, 252, 231, 1)',   // green-100
      'rgba(240, 253, 244, 1)'    // green-50
    ];
    
    // Gráfico de Turmas
    const turmasCtx = document.getElementById('turmasChart');
    if (turmasCtx && escolasData.length > 0) {
      try {
        window.turmasChart = new Chart(turmasCtx, {
          type: 'pie',
          data: {
            labels: escolasData,
            datasets: [{
              data: turmasData,
              backgroundColor: greenBackgroundColors.slice(0, escolasData.length),
              borderColor: greenBorderColors.slice(0, escolasData.length),
              borderWidth: 3,
              hoverOffset: 10,
              hoverBorderWidth: 5,
              hoverBorderColor: greenBorderColors.slice(0, escolasData.length)
            }]
          },
          options: {
            ...chartOptions,
            plugins: {
              ...chartOptions.plugins,
              tooltip: {
                ...chartOptions.plugins.tooltip,
                callbacks: {
                  label: function(context) {
                    const label = context.label || '';
                    const value = context.raw || 0;
                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                    const percentage = Math.round((value / total) * 100);
                    return `${label}: ${value} turmas (${percentage}%)`;
                  }
                }
              }
            }
          }
        });
        console.log('Gráfico de turmas inicializado com sucesso');
      } catch (error) {
        console.error('Erro ao inicializar gráfico de turmas:', error);
      }
    } else if (turmasCtx) {
      // Mostrar mensagem quando não há dados
      const ctx = turmasCtx.getContext('2d');
      ctx.fillStyle = '#9CA3AF';
      ctx.font = '14px Arial';
      ctx.textAlign = 'center';
      ctx.fillText('Nenhuma escola encontrada', turmasCtx.width / 2, turmasCtx.height / 2);
      console.log('Nenhuma escola encontrada para gráfico de turmas');
    }

    const alunosCtx = document.getElementById('alunosChart');
    if (alunosCtx && escolasData.length > 0) {
      try {
        window.alunosChart = new Chart(alunosCtx, {
          type: 'pie',
          data: {
            labels: escolasData,
            datasets: [{
              data: alunosData,
              backgroundColor: greenBackgroundColors.slice(0, escolasData.length).reverse(), // cores invertidas para diferençar
              borderColor: greenBorderColors.slice(0, escolasData.length).reverse(),
              borderWidth: 3,
              hoverOffset: 10,
              hoverBorderWidth: 5,
              hoverBorderColor: greenBorderColors.slice(0, escolasData.length).reverse()
            }]
          },
          options: {
            ...chartOptions,
            plugins: {
              ...chartOptions.plugins,
              tooltip: {
                ...chartOptions.plugins.tooltip,
                callbacks: {
                  label: function(context) {
                    const label = context.label || '';
                    const value = context.raw || 0;
                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                    const percentage = Math.round((value / total) * 100);
                    return `${label}: ${value} alunos (${percentage}%)`;
                  }
                }
              }
            }
          }
        });
        console.log('Gráfico de alunos inicializado com sucesso');
      } catch (error) {
        console.error('Erro ao inicializar gráfico de alunos:', error);
      }
    } else if (alunosCtx) {
      // Mostrar mensagem quando não há dados
      const ctx = alunosCtx.getContext('2d');
      ctx.fillStyle = '#9CA3AF';
      ctx.font = '14px Arial';
      ctx.textAlign = 'center';
      ctx.fillText('Nenhuma escola encontrada', alunosCtx.width / 2, alunosCtx.height / 2);
      console.log('Nenhuma escola encontrada para gráfico de alunos');
    }
  }

  // Função para inicializar filtros
  function initializeFilters() {
    // Manipulação do filtro dropdown
    document.querySelectorAll('.link-filtro').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const value = this.getAttribute('data-value');
        const name = this.getAttribute('data-name');
        const label = document.getElementById('filtro-label');
        const hiddenInput = document.getElementById('filtro_select_hidden');
        
        if (label) label.textContent = name;
        if (hiddenInput) hiddenInput.value = value;
      });
    });
  }

  // Inicializar quando o DOM estiver pronto
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM carregado, inicializando charts...');
    initializeCharts();
    initializeFilters();
  });

  // Reinicializar quando o Turbo carregar nova página
  document.addEventListener('turbo:load', function() {
    console.log('Turbo carregado, reinicializando charts...');
    initializeCharts();
    initializeFilters();
  });

  // Limpar gráficos antes da navegação para evitar conflitos
  document.addEventListener('turbo:before-cache', function() {
    console.log('Limpando charts antes do cache...');
    if (window.turmasChart) {
      window.turmasChart.destroy();
      window.turmasChart = null;
    }
    if (window.alunosChart) {
      window.alunosChart.destroy();
      window.alunosChart = null;
    }});

    //Filtro
    document.addEventListener("turbo:load", () => {
    const hiddenInput = document.getElementById("filtro_select_hidden");
    const labelSpan = document.getElementById("filtro-label");
    const links = document.querySelectorAll(".link-filtro");

    links.forEach(link => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        const selectedLink = event.currentTarget;

        // Remove o estilo anterior
        const previousSelected = document.querySelector(".link-filtro.bg-green-600");
        if (previousSelected) {
          previousSelected.classList.remove("bg-green-600", "text-white", "hover:bg-green-600", "hover:text-white");
        }

        // Aplica novo estilo
        selectedLink.classList.add("bg-green-600", "text-white", "hover:bg-green-600", "hover:text-white");

        // Atualiza hidden e label (agora só aqui)
        hiddenInput.value = selectedLink.dataset.value;
        labelSpan.textContent = selectedLink.dataset.name;
      });
    });
  });

  document.addEventListener("turbo:load", () => {
  const input = document.querySelector('form input[name="busca"]');
  let timeout;

  input.addEventListener("input", () => {
    clearTimeout(timeout);
    timeout = setTimeout(() => {
      input.form.requestSubmit();
    }, 300); // espera 300ms depois da última tecla
  });
  });
</script>