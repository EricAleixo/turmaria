</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Chart configuration
  const chartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        grid: {
          color: '#f3f4f6'
        }
      },
      x: {
        grid: {
          color: '#f3f4f6'
        }
      }
    }
  };

  // Distribuição de Turmas Chart
  const turmasCtx = document.getElementById('turmasChart').getContext('2d');
  const turmasData = {
    labels: [<%= raw @escolas.map(&:nome).map { |nome| "'#{nome}'" }.join(', ') %>],
    datasets: [{
      data: [<%= @escolas.map { |escola| escola.turmas.count }.join(', ') %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(turmasCtx, {
    type: 'line',
    data: turmasData,
    options: chartOptions
  });

  // Alunos por Escola Chart
  const alunosCtx = document.getElementById('alunosChart').getContext('2d');
  const alunosData = {
    labels: [<%= raw @escolas.map(&:nome).map { |nome| "'#{nome}'" }.join(', ') %>],
    datasets: [{
      data: [<%= @escolas.map { |escola| escola.alunos.count }.join(', ') %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(alunosCtx, {
    type: 'line',
    data: alunosData,
    options: chartOptions
  });

  // Crescimento do Sistema Chart
  const crescimentoCtx = document.getElementById('crescimentoChart').getContext('2d');
  const crescimentoData = {
    labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
    datasets: [{
      label: 'Escolas',
      data: [0, 1, 1, 2, 2, 3, 3, 3, 3, 3, 3, <%= @total_escolas %>],
      backgroundColor: 'rgba(16, 185, 129, 0.1)',
      borderColor: '#10B981',
      borderWidth: 2,
      fill: true,
      tension: 0.4
    }]
  };

  new Chart(crescimentoCtx, {
    type: 'line',
    data: crescimentoData,
    options: {
      ...chartOptions,
      plugins: {
        legend: {
          display: true
        }
      }
    }
  });
});

// Handle Turbo navigation
document.addEventListener('turbo:load', function() {
  // Re-initialize charts if needed
  if (typeof Chart !== 'undefined') {
    Chart.helpers.each(Chart.instances, function(instance) {
      instance.destroy();
    });
    // Trigger DOMContentLoaded to reinitialize charts
    document.dispatchEvent(new Event('DOMContentLoaded'));
  }
});
</script>