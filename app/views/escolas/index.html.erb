                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                      </svg>
                    </div>
                    <p class="text-xs font-medium text-purple-700 uppercase tracking-wide">Total de Alunos</p>
                    <p class="text-2xl font-bold text-purple-800 mt-1"><%= escola.alunos.count %></p>
                  </div>
                </div>

                <!-- Ações do Card -->
                <div class="flex justify-center space-x-2 pt-4 border-t border-purple-200/50">
                  <%= link_to escola_path(escola), class: "flex items-center px-4 py-2.5 text-sm font-medium text-purple-700 bg-purple-50 hover:bg-purple-100 rounded-xl transition-all duration-200 hover:shadow-md hover:scale-105" do %>
