<div class="min-h-screen bg-gray-100">
  <!-- Dashboard Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-900">Dashboard Geral</h1>
        <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Escolas Card (Consolidado) -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <!-- Header Principal -->
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Escolas</p>
            <p class="text-3xl font-bold text-blue-600"><%= @total_escolas %></p>
          </div>
          <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
        </div>
        
        <!-- Divisor -->
        <hr class="border-gray-200 mb-3">
        
        <!-- Sub Cards -->
        <div class="grid grid-cols-2 gap-3">
          <!-- Públicas -->
          <div class="bg-blue-50 rounded-lg p-3 border border-blue-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-blue-700">Públicas</p>
                <p class="text-lg font-bold text-blue-800">
                  <%= @total_escolas_publicas %>
                  <span class="text-xs font-normal text-blue-600">
                    (<%= @total_escolas > 0 ? ((@total_escolas_publicas.to_f / @total_escolas) * 100).round(1) : 0 %>%)
                  </span>
                </p>
              </div>
              <div class="w-6 h-6 bg-blue-200 rounded flex items-center justify-center">
                <svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                  <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </div>
          
          <!-- Privadas -->
          <div class="bg-purple-50 rounded-lg p-3 border border-purple-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-purple-700">Privadas</p>
                <p class="text-lg font-bold text-purple-800">
                  <%= @total_escolas_privadas %>
                  <span class="text-xs font-normal text-purple-600">
                    (<%= @total_escolas > 0 ? ((@total_escolas_privadas.to_f / @total_escolas) * 100).round(1) : 0 %>%)
                  </span>
                </p>
              </div>
              <div class="w-6 h-6 bg-purple-200 rounded flex items-center justify-center">
                <svg class="w-3 h-3 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Total de Turmas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Turmas</p>
            <p class="text-3xl font-bold text-green-600"><%= @total_turmas %></p>
          </div>
          <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-green-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Total de Alunos -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-3xl font-bold text-orange-600"><%= @total_alunos %></p>
          </div>
          <div class="h-12 w-12 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
        </div>
      </div>

      <!-- Métricas Consolidadas Card -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <!-- Header Principal -->
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Métricas do Sistema</p>
            <p class="text-2xl font-bold text-indigo-600">Estatísticas</p>
          </div>
          <div class="h-12 w-12 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
        </div>
        
        <!-- Divisor -->
        <hr class="border-gray-200 mb-3">
        
        <!-- Métricas -->
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600">Alunos/Escola</span>
            <span class="text-sm font-bold text-indigo-700"><%= @media_alunos_escola %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600">Turmas/Escola</span>
            <span class="text-sm font-bold text-indigo-700">
              <%= @total_escolas > 0 ? (@total_turmas.to_f / @total_escolas).round(1) : 0 %>
            </span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-600">Alunos/Turma</span>
            <span class="text-sm font-bold text-indigo-700">
              <%= @total_turmas > 0 ? (@total_alunos.to_f / @total_turmas).round(1) : 0 %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Distribuição de Turmas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Distribuição de Turmas</h3>
        <div class="h-64">
          <canvas id="turmasChart"></canvas>
        </div>
      </div>

      <!-- Alunos por Escola -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Alunos por Escola</h3>
        <div class="h-64">
          <canvas id="alunosChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Análise de Crescimento do Sistema -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Análise de Crescimento do Sistema</h3>
      <div class="h-64">
        <canvas id="crescimentoChart"></canvas>
      </div>
    </div>

    <!-- Gerenciar Escolas Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex justify-between items-center">
          <h2 class="text-xl font-semibold text-gray-900">Gerenciar Escolas</h2>
          <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
        </div>
      </div>

      <!-- Search and Filter Controls -->
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <%= form_with url: escolas_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |form| %>
          <div class="flex-1 min-w-64">
            <%= form.text_field :busca, 
                placeholder: "Buscar por nome da escola...", 
                value: params[:busca],
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" %>
          </div>
          <div class="min-w-48">
            <%= form.select :filtro_select, 
                options_for_select([
                  ["Todas as escolas", ""],
                  ["Escolas Públicas", "publicas"],
                  ["Escolas Privadas", "privadas"],
                  ["Mais alunos", "most_students"],
                  ["Menos alunos", "least_students"],
                  ["Mais turmas", "most_classes"],
                  ["Menos turmas", "least_classes"],
                  ["Com CNPJ", "with_cnpj"],
                  ["Sem CNPJ", "without_cnpj"]
                ], params[:filtro_select]),
                {},
                { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500" } %>
          </div>
          <div class="flex gap-2">
            <%= form.submit "Filtrar", class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
            <%= link_to "Limpar", escolas_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
          </div>
        <% end %>
      </div>

      <!-- Schools Table - Desktop -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">CNPJ</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Turmas</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Alunos</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Admin</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @escolas.each do |escola| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= escola.nome %></div>
                  <% if escola.endereco&.cidade.present? %>
                    <div class="text-sm text-gray-500"><%= escola.endereco.cidade %>, <%= escola.endereco.estado %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if escola.tipo == 'publica' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      Pública
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                      Privada
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.cnpj.present? ? escola.cnpj : "-" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.turmas.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= escola.alunos.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <% if escola.admin.present? %>
                      <div class="flex items-center space-x-3">
                        <div class="relative group">
                          <%= admin_avatar(escola.admin, size: 'w-10 h-10', text_size: 'text-sm') %>
                          <!-- Tooltip -->
                          <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-2 bg-gray-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap z-10">
                            <%= admin_tooltip_info(escola.admin) %>
                            <div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-900"></div>
                          </div>
                        </div>
                        <div>
                          <div class="text-sm font-medium text-gray-900"><%= escola.admin.nome %></div>
                          <div class="text-xs text-gray-500"><%= escola.admin.email %></div>
                        </div>
                      </div>
                    <% else %>
                      <span class="text-sm text-gray-500">Não atribuído</span>
                    <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to escola_path(escola), class: "text-blue-600 hover:text-blue-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                    <% end %>
                    <%= link_to edit_escola_path(escola), class: "text-yellow-600 hover:text-yellow-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    <% end %>
                    <%= button_to escola_path(escola), method: :delete, 
                        confirm: "Tem certeza que deseja excluir esta escola?",
                        class: "text-red-600 hover:text-red-900 p-1" do %>
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Schools Cards - Mobile -->
      <div class="lg:hidden space-y-4">
        <% @escolas.each do |escola| %>
          <% if escola.tipo == 'publica' %>
            <!-- Card Escola Pública -->
            <div class="relative overflow-hidden bg-gradient-to-br from-white via-blue-50/40 to-blue-100/60 border border-blue-200/50 rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
              <!-- Background Pattern -->
              <div class="absolute inset-0 bg-gradient-to-br from-blue-50/20 via-transparent to-blue-100/30 pointer-events-none"></div>
              
              <!-- Content Wrapper -->
              <div class="relative z-10">
                <!-- Header do Card -->
                <div class="flex justify-between items-start mb-4">
                  <div class="flex-1">
                    <div class="flex items-center space-x-3 mb-2">
                      <h3 class="text-xl font-bold text-gray-900 mb-1"><%= escola.nome %></h3>
                      <% if escola.admin.present? %>
                          <div class="relative group">
                            <%= admin_avatar(escola.admin, size: 'w-8 h-8', text_size: 'text-xs') %>
                            <!-- Tooltip -->
                            <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-2 bg-gray-900 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap z-20">
                              <%= admin_tooltip_info(escola.admin) %>
                              <div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-900"></div>
                            </div>
                          </div>
                        <% end %>
                    </div>
                    <% if escola.endereco&.cidade.present? %>
                      <p class="text-sm text-blue-600 flex items-center">
                        <svg class="w-4 h-4 mr-1 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                        </svg>
                        <%= escola.endereco.cidade %>, <%= escola.endereco.estado %>
                      </p>
                    <% end %>
                  </div>
                  <div class="ml-4">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-sm">
                      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                      </svg>
                      Pública
                    </span>
                  </div>
                </div>

                <!-- Informações do Card -->
                <div class="grid grid-cols-2 gap-4 mb-4">
                  <div class="bg-white/70 backdrop-blur-sm border border-blue-200/50 rounded-xl p-4 text-center shadow-sm">
                    <div class="flex items-center justify-center mb-2">
                      <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                    <p class="text-xs font-medium text-blue-700 uppercase tracking-wide">CNPJ</p>
                    <p class="text-sm font-semibold text-gray-900 mt-1">
                      <%= escola.cnpj.present? ? escola.cnpj : "Não informado" %>
                    </p>
                  </div>
                  <div class="bg-gradient-to-br from-blue-100 to-blue-200/80 border border-blue-300/50 rounded-xl p-4 text-center shadow-sm">
                    <div class="flex items-center justify-center mb-2">
                      <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                      </svg>
                    </div>
                    <p class="text-xs font-medium text-blue-800 uppercase tracking-wide">Turmas</p>
                    <p class="text-2xl font-bold text-blue-800 mt-1"><%= escola.turmas.count %></p>
                  </div>
                </div>

                <div class="mb-4">
                  <div class="bg-gradient-to-br from-blue-50 to-blue-100/80 border border-blue-200/50 rounded-xl p-4 text-center shadow-sm">
                    <div class="flex items-center justify-center mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-600">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                      </svg>
                    </div>
                    <p class="text-xs font-medium text-blue-700 uppercase tracking-wide">Total de Alunos</p>
