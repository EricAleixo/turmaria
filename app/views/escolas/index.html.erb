<div class="min-h-screen bg-gray-100">
  <!-- Dashboard Header -->
  <div class="bg-white shadow-sm border-b border-gray-200 mb-6">
    <div class="px-6 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-900">Dashboard Geral</h1>
        <%= link_to "Nova Escola", new_escola_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      </div>
    </div>
  </div>

  <div class="px-6">
    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8 mb-8">
      <!-- Escolas Card (Consolidado) -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 min-w-[280px]">
        <!-- Header Principal -->
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Escolas</p>
            <p class="text-3xl font-bold text-blue-600"><%= @total_escolas %></p>
          </div>
          <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
        </div>
        
        <!-- Divisor -->
        <hr class="border-gray-200 mb-3">
        
        <!-- Sub Cards -->
        <div class="grid grid-cols-2 gap-3">
          <!-- Públicas -->
          <div class="bg-blue-50 rounded-lg p-3 border border-blue-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-blue-700">Públicas</p>
                <p class="text-lg font-bold text-blue-800">
                  <%= @total_escolas_publicas %>
                  <span class="text-xs font-normal text-blue-600">
                    (<%= @total_escolas > 0 ? ((@total_escolas_publicas.to_f / @total_escolas) * 100).round(1) : 0 %>%)
                  </span>
                </p>
              </div>
              <div class="w-6 h-6 bg-blue-200 rounded flex items-center justify-center">
                <svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                  <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </div>
          
          <!-- Privadas -->
          <div class="bg-purple-50 rounded-lg p-3 border border-purple-100">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-purple-700">Privadas</p>
                <p class="text-lg font-bold text-purple-800">
                  <%= @total_escolas_privadas %>
                  <span class="text-xs font-normal text-purple-600">
                    (<%= @total_escolas > 0 ? ((@total_escolas_privadas.to_f / @total_escolas) * 100).round(1) : 0 %>%)
                  </span>
                </p>
              </div>
              <div class="w-6 h-6 bg-purple-200 rounded flex items-center justify-center">
                <svg class="w-3 h-3 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Total de Turmas -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 min-w-[280px]">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Turmas</p>
            <p class="text-3xl font-bold text-green-600"><%= @total_turmas %></p>
          </div>
          <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-green-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Total de Alunos -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 min-w-[280px]">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total de Alunos</p>
            <p class="text-3xl font-bold text-orange-600"><%= @total_alunos %></p>
          </div>
          <div class="h-12 w-12 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
        </div>
      </div>
      
      <!-- Média de Alunos por Escola -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 min-w-[280px]">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Média de Alunos/Escola</p>
            <p class="text-3xl font-bold text-indigo-600"><%= @media_alunos_escola %></p>
          </div>
          <div class="h-12 w-12 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-indigo-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Filtros e Busca -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
      <%= form_with url: escolas_path, method: :get, data: {turbo_frame: "escolas" }, class: 'flex flex-wrap gap-4 items-end' do |form| %>
        
        <div class="flex-1 min-w-64">
          <%= form.text_field :busca, placeholder: "Buscar por nome da escola...", value: params[:busca], class: "input input-bordered w-full bg-gray-50 border-gray-300 focus:border-green-500 focus:ring-green-500" %>
        </div> 

        <!-- Dropdown DaisyUI -->
        <div class="dropdown">
          <!-- Botão que abre o menu -->
          <label tabindex="0" class="btn bg-gray-50 border-gray-300 w-48 justify-between">
            <span id="filtro-label">
            <%= params[:filtro_select].present? ? {
              "publicas" => "Escolas Públicas",
              "privadas" => "Escolas Privadas",
              "most_students" => "Mais alunos",
              "least_students" => "Menos alunos",
              "most_classes" => "Mais turmas",
              "least_classes" => "Menos turmas",
              "with_cnpj" => "Com CNPJ",
              "without_cnpj" => "Sem CNPJ"
            }[params[:filtro_select]] || "Todas as escolas" : "Todas as escolas" %>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </label>
      
          <!-- Menu -->
          <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box w-48 p-2 shadow">
            <% [
              ["Todas as escolas", ""],
              ["Escolas Públicas", "publicas"],
              ["Escolas Privadas", "privadas"],
              ["Mais alunos", "most_students"],
              ["Menos alunos", "least_students"],
              ["Mais turmas", "most_classes"],
              ["Menos turmas", "least_classes"],
              ["Com CNPJ", "with_cnpj"],
              ["Sem CNPJ", "without_cnpj"]
            ].each do |name, value| %>

              <li>
                <a href=""
                   data-value="<%= value %>"
                   data-name="<%= name %>"
                   class="link-filtro block w-full
                   <%= 'bg-green-600 text-white hover:bg-green-600 hover:text-white' if params[:filtro_select] == value %>">
                  <%= name %>
                </a>
              </li>
            <% end %>
          </ul>
        </div>

        <!-- Hidden input para guardar o valor -->
        <%= form.hidden_field :filtro_select, id: "filtro_select_hidden", value: params[:filtro_select] %>
     
        <%= form.submit "Filtrar", class: "btn bg-green-500 hover:bg-green-600 text-white border-0 px-8" %>
     
        <%= link_to "Limpar", escolas_path, class: "btn btn-outline border-gray-300 text-gray-700 hover:bg-gray-50 px-6" %>
        
      <% end %>
    </div>
          
    <%= turbo_frame_tag "escolas" do %>
      <% if @escolas.any? %>
        <!-- Desktop Table View - Personalizada -->
        <div class="hidden lg:block overflow-x-auto bg-white rounded-xl shadow-lg border border-gray-100">
          
          <table id="schoolsTable" class="w-full">
            <!-- Header da Tabela -->
            <thead class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    <span>Escola</span>
                  </div>
                </th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <span>CNPJ</span>
                  </div>
                </th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <div class="flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <span>Turmas</span>
                  </div>
                </th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <div class="flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span>Alunos</span>
                  </div>
                </th>
                <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <div class="flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                    </svg>
                    <span>Ações</span>
                  </div>
                </th>
              </tr>
            </thead>
            
            <!-- Corpo da Tabela -->
            <tbody class="divide-y divide-gray-200 bg-white">
              <% @escolas.each_with_index do |escola, index| %>
                <tr class="<%= 'bg-gray-50/30' if index.even? %> hover:bg-blue-50/50 transition-colors duration-200">
                  
                  <!-- Nome da Escola -->
                  <td class="px-6 py-4">
                    <div class="flex items-center space-x-3">
                      <!-- Avatar/Ícone da Escola -->
                      <div class="flex-shrink-0">
                        <% if escola.tipo == 'publica' %>
                          <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg flex items-center justify-center shadow-md">
                            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                              <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                            </svg>
                          </div>
                        <% else %>
                          <div class="w-10 h-10 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center shadow-md">
                            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                            </svg>
                          </div>
                        <% end %>
                      </div>
                      
                      <!-- Info da Escola -->
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center space-x-2">
                          <p class="text-sm font-medium text-gray-900 truncate">
                            <%= escola.nome %>
                          </p>
                          <!-- Badge do Tipo -->
                          <% if escola.tipo == 'publica' %>
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                              Pública
                            </span>
                          <% else %>
                            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800 border border-purple-200">
                              Privada
                            </span>
                          <% end %>
                        </div>
                        <% if escola.endereco&.cidade_id.present? %>
                          <p class="text-xs text-gray-500 flex items-center mt-1">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                            </svg>
                            <%= escola.endereco.cidade.nome %>, <%= escola.endereco.cidade.estado.nome %>
                          </p>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  
                  <!-- CNPJ -->
                  <td class="px-6 py-4">
                    <% if escola.cnpj.present? %>
                      <div class="text-sm text-gray-900 font-mono bg-gray-50 px-3 py-1 rounded-md border">
                        <%= escola.cnpj %>
                      </div>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                        Não informado
                      </span>
                    <% end %>
                  </td>
                  
                  <!-- Turmas -->
                  <td class="px-6 py-4 text-center">
                    <div class="flex items-center justify-center">
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-green-100 text-green-800 text-sm font-semibold">
                        <%= escola.turmas.count %>
                      </span>
                    </div>
                  </td>
                  
                  <!-- Alunos -->
                  <td class="px-6 py-4 text-center">
                    <div class="flex items-center justify-center">
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-orange-100 text-orange-800 text-sm font-semibold">
                        <%= escola.alunos.count %>
                      </span>
                    </div>
                  </td>
                  
                  <!-- Ações -->
                  <td class="px-6 py-4">
                    <div class="flex items-center justify-center space-x-2">
                      <%= link_to escola_path(escola), 
                          class: "inline-flex items-center justify-center w-8 h-8 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 hover:text-blue-700 transition-all duration-200 hover:shadow-md", 
                          title: "Ver escola", 
                          data: { turbo_frame: "_top" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      <% end %>
                      
                      <%= link_to edit_escola_path(escola), 
                          class: "inline-flex items-center justify-center w-8 h-8 rounded-lg bg-yellow-50 text-yellow-600 hover:bg-yellow-100 hover:text-yellow-700 transition-all duration-200 hover:shadow-md", 
                          title: "Editar escola",
                          data: { turbo_frame: "_top" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                        </svg>
                      <% end %>
                      
                      <%= button_to escola_path(escola),
                            method: :delete,
                            data: { confirm: "Tem certeza que deseja excluir esta escola? Esta ação não pode ser desfeita." },
                            class: "inline-flex items-center justify-center w-8 h-8 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 hover:text-red-700 transition-all duration-200 hover:shadow-md",
                            form: { data: { turbo_frame: "_top" } },
                            title: "Excluir escola" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                        </svg>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Schools Cards - Mobile/Tablet - Alterado para mostrar no lg -->
        <div class="block lg:hidden space-y-4">
          <% @escolas.each do |escola| %>
            <% if escola.tipo == 'publica' %>
              <!-- Card Escola Pública -->
              <div class="relative overflow-hidden bg-gradient-to-br from-white via-blue-50/40 to-blue-100/60 border border-blue-200/50 rounded-xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                <!-- Background Pattern -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-50/20 via-transparent to-blue-100/30 pointer-events-none"></div>
                
                <!-- Content Wrapper -->
                <div class="relative z-10">
                  <!-- Header do Card -->
                  <div class="flex justify-between items-start mb-4">
                    <div class="flex-1">
