<%= form_with(model: escola, class: "bg-white rounded-lg shadow-sm border border-gray-200") do |form| %>
  <% if escola.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800">Erro ao salvar!</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% escola.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Form Header -->
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-lg font-semibold text-gray-900">
      <%= escola.persisted? ? "Editar Informações da Escola" : "Informações da Nova Escola" %>
    </h2>
    <p class="mt-1 text-sm text-gray-600">
      <%= escola.persisted? ? "Atualize as informações da escola abaixo." : "Preencha as informações da escola abaixo." %>
    </p>
  </div>

  <div class="px-6 py-6">
    <!-- Basic Information Section -->
    <div class="mb-8">
      <h3 class="text-base font-medium text-gray-900 mb-4">Informações Básicas</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
          <%= form.label :nome, "Nome da Escola *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :nome, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
              placeholder: "Ex: Colégio Estadual Dom Pedro II", 
              required: true %>
        </div>

        <div>
          <%= dropdown(form: form, method: :tipo, collection: [['Pública','publica'],['Privada','privada']], placeholder: "Selecione o tipo") %>
        </div>

        <div>
          <%= form.label :cnpj, "CNPJ", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :cnpj, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
              placeholder: "XX.XXX.XXX/XXXX-XX" %>
          <p class="mt-1 text-sm text-gray-500">Opcional - apenas para escolas privadas</p>
        </div>

        <div>
          <%= form.label :telefone, "Telefone", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :telefone, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
              placeholder: "(83) 99999-9999" %>
        </div>

        <div>
          <%= form.label :email, "E-mail", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
              placeholder: "escola@exemplo.com" %>
        </div>

        <div>
          <%= form.label :site, "Site", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.url_field :site, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
              placeholder: "https://www.escola.com.br" %>
        </div>

        <!-- Campo Admin: mostra diferente se for admin logado -->
        <div>
          <% if current_admin.present? %>
            <!-- Admin logado: mostra campo desabilitado com o nome dele -->
            <%= form.label :admin_id, "Administrador", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :admin_nome, 
                value: current_admin.nome,
                disabled: true,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-100 text-gray-600 cursor-not-allowed" %>
            <%= form.hidden_field :admin_id, value: current_admin.id %>
            <p class="mt-1 text-sm text-gray-500">Você será automaticamente associado como administrador</p>
          <% else %>
            <!-- Não é admin: mostra dropdown normal -->
            <%= dropdown(form: form, method: :admin_id, collection: Admin.where.not(confirmed_at: nil).order(:nome), label_field: :nome, value_field: :id, placeholder: "Selecione um administrador") %>
            <p class="mt-1 text-sm text-gray-500">Apenas administradores confirmados podem ser associados</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Address Section -->
    <div class="mb-8">
      <h3 class="text-base font-medium text-gray-900 mb-4">Endereço</h3>
      <%= form.fields_for :endereco do |e| %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="md:col-span-2">
            <%= e.label :logradouro, "Logradouro *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= e.text_field :logradouro, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
                placeholder: "Ex: Rua das Flores", 
                required: true %>
          </div>

          <div>
            <%= e.label :numero, "Número *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= e.text_field :numero, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
                placeholder: "123", 
                required: true %>
          </div>

          <div>
            <%= e.label :bairro, "Bairro", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= e.text_field :bairro, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
                placeholder: "Centro" %>
          </div>

          <div>
            <%= dropdown(form: e, method: :cidade_id, collection: Cidade.all, label_field: :nome_com_estado, value_field: :id, placeholder: "Selecione uma cidade") %>
          </div>

          <div>
            <%= dropdown(form: e, method: :cidade_id, collection: Cidade.all, label_field: :nome_com_estado, value_field: :id, placeholder: "Selecione uma cidade") %>
          </div>

          <div>
            <%= e.label :cep, "CEP", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= e.text_field :cep, 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500", 
                placeholder: "01234-567" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
    <div class="flex justify-between">
      <%= link_to "Cancelar", 
          request.referer.presence || (escola.persisted? ? escola_path(escola) : escolas_path), 
          class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
      <%= form.submit escola.persisted? ? "Atualizar Escola" : "Criar Escola", 
          class: "bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  </div>
<% end %>