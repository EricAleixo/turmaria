<%= form_with(model: escola, class: "bg-white rounded-lg shadow-sm border border-gray-200") do |form| %>
  <% if escola.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 mx-6 mt-6">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800">Erro ao salvar!</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% escola.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Form Header -->
  <div class="px-6 py-5 border-b border-gray-200 bg-gradient-to-r from-green-50 to-emerald-50">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900">
          <%= escola.persisted? ? "Editar Escola" : "Nova Escola" %>
        </h2>
        <p class="mt-0.5 text-sm text-gray-600">
          <%= escola.persisted? ? "Atualize as informações da escola" : "Preencha os dados para cadastrar uma nova escola" %>
        </p>
      </div>
    </div>
  </div>

  <div class="px-6 py-6 space-y-8">
    <!-- Basic Information Section -->
    <div>
      <div class="flex items-center gap-2 mb-5">
        <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Informações Básicas</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Nome da Escola -->
        <div class="md:col-span-2">
          <%= form.label :nome, class: "block text-sm font-semibold text-gray-700 mb-2" do %>
            Nome da Escola <span class="text-red-500">*</span>
          <% end %>
          <%= form.text_field :nome, 
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
              placeholder: "Ex: Colégio Estadual Dom Pedro II", 
              required: true %>
        </div>

        <!-- Tipo -->
        <div>
          <%= form.label :tipo, "Tipo de Escola", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <div class="relative">
            <%= form.select :tipo, 
                [['Selecione o tipo', ''], ['Pública', 'publica'], ['Privada', 'privada']], 
                {},
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 appearance-none bg-white text-gray-900" %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- CNPJ -->
        <div>
          <%= form.label :cnpj, class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.text_field :cnpj, 
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
              placeholder: "XX.XXX.XXX/XXXX-XX" %>
          <p class="mt-1.5 text-xs text-gray-500 flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Opcional - geralmente para escolas privadas
          </p>
        </div>

        <!-- Telefone -->
        <div>
          <%= form.label :telefone, class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.text_field :telefone, 
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
              placeholder: "(83) 99999-9999" %>
        </div>

        <!-- Email -->
        <div>
          <%= form.label :email, "E-mail", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.email_field :email, 
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
              placeholder: "escola@exemplo.com" %>
        </div>

        <!-- Site -->
        <div class="md:col-span-2">
          <%= form.label :site, class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= form.url_field :site, 
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
              placeholder: "https://www.escola.com.br" %>
        </div>
      </div>
    </div>

    <!-- Admin Section -->
    <div>
      <div class="flex items-center gap-2 mb-5">
        <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Administrador Responsável</h3>
      </div>

      <% if current_admin.present? %>
        <!-- Admin Logado -->
        <div class="bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-200 rounded-lg p-5">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-purple-500 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-purple-900 mb-1">Você será automaticamente associado como administrador</p>
              <p class="text-2xl font-bold text-purple-700"><%= current_admin.nome %></p>
              <p class="text-sm text-purple-600 mt-1"><%= current_admin.email %></p>
            </div>
            <div class="flex-shrink-0">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-500 text-white">
                Admin Atual
              </span>
            </div>
          </div>
          <%= form.hidden_field :admin_id, value: current_admin.id %>
        </div>
      <% else %>
        <!-- Seleção de Admin com Busca -->
        <div class="border border-gray-300 rounded-lg overflow-hidden">
          <!-- Search Header -->
          <div class="bg-gray-50 border-b border-gray-200 p-4">
            <label class="block text-sm font-semibold text-gray-700 mb-3">
              Selecione o Administrador <span class="text-red-500">*</span>
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <input type="text" 
                     id="admin-search" 
                     placeholder="Buscar administrador por nome ou email..." 
                     class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 text-gray-900 placeholder-gray-400">
            </div>
          </div>

          <!-- Admin List -->
          <div id="admin-list" class="max-h-80 overflow-y-auto bg-white">
            <% Admin.where.not(confirmed_at: nil).order(:nome).each do |admin| %>
              <label class="admin-item flex items-center gap-4 p-4 hover:bg-purple-50 cursor-pointer transition-colors border-b border-gray-100 last:border-b-0" 
                     data-name="<%= admin.nome&.downcase || "Nome não informado" %>" 
                     data-email="<%= admin.email&.downcase %>">
                <input type="radio" 
                       name="escola[admin_id]" 
                       value="<%= admin.id %>" 
                       class="w-5 h-5 text-purple-600 focus:ring-purple-500 border-gray-300"
                       <%= 'checked' if escola.admin_id == admin.id %>>
                <% if admin.foto.attached? %>
                  <%= image_tag admin.foto,
                        class: "w-10 h-10 rounded-full object-cover flex-shrink-0",
                        alt: admin.nome %>
                <% else %>
                  <div class="w-10 h-10 bg-gradient-to-br from-purple-400 to-indigo-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-white font-bold text-lg">
                      <%= admin.nome.present? ? admin.nome.first.upcase : "?" %>
                    </span>
                  </div>
                <% end %>

                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate"><%= admin.nome %></p>
                  <p class="text-xs text-gray-500 truncate"><%= admin.email %></p>
                </div>
                <div class="flex-shrink-0">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Confirmado
                  </span>
                </div>
              </label>
            <% end %>
          </div>

          <!-- No Results Message -->
          <div id="no-results" class="hidden p-8 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-sm text-gray-500">Nenhum administrador encontrado</p>
          </div>
        </div>

        <p class="mt-2 text-xs text-gray-500 flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Apenas administradores confirmados podem ser associados
        </p>
      <% end %>
    </div>

    <!-- Address Section -->
    <div>
      <div class="flex items-center gap-2 mb-5">
        <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Endereço</h3>
      </div>

      <%= form.fields_for :endereco do |e| %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          <!-- Logradouro -->
          <div class="md:col-span-2">
            <%= e.label :logradouro, class: "block text-sm font-semibold text-gray-700 mb-2" do %>
              Logradouro
            <% end %>
            <%= e.text_field :logradouro, 
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
                placeholder: "Ex: Rua das Flores" %>
          </div>

          <!-- Número -->
          <div>
            <%= e.label :numero, class: "block text-sm font-semibold text-gray-700 mb-2" do %>
              Número
            <% end %>
            <%= e.text_field :numero, 
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
                placeholder: "123" %>
          </div>

          <!-- Bairro -->
          <div>
            <%= e.label :bairro, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= e.text_field :bairro, 
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
                placeholder: "Centro" %>
          </div>

          <!-- Cidade -->
          <div>
            <%= e.label :cidade_id, "Cidade", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <%= e.collection_select :cidade_id, 
                  Cidade.all, 
                  :id, 
                  :nome_com_estado, 
                  { prompt: "Selecione uma cidade" },
                  class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 appearance-none bg-white text-gray-900" %>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </div>
          </div>

          <!-- CEP -->
          <div>
            <%= e.label :cep, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= e.text_field :cep, 
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors text-gray-900 placeholder-gray-400", 
                placeholder: "01234-567" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
    <div class="flex justify-between items-center gap-3">
      <%= link_to escolas_path, 
          class: "cursor-pointer inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
        Cancelar
      <% end %>
      
      <%= form.submit escola.persisted? ? "Atualizar Escola" : "Criar Escola", 
          class: "cursor-pointer inline-flex items-center gap-2 px-6 py-2.5 bg-green-500 hover:bg-green-600 text-white rounded-lg font-medium transition-colors shadow-sm hover:shadow" do %>
      <% end %>
    </div>
  </div>
<% end %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('admin-search');
  const adminItems = document.querySelectorAll('.admin-item');
  const noResults = document.getElementById('no-results');

  if (searchInput) {
    searchInput.addEventListener('input', function(e) {
      const searchTerm = e.target.value.toLowerCase().trim();
      let visibleCount = 0;

      adminItems.forEach(item => {
        const name = item.dataset.name;
        const email = item.dataset.email;
        const matches = name.includes(searchTerm) || email.includes(searchTerm);

        if (matches) {
          item.style.display = 'flex';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    });
  }
});
</script>